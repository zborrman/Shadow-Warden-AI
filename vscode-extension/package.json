{
  "name": "shadow-warden-ai",
  "displayName": "Shadow Warden AI",
  "description": "Inline AI security risk annotation — scan selected text, files, and clipboard through Shadow Warden's 9-layer filter pipeline. Catches secrets, jailbreak patterns, PII leaks, and prompt injection before they reach the pipeline.",
  "version": "5.2.0",
  "publisher": "shadow-warden-ai",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Linters"],
  "keywords": ["AI security", "jailbreak detection", "PII", "GDPR", "Shadow Warden", "LLM security"],
  "icon": "icon.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shadowWarden.scan",
        "title": "Scan Selection",
        "category": "Shadow Warden",
        "icon": "$(shield)"
      },
      {
        "command": "shadowWarden.scanFile",
        "title": "Scan Entire File",
        "category": "Shadow Warden",
        "icon": "$(search)"
      },
      {
        "command": "shadowWarden.scanClipboard",
        "title": "Scan Clipboard",
        "category": "Shadow Warden",
        "icon": "$(clippy)"
      },
      {
        "command": "shadowWarden.clearDecorations",
        "title": "Clear Risk Annotations",
        "category": "Shadow Warden",
        "icon": "$(clear-all)"
      },
      {
        "command": "shadowWarden.openSettings",
        "title": "Open Settings",
        "category": "Shadow Warden",
        "icon": "$(gear)"
      }
    ],
    "keybindings": [
      {
        "command": "shadowWarden.scan",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "editorHasSelection"
      },
      {
        "command": "shadowWarden.clearDecorations",
        "key": "ctrl+shift+x",
        "mac": "cmd+shift+x",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "shadowWarden.scan",
          "when": "editorHasSelection",
          "group": "shadowWarden@1"
        },
        {
          "command": "shadowWarden.scanFile",
          "when": "editorTextFocus",
          "group": "shadowWarden@2"
        },
        {
          "command": "shadowWarden.clearDecorations",
          "when": "editorTextFocus",
          "group": "shadowWarden@3"
        }
      ],
      "commandPalette": [
        { "command": "shadowWarden.scan",             "when": "editorHasSelection" },
        { "command": "shadowWarden.scanFile",         "when": "editorIsOpen" },
        { "command": "shadowWarden.scanClipboard" },
        { "command": "shadowWarden.clearDecorations", "when": "editorIsOpen"  },
        { "command": "shadowWarden.openSettings" }
      ]
    },
    "configuration": {
      "title": "Shadow Warden AI",
      "properties": {
        "shadowWarden.apiUrl": {
          "type": "string",
          "default": "https://api.shadow-warden-ai.com",
          "description": "Shadow Warden API base URL (self-hosted: http://localhost:8001)"
        },
        "shadowWarden.apiKey": {
          "type": "string",
          "default": "",
          "description": "Shadow Warden API key (X-API-Key header). Required for Individual+ plans.",
          "secret": true
        },
        "shadowWarden.tenantId": {
          "type": "string",
          "default": "",
          "description": "Tenant ID (optional — multi-tenant deployments only)"
        },
        "shadowWarden.minRiskLevel": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "BLOCK"],
          "enumDescriptions": [
            "Show all risk levels including low-risk findings",
            "Show MEDIUM and above (recommended)",
            "Only show HIGH and BLOCK verdicts",
            "Only show BLOCK verdicts"
          ],
          "default": "MEDIUM",
          "description": "Minimum risk level to show annotation"
        },
        "shadowWarden.showInlineDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Show coloured gutter icons and inline verdict text"
        },
        "shadowWarden.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show code lens above HIGH and BLOCK annotated lines"
        },
        "shadowWarden.autoScanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan the file when saved"
        },
        "shadowWarden.concurrency": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 16,
          "description": "Maximum concurrent API requests during file scan (1–16)"
        }
      }
    }
  },
  "scripts": {
    "build":     "esbuild src/extension.ts --bundle --platform=node --target=node18 --outfile=dist/extension.js --external:vscode",
    "watch":     "npm run build -- --watch",
    "package":   "vsce package",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node":   "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild":       "^0.20.0",
    "typescript":    "^5.3.0"
  },
  "dependencies": {}
}
