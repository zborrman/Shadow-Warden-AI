{
  "buildCommand": null,
  "outputDirectory": "landing",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/enterprise-settings", "destination": "/enterprise-settings.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/settings", "destination": "/settings.html" },
    { "source": "/fraud-score", "destination": "/fraud-score.html" },
    { "source": "/community", "destination": "/community.html" },
    { "source": "/incident",  "destination": "/incident.html" }
  ],
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
