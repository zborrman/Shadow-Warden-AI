# ─────────────────────────────────────────────────────────────────────────────
#  Shadow Warden AI — Environment Variables
#
#  Copy this file to .env and fill in the values:
#    cp .env.example .env
#
#  NEVER commit .env to version control.
#  NEVER share SECRET_KEY, POSTGRES_PASS, or ANTHROPIC_API_KEY publicly.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" before deploying.
ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-random-key

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=warden_user
# DB_PASSWORD is the canonical secret used by both docker-compose (POSTGRES_PASSWORD)
# and the app (DATABASE_URL). Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSWORD=change-me-strong-db-password
POSTGRES_DB=warden

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── GDPR ─────────────────────────────────────────────────────────────────────
# Number of days to retain analytics log entries before automatic purge.
# Default: 30 days (EU GDPR-compliant minimum for security logs).
GDPR_LOG_RETENTION_DAYS=30

# ── CORS (required for Live Demo on landing page) ────────────────────────────
# Comma-separated list of allowed origins.
# Add your Vercel/custom domain so the landing page demo can call /filter.
CORS_ORIGINS=https://shadow-warden-ai.com,https://www.shadow-warden-ai.com,http://localhost:3000

# ── Warden Gateway ───────────────────────────────────────────────────────────
# Cosine similarity threshold for jailbreak detection (0.0–1.0).
# Lower = more sensitive (more false positives).
# Higher = more permissive (more false negatives).
# Default: 0.72 (recommended starting point).
SEMANTIC_THRESHOLD=0.72

# When true, MEDIUM-risk requests are also blocked (zero-tolerance mode).
STRICT_MODE=false

# ── Data Poisoning Detection ──────────────────────────────────────────────────
# Stage 2c: detects boundary probing, adversarial perturbation, and corpus drift.
POISON_DETECTION_ENABLED=true
POISON_BOUNDARY_WINDOW=60      # sliding window in seconds for probe detection
POISON_BOUNDARY_MAX=6          # near-threshold hits within window before flag
POISON_DRIFT_THRESHOLD=0.08    # max cosine centroid drift before corpus alert
POISON_MONITOR_INTERVAL=300    # corpus health check cadence in seconds

# ── ONNX Runtime (optional — 2-4× faster CPU inference, 70% less RAM) ────────
# Step 1: Export FP32 model + apply INT8 quantization (one-time, run on server):
#      python3 scripts/export_onnx.py --quantize
#   Output:
#      warden/models/minilm-onnx/       ← FP32 model (91 MB)
#      warden/models/minilm-onnx-int8/  ← INT8 quantized model (~23 MB, git-ignored)
#
# Step 2: Set ONNX_MODEL_PATH to activate the ONNX backend.
#   Leave empty to use the default PyTorch path (safe, slower).
ONNX_MODEL_PATH=
# ONNX_MODEL_PATH=/warden/models/minilm-onnx-int8   ← INT8 (recommended, 3-4× faster)
# ONNX_MODEL_PATH=/warden/models/minilm-onnx         ← FP32 fallback

# Thread tuning — critical for avoiding Thread Thrashing on multi-worker deployments.
# Formula for N vCPU / W uvicorn workers:  INTRA_THREADS = N / W
#   8 vCPU / 4 workers  →  ONNX_INTRA_THREADS=2  (default, optimized for this server)
#   4 vCPU / 2 workers  →  ONNX_INTRA_THREADS=2
#   16 vCPU / 4 workers →  ONNX_INTRA_THREADS=4
ONNX_THREADS=1        # inter-op threads — keep at 1 to prevent worker contention
ONNX_INTRA_THREADS=2  # intra-op threads — 4 workers × 2 = 8 vCPU fully utilised

# ── OpenTelemetry + Jaeger ────────────────────────────────────────────────────
# Set OTEL_ENABLED=true in production to activate distributed tracing.
# Jaeger UI will be available at http://localhost:16686 (docker-compose starts it automatically).
OTEL_ENABLED=false
OTEL_SERVICE_NAME=shadow-warden
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SAMPLE_RATE=1.0

# ── Security features ─────────────────────────────────────────────────────────
# Session Guard: track per-session risk accumulation to catch slow-burn attacks.
SESSION_GUARD_ENABLED=true

# Shadow ban response strategy delay (ms) — applied for delay strategy (bot/stuffing attacks).
SHADOW_BAN_DELAY_MS=3000

# Estimated LLM cost saved per shadow-banned request (USD).
# Used to populate warden_shadow_ban_cost_saved_usd_total Prometheus counter.
# Default: GPT-4o-mini avg response pricing (~200 output tokens × $0.60/1M).
SHADOW_BAN_COST_PER_REQUEST_USD=0.00012

# Honey-prompts: serve fake "success" responses to blocked attackers.
HONEY_MODE=false
HONEY_PROBABILITY=0.3
HONEY_SESSION_TTL_SEC=3600
HONEY_LOG_FOLLOWUP=true

# Inject plausible-but-false credentials into honey responses.
# When an attacker tries to use the fake token, the request is blocked and logged.
HONEY_INJECT_SECRETS=false

# ── Evolution Loop ────────────────────────────────────────────────────────────
# Controls which LLM backend drives automated rule generation.
#
#   EVOLUTION_ENGINE=auto      (default) — Nemotron if NVIDIA_API_KEY is set,
#                                          else Claude if ANTHROPIC_API_KEY set
#   EVOLUTION_ENGINE=nemotron  — always use NVIDIA NIM (Nemotron Super)
#   EVOLUTION_ENGINE=claude    — always use Claude Opus (legacy)
#
# Leave both keys blank to run in offline / air-gapped mode.
# All other Warden features work without any evolution key.
EVOLUTION_ENGINE=auto

# Option A — NVIDIA NIM (Nemotron Super 49B, recommended)
# Obtain API key: https://build.nvidia.com  → "Get API Key"
# Self-hosted NIM: set NIM_BASE_URL to your container URL instead.
NVIDIA_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_MODEL=meta/llama-3.3-nemotron-super-49b-instruct
NEMOTRON_THINKING_BUDGET=4096
NEMOTRON_STORE_THINKING=false   # true → write thinking traces to Evidence Vault (S3)

# Option B — Anthropic Claude Opus (legacy fallback)
# Obtain from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Dashboard Authentication ──────────────────────────────────────────────────
# Leave DASHBOARD_PASSWORD_HASH blank for dev mode (no login required).
# In production, generate a hash then set it here:
#
#   docker-compose run --rm dashboard python -m warden.analytics.auth
#   # or locally:
#   python -m warden.analytics.auth
#
# The command will prompt for a password and print the hash to copy here.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_HASH=

# Session lifetime in minutes before the user must re-authenticate.
DASHBOARD_SESSION_MINUTES=60

# Brute-force protection: lock account after N failed attempts for M minutes.
DASHBOARD_MAX_ATTEMPTS=5
DASHBOARD_LOCKOUT_MINUTES=15

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the /filter endpoint.
# CORS_ORIGINS=https://your-app.com,https://staging.your-app.com

# ── API Key Authentication ────────────────────────────────────────────────────
# Single-key mode: clients send this value in the X-API-Key header.
# Leave blank for development mode (no key required).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WARDEN_API_KEY=

# ── API Documentation Auth (HTTP Basic) ───────────────────────────────────────
# Protects /docs, /redoc, and /openapi.json with HTTP Basic authentication.
# Leave DOCS_PASSWORD blank in development (docs served without auth).
# ALWAYS set a strong password in production — an open /docs exposes your full
# API schema to attackers (routes, parameters, webhook secrets, etc.).
#
# Generate a strong password:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DOCS_USERNAME=warden
DOCS_PASSWORD=

# Multi-tenant key file (optional — overrides WARDEN_API_KEY when set).
# Path to a JSON file mapping SHA-256(api_key) → {tenant_id, rate_limit}.
# See docs/deployment-guide.md §7 for the file format.
WARDEN_API_KEYS_PATH=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Maximum requests per minute per IP address on the /filter endpoint.
RATE_LIMIT_PER_MINUTE=60

# ── Redis Cache ───────────────────────────────────────────────────────────────
# TTL (seconds) for the content-hash cache.  0 to disable caching.
CACHE_TTL_SECONDS=300

# ── Stage 5: Notification Hook — Manager Alerts ──────────────────────────────
# When OutputGuard catches a price manipulation or unauthorized commitment,
# this hook instantly notifies the shop manager via Telegram and/or a webhook.
# Distinct from TELEGRAM_BOT_TOKEN (which alerts the security team).

# Risk types that trigger a manager notification (comma-separated).
# Default: the two highest-impact business risks.
NOTIFY_OUTPUT_RISKS=price_manipulation,unauthorized_commitment

# Telegram: manager's personal chat (can reuse the same bot as TELEGRAM_BOT_TOKEN,
# but point to a different chat ID — e.g. the shop owner's direct message).
NOTIFY_TELEGRAM_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

# Webhook: any HTTPS endpoint (CRM, n8n, Zapier, custom API).
# Leave blank to disable webhook delivery.
NOTIFY_WEBHOOK_URL=
# HMAC-SHA256 signing secret sent as X-Warden-Signature: sha256=<hex>.
# Minimum 16 chars. Generate with: python -c "import secrets; print(secrets.token_hex(24))"
NOTIFY_WEBHOOK_SECRET=

# ── OutputGuard — Stage 4: Business-Layer Output Guardrails ──────────────────
# Scans LLM responses for price manipulation, unauthorized commitments,
# competitor mentions, and hallucinated policies before they reach the client.
# Applied automatically on every /v1/chat/completions response.
OUTPUT_GUARDRAILS_ENABLED=true

# Maximum discount percentage the LLM is allowed to offer.
# Responses containing "60% off" when this is 50 will be sanitized.
OUTPUT_MAX_DISCOUNT_PCT=50

# Whether unauthorized commitment language ("I guarantee", "мы гарантируем")
# triggers sanitization (true) or only logging (false).
OUTPUT_COMMITMENT_BLOCK=true

# Comma-separated competitor brand names to flag and replace in LLM output.
# Leave blank to disable competitor detection.
# Example: OUTPUT_COMPETITOR_NAMES=Amazon,Alibaba,Wildberries
OUTPUT_COMPETITOR_NAMES=

# ── WalletShield — Token Budget Enforcement (LLM10: Resource Exhaustion) ─────
# Protects SMB clients from Financial DoS: a flood of requests cannot exhaust
# the OpenAI/Anthropic budget because each user is capped to a token window.
WALLET_ENABLED=true

# Maximum tokens per user per window (WALLET_WINDOW_SECONDS) before HTTP 429.
# Default: 100,000 tokens/hour — enough for ~200 GPT-4 Turbo requests.
WALLET_DEFAULT_BUDGET=100000

# Sliding window duration in seconds (default: 3600 = 1 hour).
WALLET_WINDOW_SECONDS=3600

# Absolute per-request ceiling: requests estimated above this are rejected
# immediately without checking the per-user budget (prevents single-shot DoS).
WALLET_HARD_LIMIT=200000

# Alert threshold: log a WARNING when this % of the user's budget is consumed.
TOKEN_ALERT_PCT=80

# ── v0.8: Prompt Shield (Indirect Injection Detection) ───────────────────────
# Scans tool results and external content for prompt injection attempts before
# they reach the LLM context. Fail-open (never blocks safe content).
PROMPT_SHIELD_ENABLED=true

# ── v0.9: Cryptographic Audit Trail (SOC 2 Type II) ──────────────────────────
# Tamper-evident SQLite hash-chain. Every filter decision is appended as one row.
# entry_hash = SHA-256(prev_hash + canonical_JSON_payload) — deletions or edits
# break the chain and are detected by GET /admin/audit/verify.
# GDPR-safe: only metadata stored (risk level, action, flags) — never content.
AUDIT_TRAIL_ENABLED=true
# Path to the SQLite database file. In Docker, /warden/data is volume-mounted.
# Locally, set to any writable path (e.g. /tmp/audit_trail.db for testing).
AUDIT_TRAIL_PATH=/warden/data/audit_trail.db

# ── v1.1: Enterprise Resilience ───────────────────────────────────────────────
# Fail strategy on pipeline timeout:
#   open   = pass request through (business priority — default)
#   closed = block request        (security priority)
WARDEN_FAIL_STRATEGY=open

# Maximum milliseconds for the filter pipeline before fail-strategy triggers.
# 0 = disabled (no timeout). Recommended: 500 for high-throughput production.
PIPELINE_TIMEOUT_MS=0

# ML uncertainty lower bound. Requests with ML score in
# [UNCERTAINTY_LOWER_THRESHOLD, SEMANTIC_THRESHOLD) are flagged ML_UNCERTAIN
# and escalated to MEDIUM risk. Set to 0 to disable.
UNCERTAINTY_LOWER_THRESHOLD=0.55

# ── v0.7: Azure OpenAI ────────────────────────────────────────────────────────
# Auto-routed when model name starts with "azure/" (e.g. azure/gpt-4o).
# Obtain from: Azure Portal → Cognitive Services → your resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ── v0.7: Amazon Bedrock ─────────────────────────────────────────────────────
# Auto-routed when model name starts with "bedrock/" (e.g. bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0).
# Streaming uses AWS EventStream binary protocol (ConverseStream API).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── v0.7: Google Vertex AI ────────────────────────────────────────────────────
# Auto-routed when model name starts with "vertex/" (e.g. vertex/gemini-1.5-pro-002).
# Auth: set VERTEX_ACCESS_TOKEN for a static Bearer token, or leave blank to use
# Application Default Credentials (ADC) — e.g. a service account key file.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_ACCESS_TOKEN=

# ── OpenAI-Compatible Proxy ───────────────────────────────────────────────────
# Upstream base URL used by /v1/chat/completions when no provider is auto-detected.
# Leave default to proxy to the official OpenAI API.
OPENAI_UPSTREAM=https://api.openai.com

# Perplexity AI — auto-routed for models: sonar-*, llama-*, r1-*, pplx-*, mixtral
# Obtain from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Google Gemini — auto-routed for models: gemini-*
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Internal URL for the Warden /filter endpoint.
# In Docker: use the service name (warden:8001).
# Locally: use localhost:8001.
WARDEN_FILTER_URL=http://warden:8001

# ── LLM Backend (OpenAI-compatible) ──────────────────────────────────────────
# Base URL for the LLM provider served via the /v1/* proxy.
# Examples: https://api.openai.com/v1  |  http://ollama:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# API key forwarded to the upstream LLM provider.
# For OpenAI: obtain from https://platform.openai.com/api-keys
LLM_API_KEY=

# ── Real-time Alerting ────────────────────────────────────────────────────────
# Slack: send blocked-attack notifications to a Slack channel.
# Obtain a Webhook URL from: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# PagerDuty: trigger an incident for BLOCK-level attacks.
# Obtain from: PagerDuty → Services → Integrations → Events API v2
PAGERDUTY_ROUTING_KEY=

# Minimum risk level that triggers an alert: low | medium | high | block
ALERT_MIN_RISK_LEVEL=high

# Telegram: send poisoning alerts + Self-Healing rollback events to a Telegram channel.
# 1. Create a bot via @BotFather → copy the token
# 2. Add the bot to your channel/group as admin → get the chat ID
#    (forward a message to @userinfobot or use /getUpdates)
# Alerts fire when poisoning_score > 0.85 or CorpusHealthMonitor triggers a rollback.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Self-Healing Corpus Snapshot ──────────────────────────────────────────────
# Path prefix for corpus snapshots (two files: .npz + .json).
# When CorpusHealthMonitor detects canary failures, it restores from this snapshot.
# In Docker the default /tmp path is ephemeral — mount a volume for persistence:
#   volumes: ["./data/snapshots:/snapshots"]  and set path to /snapshots/corpus
CORPUS_SNAPSHOT_PATH=/tmp/warden_corpus_snapshot

# ── SIEM Integration ──────────────────────────────────────────────────────────
# Splunk HTTP Event Collector
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# Elastic / OpenSearch
ELASTIC_URL=
ELASTIC_API_KEY=
ELASTIC_INDEX=shadow-warden-events

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin password for the Grafana dashboard (http://localhost:3000).
# Default: admin (change before production deployment).
GRAFANA_PASSWORD=admin
# ── SAML 2.0 SSO (optional — leave blank to disable) ─────────────────────────
# Required to enable SSO:
SAML_SP_ENTITY_ID=https://warden.yourcompany.com
SAML_SP_ACS_URL=https://warden.yourcompany.com/auth/saml/acs
# Provide one of the two:
SAML_IDP_METADATA_URL=https://your-okta-or-entra-metadata-url
SAML_IDP_METADATA_XML=
# JWT secret — min 32 chars, generate with: openssl rand -hex 32
SAML_JWT_SECRET=
# Optional: restrict login to specific email domains (comma-separated)
SAML_ALLOWED_DOMAINS=yourcompany.com
# Session lifetime in seconds (default: 28800 = 8 hours)
SAML_SESSION_TTL=28800
# URL of the Streamlit dashboard — for post-login redirect
DASHBOARD_URL=http://localhost:8501

# ── Customer Portal ───────────────────────────────────────────────────────────
# JWT secret for customer portal sessions — min 32 chars.
# Generate with: openssl rand -hex 32
# NEVER share or commit this value.
PORTAL_JWT_SECRET=change-me-generate-a-strong-random-key

# Access token lifetime in minutes (default: 60)
PORTAL_ACCESS_TOKEN_TTL=60

# Refresh token lifetime in days (default: 7)
PORTAL_REFRESH_TOKEN_TTL=7

# Add portal.shadow-warden-ai.com to CORS_ORIGINS so the portal can call the API
# CORS_ORIGINS=https://shadow-warden-ai.com,https://www.shadow-warden-ai.com,https://portal.shadow-warden-ai.com,http://localhost:3000

# ── Portal Email (password reset) ─────────────────────────────────────────────
# SMTP server for transactional email (password reset links).
# Leave SMTP_HOST blank to disable email — the reset token is logged as a warning instead.
# Works with any SMTP relay: Gmail, SendGrid, Mailgun, AWS SES, etc.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
#   SMTP_USER=you@gmail.com   SMTP_PASS=<app-password>
#
# SendGrid example (SMTP relay):
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587
#   SMTP_USER=apikey             SMTP_PASS=<sendgrid-api-key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# "From" address on portal emails.  Defaults to SMTP_USER if blank.
PORTAL_FROM_EMAIL=

# Base URL of the customer portal (used to build the reset-password link).
PORTAL_URL=https://app.shadow-warden-ai.com

# ── v1.3 Global Threat Intelligence Sync ──────────────────────────────────────
# Region label for this node — used as stream consumer group ID.
# Set to "usa", "eu", or "dubai" (or any unique string per deployment).
WARDEN_REGION=usa

# Shared Redis cluster URL for cross-region threat sync.
# If unset, falls back to REDIS_URL (same-node Redis — useful for dev/staging).
# GLOBAL_REDIS_URL=redis://global-redis.internal:6379/1

# Set to "false" to disable cross-region sync on this node.
THREAT_SYNC_ENABLED=true

# Redis Stream name — must be the same on all nodes.
THREAT_SYNC_STREAM=warden:threats:global

# ── v2.1 Data-Gravity Hybrid Hub — On-Prem S3-Compatible Object Storage ───────
# Stores Evidence Vault bundles and analytics logs on local/colocation MinIO.
# Data sovereignty: unstructured security data never leaves your infrastructure.
# Only clean filtered tokens reach the upstream LLM cloud provider.
#
# Set S3_ENABLED=true and point S3_ENDPOINT to your MinIO instance to activate.
# MinIO is included in docker-compose.yml and starts automatically.
#
# MinIO Console UI: http://localhost:9001 (login with S3_ACCESS_KEY / S3_SECRET_KEY)
# Evidence bundles: s3://<S3_BUCKET_EVIDENCE>/bundles/<session_id>.json
# Analytics logs:   s3://<S3_BUCKET_LOGS>/logs/<YYYY-MM-DD>/<request_id>.json
#
# For colocation / bare-metal: replace S3_ENDPOINT with your MinIO server URL.
# For AWS S3: set S3_ENDPOINT= (empty) and use your actual AWS credentials.
S3_ENABLED=false
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_EVIDENCE=warden-evidence
S3_BUCKET_LOGS=warden-logs
S3_REGION=us-east-1

# ── v1.3 Corpus Sync (S3 + Redis invalidation) ────────────────────────────────
# S3 bucket for cross-region corpus snapshots.
# Leave unset to disable S3 upload (local snapshots still saved).
# CORPUS_S3_BUCKET=shadow-warden-corpus-sync

# S3 key prefix (default: warden/corpus)
# CORPUS_S3_PREFIX=warden/corpus

# AWS region for the S3 bucket (default: us-east-1)
# CORPUS_S3_REGION=us-east-1

# Redis stream for corpus invalidation signals (default: warden:corpus:invalidations)
# CORPUS_INVALIDATION_STREAM=warden:corpus:invalidations

# Set to "false" to disable corpus sync on this node
# CORPUS_SYNC_ENABLED=true

# ── v2.8 Business Communities ─────────────────────────────────────────────────
# SQLite paths for community registry and key archive (dev/test).
# In production, data lives in PostgreSQL — these are ignored when PostgreSQL is used.
COMMUNITY_REGISTRY_PATH=/tmp/warden_community_registry.db
COMMUNITY_KEY_ARCHIVE_PATH=/tmp/warden_community_key_archive.db
BREAK_GLASS_AUDIT_PATH=/var/log/warden/break_glass_audit.jsonl

# Fernet key used to wrap community Ed25519 private keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# VAULT_MASTER_KEY=<generate-me>

# JWT secret for Bot_ID tokens (separate from main WARDEN_API_KEY to limit blast radius).
# BOT_JWT_SECRET=<generate-me>

# ── v2.9 Monetization — Quota & Entity Storage ────────────────────────────────
# SQLite counter store (dev fallback; Redis is used in production).
QUOTA_DB_PATH=/tmp/warden_quota.db
ENTITY_DB_PATH=/tmp/warden_entity_store.db

# S3 bucket for encrypted entity payloads (communities/{cid}/{eid}.enc).
# Reuses S3_ENDPOINT / AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY from above.
COMMUNITY_S3_BUCKET=warden-communities

# Overage billing webhook (optional — for reseller portals that handle billing externally).
# OVERAGE_WEBHOOK_URL=https://your-portal.example.com/webhooks/overage

# Portal base URL for upgrade/overage-pack CTA links returned in HTTP 402 responses.
PORTAL_BASE_URL=https://app.shadowwarden.ai

# ── Lemon Squeezy Billing ─────────────────────────────────────────────────────
# Get these values from: https://app.lemonsqueezy.com/settings/api
# Plans: Individual $5/mo · Pro $49/mo · Enterprise $199/mo (monthly subscriptions)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_INDIVIDUAL=   # variant_id for $5/mo plan
LEMONSQUEEZY_VARIANT_PRO=          # variant_id for $49/mo plan
LEMONSQUEEZY_VARIANT_ENTERPRISE=   # variant_id for $199/mo plan
LEMONSQUEEZY_DB_PATH=/warden/data/lemon.db
