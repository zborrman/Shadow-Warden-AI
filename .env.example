# ─────────────────────────────────────────────────────────────────────────────
#  Shadow Warden AI — Environment Variables
#
#  Copy this file to .env and fill in the values:
#    cp .env.example .env
#
#  NEVER commit .env to version control.
#  NEVER share SECRET_KEY, POSTGRES_PASS, or ANTHROPIC_API_KEY publicly.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" before deploying.
ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-random-key

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=warden_user
# DB_PASSWORD is the canonical secret used by both docker-compose (POSTGRES_PASSWORD)
# and the app (DATABASE_URL). Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSWORD=change-me-strong-db-password
POSTGRES_DB=warden

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── GDPR ─────────────────────────────────────────────────────────────────────
# Number of days to retain analytics log entries before automatic purge.
# Default: 30 days (EU GDPR-compliant minimum for security logs).
GDPR_LOG_RETENTION_DAYS=30

# ── CORS (required for Live Demo on landing page) ────────────────────────────
# Comma-separated list of allowed origins.
# Add your Vercel/custom domain so the landing page demo can call /filter.
CORS_ORIGINS=https://shadow-warden-ai.com,https://www.shadow-warden-ai.com,http://localhost:3000

# ── Warden Gateway ───────────────────────────────────────────────────────────
# Cosine similarity threshold for jailbreak detection (0.0–1.0).
# Lower = more sensitive (more false positives).
# Higher = more permissive (more false negatives).
# Default: 0.72 (recommended starting point).
SEMANTIC_THRESHOLD=0.72

# When true, MEDIUM-risk requests are also blocked (zero-tolerance mode).
STRICT_MODE=false

# ── ONNX Runtime (optional — 2-4× faster CPU inference) ──────────────────────
# 1. Export the model once:
#      python3 scripts/export_onnx.py
#    Output: warden/models/minilm-onnx/model.onnx  (git-ignored)
# 2. Set the path below to activate the ONNX backend.
#    Leave empty to use the default PyTorch path.
ONNX_MODEL_PATH=
# ONNX_MODEL_PATH=/warden/models/minilm-onnx   ← uncomment after export

# Inference thread counts (default: 1 inter, 4 intra — tune to your CPU core count)
ONNX_THREADS=1
ONNX_INTRA_THREADS=4

# ── OpenTelemetry + Jaeger ────────────────────────────────────────────────────
# Set OTEL_ENABLED=true in production to activate distributed tracing.
# Jaeger UI will be available at http://localhost:16686 (docker-compose starts it automatically).
OTEL_ENABLED=false
OTEL_SERVICE_NAME=shadow-warden
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SAMPLE_RATE=1.0

# ── Security features ─────────────────────────────────────────────────────────
# Session Guard: track per-session risk accumulation to catch slow-burn attacks.
SESSION_GUARD_ENABLED=true

# Honey-prompts: serve fake "success" responses to blocked attackers.
HONEY_MODE=false
HONEY_PROBABILITY=0.3
HONEY_SESSION_TTL_SEC=3600
HONEY_LOG_FOLLOWUP=true

# Inject plausible-but-false credentials into honey responses.
# When an attacker tries to use the fake token, the request is blocked and logged.
HONEY_INJECT_SECRETS=false

# ── Evolution Loop (optional) ─────────────────────────────────────────────────
# Obtain from: https://console.anthropic.com/
# Leave blank to run in offline / air-gapped mode.
# All other Warden features work without this key.
ANTHROPIC_API_KEY=

# ── Dashboard Authentication ──────────────────────────────────────────────────
# Leave DASHBOARD_PASSWORD_HASH blank for dev mode (no login required).
# In production, generate a hash then set it here:
#
#   docker-compose run --rm dashboard python -m warden.analytics.auth
#   # or locally:
#   python -m warden.analytics.auth
#
# The command will prompt for a password and print the hash to copy here.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_HASH=

# Session lifetime in minutes before the user must re-authenticate.
DASHBOARD_SESSION_MINUTES=60

# Brute-force protection: lock account after N failed attempts for M minutes.
DASHBOARD_MAX_ATTEMPTS=5
DASHBOARD_LOCKOUT_MINUTES=15

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the /filter endpoint.
# CORS_ORIGINS=https://your-app.com,https://staging.your-app.com

# ── API Key Authentication ────────────────────────────────────────────────────
# Single-key mode: clients send this value in the X-API-Key header.
# Leave blank for development mode (no key required).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WARDEN_API_KEY=

# ── API Documentation Auth (HTTP Basic) ───────────────────────────────────────
# Protects /docs, /redoc, and /openapi.json with HTTP Basic authentication.
# Leave DOCS_PASSWORD blank in development (docs served without auth).
# ALWAYS set a strong password in production — an open /docs exposes your full
# API schema to attackers (routes, parameters, webhook secrets, etc.).
#
# Generate a strong password:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DOCS_USERNAME=warden
DOCS_PASSWORD=

# Multi-tenant key file (optional — overrides WARDEN_API_KEY when set).
# Path to a JSON file mapping SHA-256(api_key) → {tenant_id, rate_limit}.
# See docs/deployment-guide.md §7 for the file format.
WARDEN_API_KEYS_PATH=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Maximum requests per minute per IP address on the /filter endpoint.
RATE_LIMIT_PER_MINUTE=60

# ── Redis Cache ───────────────────────────────────────────────────────────────
# TTL (seconds) for the content-hash cache.  0 to disable caching.
CACHE_TTL_SECONDS=300

# ── OpenAI-Compatible Proxy ───────────────────────────────────────────────────
# Upstream base URL used by /v1/chat/completions.
# Leave default to proxy to the official OpenAI API.
OPENAI_UPSTREAM=https://api.openai.com

# Internal URL for the Warden /filter endpoint.
# In Docker: use the service name (warden:8001).
# Locally: use localhost:8001.
WARDEN_FILTER_URL=http://warden:8001

# ── LLM Backend (OpenAI-compatible) ──────────────────────────────────────────
# Base URL for the LLM provider served via the /v1/* proxy.
# Examples: https://api.openai.com/v1  |  http://ollama:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# API key forwarded to the upstream LLM provider.
# For OpenAI: obtain from https://platform.openai.com/api-keys
LLM_API_KEY=

# ── Real-time Alerting ────────────────────────────────────────────────────────
# Slack: send blocked-attack notifications to a Slack channel.
# Obtain a Webhook URL from: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# PagerDuty: trigger an incident for BLOCK-level attacks.
# Obtain from: PagerDuty → Services → Integrations → Events API v2
PAGERDUTY_ROUTING_KEY=

# Minimum risk level that triggers an alert: low | medium | high | block
ALERT_MIN_RISK_LEVEL=high

# ── SIEM Integration ──────────────────────────────────────────────────────────
# Splunk HTTP Event Collector
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# Elastic / OpenSearch
ELASTIC_URL=
ELASTIC_API_KEY=
ELASTIC_INDEX=shadow-warden-events

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin password for the Grafana dashboard (http://localhost:3000).
# Default: admin (change before production deployment).
GRAFANA_PASSWORD=admin
# ── SAML 2.0 SSO (optional — leave blank to disable) ─────────────────────────
# Required to enable SSO:
SAML_SP_ENTITY_ID=https://warden.yourcompany.com
SAML_SP_ACS_URL=https://warden.yourcompany.com/auth/saml/acs
# Provide one of the two:
SAML_IDP_METADATA_URL=https://your-okta-or-entra-metadata-url
SAML_IDP_METADATA_XML=
# JWT secret — min 32 chars, generate with: openssl rand -hex 32
SAML_JWT_SECRET=
# Optional: restrict login to specific email domains (comma-separated)
SAML_ALLOWED_DOMAINS=yourcompany.com
# Session lifetime in seconds (default: 28800 = 8 hours)
SAML_SESSION_TTL=28800
# URL of the Streamlit dashboard — for post-login redirect
DASHBOARD_URL=http://localhost:8501

# ── Customer Portal ───────────────────────────────────────────────────────────
# JWT secret for customer portal sessions — min 32 chars.
# Generate with: openssl rand -hex 32
# NEVER share or commit this value.
PORTAL_JWT_SECRET=change-me-generate-a-strong-random-key

# Access token lifetime in minutes (default: 60)
PORTAL_ACCESS_TOKEN_TTL=60

# Refresh token lifetime in days (default: 7)
PORTAL_REFRESH_TOKEN_TTL=7

# Add portal.shadow-warden-ai.com to CORS_ORIGINS so the portal can call the API
# CORS_ORIGINS=https://shadow-warden-ai.com,https://www.shadow-warden-ai.com,https://portal.shadow-warden-ai.com,http://localhost:3000
