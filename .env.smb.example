# Shadow Warden AI — Community Business (SMB) Edition
# Copy this file to .env.smb and fill in your values.
# Minimum required: set WARDEN_API_KEY to a secure random string.
#
# Generate a key:  python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Required ──────────────────────────────────────────────────────────────────
WARDEN_API_KEY=change-me-generate-with-secrets-token-urlsafe-32

# ── Optional: AI Evolution Engine (requires Anthropic account) ────────────────
# Leave blank to run in air-gapped mode (all detection still works).
ANTHROPIC_API_KEY=

# ── Optional: Slack alerts on HIGH/BLOCK detections ──────────────────────────
SLACK_WEBHOOK_URL=

# ── Optional: SMTP for compliance report emails ───────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── SMB Tier ──────────────────────────────────────────────────────────────────
WARDEN_TIER=community_business
TENANT_ID=my-business

# ── Security (auto-generated on first run if left blank) ──────────────────────
VAULT_MASTER_KEY=
COMMUNITY_VAULT_KEY=

# ── File Scanner ──────────────────────────────────────────────────────────────
FILE_SCAN_ENABLED=true
FILE_SCAN_MAX_MB=10

# ── Shadow AI Monitoring (MONITOR mode — alerts only, no blocking) ────────────
SHADOW_AI_MONITOR=true

# ── Data retention ────────────────────────────────────────────────────────────
RETENTION_DAYS=180
