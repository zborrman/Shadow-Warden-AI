{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Posture Overview",
      "type": "row"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "green", "value": 80 }
          ]},
          "min": 0, "max": 100, "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "pluginVersion": "10.0.0",
      "targets": [{ "datasource": "prometheus", "expr": "warden_compliance_overall_score{tenant_id=\"default\"}", "legendFormat": "Overall" }],
      "title": "Overall Compliance Score",
      "type": "gauge"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "10.0.0",
      "targets": [{ "datasource": "prometheus", "expr": "warden_compliance_gaps_open{tenant_id=\"default\"}", "legendFormat": "Open Gaps" }],
      "title": "Open Gaps",
      "type": "stat"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 10, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "10.0.0",
      "targets": [{ "datasource": "prometheus", "expr": "warden_compliance_controls_passed{tenant_id=\"default\"}", "legendFormat": "Passed Controls" }],
      "title": "Controls Passing",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "title": "Per-Framework Scores",
      "type": "row"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "min": 0, "max": 100, "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 11,
      "options": { "legend": { "calcs": ["last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        { "datasource": "prometheus", "expr": "warden_compliance_framework_score{tenant_id=\"default\",framework=\"gdpr\"}", "legendFormat": "GDPR" },
        { "datasource": "prometheus", "expr": "warden_compliance_framework_score{tenant_id=\"default\",framework=\"soc2\"}", "legendFormat": "SOC 2" },
        { "datasource": "prometheus", "expr": "warden_compliance_framework_score{tenant_id=\"default\",framework=\"iso27001\"}", "legendFormat": "ISO 27001" },
        { "datasource": "prometheus", "expr": "warden_compliance_framework_score{tenant_id=\"default\",framework=\"hipaa\"}", "legendFormat": "HIPAA" }
      ],
      "title": "Framework Score Timeline",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "Score History",
      "type": "row"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "#10b981", "mode": "fixed" }, "custom": { "fillOpacity": 15, "lineWidth": 2 }, "min": 0, "max": 100, "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 21,
      "options": { "legend": { "calcs": ["last", "min"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [{ "datasource": "prometheus", "expr": "warden_compliance_overall_score{tenant_id=\"default\"}", "legendFormat": "Overall Score" }],
      "title": "Overall Score Timeline",
      "type": "timeseries"
    }
  ],
  "refresh": "60s",
  "schemaVersion": 38,
  "tags": ["compliance", "shadow-warden"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Compliance Posture",
  "uid": "sw-compliance",
  "version": 1
}
