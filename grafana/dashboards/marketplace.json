{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "10.0.0",
      "targets": [{ "datasource": "prometheus", "expr": "warden_marketplace_agents_active", "legendFormat": "Active Agents" }],
      "title": "Active Agents",
      "type": "stat"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "10.0.0",
      "targets": [{ "datasource": "prometheus", "expr": "warden_marketplace_escrow_active", "legendFormat": "Active Escrows" }],
      "title": "Active Escrows",
      "type": "stat"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "currencyUSD" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "10.0.0",
      "targets": [{ "datasource": "prometheus", "expr": "warden_marketplace_trade_volume_usd", "legendFormat": "Volume USD" }],
      "title": "Total Trade Volume",
      "type": "stat"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "pluginVersion": "10.0.0",
      "targets": [{ "datasource": "prometheus", "expr": "warden_marketplace_negotiations_active", "legendFormat": "Negotiations" }],
      "title": "Open Negotiations",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Listings and Purchases",
      "type": "row"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisCenteredZero": false, "barAlignment": 0, "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        { "datasource": "prometheus", "expr": "rate(warden_marketplace_listings_total[5m])", "legendFormat": "Listings/s ({{asset_type}})" },
        { "datasource": "prometheus", "expr": "rate(warden_marketplace_purchases_total[5m])", "legendFormat": "Purchases/s ({{asset_type}})" }
      ],
      "title": "Listings & Purchases Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Trade Volume",
      "type": "row"
    },
    {
      "datasource": "prometheus",
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "#3b82f6", "mode": "fixed" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "currencyUSD" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 21,
      "options": { "legend": { "calcs": ["last", "sum"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [{ "datasource": "prometheus", "expr": "rate(warden_marketplace_trade_volume_usd[5m])", "legendFormat": "USD/s" }],
      "title": "Trade Volume Rate (USD/s)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["marketplace", "shadow-warden"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Marketplace Analytics",
  "uid": "sw-marketplace",
  "version": 1
}
