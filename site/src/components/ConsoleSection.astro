<script>
// ── Chart.js loader ──────────────────────────────────────────────────
function loadChartJs(cb) {
  if (window.Chart) return cb();
  const s = document.createElement('script');
  s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
  s.onload = cb;
  document.head.appendChild(s);
}

// ── Chart defaults ───────────────────────────────────────────────────
function chartDefaults() {
  window.Chart.defaults.color = '#475569';
  window.Chart.defaults.font.family = 'Inter, system-ui, sans-serif';
  window.Chart.defaults.font.size = 11;
}

// ── Timeline chart ───────────────────────────────────────────────────
function initTimeline() {
  const el = document.getElementById('sw-timeline-chart');
  if (!el) return;
  const labels = Array.from({ length: 60 }, (_, i) => `${59 - i}m`);
  const data   = Array.from({ length: 60 }, () => Math.floor(Math.random() * 80 + 20));
  const blocked = data.map(v => Math.floor(v * 0.045 + Math.random() * 3));
  const ch = new window.Chart(el, {
    type: 'line',
    data: { labels, datasets: [
      { data, borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.08)', fill: true, tension: 0.4, pointRadius: 0, borderWidth: 2 },
      { data: blocked, borderColor: '#f87171', backgroundColor: 'rgba(248,113,113,0.06)', fill: true, tension: 0.4, pointRadius: 0, borderWidth: 1.5 },
    ]},
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } },
               scales: { x: { display: false }, y: { display: false } } }
  });
  // live update every 2s
  setInterval(() => {
    ch.data.datasets[0].data.push(Math.floor(Math.random() * 80 + 20));
    ch.data.datasets[0].data.shift();
    ch.data.datasets[1].data.push(Math.floor(Math.random() * 6));
    ch.data.datasets[1].data.shift();
    ch.update('none');
  }, 2000);
}

// ── Donut chart ──────────────────────────────────────────────────────
function initDonut() {
  const el = document.getElementById('sw-donut-chart');
  if (!el) return;
  new window.Chart(el, {
    type: 'doughnut',
    data: {
      labels: ['LOW', 'MEDIUM', 'HIGH', 'BLOCK'],
      datasets: [{ data: [18203, 7012, 1893, 1384],
        backgroundColor: ['rgba(52,211,153,0.8)','rgba(251,191,36,0.8)','rgba(248,113,113,0.8)','rgba(239,68,68,0.9)'],
        borderWidth: 0, hoverOffset: 4 }]
    },
    options: { responsive: true, maintainAspectRatio: false, cutout: '68%',
               plugins: { legend: { display: true, position: 'right',
                 labels: { color: '#64748b', font: { size: 10 }, boxWidth: 10 } } } }
  });
}

// ── Flags bars ───────────────────────────────────────────────────────
function initBars(id, labels, values, color) {
  const el = document.getElementById(id);
  if (!el) return;
  new window.Chart(el, {
    type: 'bar',
    data: { labels, datasets: [{ data: values, backgroundColor: color, borderRadius: 4, borderSkipped: false }] },
    options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y',
               plugins: { legend: { display: false } },
               scales: { x: { display: false }, y: { ticks: { color: '#475569', font: { size: 10 } }, grid: { display: false }, border: { display: false } } } }
  });
}

// ── Live event feed ──────────────────────────────────────────────────
const EVENTS = [
  { d: 'ALLOWED', r: 'LOW',   f: '—',                           lat: 12 },
  { d: 'BLOCKED', r: 'BLOCK', f: 'PROMPT_INJECTION, JAILBREAK', lat: 8  },
  { d: 'ALLOWED', r: 'MEDIUM',f: 'SECRET_REDACTED(1)',          lat: 31 },
  { d: 'BLOCKED', r: 'HIGH',  f: 'PII_DETECTED, SE_RISK',       lat: 19 },
  { d: 'ALLOWED', r: 'LOW',   f: '—',                           lat: 9  },
  { d: 'BLOCKED', r: 'BLOCK', f: 'WORM_SIGNATURE',              lat: 3  },
  { d: 'ALLOWED', r: 'MEDIUM',f: 'OBFUSCATION_DECODED',         lat: 44 },
  { d: 'BLOCKED', r: 'HIGH',  f: 'PHISHING_URL, SOCIAL_ENG',    lat: 15 },
  { d: 'ALLOWED', r: 'LOW',   f: '—',                           lat: 7  },
];
const RISK_COLORS = {
  LOW:   { bg: 'rgba(52,211,153,0.12)',  fg: '#34d399' },
  MEDIUM:{ bg: 'rgba(251,191,36,0.12)', fg: '#fbbf24' },
  HIGH:  { bg: 'rgba(248,113,113,0.15)',fg: '#f87171' },
  BLOCK: { bg: 'rgba(239,68,68,0.20)',  fg: '#ef4444' },
};

let feedPaused = false;
let feedStats  = { total: 0, blocked: 0, high: 0, latSum: 0 };

function timeStr() {
  return new Date().toTimeString().slice(0, 8);
}

function makeRow(ev) {
  const c = RISK_COLORS[ev.r];
  const row = document.createElement('div');
  row.className = 'sw-feed-row grid gap-2 px-2 py-1.5 rounded-lg';
  row.style.cssText = 'grid-template-columns:60px 80px 70px 1fr 60px;align-items:center;font-size:11px';
  row.innerHTML = `
    <span style="font-family:monospace;color:#475569">${ev.t || timeStr()}</span>
    <span style="font-weight:600;color:${ev.d === 'BLOCKED' ? '#f87171' : '#34d399'}">${ev.d}</span>
    <span style="padding:2px 7px;border-radius:5px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;background:${c.bg};color:${c.fg};display:inline-block">${ev.r}</span>
    <span style="color:#94a3b8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${ev.f}</span>
    <span style="font-family:monospace;color:#64748b;text-align:right">${ev.lat}ms</span>
  `;
  return row;
}

function updateStats() {
  const avg = feedStats.total ? Math.round(feedStats.latSum / feedStats.total) : 0;
  document.getElementById('stat-total').textContent   = feedStats.total;
  document.getElementById('stat-blocked').textContent = feedStats.blocked;
  document.getElementById('stat-high').textContent    = feedStats.high;
  document.getElementById('stat-lat').textContent     = avg ? avg + 'ms' : '—';
  document.getElementById('feed-count').textContent   = feedStats.total + ' events';
}

function pushEvent(ev) {
  if (feedPaused) return;
  feedStats.total++;
  if (ev.d === 'BLOCKED') feedStats.blocked++;
  if (ev.r === 'HIGH' || ev.r === 'BLOCK') feedStats.high++;
  feedStats.latSum += ev.lat;
  updateStats();
  const container = document.getElementById('feed-rows');
  if (!container) return;
  container.insertBefore(makeRow(ev), container.firstChild);
  // keep max 50 rows
  while (container.children.length > 50) container.removeChild(container.lastChild);
}

function initFeed() {
  // seed with initial events
  const seed = [...EVENTS].reverse();
  seed.forEach((e, i) => {
    const d = new Date(Date.now() - i * 4000);
    pushEvent({ ...e, t: d.toTimeString().slice(0, 8) });
  });

  // stream new events
  setInterval(() => {
    const e = EVENTS[Math.floor(Math.random() * EVENTS.length)];
    pushEvent({ ...e, t: timeStr() });
  }, 2500);

  // pause / clear buttons
  const pauseBtn = document.getElementById('feed-pause');
  pauseBtn?.addEventListener('click', () => {
    feedPaused = !feedPaused;
    pauseBtn.textContent = feedPaused ? '▶ Resume' : '⏸ Pause';
  });
  document.getElementById('feed-clear')?.addEventListener('click', () => {
    const c = document.getElementById('feed-rows');
    if (c) c.innerHTML = '';
    feedStats = { total: 0, blocked: 0, high: 0, latSum: 0 };
    updateStats();
  });
}

// ── Boot ─────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  initFeed();

  // Observe section; load charts when in viewport
  const section = document.getElementById('console');
  const observer = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      observer.disconnect();
      loadChartJs(() => {
        chartDefaults();
        initTimeline();
        initDonut();
        initBars('sw-flags-chart',
          ['Prompt Injection','Jailbreak','PII Detected','Social Eng.','Secret Leaked','Worm Sig.','Phishing'],
          [512, 318, 204, 189, 87, 43, 31], 'rgba(139,92,246,0.7)');
        initBars('sw-secrets-chart',
          ['AWS Key','GitHub Token','Email / PII','Credit Card','Slack Token','Password','API Key'],
          [89, 71, 63, 44, 31, 28, 21], 'rgba(34,211,238,0.65)');
      });
    }
  }, { threshold: 0.1 });
  if (section) observer.observe(section);
});
</script>
