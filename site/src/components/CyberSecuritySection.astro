---
const pipeline = [
  { name: 'Topology',    icon: '📐', desc: 'Betti β₀/β₁' },
  { name: 'Obfuscation', icon: '🔄', desc: 'Depth-3 decode' },
  { name: 'Secrets',     icon: '🔑', desc: '15 patterns' },
  { name: 'Rules',       icon: '📏', desc: 'Compound risk' },
  { name: 'Brain',       icon: '🧠', desc: 'MiniLM + Poincaré' },
  { name: 'Causal',      icon: '🎯', desc: 'Bayesian DAG' },
  { name: 'Phish',       icon: '🎣', desc: 'URL + SE-Arbiter' },
  { name: 'ERS',         icon: '🚫', desc: 'Shadow ban ≥ 0.75' },
  { name: 'Decision',    icon: '✅', desc: 'ALLOW / BLOCK' },
];

const cards = [
  { icon: '📐', title: 'Topological Gatekeeper',   desc: 'TDA n-gram point cloud → Betti numbers (β₀/β₁). Structural anomalies invisible to regex detected in <strong>&lt;2ms</strong>.',                    tier: 'All' },
  { icon: '🔄', title: 'Obfuscation Decoder',       desc: 'Depth-3 recursive decode: base64, hex, ROT13, Caesar, word-split, UUencode, Unicode homoglyphs. Nested attacks unwrapped automatically.',       tier: 'All' },
  { icon: '🔑', title: 'Secret Redaction',           desc: '15 regex patterns (AWS, JWT, Stripe, GitHub, SSH) + Shannon entropy scan for unknown secrets. Zero plaintext in memory or logs.',               tier: 'All' },
  { icon: '🧠', title: 'ML Jailbreak Detection',     desc: 'MiniLM embeddings projected into Poincaré ball. 70% cosine + 30% hyperbolic distance blend. Adversarial suffix stripping built-in.',           tier: 'Individual+' },
  { icon: '🎯', title: 'Causal Arbiter',             desc: 'Bayesian DAG over 5 evidence nodes. Pearl do-calculus backdoor correction. P(HIGH_RISK | evidence) — gray-zone requests get causal reasoning.',tier: 'Individual+' },
  { icon: '🎣', title: 'PhishGuard + SE-Arbiter',   desc: 'URL phishing detection + social engineering pattern matching. Covers pretexting, authority spoofing, urgency manipulation.',                    tier: 'Individual+' },
  { icon: '🔭', title: 'Shadow AI Discovery',        desc: '18 provider fingerprints. Async /24 subnet probe (256 hosts, 50 concurrent). DNS telemetry classifier. MONITOR / BLOCK / ALLOWLIST modes.',    tier: 'Pro+ / Add-on' },
  { icon: '🧾', title: 'Explainable AI (XAI)',       desc: '9-stage causal chain with verdict, score, counterfactuals per stage. Self-contained HTML + optional PDF report (reportlab).',                  tier: 'Pro+ / Add-on' },
  { icon: '🔬', title: 'Evolution Engine',           desc: 'Claude Opus auto-generates rules from HIGH/BLOCK events. ArXiv paper synthesis → attack examples hot-reloaded into corpus. Regex gate prevents ReDOS.', tier: 'Pro+' },
  { icon: '🛡️', title: 'Data Poisoning Guard',      desc: 'CPT drift gate rejects calibration updates that shift any parameter >25% from prior. Prevents slow-burn coordinated-borderline poisoning.',     tier: 'Pro+' },
  { icon: '🤖', title: 'SOVA Agent',                 desc: 'Claude Opus 4.6 agentic loop. 30 tools. 7 ARQ cron schedules. Visual patrol + XAI explain + Shadow AI scan. Redis memory (20-turn, 6h TTL).', tier: 'Pro+' },
  { icon: '🧩', title: 'MasterAgent',                desc: '4 specialised sub-agents (SOVAOperator / ThreatHunter / Forensics / Compliance). HMAC task tokens. Human-in-the-loop approval gate.',          tier: 'Pro' },
];

const tierColor: Record<string, string> = { 'All': 'var(--sw-fg-4)', 'Individual+': 'var(--sw-green)', 'Pro+': 'var(--sw-indigo)', 'Pro': 'var(--sw-indigo)', 'Pro+ / Add-on': 'var(--sw-orange)' };
const tierBg:    Record<string, string> = { 'All': 'rgba(100,116,139,.12)', 'Individual+': 'var(--sw-tint-green)', 'Pro+': 'var(--sw-tint-indigo)', 'Pro': 'var(--sw-tint-indigo)', 'Pro+ / Add-on': 'var(--sw-tint-amber)' };
---

<section id="security" class="relative py-24 overflow-hidden"
         style="background:var(--sw-surf-1)">

  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 50% 40% at 70% 50%,rgba(248,113,113,.05) 0%,transparent 70%)"></div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-5 text-[12px] font-semibold"
           style="color:var(--sw-red);background:var(--sw-tint-red);border:1px solid rgba(248,113,113,.2)">
        ◈ Cyber Security
      </div>
      <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold mb-4" style="color:var(--sw-fg-1)">
        Nine Layers of Defence.<br/>
        <span style="background:linear-gradient(135deg,var(--sw-red),var(--sw-orange));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">Zero Blind Spots.</span>
      </h2>
      <p class="text-[15px] max-w-2xl mx-auto" style="color:var(--sw-fg-3)">
        Every AI request passes through a 9-stage causal pipeline — topology analysis, obfuscation
        decoding, secret redaction, ML jailbreak detection, causal inference, and more — all in under 2ms.
      </p>
    </div>

    <!-- Pipeline visual -->
    <div class="mb-16 p-6 rounded-2xl overflow-x-auto" style="background:var(--sw-surf-2);border:1px solid var(--sw-border)">
      <div class="flex items-start gap-0 min-w-max mx-auto w-fit">
        {pipeline.map((stage, i) => (
          <div class="flex items-center gap-0">
            <div class="flex flex-col items-center gap-2 w-[86px]">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[18px]"
                   style="background:var(--sw-tint-red);border:1px solid rgba(248,113,113,.2)">
                {stage.icon}
              </div>
              <span class="text-[11px] font-semibold text-center" style="color:var(--sw-fg-2)">{stage.name}</span>
              <span class="text-[10px] text-center" style="color:var(--sw-fg-4)">{stage.desc}</span>
            </div>
            {i < pipeline.length - 1 && (
              <div class="w-6 flex items-center justify-center mb-6" style="color:var(--sw-fg-4)">→</div>
            )}
          </div>
        ))}
      </div>
      <div class="text-center mt-4">
        <span class="text-[11px] font-bold px-3 py-1 rounded-full"
              style="color:var(--sw-red);background:var(--sw-tint-red);border:1px solid rgba(248,113,113,.2)">
          Total pipeline latency &lt; 2ms
        </span>
      </div>
    </div>

    <!-- Feature grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {cards.map(c => (
        <div class="rounded-xl p-5 card-hover"
             style="background:var(--sw-surf-2);border:1px solid var(--sw-border);border-top:2px solid var(--sw-red)">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center text-[18px] mb-3"
               style="background:var(--sw-tint-red)">
            {c.icon}
          </div>
          <div class="text-[14px] font-semibold mb-1.5" style="color:var(--sw-fg-1)">{c.title}</div>
          <div class="text-[13px] leading-relaxed mb-3" style="color:var(--sw-fg-3)" set:html={c.desc} />
          <span class="inline-block text-[10px] font-bold px-2.5 py-0.5 rounded-full"
                style={`color:${tierColor[c.tier]};background:${tierBg[c.tier]}`}>
            {c.tier}
          </span>
        </div>
      ))}
    </div>

  </div>
</section>
