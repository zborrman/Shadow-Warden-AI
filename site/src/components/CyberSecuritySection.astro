---
const pipeline = [
  { name: 'Topology',   icon: '📐', desc: 'Betti β₀/β₁' },
  { name: 'Obfuscation',icon: '🔄', desc: 'Depth-3 decode' },
  { name: 'Secrets',    icon: '🔑', desc: '15 patterns + entropy' },
  { name: 'Rules',      icon: '📏', desc: 'Compound escalation' },
  { name: 'Brain',      icon: '🧠', desc: 'MiniLM + Poincaré' },
  { name: 'Causal',     icon: '🎯', desc: 'Bayesian DAG' },
  { name: 'Phish',      icon: '🎣', desc: 'URL + SE-Arbiter' },
  { name: 'ERS',        icon: '🚫', desc: 'Shadow ban ≥ 0.75' },
  { name: 'Decision',   icon: '✅', desc: 'ALLOW / FLAG / BLOCK' },
];

const cards = [
  {
    icon: '📐', title: 'Topological Gatekeeper',
    desc: 'TDA n-gram point cloud → Betti numbers (β₀/β₁). Detects structural anomalies invisible to regex. Runs in <strong>&lt;2ms</strong>.',
    tier: 'All', tierColor: '#48485A',
  },
  {
    icon: '🔄', title: 'Obfuscation Decoder',
    desc: 'Depth-3 recursive decode: base64, hex, ROT13, Caesar, word-split, UUencode, Unicode homoglyphs. Attackers cannot nest their way past.',
    tier: 'All', tierColor: '#48485A',
  },
  {
    icon: '🔑', title: 'Secret Redaction',
    desc: '15 regex patterns (AWS keys, JWTs, Stripe, GitHub, SSH) + Shannon entropy scan for unknown secrets. Zero plaintext in memory or logs.',
    tier: 'All', tierColor: '#48485A',
  },
  {
    icon: '🧠', title: 'ML Jailbreak Detection',
    desc: 'MiniLM embeddings projected into Poincaré ball. 70% cosine + 30% hyperbolic distance blend. Adversarial suffix stripping built-in.',
    tier: 'Individual+', tierColor: '#8E8E9E',
  },
  {
    icon: '🎯', title: 'Causal Arbiter',
    desc: 'Bayesian DAG over 5 evidence nodes. Pearl do-calculus backdoor correction. P(HIGH_RISK | evidence) — gray-zone requests get causal reasoning.',
    tier: 'Individual+', tierColor: '#8E8E9E',
  },
  {
    icon: '🎣', title: 'PhishGuard + SE-Arbiter',
    desc: 'URL phishing detection + social engineering pattern matching. Covers pretexting, authority spoofing, urgency manipulation.',
    tier: 'Individual+', tierColor: '#8E8E9E',
  },
  {
    icon: '🔭', title: 'Shadow AI Discovery',
    desc: '18 provider fingerprints. Async /24 subnet probe (256 hosts max, 50 concurrent). DNS telemetry classifier. MONITOR / BLOCK / ALLOWLIST policy.',
    tier: 'Pro+ / Add-on', tierColor: '#FF2D55',
  },
  {
    icon: '🔍', title: 'Explainable AI (XAI)',
    desc: '9-stage causal chain. Primary cause attribution + plain-English counterfactuals. Self-contained HTML + PDF reports for SOC 2 evidence.',
    tier: 'Add-on $9', tierColor: '#0A84FF',
  },
  {
    icon: '⚙️', title: 'Evolution Engine',
    desc: 'Claude Opus reads HIGH/BLOCK events → synthesizes regex rules → hot-reloads corpus. ArXiv paper pipeline: new attack → new rule in hours.',
    tier: 'Pro+', tierColor: '#FF2D55',
  },
  {
    icon: '🛡️', title: 'Data Poisoning Guard',
    desc: 'CPT drift gate in <code>calibrate_from_logs()</code>. Rejects any parameter shift >25% from prior. Blocks slow-burn coordinated poisoning attacks.',
    tier: 'Pro+', tierColor: '#FF2D55',
  },
  {
    icon: '🤖', title: 'SOVA Agent',
    desc: 'Claude Opus 4.6 agentic loop. 30 tool handlers. 7 ARQ cron schedules. Visual patrol, corpus watchdog, SLA reports, key rotation — fully autonomous.',
    tier: 'Pro+', tierColor: '#FF2D55',
  },
  {
    icon: '🎖️', title: 'MasterAgent SOC',
    desc: '4 specialized sub-agents (SOVAOperator, ThreatHunter, ForensicsAgent, ComplianceAgent). HMAC task tokens. Human-in-the-loop approval gate via Slack.',
    tier: 'Pro', tierColor: '#FF2D55',
  },
];
---

<section id="security" class="relative py-24 lg:py-32 overflow-hidden"
         style="background:linear-gradient(180deg,var(--surface-900) 0%,color-mix(in srgb,var(--cat-security) 3%,var(--surface-900)) 50%,var(--surface-900) 100%)">

  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 right-0 w-[600px] h-[400px] opacity-8 blur-[140px]"
         style="background:var(--cat-security)"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-[11px] font-semibold uppercase tracking-widest mb-6 border"
           style="color:var(--cat-security);background:color-mix(in srgb,var(--cat-security) 10%,transparent);border-color:color-mix(in srgb,var(--cat-security) 25%,transparent)">
        <span>◈</span> Cyber Security
      </div>
      <h2 class="text-4xl lg:text-5xl font-extrabold mb-5 leading-tight">
        9 Layers. One Request.<br>
        <span style="background:linear-gradient(135deg,var(--cat-security),#FF8C42);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
          Zero Compromises.
        </span>
      </h2>
      <p class="text-[#8E8E9E] text-lg max-w-2xl mx-auto">
        Every AI request passes through a full cryptographic + ML pipeline in under 2ms.
        From topology to causal inference — every layer has a job.
      </p>
    </div>

    <!-- 9-stage animated pipeline -->
    <div class="mb-16 overflow-x-auto pb-4">
      <div class="flex items-center gap-0 min-w-max mx-auto w-fit">
        {pipeline.map((stage, i) => (
          <>
            <div class="flex flex-col items-center gap-2 group">
              <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-xl border transition-all duration-200
                          group-hover:scale-105"
                   style={i === pipeline.length - 1
                     ? 'background:color-mix(in srgb,#30D158 15%,#0D0D14);border-color:color-mix(in srgb,#30D158 40%,transparent);box-shadow:0 0 20px rgba(48,209,88,0.25)'
                     : 'background:color-mix(in srgb,var(--cat-security) 10%,#0D0D14);border-color:color-mix(in srgb,var(--cat-security) 25%,transparent)'}>
                {stage.icon}
              </div>
              <div class="text-center">
                <div class="text-[11px] font-bold text-[#F5F5F7]">{stage.name}</div>
                <div class="text-[9px] text-[#8E8E9E]">{stage.desc}</div>
              </div>
            </div>
            {i < pipeline.length - 1 && (
              <div class="w-6 h-px mx-1 flex-shrink-0 -mt-6"
                   style="background:linear-gradient(90deg,color-mix(in srgb,var(--cat-security) 40%,transparent),color-mix(in srgb,var(--cat-security) 20%,transparent))">
                <div class="absolute -mt-0.5 ml-2 text-[8px]" style="color:var(--cat-security)">›</div>
              </div>
            )}
          </>
        ))}
      </div>
      <div class="flex justify-center mt-4">
        <span class="text-[11px] font-semibold px-3 py-1 rounded-full"
              style="color:#30D158;background:rgba(48,209,88,0.1);border:1px solid rgba(48,209,88,0.2)">
          ⚡ Total pipeline: &lt;2ms P99
        </span>
      </div>
    </div>

    <!-- Feature cards 4-col grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {cards.map(c => (
        <div class="card-hover rounded-2xl p-5 border"
             style="background:var(--surface-700);border-color:var(--surface-border)">
          <div class="text-2xl mb-3">{c.icon}</div>
          <div class="flex items-center gap-2 flex-wrap mb-2">
            <h3 class="text-[13px] font-bold text-[#F5F5F7]">{c.title}</h3>
            <span class="text-[9px] font-bold px-2 py-0.5 rounded-full"
                  style={`color:${c.tierColor};background:color-mix(in srgb,${c.tierColor} 12%,transparent);border:1px solid color-mix(in srgb,${c.tierColor} 30%,transparent)`}>
              {c.tier}
            </span>
          </div>
          <p class="text-[#8E8E9E] text-[12px] leading-relaxed" set:html={c.desc}/>
        </div>
      ))}
    </div>

    <!-- Shadow ban callout -->
    <div class="mt-8 grid md:grid-cols-3 gap-4">
      {[
        { icon: '👻', title: 'Gaslight Mode', desc: '30+ fake-but-plausible responses. Attackers think they succeeded.', color: '#FF2D55' },
        { icon: '⏱️', title: 'Delay Mode', desc: 'Artificial latency for bot/stuffing traffic. Burns their rate limit budget.', color: '#FF9F0A' },
        { icon: '🔇', title: 'Standard Mode', desc: 'Silent drop with no signal to the attacker. Logged for SOC review.', color: '#8E8E9E' },
      ].map(m => (
        <div class="rounded-xl p-4 border"
             style={`background:color-mix(in srgb,${m.color} 6%,var(--surface-800));border-color:color-mix(in srgb,${m.color} 20%,transparent)`}>
          <div class="text-xl mb-2">{m.icon}</div>
          <div class="text-[12px] font-bold mb-1" style={`color:${m.color}`}>{m.title}</div>
          <p class="text-[#8E8E9E] text-[12px]">{m.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
