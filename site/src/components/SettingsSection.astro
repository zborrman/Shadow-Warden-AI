    infra:         'Infrastructure Settings',
    install:       'Install / Uninstall',
    guide:         'Enterprise Integration Guide v4.11',
  };

  function showSettingsTab(id: string) {
    document.querySelectorAll('.settings-panel').forEach(p => p.classList.add('hidden'));
    document.querySelectorAll('.settings-tab-btn').forEach(b => {
      b.classList.remove('bg-white/[0.06]', 'text-[#F5F5F7]');
      b.classList.add('text-[#8E8E9E]');
    });
    const panel = document.getElementById(`spanel-${id}`);
    const btn   = document.getElementById(`stab-${id}`);
    const title = document.getElementById('settings-title');
    if (panel) panel.classList.remove('hidden');
    if (btn)   { btn.classList.add('bg-white/[0.06]', 'text-[#F5F5F7]'); btn.classList.remove('text-[#8E8E9E]'); }
    if (title) title.textContent = TITLES[id] || id;
  }

  function openSettings() {
    const el = document.getElementById('settings-modal');
    if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
  }

  function closeSettings() {
    const el = document.getElementById('settings-modal');
    if (el) { el.classList.add('hidden'); el.classList.remove('flex'); }
  }

  (window as any).showSettingsTab = showSettingsTab;
  (window as any).openSettings    = openSettings;
  (window as any).closeSettings   = closeSettings;

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSettings(); });
</script>
