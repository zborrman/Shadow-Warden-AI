---
/**
 * LemonSqueezyCheckout
 * Renders a modal containing the LS overlay iframe.
 * Open via: window.lsCheckout(variantId)
 */
---

<!-- Backdrop -->
<div id="ls-backdrop"
     style="display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px)"
     aria-hidden="true"></div>

<!-- Modal wrapper -->
<div id="ls-modal"
     role="dialog"
     aria-modal="true"
     aria-label="Checkout"
     tabindex="-1"
     style="display:none;position:fixed;inset:0;z-index:10001;display:none;align-items:center;justify-content:center;padding:16px">

  <!-- Close button -->
  <button
    id="ls-close"
    type="button"
    aria-label="Close checkout"
    style="position:absolute;top:16px;right:16px;width:36px;height:36px;border-radius:50%;border:1px solid rgba(255,255,255,0.2);background:rgba(0,0,0,0.6);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:1">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <!-- iframe container -->
  <div style="width:100%;max-width:440px;border-radius:16px;overflow:hidden;background:#fff;box-shadow:0 32px 80px rgba(0,0,0,0.6)">
    <iframe
      id="ls-iframe"
      src="about:blank"
      title="Checkout"
      width="100%"
      height="640"
      style="border:none;display:block"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
</div>

<!-- Lemon Squeezy embed script -->
<script src="https://app.lemonsqueezy.com/js/lemon.js" defer></script>

<script>
(function () {
  const backdrop = document.getElementById('ls-backdrop')!;
  const modal    = document.getElementById('ls-modal')!;
  const iframe   = document.getElementById('ls-iframe') as HTMLIFrameElement;
  const closeBtn = document.getElementById('ls-close')!;

  function open(url: string) {
    iframe.src = url;
    backdrop.style.display = 'block';
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    modal.focus();
    // Trap focus
    document.addEventListener('keydown', onKey);
  }

  function close() {
    backdrop.style.display = 'none';
    modal.style.display = 'none';
    iframe.src = 'about:blank';
    document.body.style.overflow = '';
    document.removeEventListener('keydown', onKey);
  }

  function onKey(e: KeyboardEvent) {
    if (e.key === 'Escape') close();
  }

  closeBtn.addEventListener('click', close);
  backdrop.addEventListener('click', close);

  // Global function called by price page buttons
  (window as any).lsCheckout = open;

  // Listen for LS postMessage success
  window.addEventListener('message', (e: MessageEvent) => {
    if (e.data?.event === 'Checkout.Success') {
      const orderId = e.data?.data?.order?.id ?? '';
      close();
      window.location.href = `/thank-you?order_id=${orderId}`;
    }
  });
})();
</script>
