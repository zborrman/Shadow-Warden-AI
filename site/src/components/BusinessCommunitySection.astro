---
const cards = [
  { icon: '🔗', title: 'SEP / UECIID',           desc: 'Snowflake→base-62 entity IDs (<code>SEP-{11}</code>). Cryptographically-unique, sortable, collision-free cross-community references.', tier: 'Community Business' },
  { icon: '🤝', title: 'Inter-Community Peering',  desc: 'Three modes: MIRROR_ONLY, REWRAP_ALLOWED, FULL_SYNC. HMAC-SHA256 handshake tokens. Duplicate peering guard enforced.', tier: 'Community Business' },
  { icon: '📬', title: 'Knock-and-Verify',         desc: '72-hour Redis-backed one-time invitation tokens. Invitee identity verified before member enrollment. Revoke at any time.', tier: 'Community Business' },
  { icon: '🗺️', title: 'Sovereign Data Pods',      desc: 'Per-jurisdiction MinIO routing across 8 regions (EU/US/UK/CA/SG/AU/JP/CH). Fernet-encrypted pod keys. 5-second health probes.', tier: 'Pro' },
  { icon: '🔒', title: 'STIX 2.1 Audit Chain',     desc: 'Tamper-evident SHA-256 linked bundles. Genesis + prev_hash chain per community. OASIS STIX JSONL export for SIEM ingestion.', tier: 'Pro' },
  { icon: '⚛️', title: 'Post-Quantum Keypairs',    desc: 'Hybrid Ed25519 + ML-DSA-65 (FIPS 204) community keys. Upgrade existing communities in-place. <code>is_hybrid</code> auto-detected.', tier: 'Enterprise' },
  { icon: '🏆', title: 'Reputation Engine',         desc: '5-badge system (NEWCOMER → ELITE). Points for publishing, search hits, adopted recommendations. Anonymised leaderboard — GDPR-safe.', tier: 'Community Business' },
  { icon: '📝', title: 'Obsidian Plugin',           desc: 'Auto-scan notes on save. Share via SEP UECIID. XAI pipeline visualization. Offline publish queue with Fernet-encrypted vault sync.', tier: 'Community Business' },
  { icon: '📜', title: 'Charter & Governance',      desc: 'Versioned community charters (DRAFT → ACTIVE → SUPERSEDED). Z-score behavioral anomaly detection. OAuth agent discovery with 14-provider catalog.', tier: 'Community Business' },
];

const tierColor: Record<string, string> = {
  'Community Business': 'var(--sw-violet)',
  'Pro': 'var(--sw-indigo)',
  'Enterprise': 'var(--sw-cyan)',
};
const tierBg: Record<string, string> = {
  'Community Business': 'var(--sw-tint-violet)',
  'Pro': 'var(--sw-tint-indigo)',
  'Enterprise': 'var(--sw-tint-cyan)',
};
---

<section id="community" class="relative py-24 overflow-hidden"
         style="background:var(--sw-bg)">

  <!-- ambient glow -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 40% at 30% 50%,rgba(139,92,246,.06) 0%,transparent 70%)"></div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-5 text-[12px] font-semibold"
           style="color:var(--sw-violet);background:var(--sw-tint-violet);border:1px solid rgba(139,92,246,.2)">
        ◈ Business Community
      </div>
      <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold mb-4" style="color:var(--sw-fg-1)">
        Trusted Intelligence,<br/>
        <span class="sw-gradient-text">Shared Securely</span>
      </h2>
      <p class="text-[15px] max-w-2xl mx-auto" style="color:var(--sw-fg-3)">
        Build federated knowledge networks with cryptographic identity, sovereign data residency,
        and tamper-evident audit trails — across every community boundary.
      </p>
    </div>

    <!-- Peering ring diagram -->
    <div class="flex justify-center mb-16">
      <div class="relative w-[360px] h-[180px]">
        <!-- arcs -->
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 360 180" fill="none">
          <!-- arc A→B -->
          <path d="M90,90 Q180,30 270,90" stroke="url(#arc-grad)" stroke-width="1.5" stroke-dasharray="6 4" opacity=".6"/>
          <!-- arc B→C -->
          <path d="M270,90 Q180,150 90,90" stroke="url(#arc-grad)" stroke-width="1.5" stroke-dasharray="6 4" opacity=".6"/>
          <!-- arc A→C -->
          <path d="M90,90 Q180,90 270,90" stroke="rgba(139,92,246,.25)" stroke-width="1" stroke-dasharray="4 6"/>
          <defs>
            <linearGradient id="arc-grad" x1="0" y1="0" x2="1" y2="0" gradientUnits="objectBoundingBox">
              <stop stop-color="#8b5cf6"/>
              <stop offset="1" stop-color="#06b6d4"/>
            </linearGradient>
          </defs>
        </svg>
        <!-- nodes -->
        {[
          { x: 'left-0',   y: 'top-1/2 -translate-y-1/2', label: 'Acme Corp',    flag: '🇪🇺' },
          { x: 'left-1/2 -translate-x-1/2', y: 'top-2',   label: 'SecureBank',   flag: '🇺🇸' },
          { x: 'right-0',  y: 'top-1/2 -translate-y-1/2', label: 'DataCo',       flag: '🇬🇧' },
        ].map(n => (
          <div class={`absolute ${n.x} ${n.y} flex flex-col items-center gap-1.5`}>
            <div class="w-14 h-14 rounded-full flex items-center justify-center text-xl font-bold"
                 style="background:var(--sw-surf-2);border:2px solid var(--sw-border-strong)">
              {n.flag}
            </div>
            <span class="text-[11px] font-semibold whitespace-nowrap" style="color:var(--sw-fg-3)">{n.label}</span>
          </div>
        ))}
        <!-- center badge -->
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 px-2.5 py-1 rounded-full text-[10px] font-bold"
             style="color:var(--sw-violet);background:var(--sw-tint-violet);border:1px solid rgba(139,92,246,.3)">
          SEP Peering
        </div>
      </div>
    </div>

    <!-- Feature grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {cards.map(c => (
        <div class="rounded-xl p-5 card-hover"
             style="background:var(--sw-surf-1);border:1px solid var(--sw-border);border-top:2px solid var(--sw-violet)">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center text-[18px] mb-3"
               style="background:var(--sw-tint-violet)">
            {c.icon}
          </div>
          <div class="text-[14px] font-semibold mb-1.5" style="color:var(--sw-fg-1)">{c.title}</div>
          <div class="text-[13px] leading-relaxed mb-3" style="color:var(--sw-fg-3)" set:html={c.desc} />
          <span class="inline-block text-[10px] font-bold px-2.5 py-0.5 rounded-full"
                style={`color:${tierColor[c.tier]};background:${tierBg[c.tier]}`}>
            {c.tier}
          </span>
        </div>
      ))}
    </div>

  </div>
</section>
