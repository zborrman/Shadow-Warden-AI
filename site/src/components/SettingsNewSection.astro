---
const cards = [
  { icon: '🔐', title: 'Secrets Governance',     desc: '5 vault connectors (AWS SM, Azure KV, HashiCorp, GCP SM, Env). SQLite inventory with risk scoring. Expiry alerts, auto-retire, rotation scheduling.', tier: 'Add-on $12' },
  { icon: '🌐', title: 'Sovereign Routing',       desc: '8 jurisdictions (EU/US/UK/CA/SG/AU/JP/CH). MASQUE tunnels (H3/H2/TCP). TOFU TLS pinning. Lowest-latency ACTIVE tunnel selection.',                  tier: 'Enterprise'  },
  { icon: '🗺️', title: 'Transfer Rules Matrix',  desc: 'CLASSIFIED → blocked always. PHI → 5 allowed jurisdictions. GENERAL → all with adequacy check. EU↔UK/CA/JP/CH adequacy decisions built-in.',       tier: 'Enterprise'  },
  { icon: '🪙', title: 'Sovereignty Attestation', desc: 'HMAC-SHA256 signed attestations. 7-year Redis TTL. 10K cap per tenant. Verify any historical routing decision in O(1).',                              tier: 'Enterprise'  },
  { icon: '📋', title: 'GDPR Controls',           desc: 'Export/purge APIs for Art. 17 right-to-erasure. Metadata-only logging (no content). Retention scheduler with NDJSON rotation.',                      tier: 'All'         },
  { icon: '🔑', title: 'Multi-tenant Auth',        desc: 'Per-tenant API keys with SHA-256 constant-time compare. Fail-closed at startup — no plaintext key in any log or span.',                              tier: 'All'         },
  { icon: '🔄', title: 'Key Rotation',             desc: 'SOVA-automated daily rotation at 02:00 UTC. Community keypair rotation with PQC upgrade path. Zero-downtime key swap.',                              tier: 'Pro+'        },
  { icon: '⚙️', title: 'Config API',              desc: 'Live-tune thresholds, timeouts, and resilience strategy without restart. Shadow ban score, semantic threshold, transit rules — all hot-reloadable.', tier: 'Pro+'        },
];

const toggles = [
  { label: 'Fail-closed auth',       on: true,  desc: 'Startup halts if API key unset' },
  { label: 'GDPR metadata-only mode',on: true,  desc: 'Content never leaves your stack' },
  { label: 'Evolution Engine',        on: false, desc: 'Requires ANTHROPIC_API_KEY'      },
  { label: 'OTel tracing',           on: false,  desc: 'Enable with OTEL_ENABLED=true'   },
];

const tierColor: Record<string, string> = {
  'All': 'var(--sw-fg-4)', 'Add-on $12': 'var(--sw-cyan)',
  'Enterprise': 'var(--sw-violet)', 'Pro+': 'var(--sw-indigo)',
};
const tierBg: Record<string, string> = {
  'All': 'rgba(100,116,139,.12)', 'Add-on $12': 'var(--sw-tint-cyan)',
  'Enterprise': 'var(--sw-tint-violet)', 'Pro+': 'var(--sw-tint-indigo)',
};
---

<section id="settings" class="relative py-24 overflow-hidden"
         style="background:var(--sw-surf-1)">

  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 50% 40% at 20% 80%,rgba(52,211,153,.05) 0%,transparent 70%)"></div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-5 text-[12px] font-semibold"
           style="color:var(--sw-green);background:var(--sw-tint-green);border:1px solid rgba(52,211,153,.2)">
        ◈ Settings
      </div>
      <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold mb-4" style="color:var(--sw-fg-1)">
        Compliant by Design.<br/>
        <span style="background:linear-gradient(135deg,var(--sw-green),var(--sw-cyan));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">Secure by Default.</span>
      </h2>
      <p class="text-[15px] max-w-2xl mx-auto" style="color:var(--sw-fg-3)">
        Every governance control you need — secrets vaulting, sovereign routing, GDPR purge APIs,
        and automated key rotation — shipped and ready. No custom infra required.
      </p>
    </div>

    <!-- Settings panel (design kit SettingsPanel pattern) -->
    <div class="mb-12 rounded-2xl overflow-hidden max-w-lg mx-auto"
         style="background:var(--sw-surf-2);border:1px solid var(--sw-border)">
      <div class="px-5 py-3 flex items-center gap-2" style="border-bottom:1px solid var(--sw-border)">
        <div class="w-5 h-5 rounded flex items-center justify-center text-[12px]"
             style="background:var(--sw-tint-green)">⚙️</div>
        <span class="text-[13px] font-semibold" style="color:var(--sw-fg-2)">Security Defaults</span>
      </div>
      {toggles.map((t, i) => (
        <div class={`flex items-center justify-between px-5 py-3.5 ${i < toggles.length - 1 ? 'border-b' : ''}`}
             style="border-color:var(--sw-border)">
          <div>
            <div class="text-[13px] font-medium" style="color:var(--sw-fg-1)">{t.label}</div>
            <div class="text-[11px] mt-0.5" style="color:var(--sw-fg-4)">{t.desc}</div>
          </div>
          <!-- toggle -->
          <div class="relative w-10 h-6 rounded-full flex-shrink-0 transition-colors"
               style={`background:${t.on ? 'var(--sw-green)' : 'var(--sw-surf-3)'}`}>
            <div class="absolute top-0.5 w-5 h-5 rounded-full transition-all"
                 style={`background:white;left:${t.on ? 'calc(100% - 22px)' : '2px'}`}></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Feature grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {cards.map(c => (
        <div class="rounded-xl p-5 card-hover"
             style="background:var(--sw-surf-2);border:1px solid var(--sw-border);border-top:2px solid var(--sw-green)">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center text-[18px] mb-3"
               style="background:var(--sw-tint-green)">
            {c.icon}
          </div>
          <div class="text-[13px] font-semibold mb-1.5" style="color:var(--sw-fg-1)">{c.title}</div>
          <div class="text-[12px] leading-relaxed mb-3" style="color:var(--sw-fg-3)">{c.desc}</div>
          <span class="inline-block text-[10px] font-bold px-2.5 py-0.5 rounded-full"
                style={`color:${tierColor[c.tier]};background:${tierBg[c.tier]}`}>
            {c.tier}
          </span>
        </div>
      ))}
    </div>

  </div>
</section>
