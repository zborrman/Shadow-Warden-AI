---
// EU Accessibility Widget — WCAG 2.1 AA · EAA 2019/882
---

<div id="a11y-root">
  <!-- Floating button -->
  <button id="a11y-btn" aria-label="Accessibility options" aria-expanded="false" aria-controls="a11y-panel">
    <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="4" r="2.4" fill="white"/>
      <line x1="12" y1="7" x2="12" y2="15" stroke="white" stroke-width="2.4" stroke-linecap="round"/>
      <line x1="5"  y1="10" x2="19" y2="10" stroke="white" stroke-width="2.4" stroke-linecap="round"/>
      <line x1="12" y1="15" x2="8"  y2="21" stroke="white" stroke-width="2.4" stroke-linecap="round"/>
      <line x1="12" y1="15" x2="16" y2="21" stroke="white" stroke-width="2.4" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- Panel (visibility toggled via .open class) -->
  <div id="a11y-panel" role="dialog" aria-label="Accessibility settings" aria-modal="false">

    <div class="ap-head">
      <div>
        <div class="ap-title">Accessibility</div>
        <div class="ap-sub">EAA 2019/882 · WCAG 2.1 AA</div>
      </div>
      <div class="ap-badge">🇪🇺 <span>Compliant</span></div>
    </div>

    <div class="ap-body">

      <!-- Text size -->
      <div class="ap-row">
        <div class="ap-row-label">Text size</div>
        <div class="ap-font-group">
          <button class="ap-font" data-delta="-1" aria-label="Smaller text" style="font-size:11px">A−</button>
          <button class="ap-font" data-delta="0"  aria-label="Default text size" style="font-size:13px">A</button>
          <button class="ap-font" data-delta="1"  aria-label="Larger text" style="font-size:16px">A+</button>
        </div>
      </div>

      <!-- Toggles -->
      <div class="ap-row">
        <div>
          <div class="ap-row-label">High contrast</div>
          <div class="ap-row-hint">WCAG 1.4.6</div>
        </div>
        <button class="ap-switch" data-key="contrast" role="switch" aria-checked="false" aria-label="Toggle high contrast">
          <span class="ap-knob"></span>
        </button>
      </div>

      <div class="ap-row">
        <div>
          <div class="ap-row-label">Reduce motion</div>
          <div class="ap-row-hint">WCAG 2.3.3</div>
        </div>
        <button class="ap-switch" data-key="motion" role="switch" aria-checked="false" aria-label="Toggle reduce motion">
          <span class="ap-knob"></span>
        </button>
      </div>

      <div class="ap-row">
        <div>
          <div class="ap-row-label">Dyslexia font</div>
          <div class="ap-row-hint">OpenDyslexic</div>
        </div>
        <button class="ap-switch" data-key="dyslexia" role="switch" aria-checked="false" aria-label="Toggle dyslexia font">
          <span class="ap-knob"></span>
        </button>
      </div>

      <div class="ap-row">
        <div>
          <div class="ap-row-label">Focus ring</div>
          <div class="ap-row-hint">WCAG 2.4.11</div>
        </div>
        <button class="ap-switch" data-key="focus" role="switch" aria-checked="false" aria-label="Toggle enhanced focus">
          <span class="ap-knob"></span>
        </button>
      </div>

      <button id="ap-reset">Reset all</button>
    </div>

    <div class="ap-foot">
      European Accessibility Act · Directive (EU) 2019/882<br>
      WCAG 2.1 Level AA · EN 301 549 v3.2.1
    </div>
  </div>
</div>

<!-- Global effect classes applied to body -->
<style is:global>
  body.a11y-contrast * { filter: contrast(1.6) !important; }
  body.a11y-motion *, body.a11y-motion *::before, body.a11y-motion *::after {
    animation-duration: 0.001ms !important;
    transition-duration: 0.001ms !important;
  }
  body.a11y-focus *:focus-visible {
    outline: 3px solid #818cf8 !important;
    outline-offset: 3px !important;
  }
  @font-face {
    font-family: 'OpenDyslexic';
    src: url('https://cdn.jsdelivr.net/npm/open-dyslexic@1.0.3/open-dyslexic-regular.woff') format('woff');
    font-display: swap;
  }
  body.a11y-dyslexia { font-family: 'OpenDyslexic', sans-serif !important; }
</style>

<style>
  /* ── Floating button ── */
  #a11y-btn {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 9999;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    box-shadow: 0 4px 24px rgba(99,102,241,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    outline: none;
  }
  #a11y-btn:hover  { transform: scale(1.1); box-shadow: 0 6px 32px rgba(99,102,241,0.6); }
  #a11y-btn:focus-visible { outline: 2px solid #a78bfa; outline-offset: 3px; }

  /* ── Panel ── */
  #a11y-panel {
    position: fixed;
    bottom: 88px;
    right: 28px;
    z-index: 9998;
    width: 288px;
    border-radius: 18px;
    background: #0e0e1c;
    border: 1px solid rgba(99,102,241,0.28);
    box-shadow: 0 24px 64px rgba(0,0,0,0.72), inset 0 1px 0 rgba(255,255,255,0.06);
    overflow: hidden;
    /* hidden by default */
    opacity: 0;
    transform: translateY(12px) scale(0.95);
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  #a11y-panel.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* ── Header ── */
  .ap-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 16px 13px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background: rgba(99,102,241,0.05);
  }
  .ap-title {
    font-size: 14px;
    font-weight: 700;
    color: #f1f5f9;
    font-family: system-ui, -apple-system, sans-serif;
    line-height: 1;
    margin-bottom: 3px;
  }
  .ap-sub {
    font-size: 10px;
    color: #475569;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .ap-badge {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 9px;
    border-radius: 20px;
    background: rgba(30,64,175,0.2);
    border: 1px solid rgba(99,130,254,0.3);
    font-size: 11px;
    font-weight: 600;
    color: #7ca3ff;
    font-family: system-ui, -apple-system, sans-serif;
    white-space: nowrap;
  }

  /* ── Body ── */
  .ap-body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Row ── */
  .ap-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .ap-row-label {
    font-size: 12.5px;
    font-weight: 500;
    color: #cbd5e1;
    font-family: system-ui, -apple-system, sans-serif;
    line-height: 1.2;
  }
  .ap-row-hint {
    font-size: 10px;
    color: #334155;
    font-family: system-ui, -apple-system, sans-serif;
    margin-top: 2px;
  }

  /* ── Font size buttons ── */
  .ap-font-group {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }
  .ap-font {
    width: 34px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: #94a3b8;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: system-ui, -apple-system, sans-serif;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .ap-font:hover, .ap-font.active {
    background: rgba(99,102,241,0.18);
    border-color: rgba(99,102,241,0.5);
    color: #a78bfa;
  }
  .ap-font:focus-visible { outline: 2px solid #6366f1; outline-offset: 2px; }

  /* ── Toggle switch ── */
  .ap-switch {
    flex-shrink: 0;
    position: relative;
    width: 44px;
    height: 24px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.07);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, border-color 0.2s;
  }
  .ap-switch[aria-checked="true"] {
    background: #5a5fcf;
    border-color: #6366f1;
  }
  .ap-switch:focus-visible { outline: 2px solid #6366f1; outline-offset: 2px; }
  .ap-knob {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #e2e8f0;
    box-shadow: 0 1px 4px rgba(0,0,0,0.4);
    transition: transform 0.2s cubic-bezier(0.4,0,0.2,1);
    pointer-events: none;
  }
  .ap-switch[aria-checked="true"] .ap-knob {
    transform: translateX(20px);
    background: #fff;
  }

  /* ── Reset button ── */
  #ap-reset {
    width: 100%;
    padding: 8px;
    border-radius: 9px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    color: #475569;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    font-family: system-ui, -apple-system, sans-serif;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    margin-top: 2px;
  }
  #ap-reset:hover {
    color: #94a3b8;
    border-color: rgba(255,255,255,0.16);
    background: rgba(255,255,255,0.05);
  }
  #ap-reset:focus-visible { outline: 2px solid #6366f1; outline-offset: 2px; }

  /* ── Footer ── */
  .ap-foot {
    padding: 10px 16px 14px;
    border-top: 1px solid rgba(255,255,255,0.05);
    font-size: 10px;
    color: #2d3748;
    text-align: center;
    line-height: 1.7;
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>

<script>
(function() {
  var STORE = 'sw_a11y_v3';
  var SCALES = [0.88, 0.94, 1, 1.12, 1.25];
  var DELTAS = [-2, -1, 0, 1, 2];

  var def = { delta: 0, contrast: false, motion: false, dyslexia: false, focus: false };
  var st = Object.assign({}, def);
  try { Object.assign(st, JSON.parse(localStorage.getItem(STORE) || '{}')); } catch(e) {}

  function save() {
    try { localStorage.setItem(STORE, JSON.stringify(st)); } catch(e) {}
  }

  function applyAll() {
    var body = document.body;
    // font: apply to body so rem doesn't break
    var idx = DELTAS.indexOf(st.delta);
    if (idx < 0) idx = 2;
    body.style.fontSize = (SCALES[idx] * 16) + 'px';

    body.classList.toggle('a11y-contrast', !!st.contrast);
    body.classList.toggle('a11y-motion',   !!st.motion);
    body.classList.toggle('a11y-dyslexia', !!st.dyslexia);
    body.classList.toggle('a11y-focus',    !!st.focus);
  }

  function syncUI() {
    // font buttons
    var fontBtns = document.querySelectorAll('.ap-font');
    for (var i = 0; i < fontBtns.length; i++) {
      var d = parseInt(fontBtns[i].getAttribute('data-delta') || '0');
      fontBtns[i].classList.toggle('active', d === st.delta);
    }
    // switches
    var switches = document.querySelectorAll('.ap-switch');
    for (var j = 0; j < switches.length; j++) {
      var k = switches[j].getAttribute('data-key');
      switches[j].setAttribute('aria-checked', st[k] ? 'true' : 'false');
    }
  }

  // Apply saved settings immediately
  applyAll();
  syncUI();

  // Panel open/close
  var btn   = document.getElementById('a11y-btn');
  var panel = document.getElementById('a11y-panel');

  function openPanel() {
    panel.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
  }
  function closePanel() {
    panel.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  }
  function isOpen() { return panel.classList.contains('open'); }

  btn.addEventListener('click', function() {
    isOpen() ? closePanel() : openPanel();
  });
  document.addEventListener('click', function(e) {
    if (isOpen() && !panel.contains(e.target) && e.target !== btn) closePanel();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && isOpen()) { closePanel(); btn.focus(); }
  });

  // Font buttons
  var fontBtns = document.querySelectorAll('.ap-font');
  for (var i = 0; i < fontBtns.length; i++) {
    fontBtns[i].addEventListener('click', function() {
      st.delta = parseInt(this.getAttribute('data-delta') || '0');
      applyAll(); syncUI(); save();
    });
  }

  // Toggle switches
  var switches = document.querySelectorAll('.ap-switch');
  for (var j = 0; j < switches.length; j++) {
    switches[j].addEventListener('click', function() {
      var k = this.getAttribute('data-key');
      st[k] = !st[k];
      applyAll(); syncUI(); save();
    });
  }

  // Reset
  document.getElementById('ap-reset').addEventListener('click', function() {
    st = Object.assign({}, def);
    document.body.style.fontSize = '';
    applyAll(); syncUI(); save();
  });
})();
</script>
