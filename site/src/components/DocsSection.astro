---
const docs = [
  {
    icon: '🚀',
    title: 'Quick Start',
    desc: 'Up in 5 minutes with Docker Compose. First request filtered in under 60 seconds.',
    link: '/docs/quickstart',
    color: '#30D158',
  },
  {
    icon: '📡',
    title: 'API Reference',
    desc: 'Full endpoint catalog: filter, batch, SOVA, billing, communities, XAI, sovereign — 80+ endpoints.',
    link: '/enterprise-guide',
    color: '#0A84FF',
  },
  {
    icon: '🏗️',
    title: 'Architecture',
    desc: '9-layer pipeline anatomy, n-tier agent topology, multi-cloud routing, MinIO evidence vault.',
    link: '/enterprise-guide#architecture',
    color: '#BF5AF2',
  },
  {
    icon: '🛡️',
    title: 'Security Model',
    desc: 'OWASP LLM Top 10 coverage, threat model, crypto controls (Ed25519, HMAC-SHA256, PQC).',
    link: '/enterprise-guide#security',
    color: '#FF2D55',
  },
  {
    icon: '🔒',
    title: 'GDPR DPIA',
    desc: 'Art. 35 Data Protection Impact Assessment. Metadata-only logging, data minimisation, right-to-erasure API.',
    link: '/enterprise-guide#gdpr',
    color: '#FFD60A',
  },
  {
    icon: '✅',
    title: 'SOC 2 Type II',
    desc: 'Control mapping + auditor collection procedures. Evidence Vault walkthrough. STIX 2.1 chain export.',
    link: '/enterprise-guide#soc2',
    color: '#FF8C42',
  },
  {
    icon: '📋',
    title: 'SLA',
    desc: 'Pro 99.9% / Enterprise 99.95% uptime. P99 &lt;50ms guarantee. Incident response timeline + credit schedule.',
    link: '/enterprise-guide#sla',
    color: '#8E8E9E',
  },
  {
    icon: '🔌',
    title: 'Integration Guides',
    desc: 'LangChain callback, OpenAI-compatible proxy, Obsidian plugin, k6 load tests, GitHub Actions CI matrix.',
    link: '/enterprise-guide#integrations',
    color: '#30D158',
  },
];

const changelog = [
  { version: 'v4.19', label: 'Obsidian Plugin Full Integration', color: '#BF5AF2' },
  { version: 'v4.7',  label: 'SEP · PQC Signing · STIX Chain · Security P0 Fixes', color: '#FF2D55' },
  { version: 'v4.0',  label: 'MasterAgent · SOVA 30 Tools · Agentic SOC', color: '#0A84FF' },
  { version: 'v3.0',  label: 'Sovereign AI Cloud · Shadow AI · XAI 2.0', color: '#30D158' },
  { version: 'v2.0',  label: 'Causal Arbiter · Evolution Engine · Evidence Vault', color: '#FFD60A' },
];
---

<section id="docs" class="relative py-24 lg:py-32 overflow-hidden"
         style="background:var(--surface-800)">

  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 right-1/4 w-[400px] h-[400px] opacity-6 blur-[100px]"
         style="background:var(--cat-docs)"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-[11px] font-semibold uppercase tracking-widest mb-6 border"
           style="color:var(--cat-docs);background:color-mix(in srgb,var(--cat-docs) 10%,transparent);border-color:color-mix(in srgb,var(--cat-docs) 25%,transparent)">
        <span>◈</span> Documentation
      </div>
      <h2 class="text-4xl lg:text-5xl font-extrabold mb-5 leading-tight">
        Everything Documented.<br>
        <span style="background:linear-gradient(135deg,var(--cat-docs),var(--cat-price));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
          Nothing Hidden.
        </span>
      </h2>
      <p class="text-[#8E8E9E] text-lg max-w-2xl mx-auto">
        From GDPR DPIA to k6 load tests — every integration, compliance artefact,
        and architectural decision is written down.
      </p>
    </div>

    <!-- Doc cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
      {docs.map(d => (
        <a href={d.link}
           class="card-hover rounded-2xl p-5 border group block"
           style="background:var(--surface-700);border-color:var(--surface-border)">
          <div class="text-2xl mb-3">{d.icon}</div>
          <h3 class="text-[14px] font-bold text-[#F5F5F7] mb-2 group-hover:underline"
              style={`color:${d.color}`}>{d.title}</h3>
          <p class="text-[#8E8E9E] text-[12px] leading-relaxed" set:html={d.desc}/>
          <div class="mt-4 text-[11px] font-semibold" style={`color:${d.color}`}>Read →</div>
        </a>
      ))}
    </div>

    <!-- Changelog timeline -->
    <div class="rounded-2xl p-6 border" style="border-color:var(--surface-border);background:var(--surface-700)">
      <div class="text-[13px] font-bold text-[#F5F5F7] mb-6">Release Timeline</div>
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-[19px] top-2 bottom-2 w-px"
             style="background:linear-gradient(180deg,var(--cat-community),var(--cat-docs))"></div>
        <div class="flex flex-col gap-6">
          {changelog.map(c => (
            <div class="flex items-start gap-4 pl-1">
              <div class="relative flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center text-[10px] font-extrabold border"
                   style={`background:color-mix(in srgb,${c.color} 15%,var(--surface-800));border-color:color-mix(in srgb,${c.color} 40%,transparent);color:${c.color}`}>
                {c.version.replace('v', '')}
              </div>
              <div class="flex-1 pt-1.5">
                <div class="text-[12px] font-bold" style={`color:${c.color}`}>{c.version}</div>
                <div class="text-[#8E8E9E] text-[12px]">{c.label}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
