---
const docs = [
  { icon: '🚀', title: 'Quick Start',        desc: 'Up in 5 minutes with Docker Compose. First request filtered in under 60 seconds.',                                          link: '/docs/quickstart',             color: 'var(--sw-green)'  },
  { icon: '📡', title: 'API Reference',      desc: 'Full endpoint catalog: filter, batch, SOVA, billing, communities, XAI, sovereign — 80+ endpoints with auth and examples.', link: '/enterprise-guide',            color: 'var(--sw-indigo)' },
  { icon: '🏗️', title: 'Architecture',      desc: '9-layer pipeline anatomy, n-tier agent topology, multi-cloud sovereign routing, MinIO evidence vault.',                     link: '/enterprise-guide#architecture',color: 'var(--sw-violet)' },
  { icon: '🛡️', title: 'Security Model',   desc: 'OWASP LLM Top 10 coverage, threat model, crypto controls (Ed25519, HMAC-SHA256, PQC), GDPR data flow.',                    link: '/enterprise-guide#security',   color: 'var(--sw-red)'    },
  { icon: '📄', title: 'GDPR DPIA',         desc: 'Art. 35 Data Protection Impact Assessment with necessity, proportionality, and risk mitigation analysis.',                  link: '/docs/dpia',                   color: 'var(--sw-amber)'  },
  { icon: '✅', title: 'SOC 2 Type II',     desc: 'Control mapping + auditor evidence collection procedures. Pre-built evidence bundles from MinIO.',                           link: '/docs/soc2',                   color: 'var(--sw-cyan)'   },
  { icon: '📈', title: 'SLA',               desc: 'Pro 99.9% / Enterprise 99.95% uptime. P99 &lt; 50ms. Incident response SLOs and credit schedule.',                          link: '/docs/sla',                    color: 'var(--sw-orange)' },
  { icon: '🔗', title: 'Integration Guides',desc: 'LangChain WardenCallback, OpenAI proxy, Obsidian plugin, k6 load tests, SIEM ingestion, Grafana dashboards.',               link: '/enterprise-guide#integrations',color: 'var(--sw-violet)' },
];

const changelog = [
  { version: 'v4.19', label: 'Obsidian Plugin Full Integration', date: 'May 2026' },
  { version: 'v4.10', label: 'Business Community + SEP Protocol', date: 'May 2026' },
  { version: 'v4.0',  label: 'Agentic SOC — MasterAgent & SOVA', date: 'Apr 2026' },
  { version: 'v3.0',  label: 'Sovereign Cloud + PQC Keypairs',    date: 'Mar 2026' },
  { version: 'v2.0',  label: 'Shadow AI Discovery + XAI Reports', date: 'Feb 2026' },
];
---

<section id="docs" class="relative py-24 overflow-hidden"
         style="background:var(--sw-bg)">

  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 50% 40% at 80% 30%,rgba(251,191,36,.05) 0%,transparent 70%)"></div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-5 text-[12px] font-semibold"
           style="color:var(--sw-amber);background:var(--sw-tint-amber);border:1px solid rgba(251,191,36,.2)">
        ◈ Docs
      </div>
      <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold mb-4" style="color:var(--sw-fg-1)">
        Everything You Need<br/>
        <span style="background:linear-gradient(135deg,var(--sw-amber),var(--sw-orange));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">To Ship with Confidence.</span>
      </h2>
      <p class="text-[15px] max-w-2xl mx-auto" style="color:var(--sw-fg-3)">
        Production-grade documentation: quick-start guides, full API reference, GDPR DPIA,
        SOC 2 evidence procedures, and architecture deep-dives.
      </p>
    </div>

    <!-- Doc cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
      {docs.map(d => (
        <a href={d.link}
           class="group block rounded-xl p-5 card-hover no-underline"
           style="background:var(--sw-surf-1);border:1px solid var(--sw-border)">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[20px] mb-4 transition-transform group-hover:scale-110"
               style={`background:color-mix(in srgb,${d.color} 12%,transparent)`}>
            {d.icon}
          </div>
          <div class="text-[14px] font-semibold mb-2" style="color:var(--sw-fg-1)">{d.title}</div>
          <div class="text-[12px] leading-relaxed mb-4" style="color:var(--sw-fg-3)" set:html={d.desc} />
          <span class="inline-flex items-center gap-1 text-[12px] font-semibold transition-colors"
                style={`color:${d.color}`}>
            Read →
          </span>
        </a>
      ))}
    </div>

    <!-- Changelog timeline -->
    <div class="max-w-2xl mx-auto">
      <h3 class="text-center text-[14px] font-semibold mb-8" style="color:var(--sw-fg-3)">Release Timeline</h3>
      <div class="relative">
        <!-- vertical line -->
        <div class="absolute left-[74px] top-0 bottom-0 w-px" style="background:var(--sw-border)"></div>
        <div class="space-y-6">
          {changelog.map((c, i) => (
            <div class="flex items-start gap-4">
              <div class="text-right w-[70px] shrink-0">
                <span class="text-[10px] font-bold" style="color:var(--sw-amber)">{c.version}</span>
                <div class="text-[10px]" style="color:var(--sw-fg-4)">{c.date}</div>
              </div>
              <!-- dot -->
              <div class="relative z-10 mt-1 w-3 h-3 rounded-full shrink-0"
                   style={`background:${i === 0 ? 'var(--sw-amber)' : 'var(--sw-surf-3)'};border:2px solid ${i === 0 ? 'var(--sw-amber)' : 'var(--sw-border-strong)'}`}></div>
              <div class="text-[13px] font-medium" style="color:var(--sw-fg-2)">{c.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>
