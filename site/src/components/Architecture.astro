---
const stages = [
  { id: '01', label: 'Topological\nGatekeeper',   color: '#FF2D55', ms: '<2ms' },
  { id: '02', label: 'Obfuscation\nDecoder',       color: '#FF9F0A', ms: '<1ms' },
  { id: '03', label: 'PII & Secret\nVault',        color: '#FFD60A', ms: '<1ms' },
  { id: '04', label: 'Semantic\nRule Engine',      color: '#30D158', ms: '<3ms' },
  { id: '05', label: 'Hyperbolic\nBrain',          color: '#0A84FF', ms: '<8ms' },
  { id: '06', label: 'Causal\nArbiter',            color: '#BF5AF2', ms: '<3ms' },
  { id: '07', label: 'PhishGuard\n+ SE-Arbiter',  color: '#FF2D55', ms: '<2ms' },
  { id: '08', label: 'ERS Shadow\nBan',            color: '#FF9F0A', ms: '<1ms' },
];

const pillars = [
  { icon: '🤖', title: 'Agentic SOC', desc: 'MasterAgent + 4 sub-agents running parallel threat analysis with HMAC task tokens.' },
  { icon: '🧬', title: 'Post-Quantum', desc: 'HybridSigner (Ed25519 + ML-DSA-65) and HybridKEM (X25519 + ML-KEM-768) FIPS 203/204.' },
  { icon: '👁️', title: 'Shadow AI', desc: '18-provider fingerprint DB. Async /24 subnet probe catches unauthorized AI deployments.' },
  { icon: '📊', title: 'Explainable AI', desc: '9-stage DAG with causal attribution, counterfactuals, and one-click PDF audit reports.' },
  { icon: '🌐', title: 'Sovereign Cloud', desc: 'Per-tenant routing across 8 jurisdictions via MASQUE_H3 tunnels. GDPR-native by design.' },
  { icon: '🔗', title: 'SEP Protocol', desc: 'UECIID business identity + STIX 2.1 tamper-evident audit chain for cross-community exchange.' },
];
---

<section id="architecture" class="relative py-28 lg:py-36 bg-[#080D1E]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/[0.07] to-transparent"></div>
  <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/[0.07] to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-16">
      <p class="text-[11px] font-bold tracking-[2.5px] uppercase text-[#BF5AF2] mb-3">
        Zero Entry Architecture
      </p>
      <h2 class="text-[42px] lg:text-[52px] font-bold tracking-[-2px] mb-4">
        Every request. Every layer.<br />
        <span class="bg-gradient-to-r from-[#BF5AF2] to-[#0A84FF] bg-clip-text text-transparent">
          Under 20ms total.
        </span>
      </h2>
      <p class="text-[16px] text-[#8E8E9E] max-w-xl leading-relaxed">
        A synchronous 8-stage filter pipeline. No async gaps, no blind spots.
        Each stage operates on the same enriched context object.
      </p>
    </div>

    <!-- Pipeline flow -->
    <div class="mb-16 rounded-2xl border border-white/[0.07] bg-[#03050F] p-8 overflow-x-auto">
      <!-- Request label -->
      <div class="flex items-center gap-3 mb-8">
        <div class="px-4 py-2 rounded-xl border border-white/[0.1] bg-white/[0.03] text-[13px] font-mono font-bold text-[#F5F5F7]">
          POST /filter
        </div>
        <span class="text-[#48485A] text-[12px]">→ context object flows through all stages</span>
        <div class="ml-auto flex items-center gap-2 text-[12px] text-[#30D158] font-mono font-bold">
          <span class="w-2 h-2 rounded-full bg-[#30D158] animate-pulse"></span>
          LIVE
        </div>
      </div>

      <!-- Stages grid -->
      <div class="flex flex-wrap gap-3 items-center">
        {stages.map((s, i) => (
          <div class="flex items-center gap-3">
            <div
              class="relative flex-shrink-0 w-[120px] rounded-xl border p-3 text-center"
              style={`border-color:${s.color}30;background:${s.color}08`}
            >
              <div
                class="text-[9px] font-bold font-mono mb-1.5 opacity-50"
                style={`color:${s.color}`}
              >{s.id}</div>
              <div class="text-[11px] font-semibold leading-[1.4] whitespace-pre-line text-[#F5F5F7]">
                {s.label}
              </div>
              <div
                class="mt-2 text-[9px] font-mono font-bold"
                style={`color:${s.color}`}
              >{s.ms}</div>
            </div>
            {i < stages.length - 1 && (
              <svg width="16" height="10" viewBox="0 0 16 10" fill="none" class="flex-shrink-0 opacity-40">
                <path d="M0 5h14M10 1l4 4-4 4" stroke="#8E8E9E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
        ))}

        <!-- Arrow to decision -->
        <svg width="16" height="10" viewBox="0 0 16 10" fill="none" class="flex-shrink-0 opacity-40">
          <path d="M0 5h14M10 1l4 4-4 4" stroke="#8E8E9E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>

        <!-- Decision block -->
        <div class="flex-shrink-0 w-[100px] rounded-xl border border-[#30D158]/30 bg-[#30D158]/[0.07] p-3 text-center">
          <div class="text-[9px] font-bold font-mono mb-1.5 text-[#30D158] opacity-50">DECISION</div>
          <div class="text-[11px] font-semibold text-[#F5F5F7] leading-[1.4]">ALLOW /<br/>BLOCK</div>
          <div class="mt-2 text-[9px] font-mono font-bold text-[#30D158]">&lt;20ms</div>
        </div>
      </div>

      <!-- Side paths -->
      <div class="mt-8 flex flex-wrap gap-4 border-t border-white/[0.05] pt-6">
        <div class="flex items-center gap-2.5 text-[12px] text-[#8E8E9E]">
          <span class="w-2.5 h-2.5 rounded-sm bg-[#BF5AF2]/40"></span>
          HIGH/BLOCK events → <span class="text-[#BF5AF2] font-semibold">Evolution Engine</span> (Claude Opus · hot-reload corpus)
        </div>
        <div class="flex items-center gap-2.5 text-[12px] text-[#8E8E9E]">
          <span class="w-2.5 h-2.5 rounded-sm bg-[#0A84FF]/40"></span>
          All decisions → <span class="text-[#0A84FF] font-semibold">Evidence Vault</span> (MinIO · SHA-256 attestation)
        </div>
        <div class="flex items-center gap-2.5 text-[12px] text-[#8E8E9E]">
          <span class="w-2.5 h-2.5 rounded-sm bg-[#FF9F0A]/40"></span>
          Score ≥0.75 → <span class="text-[#FF9F0A] font-semibold">Shadow Ban</span> (gaslight · delay · standard)
        </div>
      </div>
    </div>

    <!-- Strategic pillars -->
    <div>
      <p class="text-[11px] font-bold tracking-[2.5px] uppercase text-[#48485A] mb-6">
        4.7 Strategic Pillars
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {pillars.map(p => (
          <div class="flex gap-4 p-5 rounded-xl border border-white/[0.06] bg-white/[0.02] hover:border-white/[0.1] transition-colors duration-200">
            <span class="text-2xl flex-shrink-0 mt-0.5">{p.icon}</span>
            <div>
              <div class="text-[14px] font-bold mb-1.5">{p.title}</div>
              <div class="text-[12px] text-[#8E8E9E] leading-[1.65]">{p.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
