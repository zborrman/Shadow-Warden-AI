---
const tiers = [
  {
    name: 'Starter', price: 0, color: '#48485A', glow: false,
    cta: 'Get Started Free', ctaStyle: 'background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08)',
    features: [
      { text: '1 000 req/month', ok: true },
      { text: 'Basic filter pipeline', ok: true },
      { text: '1 tenant', ok: true },
      { text: 'Community support', ok: true },
    ],
  },
  {
    name: 'Individual', price: 5, color: '#8E8E9E', glow: false,
    cta: 'Start Free Trial', ctaStyle: 'background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12)',
    features: [
      { text: '5 000 req/month', ok: true },
      { text: '14-layer pipeline', ok: true },
      { text: 'PII & Secret Redaction', ok: true },
      { text: 'Streamlit dashboard', ok: true },
      { text: 'XAI Reports ($9/mo add-on)', ok: null },
      { text: 'MasterAgent SOC', ok: false },
    ],
  },
  {
    name: 'Community Business', price: 19, color: '#30D158', glow: false,
    cta: 'Start Free Trial', ctaStyle: 'background:rgba(48,209,88,0.1);border:1px solid rgba(48,209,88,0.3)',
    features: [
      { text: '10 000 req/month', ok: true },
      { text: 'Everything in Individual', ok: true },
      { text: 'File Scanner + Email Guard', ok: true },
      { text: 'Obsidian Integration', ok: true },
      { text: 'Secrets Governance (included)', ok: true },
      { text: '3 communities × 10 members', ok: true },
      { text: '180-day retention', ok: true },
    ],
  },
  {
    name: 'Pro', price: 69, color: '#FF2D55', glow: true,
    tag: 'Most Popular',
    cta: 'Start Free Trial', ctaStyle: 'background:#FF2D55;box-shadow:0 8px 32px rgba(255,45,85,0.4)',
    features: [
      { text: '50 000 req/month', ok: true },
      { text: 'Full 14-layer defense stack', ok: true },
      { text: 'MasterAgent SOC (included)', ok: true },
      { text: 'Evolution Engine (self-improving)', ok: true },
      { text: 'Evidence Vault + STIX 2.1', ok: true },
      { text: 'SOC 2 + GDPR audit package', ok: true },
      { text: 'Shadow AI Discovery ($15/mo add-on)', ok: null },
      { text: 'PQC / Sovereign Cloud', ok: false },
    ],
  },
  {
    name: 'Enterprise', price: 249, color: '#BF5AF2', glow: false,
    tag: 'Full Stack',
    cta: 'Contact Sales', ctaStyle: 'background:rgba(191,90,242,0.12);border:1px solid rgba(191,90,242,0.3)',
    features: [
      { text: 'Unlimited requests', ok: true },
      { text: 'Post-Quantum Crypto (FIPS 203/204)', ok: true },
      { text: 'Sovereign AI Cloud — 8 jurisdictions', ok: true },
      { text: 'Shadow AI Governance', ok: true },
      { text: 'XAI Audit Reports (PDF)', ok: true },
      { text: 'SEP Communities Protocol', ok: true },
      { text: 'SAML/OIDC SSO + RBAC', ok: true },
      { text: 'Dedicated SLA + 24/7 support', ok: true },
    ],
  },
];

const addons = [
  { name: 'Shadow AI Discovery', price: '$15/mo', tier: 'Pro+',
    desc: 'Async /24 subnet probe across 18 AI providers. DNS telemetry. Per-tenant MONITOR/BLOCK/ALLOWLIST policy.' },
  { name: 'XAI Audit Reports',   price: '$9/mo',  tier: 'Individual+',
    desc: '9-stage causal chain. Primary cause attribution. PDF reports for SOC 2 evidence packages.' },
  { name: 'Secrets Vault',       price: '$12/mo', tier: 'Individual+',
    desc: 'Multi-cloud vault connectors (AWS SM / Azure KV / HashiCorp / GCP). Inventory, lifecycle alerts, policy compliance score.' },
  { name: 'On-Prem Pack',        price: '$29/mo', tier: 'Pro+',
    desc: 'MinIO on-premises object store, self-hosted Prometheus/Grafana, air-gapped Evolution Engine mode.' },
  { name: 'Community Seats',     price: '$9/mo',  tier: 'Community Business+',
    desc: 'Stackable +5 extra seats per unit. Combine with any higher tier for unlimited seat expansion.' },
];

const bundle = {
  name: 'Power User Bundle',
  price: '$29/mo',
  saves: 'saves $7',
  includes: ['XAI Audit Reports', 'Secrets Vault', 'Shadow AI Discovery'],
};
---

<section id="price" class="relative py-24 lg:py-32 bg-[#03050F]">
  <div class="absolute inset-x-0 top-0 h-px"
       style="background:linear-gradient(90deg,transparent,rgba(255,45,85,0.2),transparent)"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-[11px] font-semibold uppercase tracking-widest mb-6 border"
           style="color:var(--cat-price);background:color-mix(in srgb,var(--cat-price) 10%,transparent);border-color:color-mix(in srgb,var(--cat-price) 25%,transparent)">
        <span>◈</span> Pricing
      </div>
      <h2 class="text-[42px] lg:text-[56px] font-black tracking-[-2.5px] mb-4">
        Pays for itself in<br />
        <span style="background:linear-gradient(135deg,#FF2D55,#FFD60A);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
          minutes.
        </span>
      </h2>
      <p class="text-[16px] text-[#8E8E9E] max-w-xl mx-auto leading-relaxed">
        IBM 2024: average breach costs <span class="text-[#FF2D55] font-bold">$4.88M</span>.
        Pro plan ROI at default settings: <span class="text-[#30D158] font-bold">782×</span> annually.
      </p>
    </div>

    <!-- Annual toggle -->
    <div class="flex items-center justify-center gap-3 mb-10">
      <span class="text-[13px] text-[#8E8E9E]">Monthly</span>
      <button id="annual-toggle"
              class="relative w-12 h-6 rounded-full border transition-all duration-200"
              style="background:color-mix(in srgb,var(--cat-price) 20%,#16161F);border-color:color-mix(in srgb,var(--cat-price) 40%,transparent)"
              aria-pressed="false">
        <span id="toggle-knob"
              class="absolute left-1 top-1 w-4 h-4 rounded-full bg-[#8E8E9E] transition-all duration-200"></span>
      </button>
      <span class="text-[13px] text-[#8E8E9E]">Annual</span>
      <span class="text-[10px] font-bold px-2 py-0.5 rounded-full"
            style="color:var(--cat-price);background:color-mix(in srgb,var(--cat-price) 15%,transparent);border:1px solid color-mix(in srgb,var(--cat-price) 30%,transparent)">
        Save 15%
      </span>
    </div>

    <!-- Cards -->
    <div class="grid lg:grid-cols-5 gap-3 mb-10">
      {tiers.map((t, i) => (
        <div class={`relative rounded-2xl border p-6 flex flex-col
                     ${i === 3 ? 'lg:-mt-4 lg:mb-4' : ''}`}
             style={`border-color:${t.color}${i === 3 ? '50' : '20'};background:#080D1E;
                     ${t.glow ? `box-shadow:0 0 60px ${t.color}15` : ''}`}>
          {t.tag && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 text-[9px] font-black
                        tracking-[1.5px] uppercase px-3 py-1 rounded-full whitespace-nowrap"
                 style={`${i === 3
                   ? `background:${t.color};color:#fff`
                   : `background:${t.color}20;color:${t.color};border:1px solid ${t.color}40`}`}>
              {t.tag}
            </div>
          )}

          <div class="mb-5">
            <div class="text-[11px] font-bold tracking-[2px] uppercase mb-3" style={`color:${t.color}`}>{t.name}</div>
            <div class="flex items-end gap-1">
              <span class="text-[44px] font-black tracking-[-2px] leading-none"
                    data-price={t.name} data-base={t.price}>${t.price}</span>
              <span class="text-[#8E8E9E] text-[13px] mb-2">/mo</span>
            </div>
            <p class="text-[11px] text-[#48485A] mt-1">billed monthly · cancel anytime</p>
          </div>

          <ul class="flex flex-col gap-2 mb-7 flex-1">
            {t.features.map(f => (
              <li class={`flex items-start gap-2 text-[11px] ${f.ok === false ? 'opacity-30' : ''}`}>
                <span class={`mt-0.5 text-[10px] font-bold flex-shrink-0 ${f.ok === null ? 'opacity-50' : ''}`}
                      style={`color:${f.ok ? t.color : f.ok === null ? '#8E8E9E' : '#48485A'}`}>
                  {f.ok ? '✓' : f.ok === null ? '○' : '✗'}
                </span>
                <span class={f.ok === null ? 'text-[#8E8E9E]' : f.ok === false ? 'text-[#48485A]' : 'text-[#F5F5F7]'}>
                  {f.text}
                </span>
              </li>
            ))}
          </ul>

          <a href={t.name === 'Enterprise' ? 'mailto:sales@shadow-warden-ai.com' : '#'}
             class="block w-full py-3 rounded-xl text-[13px] font-bold text-center
                    transition-all duration-200 hover:-translate-y-0.5"
             style={`${t.ctaStyle};color:${i === 3 ? '#fff' : i === 4 ? '#BF5AF2' : '#F5F5F7'}`}>
            {t.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Add-ons -->
    <div class="rounded-2xl border border-white/[0.06] bg-[#080D1E] p-7">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-[11px] font-bold tracking-[2px] uppercase text-[#48485A]">Optional Add-ons</span>
        <div class="flex-1 h-px bg-white/[0.05]"></div>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {addons.map(a => (
          <div class="p-4 rounded-xl border border-white/[0.05]">
            <div class="flex items-start justify-between gap-3 mb-2">
              <div class="text-[13px] font-bold">{a.name}</div>
              <div class="text-[18px] font-black text-[#FFD60A] flex-shrink-0">{a.price}</div>
            </div>
            <div class="text-[11px] text-[#8E8E9E] leading-[1.55] mb-2">{a.desc}</div>
            <div class="text-[9px] text-[#48485A]">Available: {a.tier}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Power User Bundle -->
    <div class="mt-4 rounded-2xl border p-6 flex items-center gap-6"
         style="background:color-mix(in srgb,var(--cat-price) 5%,#080D1E);border-color:color-mix(in srgb,var(--cat-price) 25%,transparent)">
      <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-[14px] font-black text-[#F5F5F7]">{bundle.name}</span>
          <span class="text-[10px] font-bold px-2 py-0.5 rounded-full"
                style="color:var(--cat-price);background:color-mix(in srgb,var(--cat-price) 15%,transparent);border:1px solid color-mix(in srgb,var(--cat-price) 30%,transparent)">
            {bundle.saves}
          </span>
        </div>
        <div class="flex flex-wrap gap-2">
          {bundle.includes.map(i => (
            <span class="text-[11px] px-2 py-1 rounded-lg text-[#8E8E9E]"
                  style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07)">
              ✓ {i}
            </span>
          ))}
        </div>
      </div>
      <div class="text-right flex-shrink-0">
        <div class="text-[32px] font-black" style="color:var(--cat-price)">{bundle.price}</div>
        <div class="text-[10px] text-[#8E8E9E]">Individual+ plan</div>
        <button class="mt-2 px-4 py-2 rounded-xl text-[12px] font-bold text-[#F5F5F7] transition-all"
                style="background:color-mix(in srgb,var(--cat-price) 20%,transparent);border:1px solid color-mix(in srgb,var(--cat-price) 40%,transparent)">
          Add Bundle
        </button>
      </div>
    </div>

    <!-- Trial CTA -->
    <div class="mt-6 rounded-xl border p-4 flex items-center gap-4"
         style="background:rgba(255,255,255,0.02);border-color:rgba(255,255,255,0.07)">
      <span class="text-2xl">🎁</span>
      <div class="flex-1">
        <span class="text-[13px] font-bold text-[#F5F5F7]">14-day Pro trial — no card required.</span>
        <span class="text-[13px] text-[#8E8E9E]"> Available for Individual and Community Business plans.</span>
      </div>
      <button onclick="openAuth('signup')"
              class="flex-shrink-0 px-4 py-2 rounded-xl text-[12px] font-bold text-white"
              style="background:#FF2D55;box-shadow:0 4px 14px rgba(255,45,85,0.35)">
        Start Free Trial
      </button>
    </div>

    <p class="text-center text-[11px] text-[#48485A] mt-8">
      * IBM Cost of a Data Breach Report 2024. All prices USD. Annual billing saves 15%. Enterprise pricing custom — contact sales.
    </p>
  </div>
</section>

<script>
  const toggle = document.getElementById('annual-toggle') as HTMLButtonElement;
  const knob = document.getElementById('toggle-knob') as HTMLSpanElement;
  const annualPrices: Record<string, number> = { Individual: 4, 'Community Business': 16, Pro: 59, Enterprise: 212 };
  let isAnnual = false;

  toggle?.addEventListener('click', () => {
    isAnnual = !isAnnual;
    toggle.setAttribute('aria-pressed', String(isAnnual));
    knob.style.left = isAnnual ? '26px' : '4px';
    knob.style.background = isAnnual ? 'var(--cat-price)' : '#8E8E9E';

    document.querySelectorAll<HTMLElement>('[data-price]').forEach(el => {
      const name = el.dataset.price!;
      const base = Number(el.dataset.base!);
      el.textContent = '$' + (isAnnual && annualPrices[name] ? annualPrices[name] : base);
    });
  });
</script>
