---
const tiers = [
  {
    name: 'Starter', price: 0,
    accent: 'var(--sw-fg-4)', accentHex: '#64748b',
    cta: 'Get Started Free',
    features: [
      { text: '1 000 req/month',   ok: true  },
      { text: 'Basic filter pipeline', ok: true  },
      { text: '1 tenant',          ok: true  },
      { text: 'Community support', ok: true  },
    ],
  },
  {
    name: 'Individual', price: 5,
    accent: 'var(--sw-fg-3)', accentHex: '#94a3b8',
    cta: 'Start Free Trial',
    features: [
      { text: '5 000 req/month',         ok: true  },
      { text: 'Full 9-layer pipeline',   ok: true  },
      { text: 'PII & Secret Redaction',  ok: true  },
      { text: 'Streamlit dashboard',     ok: true  },
      { text: 'XAI Reports ($9 add-on)', ok: null  },
      { text: 'MasterAgent SOC',         ok: false },
    ],
  },
  {
    name: 'Community Business', price: 19,
    accent: 'var(--sw-green)', accentHex: '#34d399',
    cta: 'Start Free Trial',
    features: [
      { text: '10 000 req/month',              ok: true },
      { text: 'Everything in Individual',       ok: true },
      { text: 'File Scanner + Email Guard',     ok: true },
      { text: 'Obsidian Integration',           ok: true },
      { text: 'Secrets Governance (included)',  ok: true },
      { text: '3 communities × 10 members',    ok: true },
      { text: '180-day retention',             ok: true },
    ],
  },
  {
    name: 'Pro', price: 69, tag: 'Most Popular',
    accent: 'var(--sw-indigo)', accentHex: '#6366f1',
    highlight: true,
    cta: 'Start Free Trial',
    features: [
      { text: '50 000 req/month',             ok: true  },
      { text: 'Full 14-layer defense stack',   ok: true  },
      { text: 'MasterAgent SOC (included)',    ok: true  },
      { text: 'Evolution Engine (self-improving)', ok: true },
      { text: 'Evidence Vault + STIX 2.1',    ok: true  },
      { text: 'SOC 2 + GDPR audit package',   ok: true  },
      { text: 'Shadow AI (+$15 add-on)',       ok: null  },
      { text: 'PQC / Sovereign Cloud',         ok: false },
    ],
  },
  {
    name: 'Enterprise', price: 249, tag: 'Full Stack',
    accent: 'var(--sw-violet)', accentHex: '#8b5cf6',
    cta: 'Contact Sales',
    features: [
      { text: 'Unlimited requests',                      ok: true },
      { text: 'Post-Quantum Crypto (FIPS 203/204)',      ok: true },
      { text: 'Sovereign AI Cloud — 8 jurisdictions',    ok: true },
      { text: 'Shadow AI Governance',                    ok: true },
      { text: 'XAI Audit Reports (PDF)',                 ok: true },
      { text: 'SEP Communities Protocol',               ok: true },
      { text: 'SAML/OIDC SSO + RBAC',                  ok: true },
      { text: 'Dedicated SLA + 24/7 support',           ok: true },
    ],
  },
];

const addons = [
  { name: 'Shadow AI Discovery', price: '$15/mo', tier: 'Pro+',
    desc: 'Async /24 subnet probe across 18 AI providers. DNS telemetry. Per-tenant MONITOR/BLOCK/ALLOWLIST policy.' },
  { name: 'XAI Audit Reports',   price: '$9/mo',  tier: 'Individual+',
    desc: '9-stage causal chain. Primary cause attribution. PDF reports for SOC 2 evidence packages.' },
  { name: 'Secrets Vault',       price: '$12/mo', tier: 'Individual+',
    desc: 'Multi-cloud vault connectors (AWS SM / Azure KV / HashiCorp / GCP). Inventory, lifecycle alerts, policy score.' },
  { name: 'On-Prem Pack',        price: '$29/mo', tier: 'Pro+',
    desc: 'MinIO on-prem object store, self-hosted Prometheus/Grafana, air-gapped Evolution Engine mode.' },
  { name: 'Community Seats',     price: '$9/mo',  tier: 'Community Business+',
    desc: 'Stackable +5 extra seats per unit. Combine with any higher tier for unlimited seat expansion.' },
];
---

<section id="price" class="relative py-24 overflow-hidden"
         style="background:var(--sw-surf-1)">

  <div class="absolute inset-0 pointer-events-none"
       style="background:radial-gradient(ellipse 60% 40% at 50% 100%,rgba(251,146,60,.05) 0%,transparent 70%)"></div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-5 text-[12px] font-semibold"
           style="color:var(--sw-orange);background:var(--sw-tint-amber);border:1px solid rgba(251,146,60,.2)">
        ◈ Pricing
      </div>
      <h2 class="text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold mb-4" style="color:var(--sw-fg-1)">
        Pays for Itself in<br/>
        <span style="background:linear-gradient(135deg,var(--sw-orange),var(--sw-amber));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">Minutes.</span>
      </h2>
      <p class="text-[15px] max-w-xl mx-auto" style="color:var(--sw-fg-3)">
        IBM 2024: average breach costs <span style="color:var(--sw-red);font-weight:700">$4.88M</span>.
        Pro plan ROI at default settings: <span style="color:var(--sw-green);font-weight:700">782×</span> annually.
      </p>
    </div>

    <!-- Annual toggle -->
    <div class="flex items-center justify-center gap-3 mb-10">
      <span class="text-[13px]" style="color:var(--sw-fg-3)">Monthly</span>
      <button id="annual-toggle"
              class="relative w-12 h-6 rounded-full transition-all duration-200"
              style="background:var(--sw-surf-3);border:1px solid var(--sw-border-strong)"
              aria-pressed="false">
        <span id="toggle-knob"
              class="absolute left-1 top-1 w-4 h-4 rounded-full transition-all duration-200"
              style="background:var(--sw-fg-4)"></span>
      </button>
      <span class="text-[13px]" style="color:var(--sw-fg-3)">Annual</span>
      <span class="text-[10px] font-bold px-2 py-0.5 rounded-full"
            style="color:var(--sw-orange);background:var(--sw-tint-amber);border:1px solid rgba(251,146,60,.3)">
        Save 15%
      </span>
    </div>

    <!-- Tier cards -->
    <div class="grid lg:grid-cols-5 gap-3 mb-10">
      {tiers.map((t, i) => (
        <div class={`relative rounded-xl p-5 flex flex-col ${t.highlight ? 'lg:-mt-4 lg:mb-4' : ''}`}
             style={`background:var(--sw-surf-2);border:1px solid ${t.highlight ? t.accentHex + '50' : 'var(--sw-border)'};
                     ${t.highlight ? `box-shadow:0 0 60px ${t.accentHex}18` : ''}`}>
          {t.tag && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 text-[9px] font-black tracking-[1px] uppercase px-3 py-0.5 rounded-full whitespace-nowrap"
                 style={t.highlight
                   ? `background:${t.accentHex};color:#fff`
                   : `background:color-mix(in srgb,${t.accentHex} 15%,transparent);color:${t.accentHex};border:1px solid ${t.accentHex}40`}>
              {t.tag}
            </div>
          )}

          <div class="mb-4">
            <div class="text-[10px] font-bold tracking-[1.5px] uppercase mb-2" style={`color:${t.accent}`}>{t.name}</div>
            <div class="flex items-end gap-1">
              <span class="text-[40px] font-black leading-none" style={`color:var(--sw-fg-1)`}
                    data-price={t.name} data-base={t.price}>${t.price}</span>
              <span class="text-[12px] mb-1.5" style="color:var(--sw-fg-4)">/mo</span>
            </div>
            <p class="text-[10px] mt-0.5" style="color:var(--sw-fg-4)">cancel anytime</p>
          </div>

          <ul class="flex flex-col gap-1.5 mb-6 flex-1">
            {t.features.map(f => (
              <li class={`flex items-start gap-2 text-[11px] ${f.ok === false ? 'opacity-30' : ''}`}>
                <span class="mt-0.5 text-[10px] font-bold flex-shrink-0"
                      style={`color:${f.ok ? t.accentHex : f.ok === null ? '#64748b' : '#334155'}`}>
                  {f.ok ? '✓' : f.ok === null ? '◦' : '✗'}
                </span>
                <span style={`color:${f.ok === false ? 'var(--sw-fg-4)' : f.ok === null ? 'var(--sw-fg-3)' : 'var(--sw-fg-2)'}`}>
                  {f.text}
                </span>
              </li>
            ))}
          </ul>

          <button onclick={t.name === 'Enterprise' ? "window.location='mailto:sales@shadow-warden-ai.com'" : "openAuth('signup')"}
                  class="w-full py-2.5 rounded-xl text-[12px] font-bold transition-all hover:-translate-y-0.5"
                  style={t.highlight
                    ? `background:${t.accentHex};color:#fff;box-shadow:0 8px 28px ${t.accentHex}40`
                    : `background:color-mix(in srgb,${t.accentHex} 10%,transparent);border:1px solid ${t.accentHex}30;color:${t.accentHex}`}>
            {t.cta}
          </button>
        </div>
      ))}
    </div>

    <!-- Add-ons -->
    <div class="rounded-xl p-6 mb-4" style="background:var(--sw-surf-2);border:1px solid var(--sw-border)">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-[11px] font-bold tracking-[1.5px] uppercase" style="color:var(--sw-fg-4)">Optional Add-ons</span>
        <div class="flex-1 h-px" style="background:var(--sw-border)"></div>
      </div>
      <div class="grid sm:grid-cols-2 gap-3">
        {addons.map(a => (
          <div class="p-4 rounded-xl" style="background:var(--sw-surf-1);border:1px solid var(--sw-border)">
            <div class="flex items-start justify-between gap-3 mb-1.5">
              <div class="text-[13px] font-semibold" style="color:var(--sw-fg-1)">{a.name}</div>
              <div class="text-[18px] font-black flex-shrink-0" style="color:var(--sw-amber)">{a.price}</div>
            </div>
            <div class="text-[11px] leading-relaxed mb-1.5" style="color:var(--sw-fg-3)">{a.desc}</div>
            <div class="text-[10px]" style="color:var(--sw-fg-4)">Available: {a.tier}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bundle + Trial CTA -->
    <div class="grid sm:grid-cols-2 gap-4">
      <!-- Power User Bundle -->
      <div class="rounded-xl p-5 flex items-center gap-4"
           style="background:color-mix(in srgb,var(--sw-orange) 5%,var(--sw-surf-2));border:1px solid rgba(251,146,60,.2)">
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-1.5">
            <span class="text-[13px] font-bold" style="color:var(--sw-fg-1)">Power User Bundle</span>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full"
                  style="color:var(--sw-orange);background:var(--sw-tint-amber)">saves $7</span>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {['XAI Audit Reports', 'Secrets Vault', 'Shadow AI'].map(item => (
              <span class="text-[10px] px-2 py-0.5 rounded-lg" style="background:var(--sw-surf-3);color:var(--sw-fg-3)">✓ {item}</span>
            ))}
          </div>
        </div>
        <div class="text-right flex-shrink-0">
          <div class="text-[28px] font-black" style="color:var(--sw-orange)">$29/mo</div>
          <button class="mt-1 px-3 py-1.5 rounded-lg text-[11px] font-bold"
                  style="background:rgba(251,146,60,.15);border:1px solid rgba(251,146,60,.3);color:var(--sw-orange)">
            Add Bundle
          </button>
        </div>
      </div>

      <!-- Trial CTA -->
      <div class="rounded-xl p-5 flex items-center gap-4"
           style="background:var(--sw-surf-2);border:1px solid var(--sw-border)">
        <span class="text-2xl flex-shrink-0">🎁</span>
        <div class="flex-1">
          <div class="text-[13px] font-bold mb-0.5" style="color:var(--sw-fg-1)">14-day Pro trial — no card required.</div>
          <div class="text-[12px]" style="color:var(--sw-fg-3)">Individual and Community Business plans.</div>
        </div>
        <button onclick="openAuth('signup')"
                class="flex-shrink-0 px-4 py-2 rounded-xl text-[12px] font-bold text-white whitespace-nowrap"
                style="background:var(--sw-gradient-primary);box-shadow:var(--sw-shadow-cta)">
          Start Free
        </button>
      </div>
    </div>

    <p class="text-center text-[11px] mt-8" style="color:var(--sw-fg-4)">
      * IBM Cost of a Data Breach Report 2024. All prices USD. Annual billing saves 15%. Enterprise pricing custom — contact sales.
    </p>
  </div>
</section>

<script>
  const toggle = document.getElementById('annual-toggle') as HTMLButtonElement;
  const knob   = document.getElementById('toggle-knob')   as HTMLSpanElement;
  const annualPrices: Record<string, number> = { Individual: 4, 'Community Business': 16, Pro: 59, Enterprise: 212 };
  let isAnnual = false;

  toggle?.addEventListener('click', () => {
    isAnnual = !isAnnual;
    toggle.setAttribute('aria-pressed', String(isAnnual));
    knob.style.left       = isAnnual ? '26px' : '4px';
    knob.style.background = isAnnual ? 'var(--sw-orange)' : 'var(--sw-fg-4)';
    document.querySelectorAll<HTMLElement>('[data-price]').forEach(el => {
      const name = el.dataset.price!;
      const base = Number(el.dataset.base!);
      el.textContent = '$' + (isAnnual && annualPrices[name] ? annualPrices[name] : base);
    });
  });
</script>
