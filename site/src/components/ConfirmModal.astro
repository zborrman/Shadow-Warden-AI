---
interface Props {
  id: string;
  title: string;
  message: string;
  confirmLabel?: string;
  requireText?: string;
  redirectTo?: string;
  danger?: boolean;
}
const {
  id,
  title,
  message,
  confirmLabel = 'Confirm',
  requireText = '',
  redirectTo = '/',
  danger = false,
} = Astro.props;
---

<div id={id}
     class="fixed inset-0 z-[9000] hidden items-center justify-center p-4"
     style="background:rgba(0,0,0,0.72);backdrop-filter:blur(8px)">
  <div class="w-full max-w-md rounded-2xl overflow-hidden shadow-2xl"
       style="background:#0e0e1c;border:1px solid rgba(255,255,255,0.08)">

    <!-- Header -->
    <div class="px-6 pt-6 pb-4" style={`border-bottom:1px solid ${danger ? 'rgba(239,68,68,0.15)' : 'rgba(255,255,255,0.06)'}`}>
      <div class="flex items-center gap-3 mb-1">
        {danger && (
          <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
               style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.2" stroke-linecap="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
        )}
        <h2 class="text-[16px] font-bold" style="color:#f1f5f9">{title}</h2>
      </div>
      <p class="text-[13px] leading-relaxed" style="color:#94a3b8">{message}</p>
    </div>

    <!-- Body -->
    <div class="px-6 py-5">
      {requireText && (
        <div class="mb-4">
          <label class="block text-[12px] font-medium mb-2" style="color:#64748b">
            Type <code class="text-[11px] px-1.5 py-0.5 rounded" style="color:#f1f5f9;background:rgba(255,255,255,0.08)">{requireText}</code> to confirm
          </label>
          <input
            type="text"
            id={`${id}-input`}
            placeholder={requireText}
            class="w-full px-3 py-2 rounded-lg text-[13px] outline-none transition-colors"
            style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:#f1f5f9"
          />
        </div>
      )}

      <div class="flex gap-3">
        <button
          id={`${id}-cancel`}
          class="flex-1 px-4 py-2.5 rounded-lg text-[13px] font-medium transition-colors"
          style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:#94a3b8">
          Cancel
        </button>
        <button
          id={`${id}-confirm`}
          data-redirect={redirectTo}
          data-require={requireText}
          class="flex-1 px-4 py-2.5 rounded-lg text-[13px] font-semibold text-white transition-all"
          style={danger ? 'background:#dc2626' : 'background:#6366f1'}
          disabled={!!requireText}>
          {confirmLabel}
        </button>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ id, requireText }}>
(function () {
  const modal   = document.getElementById(id);
  const cancel  = document.getElementById(`${id}-cancel`);
  const confirm = document.getElementById(`${id}-confirm`);
  const input   = document.getElementById(`${id}-input`);

  function open()  { modal.style.display = 'flex'; if (input) { input.value = ''; updateBtn(); input.focus(); } }
  function close() { modal.style.display = 'none'; }
  function updateBtn() {
    if (!requireText || !confirm || !input) return;
    const match = input.value.trim() === requireText;
    confirm.disabled = !match;
    confirm.style.opacity = match ? '1' : '0.4';
    confirm.style.cursor  = match ? 'pointer' : 'not-allowed';
  }

  if (cancel)  cancel.addEventListener('click', close);
  if (input)   input.addEventListener('input', updateBtn);
  if (confirm) confirm.addEventListener('click', function () {
    const dest = this.dataset.redirect || '/';
    window.location.href = dest;
  });
  modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });

  window[`open_${id}`] = open;
})();
</script>
