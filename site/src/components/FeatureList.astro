---
interface Feature {
  id: string;
  feature: string;
  description: string;
  tier: string;
  status: string;
  version: string;
}
interface Props {
  features: Feature[];
  accent?: string;
}
const { features, accent = '#6366f1' } = Astro.props;

const statusLabel: Record<string, string> = {
  shipped:     '✅ Shipped',
  in_progress: '🔄 In Progress',
  planned:     '📋 Planned',
  cancelled:   '❌ Cancelled',
};
const tierColor: Record<string, string> = {
  'All':                'rgba(148,163,184,.12)',
  'Individual+':        'rgba(16,185,129,.12)',
  'Community Business+':'rgba(139,92,246,.12)',
  'Community Business': 'rgba(139,92,246,.12)',
  'Pro':                'rgba(99,102,241,.12)',
  'Pro+':               'rgba(99,102,241,.12)',
  'Enterprise':         'rgba(6,182,212,.12)',
  'Starter':            'rgba(148,163,184,.12)',
  'Individual':         'rgba(16,185,129,.12)',
};
const tierText: Record<string, string> = {
  'All':                '#94a3b8',
  'Individual+':        '#10b981',
  'Community Business+':'#8b5cf6',
  'Community Business': '#8b5cf6',
  'Pro':                '#6366f1',
  'Pro+':               '#6366f1',
  'Enterprise':         '#06b6d4',
  'Starter':            '#94a3b8',
  'Individual':         '#10b981',
};
---

<div class="space-y-3">
  {features.map(f => (
    <div class="rounded-xl p-5 transition-all duration-200"
         style="background:#111118;border:1px solid rgba(255,255,255,0.07)"
         onmouseover={`this.style.borderColor='${accent}30'`}
         onmouseout="this.style.borderColor='rgba(255,255,255,0.07)'">
      <div class="flex items-start justify-between gap-3 mb-2">
        <div class="flex items-center gap-2.5 flex-1 min-w-0">
          <span class="text-[10px] font-mono font-bold shrink-0" style="color:#475569">{f.id}</span>
          <h3 class="text-[14px] font-semibold" style="color:#f1f5f9">{f.feature}</h3>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <span class={`text-[10px] font-semibold px-2 py-0.5 rounded-md status-${f.status}`}>
            {statusLabel[f.status] ?? f.status}
          </span>
        </div>
      </div>
      <p class="text-[13px] leading-relaxed mb-3" style="color:#94a3b8">{f.description}</p>
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-semibold px-2 py-0.5 rounded-md tier-badge"
              style={`color:${tierText[f.tier] ?? '#94a3b8'};background:${tierColor[f.tier] ?? 'rgba(148,163,184,.12)'}`}>
          {f.tier}
        </span>
        <span class="text-[10px] font-mono" style="color:#475569">{f.version}</span>
      </div>
    </div>
  ))}
</div>
