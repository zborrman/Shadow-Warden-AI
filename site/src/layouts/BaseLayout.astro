---
import '../styles/global.css';
import roadmap from '../data/roadmap.json';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Shadow Warden AI — Zero-Trust AI Security Gateway',
  description = '14-layer real-time AI security gateway. Blocks jailbreaks, strips PII, enforces compliance in <2ms. SOC 2 · GDPR · Post-Quantum Cryptography.',
  ogImage = '/og.png',
} = Astro.props;

const categories = [
  {
    label: 'Business Community',
    href: '/business-community',
    color: '#8b5cf6',
    sub: [...new Set(roadmap.filter(r => r.category === 'Business Community').map(r => r.subcategory))],
  },
  {
    label: 'Cyber Security',
    href: '/cyber-security',
    color: '#ef4444',
    sub: [...new Set(roadmap.filter(r => r.category === 'Cyber Security').map(r => r.subcategory))],
  },
  {
    label: 'Dashboard',
    href: '/dashboard',
    color: '#6366f1',
    sub: [...new Set(roadmap.filter(r => r.category === 'Dashboard').map(r => r.subcategory))],
  },
  {
    label: 'Doc',
    href: '/doc',
    color: '#f59e0b',
    sub: ['Quick Start', 'API Reference', 'Compliance', 'Changelog'],
  },
  {
    label: 'Price',
    href: '/price',
    color: '#f97316',
    sub: [],
  },
];

function slugify(s: string) {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="theme-color" content="#0a0a0f" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>{title}</title>
</head>

<body>
  <!-- Navbar -->
  <header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
          style="background:rgba(10,10,15,0.85);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.06)">
    <div class="mx-auto max-w-7xl px-4 lg:px-8 h-14 flex items-center gap-6">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0 group">
        <svg width="26" height="26" viewBox="0 0 32 32" fill="none">
          <path d="M16 2L4 8v8c0 7.18 5.14 13.9 12 15.5C22.86 29.9 28 23.18 28 16V8L16 2z"
                fill="url(#logo-g)" opacity=".95"/>
          <defs>
            <linearGradient id="logo-g" x1="4" y1="2" x2="28" y2="30" gradientUnits="userSpaceOnUse">
              <stop stop-color="#6366f1"/>
              <stop offset="1" stop-color="#06b6d4"/>
            </linearGradient>
          </defs>
          <path d="M11 16l3 3 7-7" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="text-[14px] font-bold" style="color:#f1f5f9">
          <span class="text-gradient">Shadow</span> Warden
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1 flex-1">
        {categories.map(cat => (
          <div class="relative group">
            <a href={cat.href}
               class="flex items-center gap-1 px-3 py-2 rounded-lg text-[13px] font-medium transition-colors duration-150"
               style="color:#94a3b8"
               onmouseover="this.style.color=this.dataset.color;this.style.background='rgba(255,255,255,0.05)'"
               onmouseout="this.style.color='#94a3b8';this.style.background='transparent'"
               data-color={cat.color}>
              {cat.label}
              {cat.sub.length > 0 && (
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="opacity-50">
                  <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              )}
            </a>
            {cat.sub.length > 0 && (
              <div class="absolute top-full left-0 mt-1 w-56 rounded-xl py-1.5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150"
                   style="background:#16161f;border:1px solid rgba(255,255,255,0.08);box-shadow:0 16px 40px rgba(0,0,0,0.5)">
                {cat.sub.map(sub => (
                  <a href={cat.label === 'Doc' ? `/doc/${slugify(sub)}` : `${cat.href}/${slugify(sub)}`}
                     class="block px-4 py-2 text-[13px] transition-colors duration-100"
                     style="color:#94a3b8"
                     onmouseover={`this.style.color='${cat.color}';this.style.background='rgba(255,255,255,0.04)'`}
                     onmouseout="this.style.color='#94a3b8';this.style.background='transparent'">
                    {sub}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- Right actions -->
      <div class="ml-auto flex items-center gap-2">
        <div class="hidden sm:flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-semibold"
             style="color:#10b981;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2)">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#10b981"></span>
          Live
        </div>
        <a href="https://github.com/zborrman/Shadow-Warden-AI" target="_blank" rel="noopener"
           class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-medium transition-colors"
           style="color:#94a3b8;border:1px solid rgba(255,255,255,0.08)"
           onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#f1f5f9'"
           onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.color='#94a3b8'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
        <a href="https://portal.shadow-warden-ai.com" target="_blank" rel="noopener"
           class="btn-primary text-[12px] px-4 py-1.5">
          Get Started
        </a>
        <!-- Mobile hamburger -->
        <button id="mobile-btn" class="lg:hidden p-2 rounded-lg" style="color:#94a3b8;border:1px solid rgba(255,255,255,0.08)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-40 lg:hidden flex-col pt-14"
       style="background:rgba(10,10,15,0.98);backdrop-filter:blur(24px)">
    <div class="flex-1 overflow-y-auto px-4 py-6 space-y-1">
      {categories.map(cat => (
        <div>
          <a href={cat.href}
             class="block px-4 py-3 rounded-xl text-[15px] font-semibold"
             style={`color:${cat.color}`}>
            {cat.label}
          </a>
          {cat.sub.map(sub => (
            <a href={cat.label === 'Doc' ? `/doc/${slugify(sub)}` : `${cat.href}/${slugify(sub)}`}
               class="block px-8 py-2 text-[13px]"
               style="color:#64748b">
              {sub}
            </a>
          ))}
        </div>
      ))}
      <div class="pt-4 border-t mt-4" style="border-color:rgba(255,255,255,0.06)">
        <a href="https://github.com/zborrman/Shadow-Warden-AI" target="_blank"
           class="block px-4 py-3 rounded-xl text-[13px] font-medium" style="color:#94a3b8">
          ⭐ Star on GitHub
        </a>
        <a href="https://portal.shadow-warden-ai.com" target="_blank"
           class="block mt-2 px-4 py-3 rounded-xl text-[13px] font-semibold text-center text-white"
           style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">
          Get Started Free
        </a>
      </div>
    </div>
  </div>

  <!-- Page content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="mt-24 border-t" style="border-color:rgba(255,255,255,0.06)">
    <div class="mx-auto max-w-7xl px-4 lg:px-8 py-12">
      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-8 mb-10">
        <div class="lg:col-span-2">
          <div class="flex items-center gap-2 mb-3">
            <svg width="22" height="22" viewBox="0 0 32 32" fill="none">
              <path d="M16 2L4 8v8c0 7.18 5.14 13.9 12 15.5C22.86 29.9 28 23.18 28 16V8L16 2z" fill="url(#ft-g)"/>
              <defs>
                <linearGradient id="ft-g" x1="4" y1="2" x2="28" y2="30" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#6366f1"/><stop offset="1" stop-color="#06b6d4"/>
                </linearGradient>
              </defs>
              <path d="M11 16l3 3 7-7" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-[14px] font-bold" style="color:#f1f5f9">Shadow Warden AI</span>
          </div>
          <p class="text-[13px] leading-relaxed max-w-xs" style="color:#64748b">
            Zero-trust AI security gateway. 14-layer defense pipeline.
            SOC 2 · GDPR · OWASP LLM Top 10 — deployed in 60 seconds.
          </p>
          <div class="flex items-center gap-3 mt-4">
            <a href="https://github.com/zborrman/Shadow-Warden-AI" target="_blank"
               class="text-[12px] font-medium transition-colors hover:text-white" style="color:#64748b">GitHub</a>
            <span style="color:#1e1e2a">·</span>
            <a href="https://docs.shadow-warden-ai.com" target="_blank"
               class="text-[12px] font-medium transition-colors hover:text-white" style="color:#64748b">Docs</a>
            <span style="color:#1e1e2a">·</span>
            <a href="mailto:sales@shadow-warden-ai.com"
               class="text-[12px] font-medium transition-colors hover:text-white" style="color:#64748b">Contact</a>
          </div>
        </div>
        {[
          { title: 'Product', links: [
            { label: 'Business Community', href: '/business-community' },
            { label: 'Cyber Security', href: '/cyber-security' },
            { label: 'Dashboard', href: '/dashboard' },
            { label: 'Pricing', href: '/price' },
          ]},
          { title: 'Documentation', links: [
            { label: 'Quick Start', href: '/doc/quick-start' },
            { label: 'API Reference', href: 'https://docs.shadow-warden-ai.com' },
            { label: 'Compliance', href: '/doc/compliance' },
            { label: 'Changelog', href: '/doc/changelog' },
          ]},
          { title: 'Legal', links: [
            { label: 'GDPR DPIA', href: '/doc/compliance' },
            { label: 'SOC 2 Type II', href: '/doc/compliance' },
            { label: 'SLA', href: '/doc/compliance' },
            { label: 'Privacy Policy', href: '#' },
          ]},
        ].map(col => (
          <div>
            <div class="text-[11px] font-semibold tracking-widest uppercase mb-4" style="color:#475569">{col.title}</div>
            <ul class="space-y-2.5">
              {col.links.map(l => (
                <li>
                  <a href={l.href}
                     class="text-[13px] transition-colors hover:text-white"
                     style="color:#64748b">{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="pt-6 border-t flex flex-col sm:flex-row items-center justify-between gap-3"
           style="border-color:rgba(255,255,255,0.05)">
        <p class="text-[12px]" style="color:#475569">© 2026 Shadow Warden AI. All rights reserved.</p>
        <div class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#10b981"></span>
          <span class="text-[12px]" style="color:#475569">All systems operational · v4.19</span>
        </div>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    document.querySelectorAll('#mobile-menu a').forEach(a => a.addEventListener('click', () => menu?.classList.add('hidden')));
  </script>
</body>
</html>
