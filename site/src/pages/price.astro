---
import BaseLayout from '../layouts/BaseLayout.astro';
import LemonSqueezyCheckout from '../components/LemonSqueezyCheckout.astro';
import { VARIANT_IDS, BILLING_PORTAL, checkoutUrl } from '../config/lemonsqueezy';
import roadmapData from '../data/roadmap.json';

const bl19 = roadmapData.find((r: any) => r.id === 'BL-19')!;
const bl20 = roadmapData.find((r: any) => r.id === 'BL-20')!;

const tiers = [
  {
    key: 'starter',
    name: 'Starter',
    price_monthly: 0,
    price_annual: 0,
    color: '#64748b',
    tint: 'rgba(100,116,139,0.08)',
    tag: null,
    highlight: false,
    cta: 'Get Started Free',
    features: ['1,000 req / month','Basic 9-layer pipeline','1 tenant','Community support','Streamlit dashboard'],
    missing: ['XAI Reports','Evolution Engine','MasterAgent SOC','Sovereign Cloud','Secrets Vault'],
  },
  {
    key: 'individual',
    name: 'Individual',
    price_monthly: 5,
    price_annual: 51,
    color: '#10b981',
    tint: 'rgba(16,185,129,0.08)',
    tag: null,
    highlight: false,
    cta: 'Start Free Trial',
    features: ['5,000 req / month','Full 9-layer pipeline','PII & Secret Redaction','Streamlit dashboard','Email support','14-day free trial'],
    addons: ['XAI Reports add-on available'],
    missing: ['MasterAgent SOC','Evolution Engine'],
  },
  {
    key: 'communityBusiness',
    name: 'Community Business',
    price_monthly: 19,
    price_annual: 194,
    color: '#8b5cf6',
    tint: 'rgba(139,92,246,0.08)',
    tag: 'Teams',
    highlight: false,
    cta: 'Start Free Trial',
    features: ['10,000 req / month','Everything in Individual','Obsidian Plugin','Secrets Governance','3 communities × 10 members','180-day log retention','14-day free trial'],
    missing: ['MasterAgent SOC','PQC / Sovereign'],
  },
  {
    key: 'pro',
    name: 'Pro',
    price_monthly: 69,
    price_annual: 705,
    color: '#6366f1',
    tint: 'rgba(99,102,241,0.1)',
    tag: 'Most Popular',
    highlight: true,
    cta: 'Start Free Trial',
    features: ['50,000 req / month','MasterAgent SOC (included)','Evolution Engine','Evidence Vault + STIX 2.1','SOC 2 + GDPR audit package','Priority support','14-day free trial'],
    addons: ['Shadow AI Discovery add-on available'],
    missing: ['PQC / Sovereign Cloud'],
  },
];

const addons = [
  // ── Individual+ ──────────────────────────────────────────────────────────
  { key: 'addonXai',         name: 'XAI Audit Reports',        price: 9,  tier: 'Individual+',      desc: '9-stage causal chain. Primary cause attribution. PDF reports for SOC 2 evidence.' },
  { key: 'addonSecretsVault',name: 'Secrets Vault',            price: 12, tier: 'Individual+',      desc: 'Multi-cloud vault connectors. SQLite inventory, lifecycle alerts, policy score.' },
  { key: 'addonSmbSuite',    name: 'SMB Governance Suite',     price: 29, tier: 'Individual+',      desc: 'Vendor Governance, Incident Register, Prompt Library, Training Records, Cost Allocation, Supplier Risk + SMB Suite Wizard.', bullets: ['AI Vendor Register + DPA expiry alerts (BL-22)', 'Cost Allocation + Budget Dashboard (BL-23/24)', 'Incident Register with STIX linkage (CM-35)', 'Supplier AI Risk Assessment (CM-36)', 'Shared Prompt Library with injection screening (CM-37)', 'Employee Training Records HMAC-attested (CM-38)', 'One-wizard provisioning via /smb-suite/provision (IN-25)'] },
  { key: 'addonObsidian',    name: bl20.feature.replace('Add-on: ','').replace(/ — .*/, ''), price: bl20.price, tier: bl20.tier, desc: bl20.description, planned: true, id: bl20.id,
    bullets: ['Advanced scan scheduler (configurable interval)', 'Offline publish queue + local validation', 'XAI pipeline visualization inside Obsidian', 'Dataview security dashboard for notes', 'Frontmatter auto-tagging + WardenSidebarView'] },
  // ── Community Biz+ ───────────────────────────────────────────────────────
  { key: 'addonSeats',       name: 'Extra Seats (+5)',         price: 9,  tier: 'Community Biz+',   desc: 'Stackable. Combine with any higher tier for unlimited seat expansion.' },
  { key: 'addonAgenticPack', name: 'Agentic Commerce Pack',   price: 15, tier: 'Community Biz+',   desc: 'AI procurement with mandate controls, UCP store discovery, AP2 payment execution, MCP agent intents, vendor validation, and BI spend analytics.' },
  { key: 'addonEdgePacks',   name: 'ARC Edge Agent Packs',    price: 15, tier: 'Community Biz+',   desc: 'Plug-and-play edge analytics agents: Crop Health Monitor (NDVI), Yield Optimizer, Disease Detector (Claude Vision). Deploy as marketplace agents.' },
  // ── Pro+ ─────────────────────────────────────────────────────────────────
  { key: 'addonShadowAi',    name: 'Shadow AI Discovery',     price: 15, tier: 'Pro+',             desc: 'Async /24 subnet probe. 18 provider fingerprints. MONITOR / BLOCK / ALLOWLIST policy.' },
  { key: 'addonOnPrem',      name: 'On-Prem Pack',            price: 29, tier: 'Pro+',             desc: 'MinIO on-prem, self-hosted Prometheus/Grafana, air-gapped Evolution Engine.' },
  { key: 'addonPowerBundle', name: 'Power User Bundle',       price: 29, tier: 'Pro+',             desc: 'XAI Audit Reports + Secrets Vault + Shadow AI Discovery. Saves $7/mo vs buying separately.' },
  { key: 'addonStreaming',   name: 'Event Streaming Pack',    price: 19, tier: 'Pro+',             desc: 'Kafka/Flink real-time agent event bus: produce/consume marketplace events, auto-dispute watchdog, Redis pub/sub fallback.' },
  // ── Enterprise+ ──────────────────────────────────────────────────────────
  { key: 'addonTokenomics',  name: 'Agent Tokenomics (WAT)',  price: 39, tier: 'Enterprise+',      desc: 'ERC-20 Warden Agent Token on Polygon Amoy: mint, transfer, outcome-based pricing settlements. Simulation mode for testing.' },
  { key: 'addonUsdc',        name: 'USDC Multi-Rail Payments',price: 29, tier: 'Enterprise+',      desc: 'USDC payment intents via Coinbase Commerce or on-chain Polygon: multi-rail settlement. Simulation auto-confirms for testing.' },
  { key: 'addonAns',         name: 'ANS Certificate Authority',price: 25, tier: 'Enterprise+',     desc: 'Issue X.509 agent identity certificates (agent-{id}.{community}.shadow-warden.ai), Redis CRL revocation.' },
];
---

<BaseLayout
  title="Pricing — Shadow Warden AI"
  description="Transparent pricing for every team size. From free to enterprise. 14-day trial, no card required."
>
  <div class="pt-14" style="background:#03050f">

    <!-- Hero -->
    <section class="py-20 text-center relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none"
           style="background:radial-gradient(ellipse 800px 400px at 50% 0%,rgba(249,115,22,0.07) 0%,transparent 70%)"></div>
      <div class="relative z-10 mx-auto max-w-3xl px-4">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-[11px] font-bold tracking-widest uppercase"
             style="color:#f97316;background:rgba(249,115,22,0.08);border:1px solid rgba(249,115,22,0.2)">
          ◇ Transparent Pricing
        </div>
        <h1 class="text-[clamp(32px,5vw,60px)] font-black leading-tight tracking-tight mb-4" style="color:#f1f5f9">
          The right plan for<br/>
          <span style="background:linear-gradient(135deg,#f97316,#ef4444);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">every threat model</span>
        </h1>
        <p class="text-[16px] mb-8 max-w-xl mx-auto" style="color:#94a3b8">
          14-day trial on all paid plans — no card required. Cancel anytime. IBM 2024 breach data shows Pro ROI of 782×.
        </p>

        <!-- Monthly / Annual toggle -->
        <div class="inline-flex items-center gap-3 p-1 rounded-xl" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08)">
          <button id="billing-monthly"
                  class="billing-toggle active px-5 py-2 rounded-lg text-[13px] font-semibold transition-all"
                  aria-pressed="true">Monthly</button>
          <button id="billing-annual"
                  class="billing-toggle px-5 py-2 rounded-lg text-[13px] font-semibold transition-all"
                  aria-pressed="false">
            Annual
            <span class="ml-1.5 px-2 py-0.5 rounded-full text-[10px] font-bold" style="color:#10b981;background:rgba(16,185,129,0.15)">−15%</span>
          </button>
        </div>
      </div>
    </section>

    <!-- Tier cards -->
    <section class="pb-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-4 gap-4">
          {tiers.map(t => {
            const varId    = VARIANT_IDS[t.key];
            const monthlyId = varId?.monthly ?? varId?.once ?? '';
            const annualId  = varId?.annual  ?? varId?.once ?? '';
            const monthlyUrl = monthlyId === 'contact'
              ? 'mailto:sales@shadow-warden-ai.com'
              : checkoutUrl(monthlyId, { embed: true });
            const annualUrl = annualId === 'contact'
              ? 'mailto:sales@shadow-warden-ai.com'
              : checkoutUrl(annualId, { embed: true });

            return (
              <div class={`tier-card relative rounded-2xl p-5 flex flex-col${t.highlight ? ' highlight' : ''}`}
                   style={`border:1px solid ${t.highlight ? t.color + '50' : 'rgba(255,255,255,0.07)'};background:${t.highlight ? t.tint : 'rgba(255,255,255,0.02)'}`}>

                {t.tag && (
                  <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full text-[10px] font-bold whitespace-nowrap"
                       style={`color:${t.color};background:#03050f;border:1px solid ${t.color}60`}>
                    {t.tag}
                  </div>
                )}

                <!-- Header -->
                <div class="mb-4">
                  <div class="text-[13px] font-semibold mb-3" style={`color:${t.color}`}>{t.name}</div>
                  <div class="flex items-baseline gap-1.5">
                    <span class="price-monthly text-[32px] font-black" style="color:#f1f5f9">
                      {t.price_monthly === 0 ? 'Free' : `$${t.price_monthly}`}
                    </span>
                    <span class="price-annual text-[32px] font-black hidden" style="color:#f1f5f9">
                      {t.price_annual === 0 ? 'Free' : `$${Math.round(t.price_annual / 12)}`}
                    </span>
                    {t.price_monthly > 0 && (
                      <span class="text-[12px]" style="color:#475569">
                        <span class="price-monthly">/mo</span>
                        <span class="price-annual hidden">/mo<br/><small style="font-size:10px;color:#334155">(billed ${t.price_annual}/yr)</small></span>
                      </span>
                    )}
                  </div>
                </div>

                <!-- CTA button -->
                {t.key === 'enterprise' ? (
                  <a href="mailto:sales@shadow-warden-ai.com"
                     class="tier-cta block text-center mb-4 py-2.5 rounded-xl text-[13px] font-semibold text-white"
                     style={`background:linear-gradient(135deg,${t.color}cc,${t.color});box-shadow:0 4px 16px ${t.color}33`}>
                    Contact Sales
                  </a>
                ) : t.key === 'starter' ? (
                  <a href="https://portal.shadow-warden-ai.com"
                     class="tier-cta block text-center mb-4 py-2.5 rounded-xl text-[13px] font-semibold"
                     style={`border:1px solid ${t.color}50;color:${t.color};background:rgba(255,255,255,0.02)`}>
                    {t.cta}
                  </a>
                ) : (
                  <button
                    class="tier-cta ls-buy-btn mb-4 py-2.5 rounded-xl text-[13px] font-semibold text-white w-full"
                    data-monthly-url={monthlyUrl}
                    data-annual-url={annualUrl}
                    style={`background:linear-gradient(135deg,${t.color}cc,${t.color});box-shadow:0 4px 16px ${t.color}33`}>
                    {t.cta}
                  </button>
                )}

                <!-- Features -->
                <ul class="flex-1 space-y-1.5">
                  {(t.features ?? []).map(f => (
                    <li class="flex items-start gap-2 text-[12px]" style="color:#94a3b8">
                      <span style={`color:${t.color};flex-shrink:0`}>✓</span>
                      <span>{f}</span>
                    </li>
                  ))}
                  {(t.addons ?? []).map(a => (
                    <li class="flex items-start gap-2 text-[12px]" style="color:#64748b">
                      <span style="flex-shrink:0">⊕</span>
                      <span>{a}</span>
                    </li>
                  ))}
                  {(t.missing ?? []).map(m => (
                    <li class="flex items-start gap-2 text-[12px]" style="color:#2d3748">
                      <span style="flex-shrink:0">—</span>
                      <span style="text-decoration:line-through">{m}</span>
                    </li>
                  ))}
                </ul>
              </div>
            );
          })}
        </div>

        <!-- Enterprise contact-sales banner -->
        <div class="mt-4 rounded-2xl px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-6"
             style="background:rgba(6,182,212,0.05);border:1px solid rgba(6,182,212,0.2)">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-[11px] font-bold tracking-widest uppercase" style="color:#06b6d4">Enterprise</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full font-semibold" style="color:#06b6d4;background:rgba(6,182,212,0.1);border:1px solid rgba(6,182,212,0.25)">Custom Contract</span>
            </div>
            <p class="text-[14px] font-semibold mb-1" style="color:#f1f5f9">Unlimited requests · Post-Quantum Crypto · Sovereign AI Cloud · 24/7 SLA</p>
            <p class="text-[12px]" style="color:#64748b">Custom pricing, SAML/OIDC SSO, dedicated support, and on-prem deployment. Not a self-serve subscription — contact us for a custom quote.</p>
          </div>
          <a href="mailto:sales@shadow-warden-ai.com"
             class="flex-shrink-0 px-6 py-3 rounded-xl text-[13px] font-semibold text-white whitespace-nowrap"
             style="background:linear-gradient(135deg,#0891b2,#06b6d4);box-shadow:0 4px 16px rgba(6,182,212,0.3)">
            Contact Sales →
          </a>
        </div>

        <!-- ROI banner -->
        <div class="mt-10 py-6 px-8 rounded-2xl text-center"
             style="background:rgba(249,115,22,0.06);border:1px solid rgba(249,115,22,0.15)">
          <div class="text-[13px] font-semibold mb-1" style="color:#f97316">
            IBM 2024 Cost of a Data Breach Report
          </div>
          <p class="text-[12px] max-w-2xl mx-auto" style="color:#64748b">
            Average breach cost $4.88M · Pro plan $828/yr · Threat-to-breach conversion 1-in-180.
            For 50,000 requests/month at a 5% threat rate: <strong style="color:#f97316">estimated ROI 782×</strong>
          </p>
        </div>
      </div>
    </section>

    <!-- Add-ons -->
    <section class="pb-24 border-t" style="border-color:rgba(255,255,255,0.06)">
      <div class="mx-auto max-w-7xl px-4 lg:px-8 pt-16">
        <div class="text-center mb-10">
          <h2 class="text-[22px] font-bold mb-2" style="color:#f1f5f9">Add-ons & Extensions</h2>
          <p class="text-[13px]" style="color:#64748b">Enhance any paid plan. Cancel independently.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {addons.map((a: any) => {
            const varId = VARIANT_IDS[a.key];
            const monthlyId = varId?.monthly ?? '';
            const url = monthlyId ? checkoutUrl(monthlyId, { embed: true }) : '#';
            return (
              <div class="addon-card p-5 rounded-2xl flex flex-col gap-3"
                   style={`background:rgba(255,255,255,0.02);border:1px solid ${a.planned ? 'rgba(245,158,11,0.2)' : 'rgba(255,255,255,0.07)'}`}>
                <div class="flex items-start justify-between gap-3">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap mb-0.5">
                      <div class="text-[14px] font-semibold" style="color:#f1f5f9">{a.name}</div>
                      {a.planned && (
                        <span class="px-1.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider flex-shrink-0"
                              style="color:#f59e0b;background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.25)">
                          📋 Planned
                        </span>
                      )}
                    </div>
                    <div class="flex items-center gap-1.5 flex-wrap">
                      <div class="text-[11px] px-2 py-0.5 rounded-md inline-block" style="color:#f97316;background:rgba(249,115,22,0.1)">{a.tier}</div>
                      {a.id && <span class="text-[10px] font-mono" style="color:#334155">{a.id}</span>}
                    </div>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <div class="text-[20px] font-black" style={a.planned ? 'color:#f59e0b' : 'color:#f97316'}>${a.price}</div>
                    <div class="text-[10px]" style="color:#475569">/mo</div>
                  </div>
                </div>

                {a.bullets ? (
                  <ul class="space-y-1 flex-1">
                    {a.bullets.map((b: string) => (
                      <li class="flex items-start gap-1.5 text-[11px]" style="color:#64748b">
                        <span style="color:#8b5cf6;flex-shrink:0;margin-top:1px">◆</span>
                        {b}
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="text-[12px] leading-relaxed flex-1" style="color:#64748b">{a.desc}</p>
                )}

                {a.planned ? (
                  <a href={`mailto:sales@shadow-warden-ai.com?subject=${a.id}%20${encodeURIComponent(a.name)}%20Availability`}
                     class="w-full py-2 rounded-lg text-[12px] font-semibold text-center transition-colors block"
                     style="color:#f59e0b;border:1px solid rgba(245,158,11,0.25);background:rgba(245,158,11,0.05)"
                     onmouseover="this.style.background='rgba(245,158,11,0.10)'"
                     onmouseout="this.style.background='rgba(245,158,11,0.05)'">
                    Notify me when available →
                  </a>
                ) : (
                  <button
                    class="ls-buy-btn w-full py-2 rounded-lg text-[12px] font-semibold transition-colors"
                    data-monthly-url={url}
                    data-annual-url={url}
                    style="color:#f97316;border:1px solid rgba(249,115,22,0.3);background:rgba(249,115,22,0.05)">
                    Add to plan →
                  </button>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ── Profit & ROI Estimator ──────────────────────────────────────── -->
    <section id="roi-estimator" class="pb-24 border-t" style="border-color:rgba(16,185,129,0.15)">
      <div class="mx-auto max-w-5xl px-4 pt-16">

        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4 text-[11px] font-bold tracking-widest uppercase"
               style="color:#10b981;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2)">
            ◈ Marketplace ROI Estimator
          </div>
          <h2 class="text-[22px] font-black mb-2" style="color:#f1f5f9;letter-spacing:-0.02em">
            How much will you earn?
          </h2>
          <p class="text-[13px] max-w-lg mx-auto" style="color:#6b7c96">
            Based on 94,200 trades across 2,847 communities — 33 trades/community/month baseline.
            Adjust to your forecast and see net profit in real time.
          </p>
        </div>

        <div class="rounded-2xl overflow-hidden" style="border:1px solid rgba(16,185,129,0.18);background:rgba(16,185,129,0.02)">
          <div class="grid lg:grid-cols-2">

            <!-- LEFT: Inputs -->
            <div class="p-7" style="border-right:1px solid rgba(16,185,129,0.12)">
              <div class="text-[11px] font-semibold uppercase tracking-wider mb-6" style="color:#10b981">Your numbers</div>

              <!-- Period toggle -->
              <div class="mb-6">
                <div class="text-[12px] font-semibold mb-2" style="color:#a8b8d0">Time period</div>
                <div class="inline-flex rounded-lg overflow-hidden" style="border:1px solid rgba(255,255,255,0.1)">
                  <button id="roi-monthly" class="roi-period-btn active px-5 py-2 text-[12px] font-semibold transition-all" data-p="monthly">Monthly</button>
                  <button id="roi-annual"  class="roi-period-btn px-5 py-2 text-[12px] font-semibold transition-all" data-p="annual">
                    Annual
                    <span class="ml-1 px-1.5 py-0.5 rounded text-[9px]" style="color:#10b981;background:rgba(16,185,129,0.15)">−15%</span>
                  </button>
                </div>
              </div>

              <!-- Tier selector -->
              <div class="mb-6">
                <div class="text-[12px] font-semibold mb-2" style="color:#a8b8d0">Plan tier</div>
                <select id="roi-tier" class="w-full px-3 py-2.5 rounded-lg text-[13px] font-medium outline-none transition-all"
                        style="background:#0c1020;border:1px solid rgba(255,255,255,0.1);color:#f1f5f9;-webkit-appearance:none">
                  <option value="starter">Starter — Free (1,000 req/mo)</option>
                  <option value="individual">Individual — $5/mo (5,000 req/mo)</option>
                  <option value="community" selected>Community Business — $19/mo (10,000 req/mo)</option>
                  <option value="pro">Pro — $69/mo (50,000 req/mo)</option>
                </select>
              </div>

              <!-- Trades slider -->
              <div class="mb-6">
                <div class="flex items-center justify-between mb-2">
                  <div class="text-[12px] font-semibold" style="color:#a8b8d0">Trades per month</div>
                  <div class="text-[14px] font-black tabular-nums" style="color:#10b981" id="roi-trades-val">33</div>
                </div>
                <input id="roi-trades" type="range" min="0" max="10000" value="33" step="1" class="roi-slider w-full" />
                <div class="flex justify-between mt-1">
                  <span class="text-[10px]" style="color:#404e66">0</span>
                  <span class="text-[10px]" style="color:#404e66">10,000</span>
                </div>
              </div>

              <!-- AOV input -->
              <div class="mb-6">
                <div class="flex items-center justify-between mb-2">
                  <div class="text-[12px] font-semibold" style="color:#a8b8d0">Avg. order value (USD)</div>
                  <div class="text-[14px] font-black tabular-nums" style="color:#10b981" id="roi-aov-display">$500</div>
                </div>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[13px]" style="color:#64748b">$</span>
                  <input id="roi-aov" type="number" min="0" max="1000000" value="500" step="1"
                         class="w-full pl-7 pr-3 py-2.5 rounded-lg text-[13px] font-medium outline-none"
                         style="background:#0c1020;border:1px solid rgba(255,255,255,0.1);color:#f1f5f9" />
                </div>
              </div>

              <!-- API calls slider -->
              <div class="mb-6">
                <div class="flex items-center justify-between mb-2">
                  <div class="text-[12px] font-semibold" style="color:#a8b8d0">Monthly search API calls (x402)</div>
                  <div class="text-[14px] font-black tabular-nums" style="color:#10b981" id="roi-api-val">10,000</div>
                </div>
                <input id="roi-api" type="range" min="0" max="1000000" value="10000" step="1000" class="roi-slider w-full" />
                <div class="flex justify-between mt-1">
                  <span class="text-[10px]" style="color:#404e66">0</span>
                  <span class="text-[10px]" style="color:#404e66">1M</span>
                </div>
              </div>

              <!-- Sponsored listing toggle -->
