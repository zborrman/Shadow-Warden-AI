  }
  .roi-slider::-moz-range-thumb {
    width: 16px; height: 16px;
    border-radius: 50%;
    background: #10b981;
    cursor: pointer;
    border: 2px solid #070910;
  }
</style>

<script>
(function () {
  // Billing toggle
  const monthlyBtn = document.getElementById('billing-monthly')!;
  const annualBtn  = document.getElementById('billing-annual')!;
  let   isAnnual   = localStorage.getItem('sw-billing') === 'annual';

  function apply(annual: boolean) {
    isAnnual = annual;
    localStorage.setItem('sw-billing', annual ? 'annual' : 'monthly');
    monthlyBtn.classList.toggle('active', !annual);
    annualBtn.classList.toggle('active', annual);
    monthlyBtn.setAttribute('aria-pressed', String(!annual));
    annualBtn.setAttribute('aria-pressed', String(annual));
    document.querySelectorAll('.price-monthly').forEach(el =>
      (el as HTMLElement).classList.toggle('hidden', annual));
    document.querySelectorAll('.price-annual').forEach(el =>
      (el as HTMLElement).classList.toggle('hidden', !annual));
  }

  monthlyBtn.addEventListener('click', () => apply(false));
  annualBtn.addEventListener('click',  () => apply(true));
  apply(isAnnual);

  // ── ROI Estimator ───────────────────────────────────────────────────────────
  (function roiEstimator() {
    // Tier config — all costs in CENTS to avoid float drift
    const TIERS: Record<string, { sub: number; takeRate: number; name: string; upsell: string | null; upsellTo: string | null }> = {
      starter:   { sub: 0,    takeRate: 0,     name: 'Starter',            upsell: null, upsellTo: null },
      individual:{ sub: 500,  takeRate: 0,     name: 'Individual',         upsell: 'At this GMV, upgrading to Community Business unlocks the SOVA AI agent, 1.5% take rate vs high per-action fees, and 180-day log retention — net profit improves above $1,000/mo GMV.', upsellTo: 'community' },
      community: { sub: 1900, takeRate: 0.015, name: 'Community Business', upsell: 'At this volume, Pro ($69/mo) gives 50k req/mo, MasterAgent SOC, and Evolution Engine — your effective cost per request drops 60%.', upsellTo: 'pro' },
      pro:       { sub: 6900, takeRate: 0.015, name: 'Pro',               upsell: null, upsellTo: null },
    };
    const SPONSOR_COST_CENTS = 2900; // $29/mo

    // Grab DOM
    const el = (id: string) => document.getElementById(id) as HTMLElement | null;

    function fmtDollars(cents: number): string {
      const abs = Math.abs(cents) / 100;
      const s = abs.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      return (cents < 0 ? '-' : '') + '$' + s;
    }
    function fmtShort(n: number): string {
      if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
      if (n >= 1_000)     return (n / 1_000).toFixed(n >= 10_000 ? 0 : 1) + 'k';
      return n.toLocaleString();
    }

    function calc() {
      const tierKey  = (el('roi-tier') as HTMLSelectElement)?.value ?? 'community';
      const trades   = parseInt((el('roi-trades') as HTMLInputElement)?.value ?? '33', 10);
      const aov      = parseFloat((el('roi-aov') as HTMLInputElement)?.value ?? '500');
      const apiCalls = parseInt((el('roi-api') as HTMLInputElement)?.value ?? '10000', 10);
      const isAnnual = (el('roi-annual') as HTMLElement)?.classList.contains('active') ?? false;
      const sponsored = (el('roi-sponsored') as HTMLInputElement)?.checked ?? false;
      const t = TIERS[tierKey] ?? TIERS['community'];

      // All math in cents
      const periodFactor   = isAnnual ? 12 : 1;
      const subCents       = Math.round(t.sub * periodFactor * (isAnnual ? 0.85 : 1));
      const gmvCents       = Math.round(trades * (isAnnual ? 12 : 1) * Math.max(0, aov) * 100);
      const takeCents      = Math.round(gmvCents * t.takeRate);
      const apiCostCents   = Math.round(apiCalls * (isAnnual ? 12 : 1) * 0.0001); // $0.000001 per call = 0.0001 cents
      const sponsorCents   = sponsored ? Math.round(SPONSOR_COST_CENTS * (isAnnual ? 12 : 1) * (isAnnual ? 0.85 : 1)) : 0;
      const netCents       = gmvCents - takeCents - subCents - apiCostCents - sponsorCents;
      const marginPct      = gmvCents > 0 ? Math.round((netCents / gmvCents) * 100) : 0;

      // Animate net profit counter
      const netEl = el('roi-net');
      if (netEl) {
        netEl.textContent = fmtDollars(netCents);
        netEl.style.color = netCents < 0 ? '#ef4444' : '#10b981';
      }

      // Period label
      const periodLabelEl = el('roi-period-label');
      if (periodLabelEl) periodLabelEl.textContent = isAnnual ? 'per year' : 'per month';

      // Margin
      const marginEl = el('roi-margin');
      if (marginEl) {
        marginEl.textContent = gmvCents > 0 ? `${marginPct}% margin` : '';
        marginEl.style.color = marginPct >= 80 ? '#10b981' : marginPct >= 50 ? '#fbbf24' : '#ef4444';
      }

      // Breakdown
      const set = (id: string, v: number) => { const e = el(id); if (e) e.textContent = fmtDollars(v); };
      set('roi-r-gmv',    gmvCents);
      set('roi-r-take',   takeCents);
      set('roi-r-sub',    subCents);
      set('roi-r-x402',   apiCostCents);
      set('roi-r-sponsor', sponsorCents);
      set('roi-r-net',    netCents);

      const sponsorRow = el('roi-r-sponsor')?.closest<HTMLElement>('.flex');
      if (sponsorRow) sponsorRow.style.opacity = sponsored ? '1' : '0.35';

      // ROI vs breach cost ($4.88M = 488000000 cents)
      const annualNet = isAnnual ? netCents : netCents * 12;
      const roiEl = el('roi-roi-val');
      if (roiEl && annualNet > 0) {
        const roi = (488_000_000 / Math.max(1, Math.abs(subCents * (isAnnual ? 1 : 12)))).toFixed(0);
        roiEl.textContent = `${Number(roi).toLocaleString()}× cost avoided`;
      } else if (roiEl) {
        roiEl.textContent = '—';
      }

      // Upsell logic
      const upsellEl = el('roi-upsell');
      const upsellText = el('roi-upsell-text');
      const upsellCta  = el('roi-upsell-cta') as HTMLAnchorElement | null;
      const showUpsell = t.upsell && gmvCents >= 100_000; // $1,000+ GMV
      if (upsellEl) upsellEl.classList.toggle('hidden', !showUpsell);
      if (showUpsell && upsellText) upsellText.textContent = t.upsell!;
      if (showUpsell && upsellCta && t.upsellTo) upsellCta.dataset.tier = t.upsellTo;

      // Update slider track fill
      const updateFill = (sliderId: string, max: number) => {
        const s = el(sliderId) as HTMLInputElement | null;
        if (!s) return;
        const pct = (+s.value / max) * 100;
        s.style.background = `linear-gradient(to right, #10b981 ${pct}%, rgba(255,255,255,0.1) ${pct}%)`;
      };
      updateFill('roi-trades', 10000);
      updateFill('roi-api', 1000000);
    }

    // Expose for inline onclick
    (window as any)._roiCalc = calc;

    // Period toggle
    const monthBtn = el('roi-monthly');
    const yearBtn  = el('roi-annual');
    monthBtn?.addEventListener('click', () => {
      monthBtn.classList.add('active'); yearBtn?.classList.remove('active'); calc();
    });
    yearBtn?.addEventListener('click', () => {
      yearBtn.classList.add('active'); monthBtn?.classList.remove('active'); calc();
    });

    // Trades slider
    const tradesSlider = el('roi-trades') as HTMLInputElement | null;
    tradesSlider?.addEventListener('input', () => {
      const v = parseInt(tradesSlider.value, 10);
      const d = el('roi-trades-val'); if (d) d.textContent = fmtShort(v);
      calc();
    });

    // AOV input
    const aovInput = el('roi-aov') as HTMLInputElement | null;
    aovInput?.addEventListener('input', () => {
      const d = el('roi-aov-display');
      if (d) d.textContent = '$' + (parseFloat(aovInput.value) || 0).toLocaleString();
      calc();
    });

    // API calls slider
    const apiSlider = el('roi-api') as HTMLInputElement | null;
    apiSlider?.addEventListener('input', () => {
      const v = parseInt(apiSlider.value, 10);
      const d = el('roi-api-val'); if (d) d.textContent = fmtShort(v);
      calc();
    });

    // Tier select
    el('roi-tier')?.addEventListener('change', calc);

    // Sponsored toggle
    const sponsoredCb = el('roi-sponsored') as HTMLInputElement | null;
    const track = el('roi-sponsored-track');
    const thumb = el('roi-sponsored-thumb');
    sponsoredCb?.addEventListener('change', () => {
      const on = sponsoredCb.checked;
      if (track) track.style.background = on ? '#10b981' : 'rgba(255,255,255,0.1)';
      if (thumb) thumb.style.transform = on ? 'translateX(16px)' : 'translateX(0)';
      calc();
    });

    // Initial render
    calc();
  })();

  // Buy buttons
  document.querySelectorAll<HTMLButtonElement>('.ls-buy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const url = isAnnual
        ? (btn.dataset.annualUrl ?? btn.dataset.monthlyUrl ?? '')
        : (btn.dataset.monthlyUrl ?? '');
      if (!url || url === '#') return;
      if (url.startsWith('mailto:')) { window.location.href = url; return; }
      if (typeof (window as any).lsCheckout === 'function') {
        (window as any).lsCheckout(url);
      } else {
        window.open(url, '_blank', 'noopener');
      }
    });
  });
})();
</script>
