  document.querySelectorAll('.swatch').forEach(x => x.classList.remove('sel'));
  s.classList.add('sel'); _color = s.dataset.c;
  mIconWrap.style.background  = _color + '22';
  mIconWrap.style.borderColor = _color + '44';
});

// ── Visibility ──────────────────────────────────────────────
document.getElementById('vis-row').addEventListener('click', e => {
  const c = e.target.closest('.tog-card'); if (!c) return;
  document.querySelectorAll('#vis-row .tog-card').forEach(x => x.classList.remove('sel'));
  c.classList.add('sel'); _vis = c.dataset.v;
});

// ── Category pills ──────────────────────────────────────────
document.getElementById('cat-row').addEventListener('click', e => {
  const p = e.target.closest('.cat-pill'); if (!p) return;
  document.querySelectorAll('#cat-row .cat-pill').forEach(x => x.classList.remove('sel'));
  p.classList.add('sel'); _cat = p.dataset.cat;
});

// ── Join policy ─────────────────────────────────────────────
document.getElementById('join-row').addEventListener('click', e => {
  const c = e.target.closest('.tog-card'); if (!c) return;
  document.querySelectorAll('#join-row .tog-card').forEach(x => x.classList.remove('sel'));
  c.classList.add('sel'); _join = c.dataset.j;
});

// ── Crypto mode ─────────────────────────────────────────────
document.getElementById('crypto-row').addEventListener('click', e => {
  const c = e.target.closest('.tog-card'); if (!c) return;
  document.querySelectorAll('#crypto-row .tog-card').forEach(x => x.classList.remove('sel'));
  c.classList.add('sel'); _crypto = c.dataset.crypto;
  const pb = document.getElementById('pqc-badge');
  if (pb) pb.style.display = _crypto === 'pqc' ? '' : 'none';
});

// ── Role ────────────────────────────────────────────────────
document.getElementById('role-row').addEventListener('click', e => {
  const c = e.target.closest('.tog-card'); if (!c) return;
  document.querySelectorAll('#role-row .tog-card').forEach(x => x.classList.remove('sel'));
  c.classList.add('sel'); _role = c.dataset.role;
});

// ── Peering policy ──────────────────────────────────────────
document.getElementById('peer-row').addEventListener('click', e => {
  const c = e.target.closest('.tog-card'); if (!c) return;
  document.querySelectorAll('#peer-row .tog-card').forEach(x => x.classList.remove('sel'));
  c.classList.add('sel'); _peer = c.dataset.p;
});

// ── Regions (multi-select, min 1) ───────────────────────────
document.getElementById('region-row').addEventListener('click', e => {
  const p = e.target.closest('.region-pill'); if (!p) return;
  const r = p.dataset.region;
  if (_regions.includes(r)) {
    if (_regions.length === 1) return;
    _regions = _regions.filter(x => x !== r); p.classList.remove('sel');
  } else {
    _regions.push(r); p.classList.add('sel');
  }
});

// ── Frameworks (multi-select) ───────────────────────────────
document.getElementById('framework-list').addEventListener('click', e => {
  const row = e.target.closest('.check-row'); if (!row) return;
  const fw = row.dataset.fw; const box = row.querySelector('.check-box');
  if (_frameworks.includes(fw)) {
    _frameworks = _frameworks.filter(x => x !== fw);
    row.classList.remove('sel'); box.textContent = '';
  } else {
    _frameworks.push(fw); row.classList.add('sel'); box.textContent = '✓';
  }
});

// ── STIX toggle ─────────────────────────────────────────────
document.getElementById('stix-toggle').addEventListener('click', function() {
  _stix = !_stix; this.classList.toggle('on', _stix);
});

// ── Evolution toggle ─────────────────────────────────────────
document.getElementById('evo-toggle').addEventListener('click', function() {
  _evo = !_evo; this.classList.toggle('on', _evo);
});

// ── Next from step 1 ────────────────────────────────────────
document.getElementById('btn-next1').addEventListener('click', () => {
  const name = fnEl.value.trim();
  if (!name) { fnEl.classList.add('err'); fnErr.classList.add('show'); fnEl.focus(); return; }
  _ns(2);
});

// ── Create (step 6 → 7) ─────────────────────────────────────
document.getElementById('btn-create').addEventListener('click', () => {
  const name = fnEl.value.trim() || 'My Community';
  const uid  = _uid();
  const ts   = new Date().toISOString();
  const slk  = (document.getElementById('f-slack') || {}).value || '';

  const existing = JSON.parse(localStorage.getItem('sw_communities') || '[]');
  existing.unshift({
    id: 'u-' + Math.random().toString(36).slice(2,10),
    name, description: fdEl.value.trim(),
    visibility: _vis, join_policy: _join, category: _cat, color: _color, ueciid: uid,
    crypto_mode: _crypto, default_role: _role, peering_policy: _peer,
    regions: _regions.slice(), frameworks: _frameworks.slice(),
    stix_enabled: _stix, evolution_enabled: _evo, slack_webhook: slk,
    member_invites: ((document.getElementById('f-invites') || {}).value || '').trim(),
    members: 1, transfers: 0, peerings: 0, risk: 'LOW',
    tier: 'Community', joined: true, created_at: ts,
  });
  localStorage.setItem('sw_communities', JSON.stringify(existing));

  document.getElementById('new-uid').textContent        = uid;
  document.getElementById('ok-name').textContent        = name;
  document.getElementById('ok-vis-badge').textContent   = _vis === 'public' ? 'Public' : 'Private';
  document.getElementById('ok-cat-badge').textContent   = _cat.charAt(0).toUpperCase() + _cat.slice(1);
  document.getElementById('ok-crypto-badge').textContent= _crypto === 'pqc' ? 'ML-DSA-65 Hybrid' : 'Ed25519 keypair';
  document.getElementById('ok-peer').textContent        = { mirror:'Mirror Only', rewrap:'Rewrap', full:'Full Sync' }[_peer] || _peer;
  document.getElementById('ok-regions').textContent     = _regions.join(', ');
  document.getElementById('ok-frameworks').textContent  = _frameworks.map(f => f.toUpperCase()).join(', ');
  document.getElementById('ok-evo').textContent         = _evo ? 'Enabled' : 'Disabled';
  _ns(7);
});

// ── Modal open / close ──────────────────────────────────────
document.getElementById('btn-hero').onclick = _open;
const _ctaEl = document.getElementById('btn-cta'); if (_ctaEl) _ctaEl.onclick = _open;
document.getElementById('mcls').onclick = () => modal.close();
modal.addEventListener('click', e => {
  const r = modal.getBoundingClientRect();
  if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) modal.close();
});

window._rj = function(btn) {
  btn.textContent = 'Request Sent ✓';
  btn.style.cssText = 'color:var(--green);border-color:rgba(52,211,153,.28);cursor:default;flex:1;padding:8px 14px;border-radius:8px;background:rgba(52,211,153,.06);font-size:12.5px;font-weight:500;text-align:center;border:1px solid rgba(52,211,153,.28)';
  btn.disabled = true;
};
</script>

</BaseLayout>
