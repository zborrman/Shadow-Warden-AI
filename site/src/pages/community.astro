// ── Canvas topology ─────────────────────────────────────────
(function() {
  const tc = document.getElementById('topo-canvas');
  if (!tc) return;
  const cx = tc.getContext('2d');
  function rsz2() {
    const r = tc.parentElement.getBoundingClientRect();
    tc.width = r.width; tc.height = r.height;
  }
  rsz2();
  window.addEventListener('resize', rsz2);

  const TNS = [
    {id:'c1',label:'FinTech Alliance', sub:'47 members · 6 peerings', icon:'🏦', color:'#818cf8', members:47, rx:.15, ry:.52},
    {id:'c2',label:'Healthcare AI',    sub:'31 members · 4 peerings', icon:'🏥', color:'#34d399', members:31, rx:.34, ry:.24},
    {id:'c3',label:'CyberSec Hub',     sub:'89 members · 12 peerings',icon:'🔬', color:'#fbbf24', members:89, rx:.56, ry:.52},
    {id:'c4',label:'LegalTech',        sub:'22 members · 3 peerings', icon:'⚖️', color:'#f472b6', members:22, rx:.32, ry:.78},
    {id:'c5',label:'EdTech Safety',    sub:'58 members · 8 peerings', icon:'🎓', color:'#22d3ee', members:58, rx:.77, ry:.26},
    {id:'c6',label:'Supply Chain',     sub:'34 members · 5 peerings', icon:'🚢', color:'#c084fc', members:34, rx:.83, ry:.72},
  ];
  const TES = [
    {a:'c1',b:'c2',pol:'FULL',   vol:8420},
    {a:'c1',b:'c4',pol:'MIRROR', vol:2100},
    {a:'c1',b:'c6',pol:'REWRAP', vol:3900},
    {a:'c2',b:'c3',pol:'FULL',   vol:12000},
    {a:'c2',b:'c5',pol:'REWRAP', vol:6500},
    {a:'c3',b:'c5',pol:'FULL',   vol:18000},
    {a:'c3',b:'c6',pol:'MIRROR', vol:4200},
    {a:'c4',b:'c3',pol:'MIRROR', vol:1800},
    {a:'c5',b:'c6',pol:'REWRAP', vol:5000},
  ];
  const POLC = {FULL:'#34d399', REWRAP:'#fbbf24', MIRROR:'#818cf8'};
  const MXVL = Math.max(...TES.map(e => e.vol));
  const NM = Object.fromEntries(TNS.map(n => [n.id, n]));

  function nr(n) { return 18 + Math.sqrt(n.members) * 1.6; }
  function np(n) { return {x: n.rx * tc.width, y: n.ry * tc.height}; }

  const parts = [];
  TES.forEach((e, ei) => {
    const cnt = Math.max(1, Math.round(e.vol / MXVL * 3));
    for (let i=0; i<cnt; i++) parts.push({ei, t: Math.random(), spd: .0018 + (e.vol/MXVL)*.0025});
  });

  let hovN = null, rotA = 0;
  const tip = document.getElementById('topo-tip');
  const ttNm = document.getElementById('tt-nm');
  const ttSb = document.getElementById('tt-sub');

  function drawGrid2() {
    const sp = 30;
    cx.save();
    for (let x=0; x<tc.width; x+=sp)
      for (let y=0; y<tc.height; y+=sp) {
        cx.beginPath(); cx.arc(x,y,.65,0,Math.PI*2);
        cx.fillStyle = 'rgba(129,140,248,.06)'; cx.fill();
      }
    cx.restore();
  }

  function drawEdges2() {
    TES.forEach(e => {
      const na = np(NM[e.a]), nb = np(NM[e.b]);
      const base = hovN ? (hovN===e.a||hovN===e.b ? .45 : .05) : .18;
      const lw = 1 + (e.vol/MXVL) * 2.2;
      const gc = cx.createLinearGradient(na.x,na.y,nb.x,nb.y);
      const ai = Math.round(base*255).toString(16).padStart(2,'0');
      gc.addColorStop(0, NM[e.a].color + ai);
      gc.addColorStop(1, NM[e.b].color + ai);
      cx.beginPath(); cx.strokeStyle = gc; cx.lineWidth = lw;
      cx.moveTo(na.x,na.y); cx.lineTo(nb.x,nb.y); cx.stroke();
    });
  }

  function drawParts2() {
    if (!pRM) parts.forEach(p => { p.t = (p.t + p.spd) % 1; });
    parts.forEach(p => {
      const e = TES[p.ei];
      const na = np(NM[e.a]), nb = np(NM[e.b]);
      const alpha = hovN ? (hovN===e.a||hovN===e.b ? .9 : .07) : .55;
      const x = na.x + (nb.x-na.x)*p.t;
      const y = na.y + (nb.y-na.y)*p.t;
      const col = POLC[e.pol];
      const g2 = cx.createRadialGradient(x,y,0,x,y,7);
      g2.addColorStop(0, col+'bb'); g2.addColorStop(1, col+'00');
      cx.beginPath(); cx.arc(x,y,7,0,Math.PI*2);
      cx.fillStyle = g2; cx.globalAlpha = alpha*.45; cx.fill();
      cx.beginPath(); cx.arc(x,y,2.5,0,Math.PI*2);
      cx.fillStyle = col; cx.globalAlpha = alpha; cx.fill();
      cx.globalAlpha = 1;
    });
  }

  function drawNodes2() {
    if (!pRM) rotA = (rotA + .004) % (Math.PI*2);
    TNS.forEach(n => {
      const {x,y} = np(n);
      const r = nr(n);
      const isH = hovN===n.id;
      const dim = hovN && !isH;
      cx.globalAlpha = dim ? .32 : 1;

      cx.save(); cx.translate(x,y); cx.rotate(rotA);
      cx.beginPath(); cx.arc(0,0,r+14,0,Math.PI*2);
      cx.strokeStyle = n.color + (isH ? '45' : '20');
      cx.lineWidth = isH ? 2 : 1.2; cx.setLineDash([4,9]); cx.stroke();
      cx.setLineDash([]); cx.restore();

      if (isH) {
        const gl = cx.createRadialGradient(x,y,r*.4,x,y,r+28);
        gl.addColorStop(0, n.color+'35'); gl.addColorStop(1, n.color+'00');
        cx.beginPath(); cx.arc(x,y,r+28,0,Math.PI*2); cx.fillStyle = gl; cx.fill();
      }
      cx.beginPath(); cx.arc(x,y,r+6,0,Math.PI*2);
      cx.strokeStyle = n.color+'28'; cx.lineWidth = 1; cx.stroke();

      const cg = cx.createRadialGradient(x-r*.3,y-r*.3,0,x,y,r);
      cg.addColorStop(0, n.color+'ff'); cg.addColorStop(1, n.color+'72');
      cx.beginPath(); cx.arc(x,y,r,0,Math.PI*2); cx.fillStyle = cg; cx.fill();

      cx.font = `${Math.round(r*.72)}px sans-serif`;
      cx.textAlign = 'center'; cx.textBaseline = 'middle';
      cx.fillStyle = '#fff'; cx.fillText(n.icon, x, y+1);

      cx.font = `${isH?'600 ':''}12px system-ui,sans-serif`;
      cx.textAlign = 'center'; cx.textBaseline = 'top';
      cx.fillStyle = isH ? '#f1f5f9' : '#64748b';
      cx.fillText(n.label, x, y+r+14);

      cx.globalAlpha = 1;
    });
  }

  (function loop2() {
    cx.clearRect(0,0,tc.width,tc.height);
    drawGrid2(); drawEdges2(); drawParts2(); drawNodes2();
    requestAnimationFrame(loop2);
  })();

  tc.addEventListener('mousemove', ev => {
    const rect = tc.getBoundingClientRect();
    const mx = (ev.clientX-rect.left)*(tc.width/rect.width);
    const my = (ev.clientY-rect.top)*(tc.height/rect.height);
    let found = null;
    for (const n of TNS) {
      const {x,y} = np(n);
      if ((mx-x)**2+(my-y)**2 < (nr(n)+12)**2) { found = n.id; break; }
    }
    hovN = found;
    if (found) {
      const n = NM[found];
      ttNm.textContent = n.label; ttSb.textContent = n.sub;
      tip.style.left = (ev.clientX-rect.left+16)+'px';
      tip.style.top  = (ev.clientY-rect.top-14)+'px';
      tip.classList.add('vis'); tc.style.cursor = 'pointer';
    } else {
      tip.classList.remove('vis'); tc.style.cursor = 'crosshair';
    }
  });
  tc.addEventListener('mouseleave', () => { hovN = null; tip.classList.remove('vis'); });
})();

