---
import BaseLayout from '../layouts/BaseLayout.astro';

const COMMUNITIES = [
  { id:'c1', name:'FinTech Alliance', tier:'Enterprise', members:47, transfers:12840, peerings:6, risk:'LOW', icon:'🏦', color:'#818cf8', joined:false, category:'finance', desc:'Secure AI exchange for regulated financial institutions. GDPR Art.30 compliant, ISO 27001 certified.' },
  { id:'c2', name:'Healthcare AI Consortium', tier:'Pro', members:31, transfers:8420, peerings:4, risk:'LOW', icon:'🏥', color:'#34d399', joined:false, category:'health', desc:'HIPAA-aligned AI governance for clinical data exchange across hospital networks.' },
  { id:'c3', name:'CyberSec Research Hub', tier:'Enterprise', members:89, transfers:31200, peerings:12, risk:'MEDIUM', icon:'🔬', color:'#fbbf24', joined:true, category:'security', desc:'Collaborative threat intelligence sharing. ArXiv-synced attack corpus, live CVE feeds.' },
  { id:'c4', name:'LegalTech Exchange', tier:'Community', members:22, transfers:4100, peerings:3, risk:'LOW', icon:'⚖️', color:'#f472b6', joined:false, category:'legal', desc:'AI-assisted legal document processing with PII protection and attorney-client privilege.' },
  { id:'c5', name:'EdTech Safety Network', tier:'Pro', members:58, transfers:19600, peerings:8, risk:'LOW', icon:'🎓', color:'#22d3ee', joined:false, category:'education', desc:'Student data protection for AI tutoring platforms. FERPA compliant with parental consent gates.' },
  { id:'c6', name:'Supply Chain AI Guild', tier:'Enterprise', members:34, transfers:7800, peerings:5, risk:'MEDIUM', icon:'🚢', color:'#c084fc', joined:false, category:'logistics', desc:'Cross-border supply chain intelligence with customs compliance and sanctioned-entity screening.' },
];

const commJson = JSON.stringify(COMMUNITIES);
---

<BaseLayout title="Community Network — Shadow Warden AI">

<style>
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    --pr: #818cf8;
    --pr-dim: rgba(129,140,248,0.1);
    --green: #34d399;
    --cyan: #22d3ee;
    --pink: #f472b6;
    --amber: #fbbf24;
    --red: #f87171;
    --purple: #c084fc;
    --ease: cubic-bezier(0.23,1,0.32,1);
  }

  .comm-page { background: #070b14; min-height: 100vh; color: #e2e8f0; }

  .lbl {
    font-size: 11px; font-weight: 600; letter-spacing: .12em;
    text-transform: uppercase; color: var(--pr); margin-bottom: 8px;
  }
  .ttl {
    font-size: clamp(26px,4vw,38px); font-weight: 700; color: #f1f5f9;
    margin-bottom: 10px; line-height: 1.15;
  }
  .sub {
    font-size: 15px; color: #64748b; max-width: 540px;
    line-height: 1.6; margin-bottom: 44px;
  }

  /* ── Hero ─────────────────────────────────────── */
  .hero {
    position: relative; min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  #net-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  .hero-inner {
    position: relative; z-index: 2; text-align: center;
    padding: 40px 24px; max-width: 700px;
  }
  .live-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(52,211,153,.1); border: 1px solid rgba(52,211,153,.22);
    color: var(--green); font-size: 11px; font-weight: 600;
    letter-spacing: .08em; padding: 5px 12px; border-radius: 100px;
    margin-bottom: 24px;
  }
  .live-dot {
    width: 6px; height: 6px; background: var(--green); border-radius: 50%;
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:.4; transform:scale(.7); }
  }
  .hero h1 {
    font-size: clamp(40px,7vw,70px); font-weight: 800; color: #f8fafc;
    line-height: 1.05; margin-bottom: 20px; letter-spacing: -.02em;
  }
  .grad {
    background: linear-gradient(135deg,#818cf8 0%,#c084fc 50%,#f472b6 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub { font-size: 17px; color: #94a3b8; line-height: 1.6; margin-bottom: 44px; }

  .hero-stats {
    display: grid; grid-template-columns: repeat(4,1fr);
    gap: 1px; background: rgba(129,140,248,.08);
    border: 1px solid rgba(129,140,248,.1); border-radius: 16px;
    overflow: hidden; margin-bottom: 36px;
  }
  .h-stat { background: rgba(7,11,20,.92); padding: 18px 14px; text-align: center; }
  .h-stat-n {
    display: block; font-size: clamp(20px,2.5vw,30px); font-weight: 800;
    color: #f1f5f9; font-variant-numeric: tabular-nums;
    font-family: ui-monospace,'SF Mono',monospace;
  }
  .h-stat-l {
    font-size: 10px; color: #475569; text-transform: uppercase;
    letter-spacing: .08em; margin-top: 3px;
  }

  /* ── Buttons ──────────────────────────────────── */
  .hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-pr {
    background: var(--pr); color: #07090f; font-size: 14px; font-weight: 600;
    padding: 12px 28px; border-radius: 10px; border: none; cursor: pointer;
    transition: transform 160ms var(--ease), box-shadow 160ms var(--ease);
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
  }
  .btn-ghost {
    background: rgba(129,140,248,.07); color: var(--pr); font-size: 14px;
    font-weight: 500; padding: 12px 28px; border-radius: 10px;
    border: 1px solid rgba(129,140,248,.2); cursor: pointer;
    transition: border-color 160ms var(--ease), background 160ms var(--ease), transform 160ms var(--ease);
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
  }
  .btn-pr:active   { transform: scale(.97); }
  .btn-ghost:active { transform: scale(.97); }

  /* ── Sections ─────────────────────────────────── */
  .sec { padding: 80px 24px; max-width: 1200px; margin: 0 auto; }

  /* ── Search + chips ───────────────────────────── */
  .disc-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    flex-wrap: wrap; gap: 16px; margin-bottom: 28px;
  }
  .search-box {
    display: flex; align-items: center; gap: 8px;
    background: rgba(12,18,34,.85); border: 1px solid rgba(129,140,248,.14);
    border-radius: 10px; padding: 10px 16px; flex: 1; max-width: 300px;
    transition: border-color 180ms var(--ease);
  }
  .search-box:focus-within { border-color: rgba(129,140,248,.38); }
  .search-ico { color: #475569; font-size: 14px; flex-shrink: 0; }
  .search-inp {
    background: none; border: none; outline: none;
    color: #e2e8f0; font-size: 14px; width: 100%;
  }
  .search-inp::placeholder { color: #475569; }
  .chips { display: flex; gap: 7px; flex-wrap: wrap; }
  .chip {
    background: rgba(12,18,34,.6); border: 1px solid rgba(129,140,248,.1);
    color: #64748b; font-size: 12px; font-weight: 500; padding: 5px 13px;
    border-radius: 100px; cursor: pointer;
    transition: border-color 140ms var(--ease), color 140ms var(--ease), background 140ms var(--ease);
  }
  .chip.on { border-color: rgba(129,140,248,.45); color: var(--pr); background: rgba(129,140,248,.08); }

  /* ── Community grid ───────────────────────────── */
  .c-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(330px,1fr)); gap: 16px; }
  .c-card {
    background: rgba(12,18,34,.72); border: 1px solid rgba(129,140,248,.09);
    border-radius: 16px; padding: 22px; display: flex; flex-direction: column;
    gap: 14px; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    transition: border-color 200ms var(--ease), transform 200ms var(--ease);
    position: relative; overflow: hidden;
  }
  .c-card::before {
    content:''; position:absolute; top:0; left:0; right:0; height:1px;
    background: var(--ac,rgba(129,140,248,.3)); opacity:0;
    transition: opacity 200ms var(--ease);
  }
  .c-head { display: flex; align-items: flex-start; gap: 12px; }
  .c-ico {
    width: 46px; height: 46px; border-radius: 11px;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);
    display: flex; align-items: center; justify-content: center;
    font-size: 21px; flex-shrink: 0;
  }
  .c-meta { flex: 1; min-width: 0; }
  .c-name {
    font-size: 14px; font-weight: 600; color: #f1f5f9; margin-bottom: 5px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .c-tags { display: flex; gap: 5px; flex-wrap: wrap; }
  .tag {
    font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 4px;
    letter-spacing: .03em;
  }
  .tag-tier { background: rgba(129,140,248,.1); color: var(--pr); border: 1px solid rgba(129,140,248,.18); }
  .tag-low  { background: rgba(52,211,153,.09); color: var(--green); border: 1px solid rgba(52,211,153,.18); }
  .tag-med  { background: rgba(251,191,36,.09); color: var(--amber); border: 1px solid rgba(251,191,36,.18); }
  .tag-join { background: rgba(34,211,238,.09); color: var(--cyan); border: 1px solid rgba(34,211,238,.18); }
  .c-desc { font-size: 12.5px; color: #64748b; line-height: 1.6; }
  .c-nums { display: grid; grid-template-columns: repeat(3,1fr); gap: 7px; }
  .c-num {
    background: rgba(255,255,255,.02); border: 1px solid rgba(255,255,255,.04);
    border-radius: 8px; padding: 9px; text-align: center;
  }
  .c-num-v {
    display: block; font-size: 14px; font-weight: 700; color: #f1f5f9;
    font-variant-numeric: tabular-nums; font-family: ui-monospace,'SF Mono',monospace;
  }
  .c-num-l { font-size: 9px; color: #475569; text-transform: uppercase; letter-spacing: .06em; margin-top: 1px; }
  .c-foot { display: flex; gap: 7px; align-items: center; margin-top: auto; }
  .btn-join {
    flex: 1; background: var(--pr-dim); border: 1px solid rgba(129,140,248,.22);
    color: var(--pr); font-size: 12.5px; font-weight: 500; padding: 8px 14px;
    border-radius: 8px; cursor: pointer;
    transition: background 140ms var(--ease), border-color 140ms var(--ease), transform 140ms var(--ease);
    text-align: center; text-decoration: none;
  }
  .btn-join:active { transform: scale(.97); }
  .btn-view {
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07);
    color: #64748b; font-size: 12.5px; font-weight: 500; padding: 8px 12px;
    border-radius: 8px; cursor: pointer;
    transition: border-color 140ms var(--ease), color 140ms var(--ease), transform 140ms var(--ease);
    white-space: nowrap; text-decoration: none;
  }
  .btn-view:active { transform: scale(.97); }

  /* ── Network map ──────────────────────────────── */
  .netmap-band {
    background: rgba(129,140,248,.02);
    border-top: 1px solid rgba(129,140,248,.07);
    border-bottom: 1px solid rgba(129,140,248,.07);
    padding: 80px 24px;
  }
  .netmap-in { max-width: 1200px; margin: 0 auto; }
  .netmap-box {
    margin-top: 44px; height: 380px;
    background: rgba(7,11,20,.85); border: 1px solid rgba(129,140,248,.1);
    border-radius: 20px; overflow: hidden;
  }
  .netmap-svg { width: 100%; height: 100%; }

  /* ── Activity ─────────────────────────────────── */
  .act-cols { display: grid; grid-template-columns: 1fr 340px; gap: 22px; align-items: start; }
  .act-panel {
    background: rgba(12,18,34,.72); border: 1px solid rgba(129,140,248,.09);
    border-radius: 16px; overflow: hidden;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  }
  .act-head {
    padding: 15px 18px; border-bottom: 1px solid rgba(129,140,248,.07);
    display: flex; align-items: center; justify-content: space-between;
  }
  .act-ttl { font-size: 12px; font-weight: 600; color: #94a3b8; display: flex; align-items: center; gap: 8px; }
  .feed { max-height: 340px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: rgba(129,140,248,.15) transparent; }
  .feed-row {
    display: flex; align-items: flex-start; gap: 11px;
    padding: 12px 18px; border-bottom: 1px solid rgba(255,255,255,.025);
  }
  .feed-ico {
    width: 26px; height: 26px; border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; flex-shrink: 0; font-family: ui-monospace,monospace;
  }
  .feed-msg { font-size: 12px; color: #cbd5e1; line-height: 1.4; margin-bottom: 2px; }
  .feed-t   { font-size: 10.5px; color: #475569; font-family: ui-monospace,monospace; }

  /* ── Stat sidebar ─────────────────────────────── */
  .stat-cards { display: flex; flex-direction: column; gap: 11px; }
  .s-card {
    background: rgba(12,18,34,.72); border: 1px solid rgba(129,140,248,.09);
    border-radius: 12px; padding: 15px 18px;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  }
  .s-lbl { font-size: 10px; color: #475569; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 6px; }
  .s-val { font-size: 26px; font-weight: 800; font-family: ui-monospace,'SF Mono',monospace; font-variant-numeric: tabular-nums; line-height: 1; }
  .s-tr  { font-size: 10.5px; margin-top: 4px; }

  /* ── CTA ──────────────────────────────────────── */
  .cta-sec { padding: 80px 24px; text-align: center; }
  .cta-box {
    max-width: 560px; margin: 0 auto;
    background: rgba(12,18,34,.65); border: 1px solid rgba(129,140,248,.14);
    border-radius: 24px; padding: 52px 36px;
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    position: relative; overflow: hidden;
  }
  .cta-glow {
    position: absolute; width: 280px; height: 280px;
    background: radial-gradient(circle,rgba(129,140,248,.07) 0%,transparent 70%);
    top: -90px; left: 50%; transform: translateX(-50%); pointer-events: none;
  }
  .cta-box h2 { font-size: 28px; font-weight: 700; color: #f1f5f9; margin-bottom: 12px; }
  .cta-box p  { font-size: 14px; color: #64748b; line-height: 1.6; margin-bottom: 28px; }

  /* ── Modal ────────────────────────────────────── */
  dialog {
    background: #0c1224; border: 1px solid rgba(129,140,248,.18);
    border-radius: 20px; padding: 0; width: min(460px,calc(100vw - 32px));
    color: #e2e8f0;
    box-shadow: 0 24px 80px rgba(0,0,0,.65), 0 0 0 1px rgba(129,140,248,.07);
  }
  dialog::backdrop {
    background: rgba(3,6,14,.88); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
  }
  .m-head {
    padding: 22px 22px 18px; border-bottom: 1px solid rgba(129,140,248,.07);
    display: flex; align-items: center; justify-content: space-between;
  }
  .m-ttl { font-size: 15px; font-weight: 600; color: #f1f5f9; }
  .m-cls {
    width: 26px; height: 26px; background: rgba(255,255,255,.05); border: none;
    border-radius: 6px; color: #94a3b8; cursor: pointer; font-size: 13px;
    display: flex; align-items: center; justify-content: center;
    transition: background 110ms, color 110ms;
  }
  .m-body { padding: 26px 22px 20px; }
  .steps { display: flex; gap: 7px; margin-bottom: 26px; }
  .step-d { flex: 1; height: 3px; background: rgba(129,140,248,.13); border-radius: 2px; transition: background 280ms var(--ease); }
  .step-d.on { background: var(--pr); }
  .mstep { display: none; }
  .mstep.act { display: block; }
  .f-row { margin-bottom: 14px; }
  .f-lbl { display: block; font-size: 11.5px; font-weight: 500; color: #94a3b8; margin-bottom: 5px; letter-spacing: .04em; }
  .f-inp, .f-sel, .f-ta {
    width: 100%; background: rgba(7,11,20,.85); border: 1px solid rgba(129,140,248,.14);
    border-radius: 8px; padding: 9px 13px; color: #e2e8f0; font-size: 13.5px;
    outline: none; transition: border-color 140ms var(--ease); font-family: inherit;
  }
  .f-inp:focus, .f-sel:focus, .f-ta:focus { border-color: rgba(129,140,248,.4); }
  .f-ta { resize: vertical; min-height: 76px; }
  .f-sel option { background: #0c1224; }
  .m-acts {
    display: flex; gap: 7px; justify-content: flex-end; margin-top: 22px;
    padding-top: 18px; border-top: 1px solid rgba(129,140,248,.07);
  }
  .btn-sm-g {
    background: none; border: 1px solid rgba(129,140,248,.13); color: #64748b;
    font-size: 12.5px; padding: 8px 16px; border-radius: 8px; cursor: pointer;
    transition: border-color 110ms, color 110ms;
  }
  .btn-sm-p {
    background: var(--pr); border: none; color: #07090f; font-size: 12.5px;
    font-weight: 600; padding: 8px 16px; border-radius: 8px; cursor: pointer;
    transition: transform 110ms var(--ease);
  }
  .btn-sm-p:active { transform: scale(.97); }
  .ok-ico {
    width: 52px; height: 52px; background: rgba(52,211,153,.09);
    border: 1px solid rgba(52,211,153,.22); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; margin: 0 auto 18px;
  }
  .ueciid {
    font-family: ui-monospace,'SF Mono',monospace; font-size: 12.5px;
    background: rgba(7,11,20,.85); border: 1px solid rgba(129,140,248,.14);
    border-radius: 8px; padding: 9px 13px; color: var(--pr);
    text-align: center; letter-spacing: .04em; margin-top: 10px;
  }

  /* ── Hover states (touch-safe) ────────────────── */
  @media (hover: hover) and (pointer: fine) {
    .btn-pr:hover   { background: #9ea5fb; box-shadow: 0 0 18px rgba(129,140,248,.28); }
    .btn-ghost:hover { border-color: rgba(129,140,248,.38); background: rgba(129,140,248,.1); }
    .chip:hover     { border-color: rgba(129,140,248,.28); color: #94a3b8; }
    .c-card:hover   { border-color: var(--ac,rgba(129,140,248,.28)); transform: translateY(-3px); }
    .c-card:hover::before { opacity: 1; }
    .btn-join:hover { background: rgba(129,140,248,.14); border-color: rgba(129,140,248,.32); }
    .btn-view:hover { border-color: rgba(255,255,255,.14); color: #94a3b8; }
    .m-cls:hover    { background: rgba(255,255,255,.09); color: #e2e8f0; }
    .btn-sm-g:hover { border-color: rgba(129,140,248,.28); color: #94a3b8; }
  }

  /* ── Reduced motion ───────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation: none !important; transition: opacity 200ms ease !important; }
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 900px) { .act-cols { grid-template-columns: 1fr; } }
  @media (max-width: 640px) {
    .hero-stats { grid-template-columns: repeat(2,1fr); }
    .c-grid { grid-template-columns: 1fr; }
    .disc-head { flex-direction: column; align-items: flex-start; }
    .search-box { max-width: 100%; }
  }
</style>

<div class="comm-page">

  <!-- HERO -->
  <section class="hero">
    <canvas id="net-canvas"></canvas>
    <div class="hero-inner">
      <div class="live-badge"><span class="live-dot"></span> LIVE NETWORK</div>
      <h1>Community <span class="grad">Network</span></h1>
      <p class="hero-sub">
        Federated AI governance. Cryptographic entity exchange.<br>
        Zero-trust peering across your ecosystem.
      </p>
      <div class="hero-stats">
        <div class="h-stat"><span class="h-stat-n" data-to="284">0</span><span class="h-stat-l">Communities</span></div>
        <div class="h-stat"><span class="h-stat-n" data-to="14820">0</span><span class="h-stat-l">Members</span></div>
        <div class="h-stat"><span class="h-stat-n" data-to="48300">0</span><span class="h-stat-l">Transfers / day</span></div>
        <div class="h-stat"><span class="h-stat-n" data-to="2147">0</span><span class="h-stat-l">Threats blocked</span></div>
      </div>
      <div class="hero-btns">
        <button class="btn-pr" id="btn-hero">+ Create Community</button>
        <a href="#discover" class="btn-ghost">Explore Network →</a>
      </div>
    </div>
  </section>

  <!-- DISCOVER -->
  <div class="sec" id="discover">
    <div class="lbl">Community Discovery</div>
    <div class="ttl">Find Your Network</div>
    <p class="sub">Browse federated communities. Request peering. Exchange AI entities securely with cryptographic provenance.</p>
    <div class="disc-head">
      <div class="search-box">
        <span class="search-ico">⌕</span>
        <input class="search-inp" type="search" placeholder="Search communities…" id="srch" autocomplete="off">
      </div>
      <div class="chips" id="chips">
        <button class="chip on" data-f="all">All</button>
        <button class="chip" data-f="finance">Finance</button>
        <button class="chip" data-f="health">Health</button>
        <button class="chip" data-f="security">Security</button>
        <button class="chip" data-f="legal">Legal</button>
        <button class="chip" data-f="education">Education</button>
        <button class="chip" data-f="logistics">Logistics</button>
      </div>
    </div>
    <div class="c-grid" id="cgrid"></div>
  </div>

  <!-- NETWORK MAP -->
  <div class="netmap-band">
    <div class="netmap-in">
      <div class="lbl">Topology</div>
      <div class="ttl">Live Peering Graph</div>
      <p class="sub">Real-time visualization of inter-community peering relationships and entity transfer flows.</p>
      <div class="netmap-box">
        <svg class="netmap-svg" id="nsvg" viewBox="0 0 1100 360" preserveAspectRatio="xMidYMid meet"></svg>
      </div>
    </div>
  </div>

  <!-- ACTIVITY -->
  <div class="sec">
    <div class="lbl">Event Stream</div>
    <div class="ttl">Live Activity Feed</div>
    <p class="sub">Real-time network events across all communities — transfers, blocks, peerings, compliance actions.</p>
    <div class="act-cols">
      <div class="act-panel">
        <div class="act-head">
          <div class="act-ttl"><span class="live-dot"></span> Network Events</div>
          <span style="font-size:10.5px;color:#475569;font-family:monospace" id="ecount">— events</span>
        </div>
        <div class="feed" id="feed"></div>
      </div>
      <div class="stat-cards">
        <div class="s-card">
          <div class="s-lbl">Transfers / hour</div>
          <div class="s-val" style="color:var(--pr)">2,014</div>
          <div class="s-tr" style="color:var(--green)">↑ +12% vs last hour</div>
        </div>
        <div class="s-card">
          <div class="s-lbl">Blocks / hour</div>
          <div class="s-val" style="color:var(--red)">89</div>
          <div class="s-tr" style="color:var(--amber)">↔ Stable baseline</div>
        </div>
        <div class="s-card">
          <div class="s-lbl">Active Peerings</div>
          <div class="s-val" style="color:var(--cyan)">38</div>
          <div class="s-tr" style="color:var(--green)">↑ +3 this week</div>
        </div>
        <div class="s-card">
          <div class="s-lbl">Avg Filter Latency</div>
          <div class="s-val" style="color:var(--green)">1.4<span style="font-size:15px;font-weight:400;color:#475569">ms</span></div>
          <div class="s-tr" style="color:var(--green)">↓ P99 &lt; 50ms SLA</div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="cta-sec">
    <div class="cta-box">
      <div class="cta-glow"></div>
      <div class="lbl" style="margin:0 0 10px">Get Started</div>
      <h2>Launch Your Community</h2>
      <p>Deploy a governed AI community in under 60 seconds. Cryptographic keypairs, STIX audit chain, and sovereign data pods provisioned automatically.</p>
      <button class="btn-pr" id="btn-cta" style="font-size:15px;padding:13px 30px">+ Create Community</button>
    </div>
  </div>

</div>

<!-- MODAL -->
<dialog id="mdl">
  <div class="m-head">
    <span class="m-ttl">Create Community</span>
    <button class="m-cls" id="mcls" aria-label="Close">✕</button>
  </div>
  <div class="m-body">
    <div class="steps" id="sdots">
      <div class="step-d on"></div>
      <div class="step-d"></div>
      <div class="step-d"></div>
    </div>

    <div class="mstep act" id="s1">
      <div class="f-row">
        <label class="f-lbl">Community Name</label>
        <input class="f-inp" type="text" placeholder="e.g. FinTech Alliance" id="fn">
      </div>
      <div class="f-row">
        <label class="f-lbl">Description</label>
        <textarea class="f-ta" placeholder="Describe your community's purpose…" id="fd"></textarea>
      </div>
      <div class="f-row">
        <label class="f-lbl">Category</label>
        <select class="f-sel">
          <option>Finance</option><option>Healthcare</option><option>Cybersecurity</option>
          <option>Legal</option><option>Education</option><option>Logistics</option><option>Other</option>
        </select>
      </div>
      <div class="m-acts">
        <button class="btn-sm-g" onclick="document.getElementById('mdl').close()">Cancel</button>
        <button class="btn-sm-p" onclick="_ns(2)">Next →</button>
      </div>
    </div>

    <div class="mstep" id="s2">
      <div class="f-row">
        <label class="f-lbl">Tier</label>
        <select class="f-sel">
          <option>Community (Free)</option>
          <option>Pro ($69/mo)</option>
          <option>Enterprise ($249/mo)</option>
        </select>
      </div>
      <div class="f-row">
        <label class="f-lbl">Peering Policy</label>
        <select class="f-sel">
          <option>Mirror Only — read-only cross-community</option>
          <option>Rewrap Allowed — re-key on transfer</option>
          <option>Full Sync — bidirectional</option>
        </select>
      </div>
      <div class="f-row">
        <label class="f-lbl">Cryptography</label>
        <select class="f-sel">
          <option>Classical Ed25519 (all tiers)</option>
          <option>Hybrid PQC — ML-DSA-65 + Ed25519 (Enterprise)</option>
        </select>
      </div>
      <div class="m-acts">
        <button class="btn-sm-g" onclick="_ns(1)">← Back</button>
        <button class="btn-sm-p" onclick="_submit()">Create →</button>
      </div>
    </div>

    <div class="mstep" id="s3">
      <div style="text-align:center">
        <div class="ok-ico">✓</div>
        <div style="font-size:15px;font-weight:600;color:#f1f5f9;margin-bottom:8px">Community Created</div>
        <div style="font-size:13px;color:#64748b;line-height:1.5">Keypairs generated. STIX audit chain initialized. UECIID issued.</div>
        <div class="ueciid" id="new-uid">SEP-___________</div>
        <div style="font-size:10.5px;color:#475569;margin-top:6px">Cryptographic community identity</div>
      </div>
      <div class="m-acts">
        <button class="btn-sm-p" onclick="document.getElementById('mdl').close();_reset()">Done</button>
      </div>
    </div>
  </div>
</dialog>

<script define:vars={{ commJson }}>
const COMMS = JSON.parse(commJson);
const modal = document.getElementById('mdl');

// ── Canvas particle network ─────────────────────────────────
const cv  = document.getElementById('net-canvas');
const ctx = cv.getContext('2d');
const pRM = window.matchMedia('(prefers-reduced-motion:reduce)').matches;

function rsz() { cv.width = cv.offsetWidth || window.innerWidth; cv.height = cv.offsetHeight || window.innerHeight; }
rsz(); window.addEventListener('resize', rsz);

const COLS = ['#818cf8','#34d399','#22d3ee','#f472b6','#c084fc','#fbbf24'];
const pts = Array.from({length:55}, () => ({
  x: Math.random()*cv.width, y: Math.random()*cv.height,
  vx: (Math.random()-.5)*.22, vy: (Math.random()-.5)*.22,
  r: Math.random()*1.4+.5,
  c: COLS[Math.floor(Math.random()*COLS.length)],
  ph: Math.random()*Math.PI*2,
}));

let lt = 0;
(function draw(ts) {
  const dt = Math.min((ts-lt)/16.67, 3); lt = ts;
  ctx.clearRect(0, 0, cv.width, cv.height);
  if (!pRM) {
    for (const p of pts) {
      p.x += p.vx*dt; p.y += p.vy*dt; p.ph += .014*dt;
      if (p.x < -8) p.x = cv.width+8; else if (p.x > cv.width+8)  p.x = -8;
      if (p.y < -8) p.y = cv.height+8; else if (p.y > cv.height+8) p.y = -8;
    }
  }
  const MD = 125;
  for (let i = 0; i < pts.length; i++) {
    for (let j = i+1; j < pts.length; j++) {
      const dx = pts[i].x-pts[j].x, dy = pts[i].y-pts[j].y, d2 = dx*dx+dy*dy;
      if (d2 < MD*MD) {
        ctx.beginPath();
        ctx.strokeStyle = `rgba(129,140,248,${(1-Math.sqrt(d2)/MD)*.11})`;
        ctx.lineWidth = .55;
        ctx.moveTo(pts[i].x, pts[i].y); ctx.lineTo(pts[j].x, pts[j].y);
        ctx.stroke();
      }
    }
  }
  for (const p of pts) {
    const pulse = pRM ? 1 : (Math.sin(p.ph)+1)/2;
    const rr = p.r + pulse*1.4;
    const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, rr*4);
    g.addColorStop(0, p.c+'28'); g.addColorStop(1, p.c+'00');
    ctx.beginPath(); ctx.arc(p.x, p.y, rr*4, 0, Math.PI*2); ctx.fillStyle = g; ctx.fill();
    ctx.beginPath(); ctx.arc(p.x, p.y, rr, 0, Math.PI*2);
    ctx.fillStyle = p.c; ctx.globalAlpha = .65+pulse*.35; ctx.fill(); ctx.globalAlpha = 1;
  }
  requestAnimationFrame(draw);
})(0);

// ── Counter animation ───────────────────────────────────────
const cObs = new IntersectionObserver(en => {
  if (!en[0].isIntersecting) return; cObs.disconnect();
  const els = document.querySelectorAll('[data-to]');
  const t0 = performance.now();
  (function tick(now) {
    const p = Math.min((now-t0)/1800, 1), e = 1-Math.pow(1-p, 3);
    els.forEach(el => { el.textContent = Math.round(+el.dataset.to*e).toLocaleString(); });
    if (p < 1) requestAnimationFrame(tick);
  })(t0);
}, {threshold:.3});
cObs.observe(document.querySelector('.hero'));

// ── Community cards ─────────────────────────────────────────
function fmt(n) { return n >= 1000 ? (n/1000).toFixed(1)+'k' : n.toLocaleString(); }
function renderCards(list) {
  document.getElementById('cgrid').innerHTML = list.map(c => `
    <div class="c-card" data-cat="${c.category}" style="--ac:${c.color}44">
      <div class="c-head">
        <div class="c-ico">${c.icon}</div>
        <div class="c-meta">
          <div class="c-name">${c.name}</div>
          <div class="c-tags">
            <span class="tag tag-tier">${c.tier}</span>
            <span class="tag ${c.risk==='LOW'?'tag-low':'tag-med'}">${c.risk}</span>
            ${c.joined ? '<span class="tag tag-join">✓ Joined</span>' : ''}
          </div>
        </div>
      </div>
      <div class="c-desc">${c.desc}</div>
      <div class="c-nums">
        <div class="c-num"><span class="c-num-v">${c.members}</span><span class="c-num-l">Members</span></div>
        <div class="c-num"><span class="c-num-v">${fmt(c.transfers)}</span><span class="c-num-l">Transfers</span></div>
        <div class="c-num"><span class="c-num-v">${c.peerings}</span><span class="c-num-l">Peerings</span></div>
      </div>
      <div class="c-foot">
        ${c.joined
          ? `<a href="/community/view" class="btn-join">Open Portal →</a>`
          : `<button class="btn-join" onclick="_rj(this)">Request to Join</button>`}
        <a href="/community/view" class="btn-view">View →</a>
      </div>
    </div>`).join('');
}
renderCards(COMMS);

// ── Filter ──────────────────────────────────────────────────
let af = 'all', sq = '';
function applyF() {
  renderCards(COMMS.filter(c =>
    (af === 'all' || c.category === af) &&
    (!sq || c.name.toLowerCase().includes(sq) || c.desc.toLowerCase().includes(sq))
  ));
}
document.getElementById('chips').addEventListener('click', e => {
  const ch = e.target.closest('.chip'); if (!ch) return;
  document.querySelectorAll('.chip').forEach(x => x.classList.remove('on'));
  ch.classList.add('on'); af = ch.dataset.f; applyF();
});
let st;
document.getElementById('srch').addEventListener('input', e => {
  clearTimeout(st); st = setTimeout(() => { sq = e.target.value.toLowerCase().trim(); applyF(); }, 150);
});

// ── SVG network map ─────────────────────────────────────────
(function() {
  const NDS = [
    {id:'c1',l:'FinTech',x:180,y:185,c:'#818cf8',r:26},
    {id:'c2',l:'Healthcare',x:370,y:100,c:'#34d399',r:20},
    {id:'c3',l:'CyberSec',x:600,y:185,c:'#fbbf24',r:34},
    {id:'c4',l:'LegalTech',x:340,y:280,c:'#f472b6',r:17},
    {id:'c5',l:'EdTech',x:840,y:120,c:'#22d3ee',r:28},
    {id:'c6',l:'Supply Chain',x:880,y:270,c:'#c084fc',r:22},
  ];
  const EDS = [['c1','c2'],['c1','c4'],['c1','c6'],['c2','c3'],['c2','c5'],['c3','c5'],['c3','c6'],['c4','c3'],['c5','c6']];
  const nm = Object.fromEntries(NDS.map(n => [n.id, n]));
  const svg = document.getElementById('nsvg');

  let d = '<defs><filter id="gl"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>';
  NDS.forEach(n => {
    d += `<radialGradient id="rg-${n.id}" cx="38%" cy="32%" r="62%"><stop offset="0%" stop-color="${n.c}" stop-opacity=".9"/><stop offset="100%" stop-color="${n.c}" stop-opacity=".35"/></radialGradient>`;
  });
  d += '</defs>';

  d += EDS.map(([a,b]) => {
    const na = nm[a], nb = nm[b];
    return `<line x1="${na.x}" y1="${na.y}" x2="${nb.x}" y2="${nb.y}" stroke="rgba(129,140,248,.13)" stroke-width="1.5" stroke-dasharray="5 4"><animate attributeName="stroke-dashoffset" from="0" to="-9" dur="1.2s" repeatCount="indefinite"/></line>`;
  }).join('');

  d += NDS.map(n => `
    <g>
      <circle cx="${n.x}" cy="${n.y}" r="${n.r+9}" fill="${n.c}" fill-opacity=".06"/>
      <circle cx="${n.x}" cy="${n.y}" r="${n.r}" fill="url(#rg-${n.id})" filter="url(#gl)"/>
      <text x="${n.x}" y="${n.y+n.r+15}" text-anchor="middle" font-size="11" fill="#94a3b8" font-family="system-ui,sans-serif">${n.l}</text>
    </g>`).join('');

  svg.innerHTML = d;
})();

// ── Activity feed ───────────────────────────────────────────
const TPLS = [
  {ico:'⇄',c:'#818cf8',ms:['FinTech → Healthcare · {n} entities','CyberSec → EdTech · {n} entities','Supply Chain → FinTech · {n} entities']},
  {ico:'⊘',c:'#f87171',ms:['BLOCK: prompt injection · req-{h}','BLOCK: jailbreak attempt · req-{h}','BLOCK: PII exfiltration · req-{h}']},
  {ico:'+',c:'#34d399',ms:['New member joined EdTech Network','New member joined FinTech Alliance']},
  {ico:'✓',c:'#fbbf24',ms:['DPA renewed · LegalTech ↔ Anthropic','DPA signed · Supply Chain ↔ OpenAI']},
  {ico:'⟷',c:'#22d3ee',ms:['New peering: Supply Chain ↔ FinTech','Peering upgraded: CyberSec ↔ EdTech']},
];
const rh = () => Math.random().toString(16).slice(2,6);
const rn = () => Math.floor(Math.random()*8)+1;
function genEvt() {
  const t = TPLS[Math.floor(Math.random()*TPLS.length)];
  return {ico:t.ico, c:t.c, msg:t.ms[Math.floor(Math.random()*t.ms.length)].replace('{n}',rn()).replace('{h}',rh()), time:'just now'};
}

let items = [
  {ico:'⇄',c:'#818cf8',msg:'FinTech Alliance → Healthcare · 3 entities',time:'2s ago'},
  {ico:'⊘',c:'#f87171',msg:'BLOCK: prompt injection · req-7f3a',time:'18s ago'},
  {ico:'+',c:'#34d399',msg:'New member joined EdTech Safety Network',time:'1m ago'},
  {ico:'✓',c:'#fbbf24',msg:'DPA renewed · LegalTech Exchange ↔ Anthropic',time:'4m ago'},
  {ico:'⟷',c:'#22d3ee',msg:'New peering: Supply Chain Guild ↔ FinTech Alliance',time:'12m ago'},
  {ico:'⊘',c:'#f87171',msg:'BLOCK: jailbreak attempt · req-2b9c',time:'23m ago'},
  {ico:'★',c:'#c084fc',msg:'AI Safety cert completed · 12 members · EdTech',time:'31m ago'},
];
let ec = items.length;

function renderFeed() {
  document.getElementById('feed').innerHTML = items.map(it => `
    <div class="feed-row">
      <div class="feed-ico" style="color:${it.c};background:${it.c}12;border:1px solid ${it.c}20">${it.ico}</div>
      <div><div class="feed-msg">${it.msg}</div><div class="feed-t">${it.time}</div></div>
    </div>`).join('');
  document.getElementById('ecount').textContent = ec + ' events';
}
renderFeed();

(function sched() {
  setTimeout(() => { items.unshift(genEvt()); if (items.length > 20) items.pop(); ec++; renderFeed(); sched(); },
    4000 + Math.random()*8000);
})();

// ── Modal ───────────────────────────────────────────────────
let cs = 1;
function _open() { _reset(); modal.showModal(); }
function _reset() {
  cs = 1;
  document.querySelectorAll('.mstep').forEach(s => s.classList.remove('act'));
  document.getElementById('s1').classList.add('act');
  _dots(1);
  document.getElementById('fn').value = '';
  document.getElementById('fd').value = '';
}
function _dots(n) { document.querySelectorAll('.step-d').forEach((d,i) => d.classList.toggle('on', i < n)); }
window._ns = function(n) {
  if (n === 2 && !document.getElementById('fn').value.trim()) { document.getElementById('fn').focus(); return; }
  document.getElementById('s'+cs).classList.remove('act');
  cs = n; document.getElementById('s'+n).classList.add('act'); _dots(n);
};
window._submit = function() {
  const chars = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';
  document.getElementById('new-uid').textContent = 'SEP-' + Array.from({length:11}, () => chars[Math.floor(Math.random()*62)]).join('');
  _ns(3);
};
window._rj = function(btn) {
  btn.textContent = 'Request Sent ✓';
  btn.style.cssText = 'color:var(--green);border-color:rgba(52,211,153,.28);cursor:default;flex:1;padding:8px 14px;border-radius:8px;background:rgba(52,211,153,.06);font-size:12.5px;font-weight:500;text-align:center;border:1px solid rgba(52,211,153,.28)';
  btn.disabled = true;
};

document.getElementById('btn-hero').onclick = _open;
document.getElementById('btn-cta').onclick  = _open;
document.getElementById('mcls').onclick     = () => modal.close();
modal.addEventListener('click', e => {
  const r = modal.getBoundingClientRect();
  if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) modal.close();
});
</script>

</BaseLayout>
