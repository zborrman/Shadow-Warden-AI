---
import BaseLayout from '../layouts/BaseLayout.astro';

const COMMUNITIES = [
  { id:'c1', name:'FinTech Alliance', tier:'Enterprise', members:47, transfers:12840, peerings:6, risk:'LOW', icon:'🏦', color:'#818cf8', joined:false, category:'finance', desc:'Secure AI exchange for regulated financial institutions. GDPR Art.30 compliant, ISO 27001 certified.' },
  { id:'c2', name:'Healthcare AI Consortium', tier:'Pro', members:31, transfers:8420, peerings:4, risk:'LOW', icon:'🏥', color:'#34d399', joined:false, category:'health', desc:'HIPAA-aligned AI governance for clinical data exchange across hospital networks.' },
  { id:'c3', name:'CyberSec Research Hub', tier:'Enterprise', members:89, transfers:31200, peerings:12, risk:'MEDIUM', icon:'🔬', color:'#fbbf24', joined:true, category:'security', desc:'Collaborative threat intelligence sharing. ArXiv-synced attack corpus, live CVE feeds.' },
  { id:'c4', name:'LegalTech Exchange', tier:'Community', members:22, transfers:4100, peerings:3, risk:'LOW', icon:'⚖️', color:'#f472b6', joined:false, category:'legal', desc:'AI-assisted legal document processing with PII protection and attorney-client privilege.' },
  { id:'c5', name:'EdTech Safety Network', tier:'Pro', members:58, transfers:19600, peerings:8, risk:'LOW', icon:'🎓', color:'#22d3ee', joined:false, category:'education', desc:'Student data protection for AI tutoring platforms. FERPA compliant with parental consent gates.' },
  { id:'c6', name:'Supply Chain AI Guild', tier:'Enterprise', members:34, transfers:7800, peerings:5, risk:'MEDIUM', icon:'🚢', color:'#c084fc', joined:false, category:'logistics', desc:'Cross-border supply chain intelligence with customs compliance and sanctioned-entity screening.' },
];

const commJson = JSON.stringify(COMMUNITIES);
---

<BaseLayout title="Community Network — Shadow Warden AI">

<style>
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    --pr: #818cf8;
    --pr-dim: rgba(129,140,248,0.1);
    --green: #34d399;
    --cyan: #22d3ee;
    --pink: #f472b6;
    --amber: #fbbf24;
    --red: #f87171;
    --purple: #c084fc;
    --ease: cubic-bezier(0.23,1,0.32,1);
  }

  .comm-page { background: #070b14; min-height: 100vh; color: #e2e8f0; }

  .lbl {
    font-size: 11px; font-weight: 600; letter-spacing: .12em;
    text-transform: uppercase; color: var(--pr); margin-bottom: 8px;
  }
  .ttl {
    font-size: clamp(26px,4vw,38px); font-weight: 700; color: #f1f5f9;
    margin-bottom: 10px; line-height: 1.15;
  }
  .sub {
    font-size: 15px; color: #64748b; max-width: 540px;
    line-height: 1.6; margin-bottom: 44px;
  }

  /* ── Hero ─────────────────────────────────────── */
  .hero {
    position: relative; min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  #net-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  .hero-inner {
    position: relative; z-index: 2; text-align: center;
    padding: 40px 24px; max-width: 700px;
  }
  .live-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(52,211,153,.1); border: 1px solid rgba(52,211,153,.22);
    color: var(--green); font-size: 11px; font-weight: 600;
    letter-spacing: .08em; padding: 5px 12px; border-radius: 100px;
    margin-bottom: 24px;
  }
  .live-dot {
    width: 6px; height: 6px; background: var(--green); border-radius: 50%;
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:.4; transform:scale(.7); }
  }
  .hero h1 {
    font-size: clamp(40px,7vw,70px); font-weight: 800; color: #f8fafc;
    line-height: 1.05; margin-bottom: 20px; letter-spacing: -.02em;
  }
  .grad {
    background: linear-gradient(135deg,#818cf8 0%,#c084fc 50%,#f472b6 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub { font-size: 17px; color: #94a3b8; line-height: 1.6; margin-bottom: 44px; }

  .hero-stats {
    display: grid; grid-template-columns: repeat(4,1fr);
    gap: 1px; background: rgba(129,140,248,.08);
    border: 1px solid rgba(129,140,248,.1); border-radius: 16px;
    overflow: hidden; margin-bottom: 36px;
  }
  .h-stat { background: rgba(7,11,20,.92); padding: 18px 14px; text-align: center; }
  .h-stat-n {
    display: block; font-size: clamp(20px,2.5vw,30px); font-weight: 800;
    color: #f1f5f9; font-variant-numeric: tabular-nums;
    font-family: ui-monospace,'SF Mono',monospace;
  }
  .h-stat-l {
    font-size: 10px; color: #475569; text-transform: uppercase;
    letter-spacing: .08em; margin-top: 3px;
  }

  /* ── Buttons ──────────────────────────────────── */
  .hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-pr {
    background: var(--pr); color: #07090f; font-size: 14px; font-weight: 600;
    padding: 12px 28px; border-radius: 10px; border: none; cursor: pointer;
    transition: transform 160ms var(--ease), box-shadow 160ms var(--ease);
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
  }
  .btn-ghost {
    background: rgba(129,140,248,.07); color: var(--pr); font-size: 14px;
    font-weight: 500; padding: 12px 28px; border-radius: 10px;
    border: 1px solid rgba(129,140,248,.2); cursor: pointer;
    transition: border-color 160ms var(--ease), background 160ms var(--ease), transform 160ms var(--ease);
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
  }
  .btn-pr:active   { transform: scale(.97); }
  .btn-ghost:active { transform: scale(.97); }

  /* ── Sections ─────────────────────────────────── */
  .sec { padding: 80px 24px; max-width: 1200px; margin: 0 auto; }

  /* ── Discovery toolbar ───────────────────────────── */
  .disc-toolbar { display: flex; flex-direction: column; gap: 14px; margin-bottom: 32px; }
  .search-wrap {
    display: flex; align-items: center; gap: 10px;
    background: rgba(8,13,26,.9); border: 1px solid rgba(129,140,248,.16);
    border-radius: 12px; padding: 12px 18px;
    transition: border-color 180ms var(--ease), box-shadow 180ms var(--ease);
  }
  .search-wrap:focus-within {
    border-color: rgba(129,140,248,.42);
    box-shadow: 0 0 0 3px rgba(129,140,248,.06);
  }
  .srch-ic { color: #3d4a5c; flex-shrink: 0; }
  .srch-inp {
    flex: 1; background: none; border: none; outline: none;
    color: #e2e8f0; font-size: 14px;
  }
  .srch-inp::placeholder { color: #2d3a4e; }
  .srch-ct {
    font-size: 10.5px; color: #3d4a5c; font-family: ui-monospace,monospace;
    background: rgba(129,140,248,.07); border: 1px solid rgba(129,140,248,.1);
    padding: 2px 8px; border-radius: 4px; flex-shrink: 0;
  }
  .filter-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .filter-lbl {
    font-size: 10.5px; font-weight: 600; color: #2d3a4e;
    text-transform: uppercase; letter-spacing: .1em; flex-shrink: 0;
  }
  .pills { display: flex; gap: 6px; flex-wrap: wrap; }
  .pill {
    display: flex; align-items: center; gap: 5px;
    background: rgba(8,13,26,.7); border: 1px solid rgba(255,255,255,.05);
    color: #64748b; font-size: 11.5px; font-weight: 500; padding: 5px 12px;
    border-radius: 100px; cursor: pointer;
    transition: border-color 150ms var(--ease), color 150ms var(--ease), background 150ms var(--ease);
  }
  .pill-n {
    background: rgba(255,255,255,.05); color: #3d4a5c; font-size: 10px;
    font-weight: 700; padding: 0 5px; border-radius: 3px;
    font-family: ui-monospace,monospace; min-width: 16px; text-align: center;
  }
  .pill.on { background: rgba(129,140,248,.1); border-color: rgba(129,140,248,.32); color: var(--pr); }
  .pill.on .pill-n { background: rgba(129,140,248,.14); color: #a5b4fc; }

  /* ── Community grid ───────────────────────────── */
  .c-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(340px,1fr)); gap: 20px; }
  .c-card {
    background: rgba(9,14,26,.9); border: 1px solid rgba(255,255,255,.055);
    border-left: 3px solid var(--cc,#818cf8);
    border-radius: 14px; display: flex; flex-direction: column;
    overflow: hidden; position: relative;
    transition: transform 200ms var(--ease), box-shadow 200ms var(--ease);
  }
  .c-card-bg {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at 0% 40%, var(--cc-dim,rgba(129,140,248,.05)) 0%, transparent 55%);
  }
  .c-body { padding: 20px 20px 0; display: flex; flex-direction: column; gap: 14px; flex: 1; position: relative; }
  .c-header { display: flex; align-items: flex-start; gap: 14px; }
  .c-avatar {
    width: 52px; height: 52px; border-radius: 13px; flex-shrink: 0;
    background: var(--cc-dim,rgba(129,140,248,.1));
    border: 1px solid var(--cc-bdr,rgba(129,140,248,.22));
    display: flex; align-items: center; justify-content: center; font-size: 24px;
  }
  .c-info { flex: 1; min-width: 0; }
  .c-title {
    font-size: 15px; font-weight: 700; color: #f1f5f9; margin-bottom: 7px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .c-badges { display: flex; gap: 5px; flex-wrap: wrap; align-items: center; }
  .bdg { font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 4px; letter-spacing: .03em; line-height: 1.6; }
  .bdg-ent  { background: rgba(129,140,248,.1);  color: #a5b4fc; border: 1px solid rgba(129,140,248,.2); }
  .bdg-pro  { background: rgba(34,211,238,.08);  color: #67e8f9; border: 1px solid rgba(34,211,238,.18); }
  .bdg-com  { background: rgba(255,255,255,.05); color: #94a3b8; border: 1px solid rgba(255,255,255,.1); }
  .bdg-low  { background: rgba(52,211,153,.08);  color: #6ee7b7; border: 1px solid rgba(52,211,153,.18); }
  .bdg-med  { background: rgba(251,191,36,.08);  color: #fcd34d; border: 1px solid rgba(251,191,36,.18); }
  .bdg-mbr  { background: rgba(34,211,238,.08);  color: #22d3ee; border: 1px solid rgba(34,211,238,.18); }

  .c-members { display: flex; align-items: center; gap: 10px; }
  .av-stack  { display: flex; }
  .av {
    width: 22px; height: 22px; border-radius: 50%;
    border: 2px solid #090e1a; margin-left: -7px;
  }
  .av:first-child { margin-left: 0; }
  .av-more {
    width: 22px; height: 22px; border-radius: 50%;
    border: 2px solid #090e1a; margin-left: -7px;
    background: rgba(129,140,248,.14); color: #818cf8;
    font-size: 8px; font-weight: 700; display: flex; align-items: center; justify-content: center;
  }
  .c-mlbl { font-size: 12px; color: #64748b; }

  .c-desc { font-size: 12.5px; color: #64748b; line-height: 1.65; }

  .c-metrics {
    display: flex; align-items: stretch;
    background: rgba(255,255,255,.02); border: 1px solid rgba(255,255,255,.04);
    border-radius: 10px; overflow: hidden;
  }
  .c-metric {
    flex: 1; padding: 10px 8px; text-align: center;
    border-right: 1px solid rgba(255,255,255,.04);
  }
  .c-metric:last-child { border-right: none; }
  .c-mv {
    display: block; font-size: 15px; font-weight: 700; color: #f1f5f9;
    font-variant-numeric: tabular-nums; font-family: ui-monospace,'SF Mono',monospace; margin-bottom: 2px;
  }
  .c-ml { font-size: 9px; color: #2d3a4e; text-transform: uppercase; letter-spacing: .07em; }

  .c-bar { height: 3px; background: rgba(255,255,255,.04); border-radius: 2px; overflow: hidden; margin-top: 2px; }
  .c-bar-f { height: 100%; background: var(--cc,#818cf8); border-radius: 2px; opacity: .55; }

  .c-foot {
    display: flex; gap: 8px; padding: 16px 20px;
    border-top: 1px solid rgba(255,255,255,.04); margin-top: 6px; position: relative;
  }
  .btn-jn {
    flex: 1; background: var(--cc-dim,rgba(129,140,248,.08));
    border: 1px solid var(--cc-bdr,rgba(129,140,248,.22));
    color: var(--cc,#818cf8); font-size: 12.5px; font-weight: 600;
    padding: 9px 16px; border-radius: 9px; cursor: pointer;
    transition: background 140ms var(--ease), transform 140ms var(--ease);
    text-align: center; text-decoration: none;
  }
  .btn-jn:active { transform: scale(.97); }
  .btn-vw {
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07);
    color: #475569; font-size: 12.5px; font-weight: 500; padding: 9px 14px;
    border-radius: 9px; cursor: pointer; white-space: nowrap; text-decoration: none;
    transition: border-color 140ms var(--ease), color 140ms var(--ease), transform 140ms var(--ease);
  }
  .btn-vw:active { transform: scale(.97); }

  /* ── Network map ──────────────────────────────── */
  .netmap-band {
    padding: 80px 24px;
    background: linear-gradient(180deg,#070b14 0%,#07102a 50%,#070b14 100%);
    border-top: 1px solid rgba(129,140,248,.07);
    border-bottom: 1px solid rgba(129,140,248,.07);
  }
  .netmap-in { max-width: 1200px; margin: 0 auto; }
  .netmap-hdr {
    display: flex; align-items: flex-end; justify-content: space-between;
    flex-wrap: wrap; gap: 16px; margin-bottom: 32px;
  }
  .netmap-legend { display: flex; gap: 20px; flex-wrap: wrap; align-items: center; }
  .leg-item { display: flex; align-items: center; gap: 7px; font-size: 11px; color: #475569; }
  .leg-ln { width: 20px; height: 2px; border-radius: 1px; }
  .netmap-box {
    height: 440px; position: relative;
    background: rgba(4,7,16,.92); border: 1px solid rgba(129,140,248,.1);
    border-radius: 20px; overflow: hidden;
  }
  #topo-canvas { position: absolute; inset: 0; width: 100%; height: 100%; cursor: crosshair; }
  .topo-tip {
    position: absolute; pointer-events: none; opacity: 0;
    background: rgba(8,14,28,.96); border: 1px solid rgba(129,140,248,.22);
    border-radius: 10px; padding: 10px 14px; z-index: 10;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    transition: opacity 120ms var(--ease); white-space: nowrap;
  }
  .topo-tip.vis { opacity: 1; }
  .tt-nm { font-size: 13px; font-weight: 600; color: #f1f5f9; margin-bottom: 3px; }
  .tt-sub { font-size: 11px; color: #64748b; }

  /* ── Activity ─────────────────────────────────── */
  .act-cols { display: grid; grid-template-columns: 1fr 340px; gap: 22px; align-items: start; }
  .act-panel {
    background: rgba(12,18,34,.72); border: 1px solid rgba(129,140,248,.09);
    border-radius: 16px; overflow: hidden;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  }
  .act-head {
    padding: 15px 18px; border-bottom: 1px solid rgba(129,140,248,.07);
    display: flex; align-items: center; justify-content: space-between;
  }
  .act-ttl { font-size: 12px; font-weight: 600; color: #94a3b8; display: flex; align-items: center; gap: 8px; }
  .feed { max-height: 340px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: rgba(129,140,248,.15) transparent; }
  .feed-row {
    display: flex; align-items: flex-start; gap: 11px;
    padding: 12px 18px; border-bottom: 1px solid rgba(255,255,255,.025);
  }
  .feed-ico {
    width: 26px; height: 26px; border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; flex-shrink: 0; font-family: ui-monospace,monospace;
  }
  .feed-msg { font-size: 12px; color: #cbd5e1; line-height: 1.4; margin-bottom: 2px; }
  .feed-t   { font-size: 10.5px; color: #475569; font-family: ui-monospace,monospace; }

  /* ── Stat sidebar ─────────────────────────────── */
  .stat-cards { display: flex; flex-direction: column; gap: 11px; }
  .s-card {
    background: rgba(12,18,34,.72); border: 1px solid rgba(129,140,248,.09);
    border-radius: 12px; padding: 15px 18px;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  }
  .s-lbl { font-size: 10px; color: #475569; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 6px; }
  .s-val { font-size: 26px; font-weight: 800; font-family: ui-monospace,'SF Mono',monospace; font-variant-numeric: tabular-nums; line-height: 1; }
  .s-tr  { font-size: 10.5px; margin-top: 4px; }

  /* ── 6-step section ───────────────────────────── */
  .steps-sec { padding: 80px 24px; }
  .steps-inner { max-width: 960px; margin: 0 auto; text-align: center; }
  .steps-h { font-size: clamp(24px,4vw,36px); font-weight: 700; color: #f1f5f9; margin: 0 0 14px; }
  .steps-sub { font-size: 15px; color: #64748b; line-height: 1.6; max-width: 560px; margin: 0 auto 48px; }
  .steps-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 40px;
  }
  .step-card {
    background: rgba(15,22,40,.7); border: 1px solid rgba(129,140,248,.10);
    border-radius: 16px; padding: 24px 20px; text-align: left; transition: border-color .2s;
  }
  .step-card:hover { border-color: rgba(129,140,248,.28); }
  .step-num {
    font-size: 11px; font-weight: 700; color: #818cf8; letter-spacing: .08em;
    margin-bottom: 10px; font-family: monospace;
  }
  .step-title { font-size: 15px; font-weight: 600; color: #e2e8f0; margin-bottom: 6px; }
  .step-desc { font-size: 13px; color: #64748b; line-height: 1.55; margin: 0; }
  .steps-cta { text-align: center; }
  .steps-btn { font-size: 15px; padding: 13px 32px; text-decoration: none; display: inline-block; }
  .steps-note { font-size: 12px; color: #475569; margin-top: 12px; }
  @media (max-width: 720px) { .steps-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .steps-grid { grid-template-columns: 1fr; } }

  /* ── CTA ──────────────────────────────────────── */
  .cta-sec { padding: 80px 24px; text-align: center; }
  .cta-box {
    max-width: 560px; margin: 0 auto;
    background: rgba(12,18,34,.65); border: 1px solid rgba(129,140,248,.14);
    border-radius: 24px; padding: 52px 36px;
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    position: relative; overflow: hidden;
  }
  .cta-glow {
    position: absolute; width: 280px; height: 280px;
    background: radial-gradient(circle,rgba(129,140,248,.07) 0%,transparent 70%);
    top: -90px; left: 50%; transform: translateX(-50%); pointer-events: none;
  }
  .cta-box h2 { font-size: 28px; font-weight: 700; color: #f1f5f9; margin-bottom: 12px; }
  .cta-box p  { font-size: 14px; color: #64748b; line-height: 1.6; margin-bottom: 28px; }

  /* ── Modal ────────────────────────────────────── */
  dialog {
    background: #0a0f1e; border: 1px solid rgba(129,140,248,.16);
    border-radius: 22px; padding: 0; width: min(900px,calc(100vw - 32px));
    color: #e2e8f0; max-height: calc(100vh - 48px); overflow: hidden;
    box-shadow: 0 32px 96px rgba(0,0,0,.7), 0 0 0 1px rgba(129,140,248,.06);
    display: flex; flex-direction: column;
    transform: scale(.96); opacity: 0;
    transition: transform 200ms var(--ease), opacity 200ms var(--ease);
  }
  dialog[open] { transform: scale(1); opacity: 1; }
  dialog::backdrop {
    background: rgba(3,6,14,.9); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  .m-head {
    padding: 20px 20px 16px; border-bottom: 1px solid rgba(129,140,248,.07);
    display: flex; align-items: center; gap: 12px;
  }
  .m-icon-wrap {
    width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 18px;
    background: rgba(129,140,248,.1); border: 1px solid rgba(129,140,248,.15);
  }
  .m-head-text { flex: 1; }
  .m-ttl { font-size: 15px; font-weight: 700; color: #f1f5f9; line-height: 1.2; }
  .m-sub { font-size: 11.5px; color: #475569; margin-top: 2px; }
  .m-cls {
    width: 28px; height: 28px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);
    border-radius: 7px; color: #64748b; cursor: pointer; font-size: 14px;
    display: flex; align-items: center; justify-content: center;
    transition: background 120ms, color 120ms, border-color 120ms;
  }
  .m-cls:hover { background: rgba(255,255,255,.08); color: #94a3b8; border-color: rgba(255,255,255,.12); }
  /* progress bar */
  .m-prog { height: 2px; background: rgba(129,140,248,.08); }
  .m-prog-fill { height: 100%; background: var(--pr); border-radius: 0 2px 2px 0; transition: width 300ms var(--ease); }
  .m-body { flex: 1; min-height: 0; display: flex; overflow: hidden; }
  /* step label */
  .step-label { font-size: 10.5px; color: #475569; letter-spacing: .1em; text-transform: uppercase; margin-bottom: 18px; display: flex; align-items: center; gap: 6px; }
  .step-label .step-num { width: 18px; height: 18px; border-radius: 50%; background: rgba(129,140,248,.15); border: 1px solid rgba(129,140,248,.2); color: var(--pr); font-size: 9.5px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
  /* fields */
  .mstep { display: none; }
  .mstep.act { display: block; animation: sfade 220ms var(--ease); }
  @keyframes sfade { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }
  .f-row { margin-bottom: 16px; }
  .f-lbl {
    display: flex; align-items: center; justify-content: space-between;
