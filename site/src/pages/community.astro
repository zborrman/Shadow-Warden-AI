---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="My Communities — Shadow Warden AI"
  description="Manage secure collaboration communities with end-to-end encrypted data tunnels."
>
  <section class="pt-28 pb-24 min-h-screen" style="background:#0a0a0f">
    <div class="mx-auto max-w-5xl px-4 lg:px-8">

      <!-- Header -->
      <div class="flex items-start justify-between mb-8 gap-4">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#06b6d4"></span>
            <span class="text-[11px] font-bold tracking-widest uppercase" style="color:#06b6d4">Community & Tunnel</span>
          </div>
          <h1 class="text-[clamp(28px,4vw,44px)] font-black tracking-tight mb-2" style="color:#f1f5f9">My Communities</h1>
          <p class="text-[15px]" style="color:#64748b">Secure collaboration spaces with end-to-end encrypted data tunnels</p>
        </div>
        <div class="flex gap-2 shrink-0">
          <button id="join-comm-btn"
             class="px-5 py-2.5 rounded-xl text-sm font-semibold transition-all"
             style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);color:#94a3b8;white-space:nowrap;cursor:pointer"
             onmouseover="this.style.background='rgba(255,255,255,0.08)'" onmouseout="this.style.background='rgba(255,255,255,0.04)'">
            Join Community
          </button>
          <a id="new-comm-btn" href="/community/new"
             class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white transition-all hover:opacity-90"
             style="background:linear-gradient(135deg,#06b6d4,#0e7490);white-space:nowrap">
            + New Community
          </a>
        </div>
      </div>

      <!-- Join modal -->
      <div id="join-modal" style="display:none;position:fixed;inset:0;z-index:999;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);align-items:center;justify-content:center">
        <div style="background:#0d1220;border:1px solid rgba(255,255,255,0.12);border-radius:20px;padding:32px;max-width:420px;width:90%;margin:auto">
          <p style="font-size:20px;font-weight:800;color:#f1f5f9;margin-bottom:6px">Join a Community</p>
          <p style="font-size:13px;color:#64748b;margin-bottom:20px">Enter the community code shared with you (format: COMM-XXXX)</p>
          <input id="join-input" type="text" placeholder="COMM-XXXX" maxlength="9"
                 style="width:100%;box-sizing:border-box;background:#0a0a12;border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:12px 14px;color:#f1f5f9;font-size:15px;font-family:monospace;font-weight:700;letter-spacing:0.05em;outline:none;margin-bottom:10px;transition:border-color 0.2s"
                 onfocus="this.style.borderColor='rgba(6,182,212,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
          <p id="join-err" style="color:#FF2D55;font-size:12px;margin-bottom:14px;display:none"></p>
          <p id="join-ok" style="color:#30D158;font-size:12px;margin-bottom:14px;display:none"></p>
          <div style="display:flex;gap:10px">
            <button id="join-cancel"
                    style="flex:1;padding:11px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:10px;color:#64748b;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.15s"
                    onmouseover="this.style.background='rgba(255,255,255,0.08)'" onmouseout="this.style.background='rgba(255,255,255,0.04)'">
              Cancel
            </button>
            <button id="join-confirm"
                    style="flex:2;padding:11px;background:linear-gradient(135deg,#06b6d4,#0e7490);border:none;border-radius:10px;color:white;font-size:13px;font-weight:700;cursor:pointer;transition:opacity 0.15s"
                    onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
              Join →
            </button>
          </div>
        </div>
      </div>

      <!-- User identity -->
      <div class="mb-8 flex items-center gap-3 px-4 py-3 rounded-xl"
           style="background:rgba(6,182,212,0.05);border:1px solid rgba(6,182,212,0.15)">
        <span style="font-size:22px">🛡️</span>
        <div>
          <p class="text-[10px] font-bold tracking-widest uppercase mb-1" style="color:#06b6d4">Your Identity</p>
          <p class="text-[13px] font-mono font-bold" style="color:#e2e8f0" id="my-user-id">Initializing…</p>
        </div>
        <div class="ml-auto flex items-center gap-4">
          <a href="/account" class="text-[12px] transition-colors"
             style="color:#64748b"
             onmouseover="this.style.color='#06b6d4'" onmouseout="this.style.color='#64748b'">
            Account settings →
          </a>
          <a href="/account/storage" class="text-[12px] transition-colors"
             style="color:#64748b"
             onmouseover="this.style.color='#06b6d4'" onmouseout="this.style.color='#64748b'">
            Storage
          </a>
        </div>
      </div>

      <!-- Tier banner -->
      <div id="tier-banner" class="mb-5 px-4 py-3 rounded-xl" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06)"></div>

      <!-- Communities grid -->
      <div id="communities-list">
        <p class="text-sm" style="color:#475569">Loading…</p>
      </div>
    </div>
  </section>

  <script>
    const COMM_KEY = 'sw_communities';
    const USER_KEY = 'sw_user_id';
    const TIER_KEY = 'sw_tier';

    const TIERS: Record<string, any> = {
      starter:           { name:'Starter',           color:'#64748b', maxComm:0,  obs:false, slack:false },
      individual:        { name:'Individual',         color:'#06b6d4', maxComm:1,  obs:false, slack:false },
      community_business:{ name:'Community Business', color:'#BF5AF2', maxComm:3,  obs:true,  slack:false },
      pro:               { name:'Pro',                color:'#FF8C42', maxComm:10, obs:true,  slack:true  },
      enterprise:        { name:'Enterprise',         color:'#FFD60A', maxComm:-1, obs:true,  slack:true  },
    };
    function getTier(): string { return localStorage.getItem(TIER_KEY) || 'pro'; }
    function getTC(): any { return TIERS[getTier()] || TIERS.pro; }

    function getOrCreateUserId(): string {
      let id = localStorage.getItem(USER_KEY);
      if (!id) {
        const bytes = crypto.getRandomValues(new Uint8Array(2));
        const hex = Array.from(bytes).map(b => b.toString(16).padStart(2, '0')).join('').toUpperCase();
        id = `USER-${hex}`;
        localStorage.setItem(USER_KEY, id);
      }
      return id;
    }

    function loadCommunities(): any[] {
      try { return JSON.parse(localStorage.getItem(COMM_KEY) || '[]'); } catch { return []; }
    }

    function esc(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function tunnelMsgCount(commId: string): number {
      try { return JSON.parse(localStorage.getItem(`sw_tunnel_${commId}`) || '[]').length; } catch { return 0; }
    }

    function render() {
      const uid = getOrCreateUserId();
      const uidEl = document.getElementById('my-user-id');
      if (uidEl) uidEl.textContent = uid;

      const tc = getTC();
      const comms = loadCommunities();
      const el = document.getElementById('communities-list');
      if (!el) return;

      // Tier banner
      const tierBanner = document.getElementById('tier-banner');
      if (tierBanner) {
        const used = comms.length;
        const max = tc.maxComm;
        const pct = max <= 0 ? (max === -1 ? 0 : 100) : Math.min(used / max * 100, 100);
        tierBanner.innerHTML = `
          <div style="display:flex;align-items:center;gap-12px;gap:12px;flex-wrap:wrap">
            <span style="padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;font-family:monospace;background:${tc.color}14;border:1px solid ${tc.color}35;color:${tc.color}">
              ${tc.name.toUpperCase()}
            </span>
            ${max === -1 ? `<span style="font-size:13px;color:#64748b">${used} communities (unlimited)</span>` :
              max === 0  ? `<span style="font-size:13px;color:#FF2D55">0 private communities on this plan</span>` :
              `<span style="font-size:13px;color:#64748b">${used} / ${max} communities used</span>`}
            ${max > 0 ? `
            <div style="flex:1;min-width:80px;max-width:160px;height:4px;border-radius:2px;background:#1e293b;overflow:hidden">
              <div style="height:100%;width:${pct}%;background:${pct >= 100 ? '#FF2D55' : tc.color};border-radius:2px;transition:width 0.5s"></div>
            </div>` : ''}
            <a href="/account" style="margin-left:auto;font-size:12px;color:#475569;text-decoration:none" onmouseover="this.style.color='#06b6d4'" onmouseout="this.style.color='#475569'">
              Change plan →
            </a>
          </div>`;
      }

      // At-limit banner
      const atLimit = tc.maxComm !== -1 && comms.length >= tc.maxComm;
      const newBtn = document.getElementById('new-comm-btn');
      if (newBtn) {
        if (atLimit) {
          newBtn.setAttribute('href', '/price');
          newBtn.textContent = tc.maxComm === 0 ? 'Upgrade to create' : '↑ Upgrade for more';
          (newBtn as HTMLElement).style.background = 'rgba(255,255,255,0.06)';
          (newBtn as HTMLElement).style.color = '#94a3b8';
        }
      }

      if (comms.length === 0) {
        el.innerHTML = `
          <div style="text-align:center;padding:80px 20px;border:1px dashed rgba(255,255,255,0.08);border-radius:20px">
            <div style="font-size:52px;margin-bottom:16px">🏛️</div>
            <p style="color:#e2e8f0;font-size:18px;font-weight:700;margin-bottom:8px">No communities yet</p>
            <p style="color:#475569;font-size:14px;margin-bottom:28px;line-height:1.65">
              Create your first secure collaboration space.<br>
              Each community gets a unique <code style="color:#06b6d4;font-family:monospace">COMM-XXXX</code> identifier.
            </p>
            <a href="/community/new" style="display:inline-block;padding:13px 32px;background:linear-gradient(135deg,#06b6d4,#0e7490);color:white;border-radius:12px;text-decoration:none;font-weight:700;font-size:14px">
              + Create First Community
            </a>
          </div>`;
        return;
      }

      el.innerHTML = `
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px">
          ${comms.map((c: any) => {
            const memberCount = (c.members || []).length;
            const msgCount = tunnelMsgCount(c.id);
            return `
            <div style="background:#0d1220;border:1px solid rgba(255,255,255,0.06);border-radius:16px;padding:20px;display:flex;flex-direction:column;gap:12px;transition:border-color 0.2s"
                 onmouseover="this.style.borderColor='rgba(6,182,212,0.25)'"
                 onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px">
                <div style="min-width:0">
                  <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
                    <p style="font-size:10px;font-family:monospace;color:#06b6d4;letter-spacing:0.05em;margin:0">${esc(c.id)}</p>
                    ${c.isJoined ? `<span style="padding:1px 6px;border-radius:4px;background:rgba(48,209,88,0.12);border:1px solid rgba(48,209,88,0.25);font-size:9px;font-weight:700;color:#30D158;font-family:monospace">JOINED</span>` : ''}
                  </div>
                  <h3 style="font-size:16px;font-weight:700;color:#f1f5f9;line-height:1.3;margin:0">${esc(c.name)}</h3>
                </div>
                <span style="padding:3px 10px;border-radius:20px;background:rgba(6,182,212,0.08);border:1px solid rgba(6,182,212,0.18);font-size:10px;font-weight:700;color:#06b6d4;font-family:monospace;white-space:nowrap;flex-shrink:0">
                  ${memberCount} member${memberCount !== 1 ? 's' : ''}
                </span>
              </div>
              ${c.description ? `<p style="font-size:13px;color:#64748b;line-height:1.55;margin:0">${esc(c.description)}</p>` : ''}
              <div style="display:flex;gap:8px">
                <a href="/community/view?id=${encodeURIComponent(c.id)}"
                   style="flex:1;text-align:center;padding:9px 8px;background:rgba(6,182,212,0.1);border:1px solid rgba(6,182,212,0.2);border-radius:10px;color:#06b6d4;text-decoration:none;font-size:12px;font-weight:600;transition:background 0.15s"
                   onmouseover="this.style.background='rgba(6,182,212,0.2)'" onmouseout="this.style.background='rgba(6,182,212,0.1)'">
                  Overview
                </a>
                <a href="/community/tunnel?id=${encodeURIComponent(c.id)}"
                   style="flex:1;text-align:center;padding:9px 8px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;color:#94a3b8;text-decoration:none;font-size:12px;font-weight:600;transition:background 0.15s"
                   onmouseover="this.style.background='rgba(255,255,255,0.07)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'">
                  🔒 Tunnel${msgCount > 0 ? ` (${msgCount})` : ''}
                </a>
                <a href="/community/members?id=${encodeURIComponent(c.id)}"
                   style="flex:1;text-align:center;padding:9px 8px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;color:#94a3b8;text-decoration:none;font-size:12px;font-weight:600;transition:background 0.15s"
                   onmouseover="this.style.background='rgba(255,255,255,0.07)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'">
                  Members
                </a>
              </div>
              <p style="font-size:11px;color:#334155;font-family:monospace;margin:0">
                Created ${new Date(c.created).toLocaleDateString()}
              </p>
            </div>`;
          }).join('')}
        </div>`;
    }

    render();

    // Join Community modal
    const joinModal = document.getElementById('join-modal') as HTMLElement;
    const joinInput = document.getElementById('join-input') as HTMLInputElement;
    const joinErr = document.getElementById('join-err') as HTMLElement;
    const joinOk = document.getElementById('join-ok') as HTMLElement;

    function showJoinModal() {
      joinInput.value = '';
      joinErr.style.display = 'none';
      joinOk.style.display = 'none';
      joinModal.style.display = 'flex';
      setTimeout(() => joinInput.focus(), 50);
    }
    function hideJoinModal() { joinModal.style.display = 'none'; }

    document.getElementById('join-comm-btn')?.addEventListener('click', showJoinModal);
    document.getElementById('join-cancel')?.addEventListener('click', hideJoinModal);
    joinModal.addEventListener('click', (e) => { if (e.target === joinModal) hideJoinModal(); });

    document.getElementById('join-confirm')?.addEventListener('click', () => {
      const code = joinInput.value.trim().toUpperCase();
      joinErr.style.display = 'none';
      joinOk.style.display = 'none';

      if (!code.match(/^COMM-[0-9A-F]{4}$/)) {
        joinErr.textContent = 'Format must be COMM-XXXX (e.g. COMM-1A2B)';
        joinErr.style.display = 'block';
        return;
      }

      const uid = getOrCreateUserId();
      const comms = loadCommunities();

      // Already in this community?
      const existing = comms.find((x: any) => x.id === code);
      if (existing) {
        if (!existing.members) existing.members = [];
        if (!existing.members.includes(uid)) {
          existing.members.push(uid);
          localStorage.setItem(COMM_KEY, JSON.stringify(comms));
          joinOk.textContent = `✓ Joined "${existing.name}" successfully!`;
        } else {
          joinOk.textContent = `✓ You're already a member of "${existing.name}".`;
        }
        joinOk.style.display = 'block';
        setTimeout(() => { hideJoinModal(); render(); }, 1400);
        return;
      }

      // Community not found locally — create a stub
      const stub = {
        id: code,
        name: `Community ${code}`,
        description: 'Joined via community code',
        members: [uid],
        created: new Date().toISOString(),
        isJoined: true,
      };
      comms.push(stub);
      localStorage.setItem(COMM_KEY, JSON.stringify(comms));
      joinOk.textContent = `✓ Joined ${code} — community added to your list.`;
      joinOk.style.display = 'block';
      setTimeout(() => { hideJoinModal(); render(); }, 1400);
    });

    joinInput?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') document.getElementById('join-confirm')?.click();
      if (e.key === 'Escape') hideJoinModal();
    });
  </script>
</BaseLayout>
