<script>
(function () {
  // Active link tracking via IntersectionObserver
  const sections = document.querySelectorAll<HTMLElement>('.doc-section, [id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.doc-nav-link, .toc-link');

  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const id = e.target.id;
      if (!id) return;
      navLinks.forEach(l => {
        const href = l.getAttribute('href') ?? '';
        l.classList.toggle('active', href === `#${id}`);
      });
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  document.querySelectorAll<HTMLElement>('[id]').forEach(el => obs.observe(el));
})();
</script>
