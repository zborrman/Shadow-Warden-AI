---
import BaseLayout from '../layouts/BaseLayout.astro';

const subprocessors = [
  {
    name: "Anthropic",
    service: "AI / LLM inference (Claude Opus, Sonnet, Haiku)",
    residency: "US",
    dpa: "https://www.anthropic.com/legal/privacy",
    gdpr: true,
    category: "AI Provider",
  },
  {
    name: "MinIO",
    service: "On-prem object storage — evidence vault, audit logs",
    residency: "Self-hosted (EU/US configurable)",
    dpa: "https://min.io/compliance",
    gdpr: true,
    category: "Storage",
  },
  {
    name: "Redis",
    service: "Session cache, rate-limit counters, pub/sub events",
    residency: "Self-hosted (same region as warden host)",
    dpa: "https://redis.io/legal/redis-software-subscription-agreement",
    gdpr: true,
    category: "Cache / Queue",
  },
  {
    name: "PostgreSQL",
    service: "Relational data store — tenants, billing, compliance records",
    residency: "Self-hosted (same region as warden host)",
    dpa: "https://www.postgresql.org/about/policies/",
    gdpr: true,
    category: "Database",
  },
  {
    name: "Hetzner Cloud",
    service: "VPS infrastructure — compute, network, block storage",
    residency: "EU (Germany / Finland)",
    dpa: "https://www.hetzner.com/legal/privacy-policy",
    gdpr: true,
    category: "Infrastructure",
  },
  {
    name: "Prometheus + Grafana",
    service: "Metrics collection and alerting dashboards",
    residency: "Self-hosted (same region as warden host)",
    dpa: "https://grafana.com/legal/privacy-policy/",
    gdpr: true,
    category: "Observability",
  },
];

const controls = [
  // Data Security
  { id: "DS-1", category: "Data Security", control: "Encryption at rest", status: "implemented", evidence: "Fernet AES-128 (VAULT_MASTER_KEY), MinIO SSE-S3", framework: ["SOC 2", "ISO 27001", "HIPAA"] },
  { id: "DS-2", category: "Data Security", control: "Encryption in transit", status: "implemented", evidence: "Caddy TLS 1.3, MASQUE H3/H2 sovereign tunnels", framework: ["SOC 2", "ISO 27001", "HIPAA"] },
  { id: "DS-3", category: "Data Security", control: "Key management process", status: "implemented", evidence: "warden/secrets_gov/ — HSM rotation, lifecycle, auto-retire", framework: ["SOC 2", "ISO 27001"] },
  { id: "DS-4", category: "Data Security", control: "Network and firewall access", status: "implemented", evidence: "Docker network isolation, Caddy reverse proxy, subnet allowlist", framework: ["SOC 2", "ISO 27001"] },
  { id: "DS-5", category: "Data Security", control: "Post-Quantum Cryptography", status: "implemented", evidence: "Ed25519+ML-DSA-65, X25519+ML-KEM-768 (liboqs, Enterprise)", framework: ["ISO 27001"] },
  // Product Security
  { id: "PS-1", category: "Product Security", control: "Secure SDLC", status: "implemented", evidence: "GitHub Actions CI — ruff/mypy/pytest/mutation on every PR", framework: ["SOC 2", "ISO 27001"] },
  { id: "PS-2", category: "Product Security", control: "Vulnerability scanning", status: "implemented", evidence: "intel_ops.py — OSV API CVE scan + ArXiv LLM-attack feed", framework: ["SOC 2", "ISO 27001"] },
  { id: "PS-3", category: "Product Security", control: "Change management", status: "implemented", evidence: "Versioned ROADMAP.md, semver releases, PR-gated merges", framework: ["SOC 2", "ISO 27001"] },
  { id: "PS-4", category: "Product Security", control: "Penetration testing", status: "partial", evidence: "Automated OWASP ZAP + nuclei pipeline (TC-02, in progress)", framework: ["SOC 2"] },
  { id: "PS-5", category: "Product Security", control: "Dependency auditing", status: "implemented", evidence: "GitHub Dependabot + OSV scanner in CI", framework: ["SOC 2", "ISO 27001"] },
  // Access Management
  { id: "AM-1", category: "Access Management", control: "Role-based access control", status: "implemented", evidence: "Per-tenant API keys + tier-gated feature flags (Starter→Enterprise)", framework: ["SOC 2", "ISO 27001"] },
  { id: "AM-2", category: "Access Management", control: "Multi-factor authentication", status: "implemented", evidence: "FIDO2 passkeys (warden/auth/fido.py)", framework: ["SOC 2", "ISO 27001"] },
  { id: "AM-3", category: "Access Management", control: "User access reviews", status: "implemented", evidence: "Secrets inventory with risk scoring + auto-retire (secrets_gov/)", framework: ["SOC 2", "ISO 27001"] },
  { id: "AM-4", category: "Access Management", control: "Fail-closed authentication", status: "implemented", evidence: "RuntimeError on startup if API keys unset unless ALLOW_UNAUTHENTICATED", framework: ["SOC 2"] },
  // Security & Continuity
  { id: "SC-1", category: "Security & Continuity", control: "Business continuity plan", status: "implemented", evidence: "Docker Compose healthchecks + resource limits, MinIO S3 failover", framework: ["SOC 2", "ISO 27001"] },
  { id: "SC-2", category: "Security & Continuity", control: "Incident response", status: "implemented", evidence: "WardenHealer autonomous anomaly detection + SOVA morning brief", framework: ["SOC 2", "ISO 27001"] },
  { id: "SC-3", category: "Security & Continuity", control: "Audit trail", status: "implemented", evidence: "STIX 2.1 tamper-evident SHA-256 chain (stix_audit.py)", framework: ["SOC 2", "ISO 27001", "HIPAA"] },
  { id: "SC-4", category: "Security & Continuity", control: "Data backup and restore", status: "implemented", evidence: "MinIO on-prem + S3, evidence vault, NDJSON log rotation", framework: ["SOC 2", "ISO 27001"] },
  // Organization Security
  { id: "OS-1", category: "Organization Security", control: "Risk assessment", status: "implemented", evidence: "CausalArbiter Bayesian DAG per request (causal_arbiter.py)", framework: ["SOC 2", "ISO 27001"] },
  { id: "OS-2", category: "Organization Security", control: "Vendor risk management", status: "implemented", evidence: "vendor_gov/ — DPA tracking, expiry alerts, supplier risk scoring", framework: ["ISO 27001", "GDPR"] },
  { id: "OS-3", category: "Organization Security", control: "Asset management", status: "implemented", evidence: "Secrets inventory SQLite + UECIID-tagged community assets", framework: ["ISO 27001"] },
  { id: "OS-4", category: "Organization Security", control: "Security awareness training", status: "implemented", evidence: "training_records.py — HMAC-SHA256 attested completions", framework: ["SOC 2", "ISO 27001"] },
  // Endpoint Security
  { id: "ES-1", category: "Endpoint Security", control: "Shadow AI detection (EDR for AI)", status: "implemented", evidence: "ShadowAIDetector — async subnet probe, 18-provider fingerprint DB", framework: ["ISO 27001"] },
  { id: "ES-2", category: "Endpoint Security", control: "Disk encryption", status: "partial", evidence: "Delegated to host OS; SOVA tool #68 reports status (TC-03)", framework: ["ISO 27001"] },
  { id: "ES-3", category: "Endpoint Security", control: "Threat and malware protection", status: "implemented", evidence: "PhishGuard + SE-Arbiter + VoiceGuardian deepfake detection", framework: ["SOC 2", "ISO 27001"] },
  { id: "ES-4", category: "Endpoint Security", control: "Endpoint policy enforcement", status: "implemented", evidence: "ShadowAIPolicy MONITOR/BLOCK_DENYLIST/ALLOWLIST_ONLY per tenant", framework: ["ISO 27001"] },
  // GDPR
  { id: "GD-1", category: "GDPR", control: "Content never logged", status: "implemented", evidence: "Only metadata logged (type, length, timing) — enforced in analytics/logger.py", framework: ["GDPR"] },
  { id: "GD-2", category: "GDPR", control: "Data subject rights (Art. 17)", status: "implemented", evidence: "GDPR scrub API + ARQ cron purge_before()", framework: ["GDPR"] },
  { id: "GD-3", category: "GDPR", control: "Data Protection Impact Assessment", status: "implemented", evidence: "docs/dpia.md — GDPR Art. 35 DPIA", framework: ["GDPR"] },
  { id: "GD-4", category: "GDPR", control: "Cross-border transfer controls", status: "implemented", evidence: "Sovereign routing engine — 8 jurisdictions, adequacy decisions, transfer rules matrix", framework: ["GDPR"] },
];

const categories = [...new Set(controls.map(c => c.category))];

const reports = [
  { name: "SOC 2 Type II Evidence Bundle", format: "ZIP", endpoint: "/compliance/evidence/generate", tier: "Pro+" },
  { name: "ISO 27001:2022 Control Report", format: "HTML/JSON", endpoint: "/compliance/iso27001/report", tier: "Enterprise" },
  { name: "GDPR DPIA", format: "PDF", path: "/docs/dpia.md", tier: "All" },
  { name: "Compliance Posture Export", format: "JSON", endpoint: "/compliance/posture", tier: "Pro+" },
  { name: "STIX 2.1 Audit Chain Export", format: "JSONL", endpoint: "/sep/audit-chain/{id}/export", tier: "Pro+" },
];
---

<BaseLayout>

<!-- Hero -->
<section class="pt-20 pb-12 text-center" style="background:radial-gradient(ellipse 70% 40% at 50% 0%,rgba(128,180,253,0.06) 0%,transparent 70%)">
  <div class="mx-auto max-w-3xl px-4">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold mb-6"
         style="background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.25);color:#34d399">
      <span style="width:6px;height:6px;border-radius:50%;background:#34d399;display:inline-block"></span>
      All Systems Operational
    </div>
    <h1 class="text-4xl font-bold mb-4" style="color:#f0f4fc">Shadow Warden AI Trust Center</h1>
    <p class="text-lg" style="color:#a8b8d0">
      Transparency into how we secure your data, protect your AI pipelines,
      and maintain compliance with GDPR, SOC 2, ISO 27001, and HIPAA.
    </p>
  </div>
</section>

<!-- Score cards -->
<section class="mx-auto max-w-5xl px-4 pb-10">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    {[
      { label: "SOC 2 Type II", score: "94%", color: "#34d399", note: "5 controls active" },
      { label: "ISO 27001:2022", score: "92%", color: "#80b4fd", note: "93 Annex A controls" },
      { label: "GDPR", score: "98%", color: "#38bdf8", note: "Art. 5 / 17 / 28 / 35" },
      { label: "HIPAA", score: "89%", color: "#a78bfa", note: "4 safeguard areas" },
    ].map(s => (
      <div class="rounded-xl p-5 text-center" style="background:#111827;border:1px solid rgba(128,180,253,0.09)">
        <p class="text-3xl font-bold mb-1" style={`color:${s.color}`}>{s.score}</p>
        <p class="text-sm font-semibold mb-1" style="color:#f0f4fc">{s.label}</p>
        <p class="text-xs" style="color:#6b7c96">{s.note}</p>
      </div>
    ))}
  </div>
</section>

<!-- Tab navigation -->
<section class="mx-auto max-w-5xl px-4 pb-16">
  <div class="flex gap-1 mb-8 p-1 rounded-xl" style="background:#111827;border:1px solid rgba(128,180,253,0.09);width:fit-content">
    {["Overview", "Controls", "Subprocessors", "Reports"].map((tab, i) => (
      <button
        class="trust-tab px-5 py-2 rounded-lg text-sm font-medium transition-all"
        data-tab={tab.toLowerCase()}
        style={i === 0
          ? "background:#1a2236;color:#f0f4fc;border:1px solid rgba(128,180,253,0.15)"
          : "background:transparent;color:#6b7c96;border:1px solid transparent"}
      >{tab}</button>
    ))}
  </div>

  <!-- Overview tab -->
  <div id="tab-overview" class="trust-panel">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="rounded-xl p-6" style="background:#111827;border:1px solid rgba(128,180,253,0.09)">
        <h2 class="text-lg font-semibold mb-4" style="color:#f0f4fc">Security Architecture</h2>
        <div class="space-y-3">
          {[
            { layer: "14-layer AI defense pipeline", detail: "TDA topology → Obfuscation → Secrets → Semantic → Brain → Causal → Phish → ERS → Decision" },
            { layer: "Zero-trust per-request auth", detail: "Per-tenant API keys, constant-time compare, fail-closed at startup" },
            { layer: "Post-quantum cryptography", detail: "Ed25519+ML-DSA-65 signatures, X25519+ML-KEM-768 KEM (Enterprise)" },
            { layer: "Autonomous threat response", detail: "WardenHealer + SOVA agent — detect, classify, remediate without human intervention" },
            { layer: "GDPR-by-design", detail: "Content never logged; only metadata; right-to-erasure ARQ cron; Art. 35 DPIA on file" },
          ].map(item => (
            <div class="flex gap-3">
              <span class="mt-0.5 flex-shrink-0" style="color:#34d399">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <div>
                <p class="text-sm font-medium" style="color:#f0f4fc">{item.layer}</p>
                <p class="text-xs mt-0.5" style="color:#6b7c96">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-xl p-6" style="background:#111827;border:1px solid rgba(128,180,253,0.09)">
        <h2 class="text-lg font-semibold mb-4" style="color:#f0f4fc">Certifications & Standards</h2>
        <div class="space-y-4">
          {[
            { name: "SOC 2 Type II", status: "In Progress", color: "#fbbf24", detail: "Evidence collection active · Annual audit cycle" },
            { name: "ISO 27001:2022", status: "Implemented", color: "#34d399", detail: "93 Annex A controls mapped · Enterprise tier" },
            { name: "GDPR", status: "Compliant", color: "#34d399", detail: "DPIA on file · DPA with all subprocessors · Art. 5/17/28/35" },
            { name: "HIPAA", status: "Implemented", color: "#34d399", detail: "PHI data-class enforcement · Fernet encryption · STIX audit" },
            { name: "OWASP LLM Top 10", status: "Covered", color: "#34d399", detail: "Full LLM01–LLM10 coverage per docs/security-model.md" },
          ].map(cert => (
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-medium" style="color:#f0f4fc">{cert.name}</p>
                <p class="text-xs mt-0.5" style="color:#6b7c96">{cert.detail}</p>
              </div>
              <span class="flex-shrink-0 text-xs font-semibold px-2.5 py-0.5 rounded-full"
                    style={`color:${cert.color};background:${cert.color}18;border:1px solid ${cert.color}35`}>
                {cert.status}
              </span>
            </div>
          ))}
        </div>
      </div>

      <div class="md:col-span-2 rounded-xl p-6" style="background:#111827;border:1px solid rgba(128,180,253,0.09)">
        <h2 class="text-lg font-semibold mb-4" style="color:#f0f4fc">Data Handling Principles</h2>
        <div class="grid sm:grid-cols-3 gap-6">
          {[
            { icon: "🔒", title: "Zero Content Logging", body: "Prompt and response content is NEVER stored. Only metadata (type, length, timing) enters our logs — enforced at the analytics layer." },
            { icon: "🌍", title: "Sovereign Routing", body: "Data stays in your jurisdiction. The sovereign routing engine enforces 8-jurisdiction transfer rules, adequacy decisions, and PHI restrictions." },
            { icon: "🗑️", title: "Right to Erasure", body: "GDPR Art. 17 erasure runs as an ARQ cron. Request-level purge available via API. Data minimisation enforced pipeline-wide." },
          ].map(p => (
            <div>
              <p class="text-2xl mb-2">{p.icon}</p>
              <p class="text-sm font-semibold mb-1" style="color:#f0f4fc">{p.title}</p>
              <p class="text-xs leading-relaxed" style="color:#6b7c96">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Controls tab -->
  <div id="tab-controls" class="trust-panel hidden">
    <div class="mb-6 flex flex-wrap gap-2">
      <button class="ctrl-filter active text-xs px-3 py-1.5 rounded-full font-medium transition-all"
              data-filter="all"
              style="background:#1a2236;color:#80b4fd;border:1px solid rgba(128,180,253,0.25)">All</button>
      {categories.map(cat => (
        <button class="ctrl-filter text-xs px-3 py-1.5 rounded-full font-medium transition-all"
                data-filter={cat}
                style="background:transparent;color:#6b7c96;border:1px solid rgba(128,180,253,0.09)">
          {cat}
        </button>
      ))}
    </div>

    <div class="overflow-x-auto rounded-xl" style="border:1px solid rgba(128,180,253,0.09)">
      <table class="w-full text-sm">
        <thead>
          <tr style="background:#111827;border-bottom:1px solid rgba(128,180,253,0.09)">
            <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider" style="color:#6b7c96">ID</th>
            <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider" style="color:#6b7c96">Category</th>
            <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider" style="color:#6b7c96">Control</th>
            <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider" style="color:#6b7c96">Status</th>
            <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider" style="color:#6b7c96">Evidence</th>
            <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider" style="color:#6b7c96">Frameworks</th>
          </tr>
        </thead>
        <tbody>
          {controls.map((c, i) => (
            <tr class="ctrl-row border-b transition-colors hover:bg-white/2"
                data-category={c.category}
                style={`border-color:rgba(128,180,253,0.06);background:${i % 2 === 0 ? '#0c1020' : '#070910'}`}>
              <td class="px-4 py-3 font-mono text-xs" style="color:#6b7c96">{c.id}</td>
              <td class="px-4 py-3 text-xs" style="color:#a8b8d0">{c.category}</td>
              <td class="px-4 py-3 text-xs font-medium" style="color:#f0f4fc">{c.control}</td>
              <td class="px-4 py-3">
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full"
                      style={c.status === 'implemented'
                        ? 'color:#34d399;background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.2)'
                        : 'color:#fbbf24;background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2)'}>
                  {c.status === 'implemented' ? 'Implemented' : 'Partial'}
                </span>
              </td>
              <td class="px-4 py-3 text-xs" style="color:#6b7c96;max-width:280px">{c.evidence}</td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-1">
                  {c.framework.map(f => (
                    <span class="text-xs px-1.5 py-0.5 rounded"
                          style="color:#80b4fd;background:rgba(128,180,253,0.08)">
                      {f}
                    </span>
                  ))}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Subprocessors tab -->
  <div id="tab-subprocessors" class="trust-panel hidden">
    <p class="text-sm mb-6" style="color:#a8b8d0">
      Shadow Warden AI acts as a Data Processor under GDPR Art. 28. The following sub-processors
      may process data on your behalf. A Data Processing Agreement (DPA) is in place with each.
      Last updated: <span style="color:#f0f4fc">2026-06-18</span>.
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {subprocessors.map(sp => (
        <div class="rounded-xl p-5" style="background:#111827;border:1px solid rgba(128,180,253,0.09)">
          <div class="flex items-start justify-between mb-3">
            <div>
              <p class="font-semibold text-sm" style="color:#f0f4fc">{sp.name}</p>
              <p class="text-xs mt-0.5" style="color:#6b7c96">{sp.category}</p>
            </div>
            {sp.gdpr && (
              <span class="text-xs font-semibold px-2 py-0.5 rounded-full flex-shrink-0"
                    style="color:#34d399;background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.2)">
                GDPR ✓
              </span>
            )}
          </div>
          <p class="text-xs mb-3 leading-relaxed" style="color:#a8b8d0">{sp.service}</p>
          <div class="flex items-center gap-2 text-xs" style="color:#6b7c96">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            {sp.residency}
          </div>
          <a href={sp.dpa} target="_blank" rel="noopener"
             class="mt-3 inline-flex items-center gap-1 text-xs transition-colors hover:underline"
             style="color:#80b4fd">
            View DPA
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      ))}
    </div>

    <div class="mt-8 rounded-xl p-5" style="background:rgba(128,180,253,0.04);border:1px solid rgba(128,180,253,0.12)">
      <p class="text-sm font-semibold mb-1" style="color:#80b4fd">Data Residency Guarantee</p>
      <p class="text-xs leading-relaxed" style="color:#a8b8d0">
        All sub-processors that handle EU personal data are covered by Standard Contractual Clauses (SCCs)
        or operate within adequacy-decision jurisdictions. The Sovereign Routing Engine ensures
        PHI and CLASSIFIED data never leaves the configured jurisdiction.
        Classified data transfer is hardcoded to <code style="color:#80b4fd">BLOCKED</code> in
        <code style="color:#80b4fd">warden/sovereign/jurisdictions.py</code>.
      </p>
    </div>
  </div>

  <!-- Reports tab -->
  <div id="tab-reports" class="trust-panel hidden">
    <p class="text-sm mb-6" style="color:#a8b8d0">
      Download compliance evidence packages, audit reports, and security documentation.
      Report generation requires an active API key and the appropriate subscription tier.
    </p>

    <div class="space-y-3">
      {reports.map(r => (
        <div class="flex items-center justify-between p-4 rounded-xl"
             style="background:#111827;border:1px solid rgba(128,180,253,0.09)">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                 style="background:rgba(128,180,253,0.08)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#80b4fd" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium" style="color:#f0f4fc">{r.name}</p>
              <p class="text-xs mt-0.5" style="color:#6b7c96">Format: {r.format} · Tier: {r.tier}</p>
            </div>
          </div>
          <a href={`https://api.shadow-warden-ai.com${r.endpoint ?? r.path}`}
             target="_blank" rel="noopener"
             class="flex items-center gap-2 text-xs font-medium px-4 py-2 rounded-lg transition-all"
             style="background:rgba(128,180,253,0.08);color:#80b4fd;border:1px solid rgba(128,180,253,0.15)">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download
          </a>
        </div>
      ))}
    </div>

    <div class="mt-8 rounded-xl p-5" style="background:#111827;border:1px solid rgba(128,180,253,0.09)">
      <p class="text-sm font-semibold mb-3" style="color:#f0f4fc">Request a Custom Audit Package</p>
      <p class="text-xs mb-4" style="color:#a8b8d0">
        Enterprise customers can request a tailored evidence bundle including penetration test results,
        STIX chain exports, and ISO 27001 control evidence mapped to your specific audit requirements.
      </p>
      <a href="/contact"
         class="inline-flex items-center gap-2 text-sm font-medium px-5 py-2.5 rounded-lg"
         style="background:linear-gradient(135deg,#80b4fd,#38bdf8);color:#070910">
        Contact Security Team
      </a>
    </div>
  </div>
</section>

<script>
  // Tab switching
  const tabs   = document.querySelectorAll<HTMLButtonElement>('.trust-tab');
  const panels = document.querySelectorAll<HTMLElement>('.trust-panel');

  function activateTab(name: string) {
    tabs.forEach(t => {
      const active = t.dataset.tab === name;
      t.style.background = active ? '#1a2236' : 'transparent';
      t.style.color      = active ? '#f0f4fc' : '#6b7c96';
      t.style.border     = active ? '1px solid rgba(128,180,253,0.15)' : '1px solid transparent';
    });
    panels.forEach(p => {
      p.classList.toggle('hidden', p.id !== `tab-${name}`);
    });
  }

  tabs.forEach(t => t.addEventListener('click', () => activateTab(t.dataset.tab!)));

  // Controls filter
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.ctrl-filter');
  const ctrlRows   = document.querySelectorAll<HTMLElement>('.ctrl-row');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      filterBtns.forEach(b => {
        const active = b.dataset.filter === filter;
        b.style.background = active ? '#1a2236' : 'transparent';
        b.style.color      = active ? '#80b4fd' : '#6b7c96';
        b.style.border     = active ? '1px solid rgba(128,180,253,0.25)' : '1px solid rgba(128,180,253,0.09)';
      });
      ctrlRows.forEach(row => {
        const show = filter === 'all' || row.dataset.category === filter;
        row.style.display = show ? '' : 'none';
      });
    });
  });

  // Restore tab from URL hash
  const hash = location.hash.replace('#', '');
  if (['overview','controls','subprocessors','reports'].includes(hash)) {
    activateTab(hash);
  }
</script>

</BaseLayout>
