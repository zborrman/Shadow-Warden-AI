---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    name: 'AI Filter Pipeline',
    controls: [
      'Topological jailbreak detection (Betti numbers β₀/β₁) implemented',
      'Obfuscation decoding (base64, hex, ROT13, homoglyphs) implemented',
      'Secret and PII redaction (15 regex patterns + entropy scan) implemented',
      'Semantic rule engine with compound risk escalation implemented',
      'ML semantic guard (MiniLM + Poincaré hyperbolic blend) implemented',
      'Causal Bayesian arbitration (Pearl do-calculus) implemented',
      'Phishing and social engineering detection implemented',
      'Elastic Rate Scoring with differentiated shadow ban implemented',
      'Progressive streaming fast-scan (400-char live-emit buffer) implemented',
    ],
  },
  {
    name: 'Data Security',
    controls: [
      'Encryption at rest (Fernet AES-128-CBC, HMAC-SHA256 reverse map) implemented',
      'Encryption in transit (TLS 1.3 via Cloudflare QUIC/HTTP3) implemented',
      'GDPR-compliant content never logged — metadata only implemented',
      'Post-Quantum Cryptography (ML-DSA-65 + ML-KEM-768 hybrid) implemented',
      'Cryptographic audit trail (SHA-256 hash chain, SQLite WAL) implemented',
      'STIX 2.1 tamper-evident transfer audit chain implemented',
      'Atomic file writes (tempfile + os.replace) to prevent corruption implemented',
    ],
  },
  {
    name: 'Access Management',
    controls: [
      'Per-tenant API key management (JSON multi-key + SHA-256 hash) implemented',
      'Constant-time key comparison (timing-attack resistant) implemented',
      'Fail-closed authentication at startup implemented',
      'Multi-tenant workload isolation implemented',
      'HMAC-SHA256 task token binding (cross-agent injection prevention) implemented',
      'Role-based community membership (Owner, Admin, Member) implemented',
      'Human-in-the-loop approval gate for high-impact actions implemented',
    ],
  },
  {
    name: 'Compliance & Privacy',
    controls: [
      'GDPR Article 35 Data Protection Impact Assessment conducted',
      'SOC 2 Type II evidence collection and control mapping implemented',
      'ISO 27001:2022 full 93-control mapping with theme coverage implemented',
      'Continuous compliance posture scoring (GDPR/SOC2/ISO/HIPAA) implemented',
      'GDPR data purge API and ARQ cron scrub job implemented',
      'Causal Transfer Guard (exfiltration risk blocked at P ≥ 0.70) implemented',
      'Sovereignty attestation (HMAC-SHA256, 7-year Redis TTL) implemented',
    ],
  },
  {
    name: 'Agentic SOC',
    controls: [
      'SOVA autonomous AI operator (30 tools, Claude Opus, ≤10 iterations) implemented',
      'MasterAgent multi-agent SOC coordinator (4 sub-agents) implemented',
      'WardenHealer autonomous anomaly detection (OLS trend, Haiku triage) implemented',
      'Agent injection chain detection with cryptographic attestation implemented',
      'Visual patrol (ScreencastRecorder + Claude Vision → MinIO) implemented',
      'Scheduled SOC jobs (morning brief, threat sync, rotation check) implemented',
    ],
  },
  {
    name: 'Infrastructure Security',
    controls: [
      'Cloudflare Zero Trust tunnel (QUIC/HTTP3, TOFU TLS pinning) implemented',
      'Docker non-root user (UID/GID 10001, MCR Playwright base) implemented',
      'Redis sliding window rate limiting (socket timeout hardened) implemented',
      'Prometheus metrics + Grafana SLO alerts (P99, 5xx, availability) implemented',
      'MinIO on-premises object store (no third-party data exfiltration) implemented',
      '30-second graceful shutdown for in-flight requests implemented',
    ],
  },
  {
    name: 'Threat Intelligence',
    controls: [
      'ArXiv LLM-attack paper monitoring with auto-synthesis implemented',
      'Evolution Engine (Claude Opus auto-rule generation + ReDoS gate) implemented',
      'CVE dependency scanner (OSV API, real-time advisories) implemented',
      'Shadow AI discovery (18 providers, /24 subnet probe, DNS telemetry) implemented',
      'Intel Bridge (ArXiv to Evolution sync, configurable interval) implemented',
    ],
  },
  {
    name: 'Vendor & Document Security',
    controls: [
      'AI Vendor Governance Register with DPA tracking and expiry alerts implemented',
      'Supplier AI risk composite scoring (5-criteria, peering-based) implemented',
      'Prompt library injection screening via filter pipeline before save implemented',
      'Document intelligence (SHA-256 Redis cache, 50 MB gate, 30s timeout) implemented',
      'Employee AI training records with HMAC-SHA256 attestation implemented',
    ],
  },
];

const subprocessors = [
  { name: 'Anthropic', purpose: 'AI model inference (SOVA, Evolution Engine, visual patrol)', region: 'US', type: 'AI Provider' },
  { name: 'Cloudflare', purpose: 'Zero Trust tunnel, CDN, DDoS protection', region: 'Global', type: 'Network' },
  { name: 'Hetzner Cloud', purpose: 'VPS infrastructure hosting', region: 'EU (Germany)', type: 'Infrastructure' },
  { name: 'MinIO', purpose: 'On-premises S3-compatible object storage (self-hosted)', region: 'On-prem', type: 'Storage' },
  { name: 'Redis', purpose: 'Rate limiting, session memory, cache (self-hosted)', region: 'On-prem', type: 'Cache' },
  { name: 'PostgreSQL', purpose: 'Relational database (self-hosted)', region: 'On-prem', type: 'Database' },
];

const reports = [
  { name: 'GDPR Art. 35 DPIA', description: 'Data Protection Impact Assessment covering all processing activities', href: '/doc/compliance', badge: 'GDPR' },
  { name: 'SOC 2 Type II Evidence Guide', description: 'Control mapping, auditor collection procedures, evidence bundles', href: '/doc/compliance', badge: 'SOC 2' },
  { name: 'ISO 27001:2022 Control Matrix', description: '93 controls across Organizational, People, Physical, Technological themes', href: '/doc/compliance', badge: 'ISO 27001' },
  { name: 'Security Model', description: '9-layer defense model, OWASP LLM Top 10 coverage, full threat model', href: '/doc/compliance', badge: 'Security' },
  { name: 'SLA Document', description: 'Pro 99.9% / Enterprise 99.95% uptime, P99 < 50ms, incident response', href: '/doc/compliance', badge: 'SLA' },
  { name: 'OpenAPI Specification', description: 'Full API reference — 562 endpoints, v5.6.0', href: '/doc/api-reference', badge: 'API' },
];

const totalControls = categories.reduce((s, c) => s + c.controls.length, 0);
---

<BaseLayout
  title="Trust Center — Shadow Warden AI"
  description="Shadow Warden AI security controls, compliance posture, subprocessors, and audit reports. SOC 2 · GDPR · ISO 27001 · Post-Quantum."
>
  <div class="trust-root" style="padding-top:56px">

    <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
    <div class="trust-hero">
      <div class="trust-hero-inner">
        <div class="trust-logo">
          <img src="/logo.png" alt="Shadow Warden AI" width="40" height="40" />
        </div>
        <h1 class="trust-h1">Shadow Warden AI Trust Center</h1>
        <p class="trust-sub">
          Security controls, compliance posture, and audit reports for the GDPR-compliant AI security gateway.
        </p>
        <div class="trust-kpis">
          <div class="trust-kpi">
            <span class="trust-kpi-n">{totalControls}</span>
            <span class="trust-kpi-l">Security Controls</span>
          </div>
          <div class="trust-kpi-div"></div>
          <div class="trust-kpi">
            <span class="trust-kpi-n">4</span>
            <span class="trust-kpi-l">Compliance Frameworks</span>
          </div>
          <div class="trust-kpi-div"></div>
          <div class="trust-kpi">
            <span class="trust-kpi-n">9</span>
            <span class="trust-kpi-l">Pipeline Layers</span>
          </div>
          <div class="trust-kpi-div"></div>
          <div class="trust-kpi">
            <span class="trust-kpi-n">&lt;2ms</span>
            <span class="trust-kpi-l">Filter Latency</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Tab bar ────────────────────────────────────────────────────────────── -->
    <div class="trust-tabbar-wrap">
      <div class="trust-tabbar">
        <button class="trust-tab active" data-tab="overview">Overview</button>
        <button class="trust-tab" data-tab="controls">Controls</button>
        <button class="trust-tab" data-tab="subprocessors">Subprocessors</button>
        <button class="trust-tab" data-tab="reports">Reports &amp; Documents</button>
      </div>
    </div>

    <!-- ── Tab: Overview ─────────────────────────────────────────────────────── -->
    <div id="tab-overview" class="trust-panel active">
      <div class="trust-grid">
        {categories.map(cat => (
          <div class="trust-card">
            <div class="trust-card-head">
              <span class="trust-cat-name">{cat.name}</span>
              <span class="trust-cat-pipe">|</span>
              <span class="trust-cat-count">{cat.controls.length} Controls</span>
            </div>
            <ul class="trust-ctrl-list">
              {cat.controls.slice(0, 4).map(ctrl => (
                <li class="trust-ctrl">
                  <span class="trust-check" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <circle cx="8" cy="8" r="8" fill="rgba(16,185,129,0.15)"/>
                      <path d="M5 8.5l2 2 4-4" stroke="#10b981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span class="trust-ctrl-text">{ctrl.replace(' implemented', '').replace(' conducted', '')}</span>
                </li>
              ))}
              {cat.controls.length > 4 && (
                <li class="trust-more">+{cat.controls.length - 4} more controls</li>
              )}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Tab: Controls ─────────────────────────────────────────────────────── -->
    <div id="tab-controls" class="trust-panel">
      <div class="trust-panel-inner">
        {categories.map(cat => (
          <div class="trust-ctrl-section">
            <div class="trust-ctrl-section-head">
              <h2 class="trust-ctrl-section-title">{cat.name}</h2>
              <span class="trust-ctrl-badge">{cat.controls.length}</span>
            </div>
            <div class="trust-ctrl-rows">
              {cat.controls.map(ctrl => (
                <div class="trust-ctrl-row">
                  <span class="trust-check">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <circle cx="8" cy="8" r="8" fill="rgba(16,185,129,0.15)"/>
                      <path d="M5 8.5l2 2 4-4" stroke="#10b981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span class="trust-ctrl-row-text">{ctrl}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Tab: Subprocessors ────────────────────────────────────────────────── -->
    <div id="tab-subprocessors" class="trust-panel">
      <div class="trust-panel-inner">
        <p class="trust-section-desc">
          Shadow Warden AI processes all data on-premises by default. The following third-party services
          are used only for the specific functions listed below.
        </p>
        <div class="trust-table-wrap">
          <table class="trust-table">
            <thead>
              <tr>
                <th>Subprocessor</th>
                <th>Purpose</th>
                <th>Data Region</th>
                <th>Type</th>
              </tr>
            </thead>
            <tbody>
              {subprocessors.map(sp => (
                <tr>
                  <td class="trust-table-name">{sp.name}</td>
                  <td class="trust-table-purpose">{sp.purpose}</td>
                  <td>
                    <span class={`trust-region-badge ${sp.region.startsWith('EU') ? 'eu' : sp.region === 'On-prem' ? 'onprem' : ''}`}>
                      {sp.region}
                    </span>
                  </td>
                  <td><span class="trust-type-badge">{sp.type}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="trust-onprem-note">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:1px">
            <circle cx="8" cy="8" r="7" stroke="#6366f1" stroke-width="1.5"/>
            <path d="M8 7v4M8 5h.01" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>MinIO, Redis, and PostgreSQL run entirely on your infrastructure. No data ever leaves your environment for these services. Anthropic API calls are the only external LLM traffic and can be disabled for air-gapped deployments.</span>
        </div>
      </div>
    </div>

    <!-- ── Tab: Reports ──────────────────────────────────────────────────────── -->
    <div id="tab-reports" class="trust-panel">
      <div class="trust-panel-inner">
        <div class="trust-reports-grid">
          {reports.map(r => (
            <a href={r.href} class="trust-report-card">
              <div class="trust-report-top">
                <span class="trust-report-badge">{r.badge}</span>
              </div>
              <h3 class="trust-report-name">{r.name}</h3>
              <p class="trust-report-desc">{r.description}</p>
              <span class="trust-report-link">
                View document
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
        <div class="trust-report-cta">
          <p>Need a custom audit package or evidence bundle for your security review?</p>
          <a href="mailto:security@shadow-warden-ai.com" class="trust-cta-btn">Request Audit Package</a>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .trust-root {
    min-height: 100vh;
    background: #0b0d14;
    color: #e2e8f0;
  }

  /* Hero */
  .trust-hero {
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background: #0e1018;
  }
  .trust-hero-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 64px 24px 48px;
    text-align: center;
  }
  .trust-logo {
    width: 56px;
    height: 56px;
    margin: 0 auto 20px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .trust-logo img { width: 100%; height: 100%; object-fit: contain; }
  .trust-h1 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #f1f5f9;
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }
  .trust-sub {
    font-size: 15px;
    color: #94a3b8;
    max-width: 520px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }
  .trust-kpis {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    row-gap: 20px;
  }
  .trust-kpi {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 28px;
  }
  .trust-kpi-n {
    font-size: 28px;
    font-weight: 800;
    color: #f1f5f9;
    letter-spacing: -0.03em;
  }
  .trust-kpi-l {
    font-size: 11px;
    font-weight: 500;
    color: #475569;
    margin-top: 2px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .trust-kpi-div {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.08);
  }

  /* Tab bar */
  .trust-tabbar-wrap {
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background: #0e1018;
    position: sticky;
    top: 56px;
    z-index: 40;
  }
  .trust-tabbar {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
  }
  .trust-tab {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: #64748b;
    font-size: 13.5px;
    font-weight: 500;
    padding: 14px 20px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .trust-tab:hover { color: #cbd5e1; }
  .trust-tab.active {
    color: #f1f5f9;
    border-bottom-color: #6366f1;
  }

  /* Panels */
  .trust-panel { display: none; }
  .trust-panel.active { display: block; }
  .trust-panel-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  /* Overview grid */
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(460px, 1fr));
    gap: 16px;
    max-width: 1120px;
    margin: 0 auto;
    padding: 32px 24px 80px;
  }
  .trust-card {
    background: #111420;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 24px;
    transition: border-color 0.15s;
  }
  .trust-card:hover { border-color: rgba(99,102,241,0.3); }
  .trust-card-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .trust-cat-name {
    font-size: 14px;
    font-weight: 600;
    color: #f1f5f9;
  }
  .trust-cat-pipe { color: rgba(255,255,255,0.2); font-size: 14px; }
  .trust-cat-count {
    font-size: 13px;
    color: #6366f1;
    font-weight: 500;
  }
  .trust-ctrl-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .trust-ctrl {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .trust-check { flex-shrink: 0; margin-top: 1px; }
  .trust-ctrl-text {
    font-size: 13.5px;
    color: #94a3b8;
    line-height: 1.5;
  }
  .trust-more {
    font-size: 12px;
    color: #475569;
    padding-left: 26px;
    margin-top: 2px;
  }

  /* Controls tab */
  .trust-ctrl-section {
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .trust-ctrl-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .trust-ctrl-section-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .trust-ctrl-section-title {
    font-size: 16px;
    font-weight: 600;
    color: #f1f5f9;
    margin: 0;
  }
  .trust-ctrl-badge {
    background: rgba(99,102,241,0.15);
    color: #818cf8;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 99px;
    border: 1px solid rgba(99,102,241,0.25);
  }
  .trust-ctrl-rows {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .trust-ctrl-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .trust-ctrl-row-text {
    font-size: 14px;
    color: #94a3b8;
    line-height: 1.5;
  }

  /* Subprocessors tab */
  .trust-section-desc {
    font-size: 14px;
    color: #64748b;
    line-height: 1.6;
    margin-bottom: 28px;
    max-width: 680px;
  }
  .trust-table-wrap {
    overflow-x: auto;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    margin-bottom: 20px;
  }
  .trust-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
  }
  .trust-table thead tr {
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.03);
  }
  .trust-table th {
    text-align: left;
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #475569;
  }
  .trust-table td {
    padding: 14px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    vertical-align: top;
  }
  .trust-table tbody tr:last-child td { border-bottom: none; }
  .trust-table tbody tr:hover td { background: rgba(255,255,255,0.02); }
  .trust-table-name { font-weight: 600; color: #e2e8f0; }
  .trust-table-purpose { color: #94a3b8; }
  .trust-region-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 99px;
    background: rgba(255,255,255,0.07);
    color: #94a3b8;
  }
  .trust-region-badge.eu { background: rgba(16,185,129,0.1); color: #34d399; }
  .trust-region-badge.onprem { background: rgba(99,102,241,0.1); color: #818cf8; }
  .trust-type-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 6px;
    background: rgba(255,255,255,0.06);
    color: #64748b;
  }
  .trust-onprem-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: rgba(99,102,241,0.07);
    border: 1px solid rgba(99,102,241,0.18);
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 13px;
    color: #94a3b8;
    line-height: 1.6;
  }

  /* Reports tab */
  .trust-reports-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
  }
  .trust-report-card {
    display: flex;
    flex-direction: column;
    background: #111420;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 22px;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s;
  }
  .trust-report-card:hover {
    border-color: rgba(99,102,241,0.35);
    transform: translateY(-2px);
  }
  .trust-report-top { margin-bottom: 14px; }
  .trust-report-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 99px;
    background: rgba(99,102,241,0.15);
    color: #818cf8;
    border: 1px solid rgba(99,102,241,0.25);
  }
  .trust-report-name {
    font-size: 14.5px;
    font-weight: 600;
    color: #f1f5f9;
    margin: 0 0 8px;
  }
  .trust-report-desc {
    font-size: 13px;
    color: #64748b;
    line-height: 1.5;
    flex: 1;
    margin: 0 0 16px;
  }
  .trust-report-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    font-weight: 500;
    color: #6366f1;
    transition: color 0.15s;
  }
  .trust-report-card:hover .trust-report-link { color: #818cf8; }
  .trust-report-cta {
    background: rgba(99,102,241,0.07);
    border: 1px solid rgba(99,102,241,0.18);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .trust-report-cta p { margin: 0; font-size: 14px; color: #94a3b8; }
  .trust-cta-btn {
    display: inline-block;
    background: #6366f1;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    padding: 9px 18px;
    border-radius: 8px;
    transition: background 0.15s, transform 0.1s;
    white-space: nowrap;
  }
  .trust-cta-btn:hover { background: #4f46e5; }
  .trust-cta-btn:active { transform: scale(0.97); }

  /* Responsive */
  @media (max-width: 640px) {
    .trust-grid { grid-template-columns: 1fr; padding: 20px 16px 60px; }
    .trust-tab { padding: 12px 14px; font-size: 12.5px; }
    .trust-kpi { padding: 0 16px; }
    .trust-kpi-n { font-size: 22px; }
    .trust-report-cta { flex-direction: column; text-align: center; }
    .trust-panel-inner { padding: 28px 16px 60px; }
  }
</style>

<script is:inline>
  const tabs = document.querySelectorAll('.trust-tab');
  const panels = document.querySelectorAll('.trust-panel');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => t.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById('tab-' + target)?.classList.add('active');
    });
  });
</script>
