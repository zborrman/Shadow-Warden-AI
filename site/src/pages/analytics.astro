---
import Layout from '../layouts/Layout.astro';

const models = [
  { id: 'filter_events',          icon: '🛡️', name: 'Filter Events',              domain: 'Security',    metrics: 7, desc: 'Block rate, P99 latency, verdict distribution across the 15-layer pipeline.' },
  { id: 'ers_scores',             icon: '⚡', name: 'Entity Risk Scores',         domain: 'Security',    metrics: 4, desc: 'Session risk scores, shadow-ban events, high-risk session count.' },
  { id: 'incidents',              icon: '🔥', name: 'Security Incidents',         domain: 'Security',    metrics: 5, desc: 'STIX-linked incident journal — severity, status, avg resolution time.' },
  { id: 'billing_usage',          icon: '📊', name: 'Billing & Quota',            domain: 'Revenue',     metrics: 4, desc: 'Requests consumed, cost, quota utilisation, overage charges.' },
  { id: 'ai_spend',               icon: '💰', name: 'AI Cost Allocation',         domain: 'Revenue',     metrics: 4, desc: 'Per-department AI spend vs budget — the source of truth for Budget Guardian.' },
  { id: 'agentic_orders',         icon: '🛒', name: 'Agentic Commerce Orders',    domain: 'Commerce',    metrics: 5, desc: 'Purchases by AI agents: spend by merchant, protocol (UCP/AP2/MCP), status.' },
  { id: 'vendor_contracts',       icon: '📋', name: 'Vendor Contracts & DPA',     domain: 'Governance',  metrics: 4, desc: 'DPA expiry countdown, risk tiers, active vs pending vendor contracts.' },
  { id: 'compliance_attestations',icon: '✅', name: 'Compliance & Training',      domain: 'Compliance',  metrics: 4, desc: 'Employee AI training completion %, overdue renewals by department.' },
  { id: 'tunnel_sessions',        icon: '🌐', name: 'Sovereign Tunnel Sessions',  domain: 'Sovereignty', metrics: 4, desc: 'MASQUE tunnel compliance rate per jurisdiction — EU, US, UK, CA and more.' },
];

const domainColor: Record<string, string> = {
  Security: '#FF2D55', Revenue: '#30D158', Commerce: '#FFD60A',
  Governance: '#0A84FF', Compliance: '#BF5AF2', Sovereignty: '#FF9F0A',
};

const flow = [
  { step: '1', label: 'Consumer', detail: 'SOC Dashboard · Streamlit · Portal · SOVA · External BI', color: '#8E8E9E' },
  { step: '2', label: 'Query Intent', detail: 'Natural language or structured QueryObject', color: '#0A84FF' },
  { step: '3', label: 'Semantic Layer API', detail: 'POST /semantic-layer/query · /query/intent · /models/catalog', color: '#BF5AF2' },
  { step: '4', label: 'Engine + Cache', detail: 'Deterministic SQL · AccessRules · Redis 10 min TTL', color: '#FF2D55' },
  { step: '5', label: 'Data Source', detail: 'PostgreSQL + TimescaleDB · ai_spend · filter_log · …', color: '#30D158' },
];
---

<Layout
  title="AI Analytics Hub — Shadow Warden AI"
  description="9 semantic models covering security, risk, billing, incidents, commerce, compliance, and sovereignty. One deterministic SQL interface for every dashboard and AI agent."
>
<div class="bg-[#03050F] text-[#F5F5F7] min-h-screen" style="font-family:'Inter',system-ui,sans-serif">

  <!-- Top bar -->
  <header class="fixed top-0 left-0 right-0 z-50 h-14 border-b border-white/[0.07]"
          style="background:rgba(3,5,15,0.95);backdrop-filter:blur(20px)">
    <div class="max-w-[1100px] mx-auto px-6 h-full flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center gap-2">
          <img src="/logo.png" alt="Shadow Warden AI" style="height:28px;width:auto;border-radius:6px;display:block" />
          <span class="text-[13px] font-bold">Shadow Warden</span>
        </a>
        <div class="w-px h-4 bg-white/[0.12]"></div>
        <span class="text-[12px] font-bold text-[#BF5AF2]">AI Analytics Hub</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-[9px] font-bold px-2.5 py-1 rounded-full bg-[#BF5AF2]/15 text-[#BF5AF2] border border-[#BF5AF2]/30 uppercase tracking-[1.5px]">v6.8</span>
        <a href="/" class="text-[12px] text-[#8E8E9E] hover:text-white transition-colors">← Back</a>
        <a href="/pricing" class="text-[11px] px-3 py-1.5 rounded-lg bg-[#BF5AF2] text-white font-bold hover:-translate-y-0.5 transition-all">Get Pro+</a>
      </div>
    </div>
  </header>

  <div class="max-w-[1100px] mx-auto px-6 pt-24 pb-20">

    <!-- Hero -->
    <div class="mb-16 pb-12 border-b border-white/[0.07]">
      <div class="flex items-center gap-3 mb-6">
        <img src="/logo.png" alt="Shadow Warden AI" style="width:48px;height:48px;border-radius:12px;display:block;object-fit:cover" />
        <div>
          <div class="text-[11px] font-semibold tracking-[2px] uppercase text-[#BF5AF2]">Shadow Warden AI</div>
          <div class="text-[12px] text-[#64748b]">Headless BI · v6.8</div>
        </div>
      </div>
      <h1 class="text-[36px] lg:text-[48px] font-black tracking-[-2px] mb-4">
        AI Analytics Hub
      </h1>
      <p class="text-[16px] leading-relaxed max-w-[680px] mb-8" style="color:#94a3b8">
        One API. Nine semantic models. Every dashboard, every AI agent, every external BI tool
        queries through a single deterministic SQL interface — so changing a metric definition
        updates every surface instantly.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {[
          ['9', 'Semantic Models'],
          ['10 min', 'Redis Cache TTL'],
          ['< 2 ms', 'SQL Generation'],
          ['Pro+', 'Tier Required'],
        ].map(([val, label]) => (
          <div class="rounded-xl p-4 border border-white/[0.07]" style="background:rgba(191,90,242,0.05);border-color:rgba(191,90,242,0.2)">
            <div class="text-[22px] font-bold text-[#BF5AF2] mb-1">{val}</div>
            <div class="text-[11px] text-[#64748b]">{label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Architecture flow -->
    <div class="mb-16">
      <h2 class="text-[22px] font-bold mb-6">How It Works</h2>
      <div class="rounded-2xl border border-white/[0.07] p-6 overflow-x-auto" style="background:rgba(255,255,255,0.02)">
        <div class="flex items-center gap-2 min-w-max">
          {flow.map((f, i) => (
            <>
              <div class="flex flex-col items-center gap-2 min-w-[140px]">
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-[12px] font-black text-white"
                     style={`background:${f.color}30;border:1px solid ${f.color}40`}>{f.step}</div>
                <div class="text-[12px] font-bold text-white text-center">{f.label}</div>
                <div class="text-[10px] text-[#64748b] text-center leading-[1.4]">{f.detail}</div>
              </div>
              {i < flow.length - 1 && (
                <div class="flex-shrink-0 w-8 h-px bg-white/10 relative">
                  <div class="absolute right-0 top-[-3px] w-0 h-0" style="border-left:6px solid rgba(255,255,255,0.15);border-top:3px solid transparent;border-bottom:3px solid transparent"></div>
                </div>
              )}
            </>
          ))}
        </div>
      </div>
      <p class="text-[12px] text-[#64748b] mt-3">
        LLM (Claude Haiku) translates natural language → <code class="text-[#BF5AF2]">QueryObject</code> → deterministic SQL — no hallucinated numbers, no raw DB access exposed.
      </p>
    </div>

    <!-- 9 Models grid -->
    <div class="mb-16">
      <h2 class="text-[22px] font-bold mb-2">9 Built-in Models</h2>
      <p class="text-[13px] text-[#64748b] mb-6">All models available immediately on Pro+. Expand any model with custom metrics via the Self-Service Catalog.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {models.map(m => (
          <div class="rounded-xl border border-white/[0.07] p-5 hover:border-white/[0.15] transition-colors"
               style="background:rgba(255,255,255,0.02)">
            <div class="flex items-start justify-between gap-2 mb-3">
              <div class="flex items-center gap-2.5">
                <span class="text-[18px]">{m.icon}</span>
                <div>
                  <p class="text-[13px] font-bold">{m.name}</p>
                  <p class="font-mono text-[9px] text-[#48485A]">{m.id}</p>
                </div>
              </div>
              <span class="text-[9px] font-bold px-2 py-0.5 rounded-full flex-shrink-0"
                    style={`background:${domainColor[m.domain] ?? '#48485A'}15;color:${domainColor[m.domain] ?? '#8E8E9E'};border:1px solid ${domainColor[m.domain] ?? '#48485A'}30`}>
                {m.domain}
              </span>
            </div>
            <p class="text-[12px] text-[#94a3b8] leading-[1.6] mb-3">{m.desc}</p>
            <div class="flex items-center gap-2 text-[10px] text-[#48485A]">
              <span>{m.metrics} metrics</span>
              <span>·</span>
              <span>tenant-isolated</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Three pillars -->
    <div class="mb-16">
      <h2 class="text-[22px] font-bold mb-6">Three Pillars</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          {
            icon: '💰',
            title: 'Commerce Budget Guardian',
            color: '#30D158',
            points: [
              'Reads actual MTD spend from ai_spend model',
              'Per-transaction limit enforcement',
              'Monthly budget ceiling check',
              'Approval gate for large purchases',
              'Slack alert when budget exceeded',
            ],
            api: 'GET /business-community/commerce/budget',
          },
          {
            icon: '🗂️',
            title: 'Self-Service Catalog',
            color: '#BF5AF2',
            points: [
              'Register custom models via API or Streamlit',
              'Persisted to SQLite, hot-loaded instantly',
              'Access rules enforce tenant isolation',
              'OSI 1.0 export/import for external BI',
              'SOVA can discover and query any model',
            ],
            api: 'POST /semantic-layer/models/catalog',
          },
          {
            icon: '🤖',
            title: 'SOVA AI Tools (74 total)',
            color: '#FF2D55',
            points: [
              'semantic_query() — NL or structured QueryObject',
              'list_semantic_models() — discover available models',
              'check_commerce_budget() — pre-flight payment check',
              'get_spend_summary() — MTD spend report',
              '#70-74: write_handoff_memory, read_handoff_memory, semantic_listing_search, get_protocol_schema, send_order_proposal',
            ],
            api: 'Via SOVA agent tool dispatch',
          },
        ].map(p => (
          <div class="rounded-xl border p-5 flex flex-col gap-4" style={`border-color:${p.color}25;background:${p.color}08`}>
            <div class="flex items-center gap-2.5">
              <span class="text-2xl">{p.icon}</span>
              <h3 class="text-[14px] font-bold">{p.title}</h3>
            </div>
            <ul class="space-y-2 flex-1">
              {p.points.map(pt => (
                <li class="flex items-start gap-2 text-[12px] text-[#94a3b8]">
                  <span style={`color:${p.color}`} class="mt-0.5 flex-shrink-0">✓</span>
                  {pt}
                </li>
              ))}
            </ul>
            <code class="text-[10px] font-mono px-3 py-2 rounded-lg" style={`background:${p.color}12;color:${p.color}`}>{p.api}</code>
          </div>
        ))}
      </div>
    </div>

    <!-- Code example -->
    <div class="mb-16">
      <h2 class="text-[22px] font-bold mb-4">Query Example</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <p class="text-[11px] font-semibold text-[#64748b] uppercase tracking-wider mb-2">Structured API call</p>
          <pre class="rounded-xl bg-[#080D1E] text-[#e2e8f0] p-4 text-[11px] overflow-x-auto leading-relaxed border border-white/[0.05]">{`POST /semantic-layer/query
{
  "model_id": "ai_spend",
  "metrics":  ["total_cost_usd"],
  "dimensions": ["department"],
  "filters": [{
    "dimension": "tenant_id",
    "operator": "=",
    "value": "your-tenant"
  }],
  "limit": 100
}`}</pre>
        </div>
        <div>
          <p class="text-[11px] font-semibold text-[#64748b] uppercase tracking-wider mb-2">Generated SQL (deterministic)</p>
          <pre class="rounded-xl bg-[#080D1E] text-[#86efac] p-4 text-[11px] overflow-x-auto leading-relaxed border border-white/[0.05]">{`SELECT
    department AS department,
    SUM(amount_usd) AS total_cost_usd
FROM cost_allocation_entries
WHERE (tenant_id = %s)
GROUP BY department
LIMIT 100`}</pre>
        </div>
      </div>
      <p class="text-[12px] text-[#64748b] mt-3">
        The same query works for SOVA agents, SOC Dashboard, Streamlit, external BI — and results are Redis-cached for 10 minutes.
        SQL never reaches the LLM; only metric names and descriptions are in the prompt.
      </p>
    </div>

    <!-- CTA -->
    <div class="rounded-2xl border border-[#BF5AF2]/25 p-8 text-center" style="background:rgba(191,90,242,0.06)">
      <h2 class="text-[24px] font-bold mb-3">Ready to centralise your analytics?</h2>
      <p class="text-[14px] text-[#94a3b8] max-w-lg mx-auto mb-6">
        AI Analytics Hub is available on the Pro plan ($69/mo). Register custom models, query with natural language, and share OSI models with your community — all from a single API.
      </p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a href="/pricing"
           class="px-6 py-3 rounded-xl text-[13px] font-bold text-white hover:-translate-y-0.5 transition-all"
           style="background:#BF5AF2;box-shadow:0 8px 32px rgba(191,90,242,0.35)">
          Get Pro+ — $69/mo
        </a>
        <a href="/roadmap"
           class="px-6 py-3 rounded-xl text-[13px] font-bold text-[#BF5AF2] border border-[#BF5AF2]/30 hover:border-[#BF5AF2]/60 hover:-translate-y-0.5 transition-all">
          View Full Roadmap
        </a>
      </div>
    </div>

  </div>
</div>
</Layout>
