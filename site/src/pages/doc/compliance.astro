---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureList from '../../components/FeatureList.astro';
import roadmap from '../../data/roadmap.json';

const features = roadmap.filter(r => r.subcategory === 'Compliance & Privacy' || r.id.startsWith('TQ'));
---
<BaseLayout title="Compliance & Privacy — Shadow Warden AI">
  <div class="pt-14">
    <div class="border-b" style="border-color:rgba(255,255,255,0.06);background:#111118">
      <div class="mx-auto max-w-7xl px-4 lg:px-8 py-14">
        <div class="flex items-center gap-2 mb-4">
          <a href="/" class="text-[13px] hover:text-white transition-colors" style="color:#475569">Home</a>
          <span style="color:#1e1e2a">/</span>
          <a href="/doc" class="text-[13px] hover:text-white transition-colors" style="color:#475569">Doc</a>
          <span style="color:#1e1e2a">/</span>
          <span class="text-[13px]" style="color:#94a3b8">Compliance</span>
        </div>
        <h1 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold mb-2" style="color:#f1f5f9">Compliance & Privacy</h1>
        <p class="text-[14px] max-w-xl" style="color:#94a3b8">
          GDPR Art.35 DPIA, SOC 2 Type II, SLA, secrets governance — all shipped.
        </p>
      </div>
    </div>
    <div class="mx-auto max-w-7xl px-4 lg:px-8 py-10">
      <!-- Compliance badges -->
      <div class="flex flex-wrap gap-3 mb-8">
        {['GDPR Art. 17 & 35','SOC 2 Type II','OWASP LLM Top 10','STIX 2.1','FIPS 203/204 PQC','ISO 27001 (partial)'].map(b => (
          <span class="px-3 py-1.5 rounded-lg text-[12px] font-semibold"
                style="color:#f59e0b;background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.2)">
            ✓ {b}
          </span>
        ))}
      </div>
      <FeatureList features={features} accent="#f59e0b" />
    </div>
  </div>
</BaseLayout>
