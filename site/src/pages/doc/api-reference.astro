---
// Renders the Redoc API explorer inline — no redirect to docs.shadow-warden-ai.com needed.
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>API Reference — Shadow Warden AI</title>
  <meta name="description" content="Shadow Warden AI REST API — interactive documentation powered by Redoc. 80+ endpoints." />
  <link rel="icon" href="/logo.png" type="image/png" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #03050f;
    }
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(8,9,15,0.96);
      border-bottom: 1px solid rgba(255,255,255,0.07);
      padding: 0 24px;
      height: 56px;
      position: sticky;
      top: 0;
      z-index: 1000;
      backdrop-filter: blur(20px);
    }
    .topbar-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: #f1f5f9;
      font-weight: 700;
      font-size: 14px;
    }
    .topbar-brand img { width: 32px; height: 32px; border-radius: 8px; object-fit: contain; }
    .topbar-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .topbar-right a {
      color: #64748b;
      text-decoration: none;
      font-size: 13px;
      transition: color 0.15s;
    }
    .topbar-right a:hover { color: #f1f5f9; }
    .badge {
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 99px;
      letter-spacing: 0.06em;
    }
    #redoc-container { min-height: calc(100vh - 56px); }
  </style>
</head>
<body>
  <header class="topbar">
    <a class="topbar-brand" href="/">
      <img src="/logo.png" alt="Shadow Warden AI" />
      Shadow Warden AI
    </a>
    <div class="topbar-right">
      <span class="badge">v5.6</span>
      <a href="/">Home</a>
      <a href="/doc">Docs</a>
      <a href="https://api.shadow-warden-ai.com/health" target="_blank" rel="noopener">Status</a>
      <a href="/price">Pricing</a>
    </div>
  </header>

  <div id="redoc-container"></div>

  <!-- is:inline prevents Astro/Vite from processing these as ES modules,
       which would break Redoc's UMD global registration. -->
  <script is:inline>
    (function () {
      var s = document.createElement("script");
      s.src = "https://cdn.jsdelivr.net/npm/redoc@2.1.5/bundles/redoc.standalone.js";
      s.onload = function () {
        Redoc.init(
          "https://api.shadow-warden-ai.com/openapi.json",
          {
            theme: {
              colors: {
                primary: { main: "#6366f1" },
                success: { main: "#10b981" },
                warning: { main: "#f59e0b" },
                error:   { main: "#ef4444" },
                text: { primary: "#e2e8f0", secondary: "#94a3b8" },
                border: { dark: "rgba(255,255,255,0.08)", light: "rgba(255,255,255,0.08)" },
                responses: {
                  success: { color: "#10b981", backgroundColor: "#022c22" },
                  error:   { color: "#ef4444", backgroundColor: "#2d0a0a" },
                },
                http: {
                  get: "#10b981", post: "#6366f1", put: "#f59e0b",
                  delete: "#ef4444", patch: "#38bdf8",
                },
              },
              typography: {
                fontSize: "14px",
                lineHeight: "1.6",
                fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
                headings: {
                  fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
                  fontWeight: "700",
                },
                code: {
                  fontSize: "13px",
                  fontFamily: "'JetBrains Mono', 'Fira Code', monospace",
                },
              },
              sidebar: { width: "280px", backgroundColor: "#080910", textColor: "#94a3b8" },
              rightPanel: { backgroundColor: "#050610" },
              schema: { nestedBackground: "#080910" },
            },
            scrollYOffset: 56,
            hideDownloadButton: false,
            expandDefaultServerVariables: true,
            requiredPropsFirst: true,
            menuToggle: true,
            jsonSampleExpandLevel: 2,
            hideSingleRequestSampleTab: true,
            nativeScrollbars: false,
            disableSearch: false,
          },
          document.getElementById("redoc-container")
        );
      };
      document.head.appendChild(s);
    })();
  </script>
</body>
</html>
