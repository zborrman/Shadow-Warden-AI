  /* ── Pricing tiers ─────────────────────────────────────────── */
  .tiers-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
  .tier-card { border-radius:14px; padding:28px 24px; border:1px solid rgba(128,180,253,.1); background:rgba(9,12,25,.9); display:flex; flex-direction:column; gap:18px; }
  .tier-card-featured { border-color:rgba(16,185,129,.3); background:rgba(9,12,25,.95); box-shadow:0 0 40px rgba(16,185,129,.08); }
  .tier-badge-label { font-size:11px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; padding:4px 10px; border-radius:5px; display:inline-block; }
  .tier-badge-pay   { background:rgba(16,185,129,.12); color:var(--grn); }
  .tier-badge-gmv   { background:rgba(128,180,253,.15); color:var(--pr); }
