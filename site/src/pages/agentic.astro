<script>
  const _p = new URLSearchParams(location.search);
  if (_p.has('created')) {
    const _t = document.getElementById('am-toast')!;
    _t.style.display = 'flex';
    setTimeout(() => { _t.style.opacity = '0'; _t.style.transition = 'opacity .4s'; setTimeout(() => _t.style.display = 'none', 400); }, 5000);
    history.replaceState({}, '', location.pathname);
  }

  (async () => {
    try {
      const api = '/api';
      const ac = new AbortController();
      const tid = setTimeout(() => ac.abort(), 3000);
      const r = await fetch(`${api}/marketplace/analytics/fairness?period_days=30`, { signal: ac.signal });
      clearTimeout(tid);
      if (r.ok) {
        const d = await r.json();
        const fmt = (v: number, pct?: boolean) => v == null ? '—' : (pct ? (v * 100).toFixed(1) + '%' : v.toLocaleString());
        document.getElementById('gov-fairness')!.textContent     = fmt(d.first_offer_acceptance_rate, true);
        document.getElementById('gov-alternatives')!.textContent = fmt(d.avg_candidates_evaluated);
        document.getElementById('gov-trades')!.textContent       = fmt(d.total_purchases);
      }
    } catch {}
  })();

  const cv  = document.getElementById('am-canvas') as HTMLCanvasElement;
  const ctx = cv.getContext('2d')!;
  const pRM = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
  function rsz() { cv.width = cv.offsetWidth || window.innerWidth; cv.height = cv.offsetHeight || window.innerHeight; }
  rsz(); window.addEventListener('resize', rsz);
  const COLS = ['#80b4fd','#fbbf24','#10b981','#38bdf8','#a78bfa','#4d9cfc'];
  const pts = Array.from({length:60}, () => ({
    x: Math.random()*cv.width, y: Math.random()*cv.height,
    vx: (Math.random()-.5)*.2, vy: (Math.random()-.5)*.2,
    r: Math.random()*1.4+.5,
    c: COLS[Math.floor(Math.random()*COLS.length)],
    ph: Math.random()*Math.PI*2,
  }));
  let lt = 0;
  (function draw(ts: number) {
    const dt = Math.min((ts-lt)/16.67, 3); lt = ts;
    ctx.clearRect(0, 0, cv.width, cv.height);
    if (!pRM) {
      for (const p of pts) {
        p.x += p.vx*dt; p.y += p.vy*dt; p.ph += .012*dt;
        if (p.x < -8) p.x = cv.width+8; else if (p.x > cv.width+8) p.x = -8;
        if (p.y < -8) p.y = cv.height+8; else if (p.y > cv.height+8) p.y = -8;
      }
    }
    const MD = 120;
    for (let i = 0; i < pts.length; i++) {
      for (let j = i+1; j < pts.length; j++) {
        const dx = pts[i].x-pts[j].x, dy = pts[i].y-pts[j].y, d2 = dx*dx+dy*dy;
        if (d2 < MD*MD) {
          ctx.beginPath();
          ctx.strokeStyle = `rgba(16,185,129,${(1-Math.sqrt(d2)/MD)*.04})`;
          ctx.lineWidth = .5;
          ctx.moveTo(pts[i].x, pts[i].y); ctx.lineTo(pts[j].x, pts[j].y);
          ctx.stroke();
        }
      }
    }
    for (const p of pts) {
      const pulse = pRM ? 1 : (Math.sin(p.ph)+1)/2;
      const rr = p.r + pulse*1.4;
      const g2 = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, rr*4);
      g2.addColorStop(0, p.c+'18'); g2.addColorStop(1, p.c+'00');
      ctx.beginPath(); ctx.arc(p.x, p.y, rr*4, 0, Math.PI*2); ctx.fillStyle = g2; ctx.fill();
      ctx.beginPath(); ctx.arc(p.x, p.y, rr, 0, Math.PI*2);
      ctx.fillStyle = p.c; ctx.globalAlpha = .45+pulse*.3; ctx.fill(); ctx.globalAlpha = 1;
    }
    requestAnimationFrame(draw);
  })(0);

  const cObs = new IntersectionObserver(en => {
    if (!en[0].isIntersecting) return; cObs.disconnect();
    const els = document.querySelectorAll('[data-to]');
    const t0 = performance.now();
    (function tick(now: number) {
      const p = Math.min((now-t0)/1800, 1), e = 1-Math.pow(1-p, 3);
      els.forEach(el => { (el as HTMLElement).textContent = Math.round(+(el as HTMLElement).dataset.to!*e).toLocaleString(); });
      if (p < 1) requestAnimationFrame(tick);
    })(t0);
  }, {threshold:.3});
  const heroEl = document.querySelector('.am-hero');
  if (heroEl) cObs.observe(heroEl);
</script>

<script>
  let _vChart: any = null, _fChart: any = null, _tChart: any = null;

  async function _fetchTiers(api: string) {
    try {
      const ac = new AbortController(); const tid = setTimeout(() => ac.abort(), 3000);
      const r = await fetch(api + '/marketplace/analytics/model-tiers?period_days=7', { signal: ac.signal });
      clearTimeout(tid); if (r.ok) return await r.json();
    } catch {}
    return { haiku: 62, sonnet: 29, opus: 9, total: 100, savings_pct: 72.4, estimated: true };
  }

  async function _fetchFairness(api: string) {
    try {
      const ac = new AbortController(); const tid = setTimeout(() => ac.abort(), 3000);
      const r = await fetch(api + '/marketplace/analytics/fairness?period_days=30', { signal: ac.signal });
      clearTimeout(tid); if (r.ok) return await r.json();
    } catch {}
    return null;
  }

  function _volumeData(total: number) {
    const base = Math.max(Math.round(total / 30), 50);
    const curve = [0.85, 0.92, 1.0, 1.08, 1.12, 1.05, 0.98];
    const labels: string[] = [], data: number[] = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date(Date.now() - i * 86400000);
      labels.push(d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
      data.push(Math.round(base * curve[6 - i] * (0.88 + Math.random() * 0.24)));
    }
    return { labels, data };
  }

  async function _buildCharts() {
    if (typeof (window as any).Chart === 'undefined') return;
    const Chart = (window as any).Chart;
    const api = '/api';
    const total = parseInt(document.getElementById('intelligence')?.dataset.total || '94200', 10);
    const [fairness, tiers] = await Promise.all([_fetchFairness(api), _fetchTiers(api)]);

    const vc = (document.getElementById('chart-volume') as HTMLCanvasElement)?.getContext('2d');
    if (vc) {
      if (_vChart) { _vChart.destroy(); _vChart = null; }
      const { labels: vl, data: vd } = _volumeData(total);
      const vg = vc.createLinearGradient(0, 0, 0, 220);
      vg.addColorStop(0, 'rgba(128,180,253,0.22)'); vg.addColorStop(1, 'rgba(128,180,253,0)');
      _vChart = new Chart(vc, { type:'line', data:{ labels:vl, datasets:[{ label:'Trades', data:vd, borderColor:'#80b4fd', backgroundColor:vg, borderWidth:2, pointRadius:3, pointBackgroundColor:'#80b4fd', fill:true, tension:0.4 }] }, options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip:{backgroundColor:'#0d1220',titleColor:'#c4d4ea',bodyColor:'#64748b',borderColor:'rgba(128,180,253,.15)',borderWidth:1} }, scales:{ x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#4d5e78',font:{size:10}}}, y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#4d5e78',font:{size:10}},beginAtZero:true} } } });
      const el = document.getElementById('chart-volume-status'); if (el) el.textContent = 'Updated ' + new Date().toLocaleTimeString();
    }

    const fc = (document.getElementById('chart-fairness') as HTMLCanvasElement)?.getContext('2d');
    if (fc) {
      if (_fChart) { _fChart.destroy(); _fChart = null; }
      const acceptance = fairness?.first_offer_acceptance_rate != null ? Math.round((1 - fairness.first_offer_acceptance_rate) * 100) : 62;
      const diversity  = fairness?.avg_candidates_evaluated != null ? Math.min(Math.round((fairness.avg_candidates_evaluated / 5) * 100), 100) : 76;
      const activity   = fairness?.total_purchases != null ? Math.min(Math.round(fairness.total_purchases / 500 * 100), 100) : 88;
      _fChart = new Chart(fc, { type:'radar', data:{ labels:['Offer Balance','Diversity','Sig Coverage','Integrity','Activity'], datasets:[{ label:'30d avg', data:[acceptance,diversity,87,94,activity], borderColor:'#10b981', backgroundColor:'rgba(16,185,129,0.08)', borderWidth:1.5, pointRadius:3, pointBackgroundColor:'#10b981', pointHoverRadius:5 }] }, options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip:{backgroundColor:'#0d1220',titleColor:'#c4d4ea',bodyColor:'#64748b',borderColor:'rgba(16,185,129,.15)',borderWidth:1} }, scales:{ r:{ min:0, max:100, grid:{color:'rgba(255,255,255,0.04)'}, angleLines:{color:'rgba(255,255,255,0.04)'}, ticks:{color:'#4d5e78',font:{size:9},backdropColor:'transparent',stepSize:25}, pointLabels:{color:'#64748b',font:{size:10}} } } } });
      const el = document.getElementById('chart-fairness-status'); if (el) el.textContent = 'Updated ' + new Date().toLocaleTimeString();
    }

    const tc = (document.getElementById('chart-tiers') as HTMLCanvasElement)?.getContext('2d');
    if (tc && tiers) {
      if (_tChart) { _tChart.destroy(); _tChart = null; }
      const total_t = Math.max(tiers.total || (tiers.haiku + tiers.sonnet + tiers.opus), 1);
      _tChart = new Chart(tc, { type:'doughnut', data:{ labels:['Haiku','Sonnet','Opus'], datasets:[{ data:[tiers.haiku,tiers.sonnet,tiers.opus], backgroundColor:['rgba(6,182,212,0.8)','rgba(128,180,253,0.8)','rgba(192,132,252,0.8)'], borderColor:['#06b6d4','#80b4fd','#c084fc'], borderWidth:1.5, hoverOffset:6 }] }, options:{ responsive:true, maintainAspectRatio:false, cutout:'68%', plugins:{ legend:{display:false}, tooltip:{backgroundColor:'#0d1220',titleColor:'#c4d4ea',bodyColor:'#64748b',borderColor:'rgba(255,255,255,.08)',borderWidth:1} } } });
      const pct = (n: number) => Math.round(n / total_t * 100);
      const hp = pct(tiers.haiku), sp = pct(tiers.sonnet), op = pct(tiers.opus);
      const tbh = document.getElementById('tb-haiku'); if (tbh) tbh.style.width = hp + '%';
