/* ── ROI Calculator ────────────────────────────────────────── */
(function(){
  var T={starter:{sub:0,take:0},individual:{sub:500,take:0},community:{sub:1900,take:0.015},pro:{sub:6900,take:0.015}};
  var UPSELL={individual:'Upgrading to Community Business unlocks SOVA agent + 1.5% take rate — net profit improves above $1k GMV.',community:'At 300+ trades, Pro ($69/mo) gives 50k req/mo and MasterAgent SOC — effective cost per request drops 60%.'};
  function g(id){return document.getElementById(id)}
  function fmt(c){var a=Math.abs(c)/100;return(c<0?'-':'')+'$'+a.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}
  function fmtS(n){return n>=1e6?(n/1e6).toFixed(1)+'M':n>=1e3?(n/1e3).toFixed(0)+'k':n.toString()}
  function calc(){
    var tier=g('mp-tier').value,t=T[tier]||T.community;
    var trades=+g('mp-trades').value,aov=Math.max(0,+g('mp-aov').value||0),api=+g('mp-api').value;
    var gmv=Math.round(trades*aov*100),take=Math.round(gmv*t.take),sub=t.sub,x=Math.round(api*0.0001),net=gmv-take-sub-x;
    var pct=gmv>0?Math.round(net/gmv*100):0;
    g('mp-net').textContent=fmt(net);g('mp-net').style.color=net<0?'#ef4444':'#10b981';
    g('mp-margin').textContent=gmv>0?pct+'% margin':'';g('mp-margin').style.color=pct>=80?'#10b981':pct>=50?'#fbbf24':'#ef4444';
    g('mp-r-gmv').textContent=fmt(gmv);g('mp-r-take').textContent=fmt(take);g('mp-r-sub').textContent=fmt(sub);g('mp-r-api').textContent=fmt(x);
    var up=UPSELL[tier]&&gmv>=100000;g('mp-upsell').style.display=up?'block':'none';if(up)g('mp-upsell-text').textContent=UPSELL[tier];
  }
  g('mp-tier')&&g('mp-tier').addEventListener('change',calc);
  g('mp-trades')&&g('mp-trades').addEventListener('input',function(){g('mp-trades-v').textContent=fmtS(+this.value);calc()});
  g('mp-aov')&&g('mp-aov').addEventListener('input',function(){g('mp-aov-v').textContent='$'+(+this.value||0).toLocaleString();calc()});
  g('mp-api')&&g('mp-api').addEventListener('input',function(){g('mp-api-v').textContent=fmtS(+this.value);calc()});
  calc();
})();
</script>


