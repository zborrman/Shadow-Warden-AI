<script is:inline>
/* ── Community search + filter ─────────────────────────────── */
(function(){
  var cards=Array.from(document.querySelectorAll('#comm-grid .comm-card'));
  var ct=document.getElementById('comm-ct');
  var srch=document.getElementById('comm-srch');
  var chips=document.querySelectorAll('#comm-chips .cpill');
  var active='all';
  function update(){
    var q=(srch?srch.value:'').toLowerCase();
    var vis=0;
    cards.forEach(function(c){
      var cat=c.dataset.cat||'';
      var txt=c.textContent.toLowerCase();
      var show=(active==='all'||cat===active)&&(!q||txt.includes(q));
      c.style.display=show?'':'none';
      if(show)vis++;
    });
    if(ct)ct.textContent=vis+' comm'+(vis===1?'unity':'unities');
  }
  chips.forEach(function(p){
    p.addEventListener('click',function(){
      chips.forEach(function(x){x.classList.remove('on')});
      p.classList.add('on');
      active=p.dataset.f||'all';
      update();
    });
  });
  if(srch)srch.addEventListener('input',update);
  update();
})();

/* ── Topology canvas ───────────────────────────────────────── */
(function(){
  var cv=document.getElementById('topo-canvas');
  if(!cv)return;
  var tip=document.getElementById('topo-tip');
  var nm=document.getElementById('tt-nm');
  var sb=document.getElementById('tt-sub');
  function resize(){cv.width=cv.offsetWidth;cv.height=cv.offsetHeight;}
  resize();
  window.addEventListener('resize',function(){resize();draw();});
  var nodes=[
    {id:'c1',label:'FinTech Alliance',     tier:'Enterprise',sub:'38 active peerings', color:'#80b4fd',x:.18,y:.3},
    {id:'c2',label:'Healthcare Consortium',tier:'Pro',       sub:'31 members, LOW risk',color:'#34d399',x:.5, y:.15},
    {id:'c3',label:'CyberSec Research',    tier:'Enterprise',sub:'89 members, 12 peers',color:'#fbbf24',x:.82,y:.28},
    {id:'c4',label:'LegalTech Exchange',   tier:'Community', sub:'22 members, 3 peers', color:'#f472b6',x:.72,y:.7},
    {id:'c5',label:'EdTech Safety',        tier:'Pro',       sub:'58 members, 8 peers', color:'#22d3ee',x:.28,y:.72},
    {id:'c6',label:'Supply Chain Guild',   tier:'Enterprise',sub:'34 members, MEDIUM',  color:'#c084fc',x:.5, y:.58},
  ];
  var edges=[
    {a:'c1',b:'c2',policy:'full',color:'#34d399'},
    {a:'c2',b:'c3',policy:'rewrap',color:'#fbbf24'},
    {a:'c3',b:'c4',policy:'mirror',color:'#80b4fd'},
    {a:'c4',b:'c6',policy:'full',color:'#34d399'},
    {a:'c5',b:'c6',policy:'rewrap',color:'#fbbf24'},
    {a:'c1',b:'c5',policy:'mirror',color:'#80b4fd'},
    {a:'c2',b:'c6',policy:'mirror',color:'#80b4fd'},
    {a:'c3',b:'c6',policy:'rewrap',color:'#fbbf24'},
  ];
  var hovered=null;
  var pulse=0;
  function px(n){return{x:n.x*cv.width,y:n.y*cv.height};}
  function draw(){
    var ctx=cv.getContext('2d');
    ctx.clearRect(0,0,cv.width,cv.height);
    pulse=(pulse+0.02)%(Math.PI*2);
    edges.forEach(function(e){
      var a=nodes.find(function(n){return n.id===e.a;});
      var b=nodes.find(function(n){return n.id===e.b;});
      if(!a||!b)return;
      var pa=px(a),pb=px(b);
      ctx.beginPath();
      ctx.moveTo(pa.x,pa.y);
      ctx.lineTo(pb.x,pb.y);
      ctx.strokeStyle=e.color+'55';
      ctx.lineWidth=1.5;
      ctx.setLineDash([4,4]);
      ctx.stroke();
      ctx.setLineDash([]);
      var t=(Math.sin(pulse)+1)/2;
      var mx=pa.x+(pb.x-pa.x)*t,my=pa.y+(pb.y-pa.y)*t;
      ctx.beginPath();ctx.arc(mx,my,2.5,0,Math.PI*2);
      ctx.fillStyle=e.color;ctx.fill();
    });
    nodes.forEach(function(n){
      var p=px(n);
      var r=n===hovered?22:16;
      ctx.beginPath();ctx.arc(p.x,p.y,r+Math.sin(pulse)*2,0,Math.PI*2);
      ctx.strokeStyle=n.color+'33';ctx.lineWidth=1;ctx.stroke();
      ctx.beginPath();ctx.arc(p.x,p.y,r,0,Math.PI*2);
      ctx.fillStyle=n.color+'22';ctx.fill();
      ctx.beginPath();ctx.arc(p.x,p.y,r,0,Math.PI*2);
      ctx.strokeStyle=n.color;ctx.lineWidth=1.5;ctx.stroke();
      ctx.fillStyle=n.color;ctx.font='bold 10px JetBrains Mono,monospace';
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(n.tier==='Enterprise'?'E':n.tier==='Pro'?'P':'C',p.x,p.y);
      ctx.fillStyle='#94a3b8';ctx.font='10px system-ui,sans-serif';
      ctx.fillText(n.label,p.x,p.y+r+10);
    });
    requestAnimationFrame(draw);
  }
  draw();
  cv.addEventListener('mousemove',function(e){
    var rect=cv.getBoundingClientRect();
    var mx=e.clientX-rect.left,my=e.clientY-rect.top;
    var found=null;
    nodes.forEach(function(n){
      var p=px(n);
      var d=Math.hypot(mx-p.x,my-p.y);
      if(d<22)found=n;
    });
    hovered=found;
    if(tip){
      if(found){
        tip.style.opacity='1';
        tip.style.left=(mx+14)+'px';
        tip.style.top=(my-10)+'px';
        if(nm)nm.textContent=found.label;
        if(sb)sb.textContent=found.sub;
      } else {
        tip.style.opacity='0';
      }
    }
  });
  cv.addEventListener('mouseleave',function(){
    hovered=null;
    if(tip)tip.style.opacity='0';
  });
})();

