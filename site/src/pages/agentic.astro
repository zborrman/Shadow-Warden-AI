  .tier-unit  { font-size:13px; color:#4d5e78; font-weight:400; }
  .tier-list  { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; flex:1; }
  .tier-list li { font-size:13px; color:#8090a8; padding-left:18px; position:relative; line-height:1.5; }
  .tier-list li::before { content:'→'; position:absolute; left:0; color:#2d3f5a; }
  .tier-cta { display:block; text-align:center; padding:11px 18px; border-radius:8px; font-size:13px; font-weight:600; text-decoration:none; transition:opacity .2s; }
  .tier-cta-primary { background:#10b981; color:#07090f; }
  .tier-cta-outline { border:1px solid rgba(128,180,253,.25); color:var(--pr); }
  .tier-cta:hover { opacity:.85; }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width:900px) {
    .am-hero-grid { grid-template-columns:1fr; gap:40px; }
    .am-stats-bar { grid-template-columns:repeat(2,1fr); }
    .pillar-grid  { grid-template-columns:1fr; gap:40px; }
