  .nsc { background:rgba(10,14,28,.72); border:1px solid rgba(128,180,253,.09); border-radius:11px; padding:14px 16px; }
  .nsc-lbl { font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:.08em; margin-bottom:5px; }
  .nsc-val { font-size:24px; font-weight:800; font-family:'JetBrains Mono',monospace; line-height:1; }
  .nsc-tr  { font-size:10.5px; margin-top:3px; }

  /* ── 6-step creation ─────────────────────────────────────────── */
  .steps-grid6 { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
  .step-card6 { background:rgba(13,19,36,.7); border:1px solid rgba(128,180,253,.1); border-radius:14px; padding:22px 18px; transition:border-color .2s; }
  .step-card6:hover { border-color:rgba(128,180,253,.28); }
