    }

  }

  // ── SSE live-metrics: replace 60 s poll with push stream ──────────────────
  let _sse: EventSource | null = null;

  function _applyMetrics(d: any) {
    // Hero stat counters
    const _setS = (id: string, n: number | string) => {
      const el = document.getElementById(id);
      if (!el) return;
      if (typeof n === 'number') {
        el.dataset.to = String(n);
        el.textContent = n.toLocaleString();
      } else {
        el.textContent = String(n);
      }
    };
    if (d.communities != null) _setS('stat-communities', d.communities);
    if (d.assets      != null) _setS('stat-assets',      d.assets);
    if (d.trades      != null) _setS('stat-trades',      d.trades);
    if (d.auto_import_pct != null) _setS('stat-auto', d.auto_import_pct + '%');

    // Governance cards (same data)
    const gf = document.getElementById('gov-fairness');
    if (gf && d.fairness?.first_offer_acceptance_rate != null) {
      gf.textContent = Math.round((1 - d.fairness.first_offer_acceptance_rate) * 100) + '%';
    }
    const ga = document.getElementById('gov-alternatives');
    if (ga && d.fairness?.avg_candidates_evaluated != null) {
      ga.textContent = d.fairness.avg_candidates_evaluated.toFixed(1);
    }
    const gt = document.getElementById('gov-trades');
    if (gt && d.trades != null) gt.textContent = d.trades.toLocaleString();

    // Update charts if Chart.js already loaded
    if (typeof (window as any).Chart === 'undefined') return;
    const Chart = (window as any).Chart;

    // Volume series (line chart)
    if (_vChart && d.volume_series?.labels?.length) {
      _vChart.data.labels    = d.volume_series.labels;
      _vChart.data.datasets[0].data = d.volume_series.data;
      _vChart.update('none');
      const el = document.getElementById('chart-volume-status');
      if (el) el.textContent = 'Live — ' + new Date().toLocaleTimeString();
    }

    // Fairness radar
    const fc = (document.getElementById('chart-fairness') as HTMLCanvasElement)?.getContext('2d');
    if (fc && d.fairness) {
      if (_fChart) { _fChart.destroy(); _fChart = null; }
      const acceptance = d.fairness.first_offer_acceptance_rate != null
        ? Math.round((1 - d.fairness.first_offer_acceptance_rate) * 100) : 62;
      const diversity  = d.fairness.avg_candidates_evaluated != null
        ? Math.min(Math.round((d.fairness.avg_candidates_evaluated / 5) * 100), 100) : 76;
      const activity   = d.fairness.total_purchases != null
        ? Math.min(Math.round(d.fairness.total_purchases / 500 * 100), 100) : 88;
      _fChart = new Chart(fc, { type:'radar', data:{ labels:['Offer Balance','Diversity','Sig Coverage','Integrity','Activity'], datasets:[{ label:'30d avg', data:[acceptance,diversity,87,94,activity], borderColor:'#10b981', backgroundColor:'rgba(16,185,129,0.08)', borderWidth:1.5, pointRadius:3, pointBackgroundColor:'#10b981', pointHoverRadius:5 }] }, options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip:{backgroundColor:'#0d1220',titleColor:'#c4d4ea',bodyColor:'#64748b',borderColor:'rgba(16,185,129,.15)',borderWidth:1} }, scales:{ r:{ min:0, max:100, grid:{color:'rgba(255,255,255,0.04)'}, angleLines:{color:'rgba(255,255,255,0.04)'}, ticks:{color:'#4d5e78',font:{size:9},backdropColor:'transparent',stepSize:25}, pointLabels:{color:'#64748b',font:{size:10}} } } } });
      const el = document.getElementById('chart-fairness-status'); if (el) el.textContent = 'Live — ' + new Date().toLocaleTimeString();
    }

    // Model tiers doughnut
    const tc = (document.getElementById('chart-tiers') as HTMLCanvasElement)?.getContext('2d');
    if (tc && d.tiers?.total > 0) {
      const tiers = d.tiers;
      if (_tChart) { _tChart.destroy(); _tChart = null; }
      const total_t = Math.max(tiers.total || (tiers.haiku + tiers.sonnet + tiers.opus), 1);
      _tChart = new Chart(tc, { type:'doughnut', data:{ labels:['Haiku','Sonnet','Opus'], datasets:[{ data:[tiers.haiku,tiers.sonnet,tiers.opus], backgroundColor:['rgba(6,182,212,0.8)','rgba(128,180,253,0.8)','rgba(192,132,252,0.8)'], borderColor:['#06b6d4','#80b4fd','#c084fc'], borderWidth:1.5, hoverOffset:6 }] }, options:{ responsive:true, maintainAspectRatio:false, cutout:'68%', plugins:{ legend:{display:false}, tooltip:{backgroundColor:'#0d1220',titleColor:'#c4d4ea',bodyColor:'#64748b',borderColor:'rgba(255,255,255,.08)',borderWidth:1} } } });
      const pct = (n: number) => Math.round(n / total_t * 100);
      const hp = pct(tiers.haiku), sp = pct(tiers.sonnet), op = pct(tiers.opus);
      const tbh = document.getElementById('tb-haiku'); if (tbh) tbh.style.width = hp + '%';
      const tbs = document.getElementById('tb-sonnet'); if (tbs) tbs.style.width = sp + '%';
      const tbo = document.getElementById('tb-opus');   if (tbo) tbo.style.width = op + '%';
      const tph = document.getElementById('tp-haiku'); if (tph) tph.textContent = hp + '%';
      const tps = document.getElementById('tp-sonnet'); if (tps) tps.textContent = sp + '%';
      const tpo = document.getElementById('tp-opus');   if (tpo) tpo.textContent = op + '%';
      if (tiers.savings_pct > 0) {
        const pill = document.getElementById('savings-pill'), txt = document.getElementById('savings-text');
        if (pill && txt) { txt.textContent = tiers.savings_pct.toFixed(1) + '% cost saved'; pill.style.display = 'inline-flex'; }
      }
      const el = document.getElementById('chart-tiers-status');
      if (el) el.textContent = (tiers.estimated ? 'Estimated — ' : 'Live — ') + new Date().toLocaleTimeString();
    }
  }

  function _startSSE(api: string) {
    if (!api) return;
    if (_sse) { _sse.close(); _sse = null; }
    try {
      _sse = new EventSource(api + '/marketplace/analytics/stream');
      _sse.onmessage = (e: MessageEvent) => {
        try { _applyMetrics(JSON.parse(e.data)); } catch {}
      };
      _sse.onerror = () => {
        // Browser handles automatic reconnect; close and let it retry
        if (_sse && _sse.readyState === EventSource.CLOSED) {
          _sse = null;
          // Fallback to periodic poll after persistent failure
          setTimeout(() => _startSSE(api), 30000);
        }
      };
    } catch {}
  }

  const _cjs = document.createElement('script');
  _cjs.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js';
  _cjs.onload = () => {
    _buildCharts();   // initial render with static/cached data
    const api = '/api';
    _startSSE(api);   // then upgrade to live SSE push
  };
  _cjs.onerror = () => {
    ['chart-volume-status','chart-fairness-status','chart-tiers-status'].forEach(id => {
      const el = document.getElementById(id); if (el) el.textContent = 'Charts unavailable offline';
    });
  };
  document.head.appendChild(_cjs);
  window.addEventListener('pagehide', () => { if (_sse) { _sse.close(); _sse = null; } });
</script>

</BaseLayout>
