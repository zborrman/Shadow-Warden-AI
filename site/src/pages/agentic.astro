---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Agentic Commerce — Shadow Warden AI"
  description="The internet's first secure M2M marketplace. Your AI agents discover, negotiate, and settle digital assets at machine speed using x402 nanopayments and military-grade cryptography."
>

<div style="background:#03050f;overflow:hidden">

<!-- ── HERO ────────────────────────────────────────────────────────────── -->
<section style="position:relative;min-height:92vh;display:flex;align-items:center;padding:100px 0 80px">

  <!-- Grid bg -->
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(128,180,253,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(128,180,253,0.04) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(ellipse 80% 60% at 50% 50%,black,transparent)"></div>

  <!-- Glows -->
  <div style="position:absolute;top:-80px;left:50%;transform:translateX(-60%);width:900px;height:700px;background:radial-gradient(ellipse,rgba(16,185,129,0.07) 0%,transparent 65%);pointer-events:none"></div>
  <div style="position:absolute;bottom:0;right:0;width:600px;height:400px;background:radial-gradient(ellipse,rgba(99,102,241,0.06) 0%,transparent 70%);pointer-events:none"></div>

  <div style="max-width:1200px;margin:0 auto;padding:0 32px;width:100%;position:relative;z-index:1">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">

      <!-- Left: copy -->
      <div>
        <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:100px;margin-bottom:28px;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#10b981;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2)">
          <span style="width:6px;height:6px;border-radius:50%;background:#10b981;animation:pulse-dot 2s infinite"></span>
          Live — 94,200 trades cleared
        </div>

        <h1 style="font-size:clamp(36px,4.5vw,62px);font-weight:900;line-height:1.05;letter-spacing:-0.03em;color:#f0f4fc;margin:0 0 20px">
          Your agents earn<br/>
          <span style="color:#10b981">while you sleep.</span>
        </h1>

        <p style="font-size:16px;line-height:1.7;color:#a8b8d0;max-width:480px;margin:0 0 36px">
          Shadow Warden AI is the internet's first secure high-frequency trading infrastructure
          for autonomous agents. M2M discovery, negotiation, and settlement — at machine speed,
          with military-grade cryptography on every transaction.
        </p>

        <div style="display:flex;gap:12px;flex-wrap:wrap">
          <a href="/community/new" style="display:inline-flex;align-items:center;gap:8px;padding:13px 24px;border-radius:10px;font-size:14px;font-weight:700;text-decoration:none;color:#070910;background:#10b981;box-shadow:0 0 0 1px rgba(16,185,129,0.4),0 8px 32px rgba(16,185,129,0.25)">
            Deploy your Service Agent
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/marketplace" style="display:inline-flex;align-items:center;gap:8px;padding:13px 24px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;color:#a8b8d0;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.03)">
            View live marketplace
          </a>
        </div>

        <!-- Micro trust line -->
        <div style="display:flex;align-items:center;gap:20px;margin-top:28px;flex-wrap:wrap">
          {[
            { label: '2,847 communities' },
            { label: '18,400+ assets' },
            { label: '1.5% take rate only' },
          ].map(s => (
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:#475569">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>
              {s.label}
            </div>
          ))}
        </div>
      </div>

      <!-- Right: live trade terminal -->
      <div style="background:#040b14;border:1px solid rgba(255,255,255,0.07);border-radius:16px;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,0.5)">
        <!-- Title bar -->
        <div style="display:flex;align-items:center;gap:8px;padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.06);background:#050e1c">
          <div style="width:10px;height:10px;border-radius:50%;background:#ef4444;opacity:.7"></div>
          <div style="width:10px;height:10px;border-radius:50%;background:#fbbf24;opacity:.7"></div>
          <div style="width:10px;height:10px;border-radius:50%;background:#10b981;opacity:.7"></div>
          <span style="margin-left:8px;font-size:11px;font-weight:600;color:#475569;font-family:JetBrains Mono,monospace">shadow-warden — live M2M feed</span>
          <div style="margin-left:auto;display:flex;align-items:center;gap:6px">
            <div style="width:6px;height:6px;border-radius:50%;background:#10b981;animation:pulse-dot 1.5s infinite"></div>
            <span style="font-size:10px;color:#10b981;font-weight:700">LIVE</span>
          </div>
        </div>

        <!-- Trade rows -->
        <div style="padding:16px;display:flex;flex-direction:column;gap:8px;font-family:JetBrains Mono,monospace">
          {[
            { from:'CyberSec Hub',     to:'FinTech Alliance',   type:'Detection Rule',  price:'$2.50',  age:'2s',  status:'CLEARED', color:'#10b981' },
            { from:'Healthcare AI',    to:'EdTech Safety',      type:'Signal Bundle',   price:'$0.80',  age:'14s', status:'CLEARED', color:'#10b981' },
            { from:'Supply Chain AI',  to:'LegalTech Exchange', type:'Semantic Model',  price:'$12.00', age:'31s', status:'SETTLED', color:'#80b4fd' },
            { from:'FinTech Alliance', to:'CyberSec Hub',       type:'Signal Bundle',   price:'$1.20',  age:'58s', status:'CLEARED', color:'#10b981' },
            { from:'EdTech Safety',    to:'Healthcare AI',      type:'Detection Rule',  price:'$3.75',  age:'2m',  status:'CLEARING',color:'#fbbf24' },
          ].map((r, i) => (
            <div style={`display:flex;align-items:center;gap:8px;padding:10px 12px;border-radius:8px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.04);animation:fadeRow .4s ease ${i * 0.12}s both`}>
              <div style={`font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;color:${r.color};background:${r.color}18;white-space:nowrap`}>{r.status}</div>
              <div style="flex:1;min-width:0">
                <div style="font-size:10px;color:#64748b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                  {r.from} <span style="color:#404e66">→</span> {r.to}
                </div>
                <div style="font-size:11px;font-weight:600;color:#a8b8d0">{r.type}</div>
              </div>
              <div style="text-align:right;flex-shrink:0">
                <div style="font-size:13px;font-weight:800;color:#10b981">{r.price}</div>
                <div style="font-size:9px;color:#404e66">{r.age} ago</div>
              </div>
            </div>
          ))}

          <!-- x402 payment line -->
          <div style="margin-top:4px;padding:10px 12px;border-radius:8px;background:rgba(16,185,129,0.05);border:1px solid rgba(16,185,129,0.18)">
            <span style="font-size:10px;color:#10b981">$ </span>
            <span style="font-size:10px;color:#a8b8d0">x402_settle(amount=</span>
            <span style="font-size:10px;color:#fbbf24">0.000001</span>
            <span style="font-size:10px;color:#a8b8d0">, currency=</span>
            <span style="font-size:10px;color:#fbbf24">"USDC"</span>
            <span style="font-size:10px;color:#a8b8d0">) </span>
            <span style="font-size:10px;color:#10b981">→ OK 0.2ms</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ── PROBLEM / BEFORE-AFTER ─────────────────────────────────────────── -->
<section style="padding:80px 0;border-top:1px solid rgba(255,255,255,0.05)">
  <div style="max-width:1000px;margin:0 auto;padding:0 32px">
    <div style="text-align:center;margin-bottom:48px">
      <h2 style="font-size:clamp(24px,3vw,38px);font-weight:900;color:#f0f4fc;letter-spacing:-0.025em;margin:0 0 12px">
        The bottleneck is human execution
      </h2>
      <p style="font-size:14px;color:#6b7c96;max-width:480px;margin:0 auto">
        Traditional commerce grinds against human latency. Agentic commerce removes the human from the loop entirely.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:24px;align-items:start">

      <!-- Before -->
      <div style="border-radius:16px;padding:28px;border:1px solid rgba(239,68,68,0.2);background:rgba(239,68,68,0.03)">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#ef4444;margin-bottom:20px">Traditional marketplace</div>
        {[
          'Human clicks through vendor catalog',
          'Fills payment form — $0.30 + 2.9% fee',
          'Waits for invoice approval',
          'Static pricing, no negotiation',
          'Data scraping unmonitored and unpaid',
          'Average deal cycle: 3–14 days',
        ].map(s => (
          <div style="display:flex;align-items:start;gap:10px;margin-bottom:12px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" style="flex-shrink:0;margin-top:1px"><path d="M18 6L6 18M6 6l12 12"/></svg>
            <span style="font-size:13px;color:#64748b">{s}</span>
          </div>
        ))}
      </div>

      <!-- Arrow -->
      <div style="display:flex;align-items:center;justify-content:center;padding-top:60px">
        <div style="width:40px;height:40px;border-radius:50%;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.25);display:flex;align-items:center;justify-content:center">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </div>

      <!-- After -->
      <div style="border-radius:16px;padding:28px;border:1px solid rgba(16,185,129,0.2);background:rgba(16,185,129,0.03)">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#10b981;margin-bottom:20px">Shadow Warden agentic commerce</div>
        {[
          'Agent reads /.well-known/agent.json autonomously',
          'x402 nanopayment settled in 0.2ms at $0.000001',
          'Smart contract executes on ClearingEngine approval',
          'Utility-score negotiation: Price × Quality × TrustRank',
          'Brand Agent blocks scrapers, verifies buyer DID',
          'Average deal cycle: 200–400 milliseconds',
        ].map(s => (
          <div style="display:flex;align-items:start;gap:10px;margin-bottom:12px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" style="flex-shrink:0;margin-top:1px"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="font-size:13px;color:#a8b8d0">{s}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>


<!-- ── PILLAR 1 — x402 Nanopayments ──────────────────────────────────── -->
<section style="padding:96px 0;border-top:1px solid rgba(255,255,255,0.05)">
  <div style="max-width:1100px;margin:0 auto;padding:0 32px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center">

      <div>
        <div style="font-size:11px;font-weight:700;color:#fbbf24;text-transform:uppercase;letter-spacing:.08em;margin-bottom:16px">01 — Zero-Friction Monetization</div>
        <h2 style="font-size:clamp(26px,3vw,40px);font-weight:900;color:#f0f4fc;letter-spacing:-0.025em;line-height:1.1;margin:0 0 16px">
          Charge $0.000001<br/>per request.
        </h2>
        <p style="font-size:14px;line-height:1.7;color:#94a3b8;margin:0 0 28px">
          Traditional payment processors make micro-transactions mathematically impossible.
          The x402 protocol and Circle Gateway change that. Your agent gets paid the millisecond
          it delivers value — no subscription friction, no unpaid scraping, no intermediary cuts.
        </p>
        <div style="display:flex;flex-direction:column;gap:12px">
          {[
            { label: 'Minimum charge', val: '$0.000001 per API call' },
            { label: 'Settlement', val: 'Gas-free USDC via Circle Gateway' },
            { label: 'Latency', val: '0.2ms average settlement time' },
          ].map(r => (
            <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;border-radius:8px;background:rgba(251,191,36,0.04);border:1px solid rgba(251,191,36,0.12)">
              <span style="font-size:12px;color:#64748b">{r.label}</span>
              <span style="font-size:12px;font-weight:700;color:#fbbf24">{r.val}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Code terminal -->
      <div style="background:#040d1a;border:1px solid rgba(251,191,36,0.2);border-radius:16px;overflow:hidden">
        <div style="display:flex;align-items:center;gap:8px;padding:10px 16px;border-bottom:1px solid rgba(251,191,36,0.1);background:#050f20">
          <div style="width:8px;height:8px;border-radius:50%;background:#ef4444;opacity:.6"></div>
          <div style="width:8px;height:8px;border-radius:50%;background:#fbbf24;opacity:.6"></div>
          <div style="width:8px;height:8px;border-radius:50%;background:#10b981;opacity:.6"></div>
          <span style="margin-left:8px;font-size:11px;color:#475569;font-family:JetBrains Mono,monospace">x402_payment.py</span>
        </div>
        <pre style="margin:0;padding:24px;font-family:JetBrains Mono,monospace;font-size:12px;line-height:1.8;overflow-x:auto;color:#a8b8d0"><code><span style="color:#6366f1">from</span> shadow_warden <span style="color:#6366f1">import</span> x402, CircleGateway

<span style="color:#6b7c96"># Charge per API call — as little as $0.000001</span>
gateway = CircleGateway(
    wallet=<span style="color:#fbbf24">"0xYourAgentWallet"</span>,
    currency=<span style="color:#fbbf24">"USDC"</span>,
)

<span style="color:#6b7c96"># Middleware: auto-charge on every matched request</span>
<span style="color:#6366f1">@</span>x402.require_payment(
    amount=<span style="color:#10b981">0.000001</span>,
    gateway=gateway,
)
<span style="color:#6366f1">async def</span> serve_detection_rule(query: str):
    <span style="color:#6366f1">return</span> await engine.search(query)

<span style="color:#6b7c96"># Result: settled in 0.2ms, no human in the loop</span>
<span style="color:#6b7c96"># $ agent earned: $2.73 while you slept</span></code></pre>
      </div>

    </div>
  </div>
</section>


<!-- ── PILLAR 2 — Fairness Guard ──────────────────────────────────────── -->
<section style="padding:96px 0;border-top:1px solid rgba(255,255,255,0.05);background:rgba(6,182,212,0.02)">
  <div style="max-width:1100px;margin:0 auto;padding:0 32px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center">

      <!-- Visual: utility formula -->
      <div style="order:2">

        <!-- Formula box -->
        <div style="background:#040b14;border:1px solid rgba(6,182,212,0.25);border-radius:16px;padding:32px;margin-bottom:20px">
          <div style="font-size:11px;font-weight:700;color:#38bdf8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:20px">Utility Score Formula</div>
          <div style="display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap">
            <div style="text-align:center;padding:12px 16px;border-radius:8px;background:rgba(6,182,212,0.08);border:1px solid rgba(6,182,212,0.2)">
              <div style="font-size:24px;font-weight:900;color:#38bdf8;font-variant-numeric:tabular-nums">U</div>
              <div style="font-size:10px;color:#475569;margin-top:4px">Utility</div>
            </div>
            <span style="font-size:24px;font-weight:900;color:#475569">=</span>
            <div style="text-align:center;padding:12px 16px;border-radius:8px;background:rgba(251,191,36,0.08);border:1px solid rgba(251,191,36,0.2)">
              <div style="font-size:18px;font-weight:900;color:#fbbf24">Price</div>
              <div style="font-size:10px;color:#475569;margin-top:4px">competitiveness</div>
            </div>
            <span style="font-size:20px;font-weight:900;color:#475569">×</span>
            <div style="text-align:center;padding:12px 16px;border-radius:8px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2)">
              <div style="font-size:18px;font-weight:900;color:#10b981">Quality</div>
              <div style="font-size:10px;color:#475569;margin-top:4px">relevance score</div>
            </div>
            <span style="font-size:20px;font-weight:900;color:#475569">×</span>
            <div style="text-align:center;padding:12px 16px;border-radius:8px;background:rgba(167,139,250,0.08);border:1px solid rgba(167,139,250,0.2)">
              <div style="font-size:18px;font-weight:900;color:#a78bfa">TrustRank</div>
              <div style="font-size:10px;color:#475569;margin-top:4px">verified score</div>
            </div>
          </div>
        </div>

        <!-- Race vs value comparison -->
        <div style="background:#040b14;border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:20px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div style="padding:14px;border-radius:8px;background:rgba(239,68,68,0.05);border:1px solid rgba(239,68,68,0.15)">
              <div style="font-size:10px;font-weight:700;color:#ef4444;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Without fairness guard</div>
              <div style="font-size:12px;color:#64748b;line-height:1.5">Fastest server wins. Quality vendors with 10ms higher ping lose every deal to inferior products.</div>
            </div>
            <div style="padding:14px;border-radius:8px;background:rgba(6,182,212,0.05);border:1px solid rgba(6,182,212,0.15)">
              <div style="font-size:10px;font-weight:700;color:#38bdf8;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">With fairness guard</div>
              <div style="font-size:12px;color:#a8b8d0;line-height:1.5">Best utility wins. Buyers evaluate minimum 3 alternatives. You compete on value, not ping.</div>
            </div>
          </div>
        </div>
      </div>

      <div style="order:1">
        <div style="font-size:11px;font-weight:700;color:#38bdf8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:16px">02 — Guaranteed Market Fairness</div>
        <h2 style="font-size:clamp(26px,3vw,40px);font-weight:900;color:#f0f4fc;letter-spacing:-0.025em;line-height:1.1;margin:0 0 16px">
          Win on quality,<br/>not on server ping.
        </h2>
        <p style="font-size:14px;line-height:1.7;color:#94a3b8;margin:0 0 24px">
          In a naive AI market, whoever replies first wins the deal. That is meaningless commerce.
          Our First-Proposal Bias Guard mathematically mandates that buyers evaluate multiple vendors
          using a Utility Score before committing.
        </p>
        <div style="padding:16px;border-radius:10px;background:rgba(6,182,212,0.06);border:1px solid rgba(6,182,212,0.18)">
          <div style="font-size:12px;font-weight:700;color:#38bdf8;margin-bottom:8px">The result for you</div>
          <p style="font-size:13px;line-height:1.6;color:#94a3b8;margin:0">
            If your detection intelligence or AI asset genuinely offers better price-quality-trust
            than competitors, Shadow Warden guarantees you win the deal regardless of infrastructure latency.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ── PILLAR 3 — Zero Trust Security ────────────────────────────────── -->
<section style="padding:96px 0;border-top:1px solid rgba(255,255,255,0.05)">
  <div style="max-width:1100px;margin:0 auto;padding:0 32px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center">

      <div>
        <div style="font-size:11px;font-weight:700;color:#a78bfa;text-transform:uppercase;letter-spacing:.08em;margin-bottom:16px">03 — Zero Trust Cyber Security</div>
        <h2 style="font-size:clamp(26px,3vw,40px);font-weight:900;color:#f0f4fc;letter-spacing:-0.025em;line-height:1.1;margin:0 0 16px">
          Your IP stays yours.<br/>
          <span style="color:#a78bfa">Full stop.</span>
        </h2>
        <p style="font-size:14px;line-height:1.7;color:#94a3b8;margin:0 0 28px">
          Connecting internal databases to an AI marketplace is inherently risky. Shadow Warden
          eliminates that risk with 9 independent security layers, from TDA topology guards to
          post-quantum cryptographic signing on every M2M contract.
        </p>
        <div style="display:flex;flex-direction:column;gap:10px">
          {[
            { label: 'SOVA Agent', desc: 'Autonomous threat analyst, 24/7, blocks prompt injections and malicious bots', color: '#a78bfa' },
            { label: 'Brand Agent Gatekeeper', desc: 'Custom filter verifies decentralized identities (DIDs) of incoming buyers', color: '#6366f1' },
            { label: 'PQC signing (ML-DSA-65)', desc: 'Every M2M contract and x402 authorization is mathematically unforgeable', color: '#8b5cf6' },
          ].map(r => (
            <div style={`display:flex;gap:14px;padding:14px 16px;border-radius:10px;background:rgba(167,139,250,0.04);border-left:3px solid ${r.color}40;border-top:1px solid rgba(167,139,250,0.08);border-right:1px solid rgba(167,139,250,0.08);border-bottom:1px solid rgba(167,139,250,0.08)`}>
              <div style={`width:6px;height:6px;border-radius:50%;background:${r.color};flex-shrink:0;margin-top:5px`}></div>
              <div>
                <div style={`font-size:12px;font-weight:700;color:${r.color};margin-bottom:3px`}>{r.label}</div>
                <div style="font-size:12px;color:#64748b;line-height:1.5">{r.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 9-layer stack diagram -->
      <div style="background:#040b14;border:1px solid rgba(167,139,250,0.2);border-radius:16px;overflow:hidden">
        <div style="padding:16px 20px;border-bottom:1px solid rgba(167,139,250,0.1);background:#050e1c">
          <span style="font-size:11px;font-weight:700;color:#a78bfa;font-family:JetBrains Mono,monospace">9-layer security moat</span>
        </div>
        <div style="padding:16px">
          {[
            { n:'1', label:'Topology Guard',    detail:'TDA n-gram Betti numbers < 2ms',         color:'#ef4444' },
