---
import BaseLayout from '../layouts/BaseLayout.astro';

const API_URL = import.meta.env.API_URL ?? 'https://api.shadow-warden-ai.com';

const FALLBACK_TRADES = [
  { from:'CyberSec Research Hub',    to:'FinTech Alliance',      type:'Detection Rule',  price:'$2.50',  age:'2s',  target:'Evolution Engine' },
  { from:'Healthcare AI Consortium', to:'EdTech Safety',         type:'Signal Bundle',   price:'$0.80',  age:'14s', target:'Threat Radar'     },
  { from:'Supply Chain AI Guild',    to:'LegalTech Exchange',    type:'Semantic Model',  price:'$12.00', age:'31s', target:'Semantic Layer'   },
  { from:'FinTech Alliance',         to:'CyberSec Research Hub', type:'Signal Bundle',   price:'$1.20',  age:'58s', target:'Threat Radar'     },
  { from:'EdTech Safety Network',    to:'Healthcare Consortium', type:'Detection Rule',  price:'$3.75',  age:'2m',  target:'Evolution Engine' },
  { from:'LegalTech Exchange',       to:'Supply Chain AI Guild', type:'Detection Rule',  price:'$1.50',  age:'4m',  target:'Evolution Engine' },
];

type TradeRow = typeof FALLBACK_TRADES[0];
type LiveTrade = { buyer_agent: string; seller_agent: string; asset_type?: string; price_usd?: number; created_at?: string; };

function assetTypeLabel(t: string): string {
  if (t.includes('detect') || t.includes('rule')) return 'Detection Rule';
  if (t.includes('model') || t.includes('semantic')) return 'Semantic Model';
  return 'Signal Bundle';
}
function targetLabel(t: string): string {
  if (t.includes('rule') || t.includes('detect')) return 'Evolution Engine';
  if (t.includes('model')) return 'Semantic Layer';
  return 'Threat Radar';
}
function ageLabel(ts: string): string {
  const diff = Math.floor((Date.now() - new Date(ts).getTime()) / 1000);
  if (diff < 60) return `${diff}s`;
  if (diff < 3600) return `${Math.floor(diff / 60)}m`;
  return `${Math.floor(diff / 3600)}h`;
}

let trades: TradeRow[] = FALLBACK_TRADES;
let summaryStats = { communities: 2847, assets: 18400, totalTrades: 94200 };

try {
  const [tradesResp, summaryResp] = await Promise.allSettled([
    fetch(`${API_URL}/marketplace/analytics/recent-trades?limit=6`, { signal: AbortSignal.timeout(3000) }),
    fetch(`${API_URL}/marketplace/analytics/summary`, { signal: AbortSignal.timeout(3000) }),
  ]);
  if (tradesResp.status === 'fulfilled' && tradesResp.value.ok) {
    const raw: LiveTrade[] = await tradesResp.value.json();
    if (Array.isArray(raw) && raw.length > 0) {
      trades = raw.map((t) => ({
        from:   t.buyer_agent  ?? 'Unknown Buyer',
        to:     t.seller_agent ?? 'Unknown Seller',
        type:   assetTypeLabel(t.asset_type ?? ''),
        price:  t.price_usd != null ? `$${t.price_usd.toFixed(2)}` : '—',
        age:    t.created_at ? ageLabel(t.created_at) : '—',
        target: targetLabel(t.asset_type ?? ''),
      }));
    }
  }
  if (summaryResp.status === 'fulfilled' && summaryResp.value.ok) {
    const s = await summaryResp.value.json();
    summaryStats = {
      communities: s.active_agents ?? summaryStats.communities,
      assets:      s.total_trades  ? s.total_trades * 3 : summaryStats.assets,
      totalTrades: s.total_trades  ?? summaryStats.totalTrades,
    };
  }
} catch { /* fail-open */ }
---

<BaseLayout
  title="Agentic Marketplace — Shadow Warden AI"
  description="The internet's first secure M2M marketplace. Your AI agents discover, negotiate, and settle detection intelligence at machine speed using x402 nanopayments and military-grade cryptography."
>

<style>
  *, *::before, *::after { box-sizing: border-box; }
  :root {
    --grn: #10b981; --amb: #fbbf24; --cyn: #38bdf8;
    --pur: #a78bfa; --pr:  #80b4fd;
    --ease: cubic-bezier(0.23,1,0.32,1);
  }

  .am-page { background:#03050f; min-height:100vh; color:#e2e8f0; }

  /* ── Hero ─────────────────────────────────────────────────── */
  .am-hero { position:relative; min-height:100vh; display:flex; align-items:center; overflow:hidden; padding:100px 0 60px; }
  #am-canvas { position:absolute; inset:0; width:100%; height:100%; }
  .am-hero-inner { max-width:1200px; margin:0 auto; padding:0 32px; width:100%; position:relative; z-index:1; }
  .am-hero-grid { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; margin-bottom:40px; }
  .live-badge { display:inline-flex; align-items:center; gap:8px; padding:5px 14px; border-radius:100px; margin-bottom:28px; font-size:10.5px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--grn); background:rgba(16,185,129,.07); border:1px solid rgba(16,185,129,.2); }
  .live-dot { width:6px; height:6px; border-radius:50%; background:var(--grn); animation:pulse-dot 2s infinite; }
  .am-h1 { font-size:clamp(34px,4.5vw,60px); font-weight:900; line-height:1.05; letter-spacing:-0.03em; color:#f0f4fc; margin:0 0 20px; }
  .am-sub { font-size:15px; line-height:1.7; color:#94a3b8; max-width:460px; margin:0 0 32px; }
  .am-btns { display:flex; gap:12px; flex-wrap:wrap; }
  .btn-green { display:inline-flex; align-items:center; gap:8px; padding:13px 24px; border-radius:10px; font-size:14px; font-weight:700; text-decoration:none; color:#070910; background:var(--grn); box-shadow:0 0 0 1px rgba(16,185,129,.4),0 8px 32px rgba(16,185,129,.25); transition:box-shadow .2s; }
  .btn-green:hover { box-shadow:0 0 0 1px rgba(16,185,129,.6),0 12px 40px rgba(16,185,129,.35); }
  .btn-ghost-am { display:inline-flex; align-items:center; gap:8px; padding:13px 24px; border-radius:10px; font-size:14px; font-weight:600; text-decoration:none; color:#a8b8d0; border:1px solid rgba(255,255,255,.1); background:rgba(255,255,255,.03); transition:border-color .2s,color .2s; }
  .btn-ghost-am:hover { border-color:rgba(255,255,255,.2); color:#f0f4fc; }

  .am-stats-bar { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
  .am-stat { background:rgba(4,7,16,.85); border:1px solid rgba(128,180,253,.1); border-radius:12px; padding:14px 16px; }
  .am-stat-n { display:block; font-size:22px; font-weight:800; color:var(--pr); line-height:1; font-variant-numeric:tabular-nums; }
  .am-stat-l { display:block; font-size:10.5px; color:#3d4f66; margin-top:4px; }

  /* ── Terminal ──────────────────────────────────────────────── */
  .am-terminal { background:#040b14; border:1px solid rgba(255,255,255,.07); border-radius:16px; overflow:hidden; box-shadow:0 32px 80px rgba(0,0,0,.5); }
  .am-term-bar { display:flex; align-items:center; gap:8px; padding:11px 16px; border-bottom:1px solid rgba(255,255,255,.06); background:#050e1c; }
  .am-term-dot { width:10px; height:10px; border-radius:50%; opacity:.7; }

  /* ── Sections ──────────────────────────────────────────────── */
  .sec { padding:80px 0; border-top:1px solid rgba(255,255,255,.05); }
  .sec-alt { background:rgba(5,8,18,.8); }
  .sec-inner { max-width:1100px; margin:0 auto; padding:0 32px; }
  .sec-inner-lg { max-width:1200px; margin:0 auto; padding:0 32px; }
  .sec-pre { font-size:10.5px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; margin-bottom:10px; }
  .sec-title { font-size:clamp(22px,3vw,34px); font-weight:800; color:#f0f4fc; margin-bottom:10px; line-height:1.2; letter-spacing:-0.02em; }
  .sec-sub { font-size:14px; color:#4d5e78; line-height:1.6; margin-bottom:40px; max-width:540px; }

  /* ── Eco flow ──────────────────────────────────────────────── */
  .eco-flow { display:flex; align-items:center; overflow-x:auto; padding-bottom:8px; }
  .eco-node { flex:1; min-width:150px; background:rgba(4,7,16,.9); border:1px solid rgba(128,180,253,.1); border-radius:14px; padding:18px 14px; text-align:center; }
  .eco-node-center { border-color:rgba(16,185,129,.25); background:rgba(16,185,129,.04); }
  .eco-arrow { font-size:18px; color:#1e2d40; padding:0 10px; flex-shrink:0; }
  .eco-ic { width:34px; height:34px; border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:800; margin:0 auto 10px; }
  .eco-ic-blue   { background:rgba(128,180,253,.12); border:1px solid rgba(128,180,253,.25); color:var(--pr); }
  .eco-ic-cyan   { background:rgba(56,189,248,.1);   border:1px solid rgba(56,189,248,.22);  color:var(--cyn); }
  .eco-ic-green  { background:rgba(16,185,129,.1);   border:1px solid rgba(16,185,129,.22);  color:var(--grn); }
  .eco-ic-amber  { background:rgba(251,191,36,.1);   border:1px solid rgba(251,191,36,.25);  color:var(--amb); }
  .eco-ic-purple { background:rgba(167,139,250,.1);  border:1px solid rgba(167,139,250,.22); color:var(--pur); }
  .eco-node-name { font-size:12px; font-weight:700; color:#c4d4ea; margin-bottom:5px; }
  .eco-node-desc { font-size:10px; color:#2d3a4e; line-height:1.5; }

  /* ── Asset types ──────────────────────────────────────────── */
  .asset-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
  .asset-card { border-radius:14px; border:1px solid rgba(128,180,253,.1); background:rgba(4,7,16,.9); padding:24px 20px; display:flex; flex-direction:column; gap:14px; }
  .asset-card-blue  { border-color:rgba(128,180,253,.18); }
  .asset-card-green { border-color:rgba(16,185,129,.16); }
  .asset-card-amber { border-color:rgba(251,191,36,.15); }
  .asset-ic { width:34px; height:34px; border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:800; flex-shrink:0; }
  .asset-meta { display:flex; flex-direction:column; gap:5px; border-top:1px solid rgba(128,180,253,.07); padding-top:12px; }
  .meta-row { display:flex; justify-content:space-between; align-items:center; }
  .meta-lbl { font-size:9.5px; color:#2d3a4e; font-weight:600; text-transform:uppercase; letter-spacing:.04em; }
  .meta-val { font-size:10.5px; color:#64748b; font-family:'JetBrains Mono',monospace; }

  /* ── How it works ─────────────────────────────────────────── */
  .how-steps { display:flex; flex-direction:column; max-width:680px; }
  .how-step { display:flex; gap:20px; padding:28px 0; border-bottom:1px solid rgba(128,180,253,.06); }
  .how-step:last-child { border-bottom:none; }
  .how-n { width:32px; height:32px; border-radius:50%; background:rgba(16,185,129,.1); border:1px solid rgba(16,185,129,.22); color:var(--grn); font-size:13px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px; }
  .how-title { font-size:14.5px; font-weight:700; color:#c4d4ea; margin-bottom:6px; }
  .how-desc { font-size:13px; color:#3d4f66; line-height:1.6; }

  /* ── Pillars ───────────────────────────────────────────────── */
  .pillar-grid { display:grid; grid-template-columns:1fr 1fr; gap:72px; align-items:center; }
  .pillar-tag { font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; margin-bottom:16px; }
  .pillar-h2 { font-size:clamp(24px,3vw,38px); font-weight:900; color:#f0f4fc; letter-spacing:-0.025em; line-height:1.1; margin:0 0 16px; }
  .pillar-p  { font-size:14px; line-height:1.7; color:#94a3b8; margin:0 0 24px; }
  .pillar-rows { display:flex; flex-direction:column; gap:10px; }
  .pillar-row { display:flex; justify-content:space-between; align-items:center; padding:10px 14px; border-radius:8px; }

  /* ── Activity feed ─────────────────────────────────────────── */
  .act-feed { display:flex; flex-direction:column; gap:2px; }
  .act-row { display:grid; grid-template-columns:28px 1fr auto auto; align-items:center; gap:12px; padding:10px 14px; border-radius:10px; border:1px solid rgba(128,180,253,.07); background:rgba(4,7,16,.9); font-size:11.5px; }
  .act-dot  { width:6px; height:6px; border-radius:50%; background:var(--grn); flex-shrink:0; }
  .act-from { color:#64748b; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .act-route { color:#2d3a4e; font-size:10px; margin-top:1px; }
  .act-price { font-weight:700; color:var(--amb); white-space:nowrap; }
  .act-badge { font-size:9.5px; padding:2px 7px; border-radius:20px; white-space:nowrap; }
  .act-badge-rule   { background:rgba(128,180,253,.08); border:1px solid rgba(128,180,253,.18); color:var(--pr); }
  .act-badge-model  { background:rgba(16,185,129,.07);  border:1px solid rgba(16,185,129,.18);  color:var(--grn); }
  .act-badge-signal { background:rgba(251,191,36,.07);  border:1px solid rgba(251,191,36,.18);  color:var(--amb); }

  /* ── Governance ────────────────────────────────────────────── */
  .gov-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; }
  .gov-card { background:#0a0d18; border:1px solid rgba(128,180,253,.1); border-radius:10px; padding:24px 20px; }
  .gov-val   { font-size:28px; font-weight:700; color:#80b4fd; margin-bottom:6px; font-variant-numeric:tabular-nums; }
  .gov-label { font-size:13px; font-weight:600; color:#b0c4e8; margin-bottom:4px; }
  .gov-hint  { font-size:11px; color:#3d4f6a; line-height:1.5; }

  /* ── Charts ────────────────────────────────────────────────── */
  .charts-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-top:40px; }
  .chart-panel { background:#090c19; border:1px solid rgba(128,180,253,.1); border-radius:14px; padding:24px; }
  .chart-panel-title { font-size:14px; font-weight:700; color:#c4d4ea; margin-bottom:4px; }
  .chart-panel-sub   { font-size:11.5px; color:#3d4f66; margin-bottom:20px; line-height:1.5; }
  .chart-wrap   { position:relative; height:220px; }
  .chart-status { font-size:10px; color:#2d3a4e; margin-top:10px; text-align:right; font-variant-numeric:tabular-nums; }
  .chart-span   { grid-column:1 / -1; }
  .tier-chart-inner { display:grid; grid-template-columns:200px 1fr; gap:32px; align-items:center; }
  .tier-stats { display:flex; flex-direction:column; gap:14px; }
  .tier-row { display:flex; align-items:center; gap:12px; }
  .tier-swatch { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
  .tier-label  { font-size:13px; font-weight:600; color:#c4d4ea; min-width:68px; }
  .tier-bar-wrap { flex:1; height:6px; background:rgba(255,255,255,.05); border-radius:3px; overflow:hidden; }
  .tier-bar    { height:100%; border-radius:3px; transition:width .6s var(--ease); }
  .tier-pct    { font-size:12px; color:#4d5e78; min-width:34px; text-align:right; font-variant-numeric:tabular-nums; }
  .savings-pill { display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:700; padding:5px 12px; border-radius:20px; background:rgba(16,185,129,.08); border:1px solid rgba(16,185,129,.2); color:var(--grn); margin-top:18px; }

  /* ── Community discovery ────────────────────────────────────── */
  .disc-bar { display:flex; flex-direction:column; gap:12px; margin-bottom:28px; }
  .srch-wrap { display:flex; align-items:center; gap:10px; background:rgba(4,7,16,.9); border:1px solid rgba(128,180,253,.16); border-radius:11px; padding:11px 16px; transition:border-color .18s,box-shadow .18s; }
  .srch-wrap:focus-within { border-color:rgba(128,180,253,.4); box-shadow:0 0 0 3px rgba(128,180,253,.06); }
  .srch-inp { flex:1; background:none; border:none; outline:none; color:#e2e8f0; font-size:14px; }
  .srch-inp::placeholder { color:#2d3a4e; }
  .srch-ct  { font-size:10.5px; color:#3d4a5c; font-family:'JetBrains Mono',monospace; background:rgba(128,180,253,.07); border:1px solid rgba(128,180,253,.1); padding:2px 8px; border-radius:4px; white-space:nowrap; }
  .filter-row { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
  .filter-lbl { font-size:10px; font-weight:700; color:#2d3a4e; text-transform:uppercase; letter-spacing:.1em; flex-shrink:0; }
  .cpills { display:flex; gap:6px; flex-wrap:wrap; }
  .cpill { display:flex; align-items:center; gap:5px; background:rgba(4,7,16,.7); border:1px solid rgba(255,255,255,.05); color:#64748b; font-size:11.5px; padding:5px 12px; border-radius:100px; cursor:pointer; transition:border-color .15s,color .15s,background .15s; }
  .cpill.on { background:rgba(128,180,253,.1); border-color:rgba(128,180,253,.32); color:var(--pr); }
  .cpill-n { background:rgba(255,255,255,.05); color:#3d4a5c; font-size:10px; font-weight:700; padding:0 5px; border-radius:3px; font-family:'JetBrains Mono',monospace; min-width:16px; text-align:center; }
  .cpill.on .cpill-n { background:rgba(128,180,253,.14); color:#80b4fd; }
  .comm-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:18px; }
  .comm-card { background:rgba(7,11,26,.92); border:1px solid rgba(255,255,255,.055); border-left:3px solid var(--cc,#80b4fd); border-radius:14px; display:flex; flex-direction:column; overflow:hidden; position:relative; transition:transform .2s,box-shadow .2s; }
  .comm-card:hover { transform:translateY(-3px); box-shadow:0 12px 40px rgba(0,0,0,.35); }
  .comm-card-bg { position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse at 0% 40%,var(--cc-dim,rgba(128,180,253,.05)) 0%,transparent 55%); }
  .comm-body { padding:18px 18px 0; display:flex; flex-direction:column; gap:12px; flex:1; position:relative; }
  .comm-hdr { display:flex; align-items:flex-start; gap:12px; }
  .comm-avatar { width:44px; height:44px; border-radius:11px; flex-shrink:0; background:var(--cc-dim,rgba(128,180,253,.1)); border:1px solid var(--cc-bdr,rgba(128,180,253,.22)); display:flex; align-items:center; justify-content:center; font-size:20px; }
  .comm-info { flex:1; min-width:0; }
  .comm-name { font-size:14px; font-weight:700; color:#f1f5f9; margin-bottom:5px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .comm-badges { display:flex; gap:5px; flex-wrap:wrap; }
  .cbdg { font-size:9.5px; font-weight:600; padding:2px 7px; border-radius:4px; letter-spacing:.03em; }
  .cbdg-ent  { background:rgba(128,180,253,.1);  color:#80b4fd; border:1px solid rgba(128,180,253,.2); }
  .cbdg-pro  { background:rgba(34,211,238,.08);  color:#67e8f9; border:1px solid rgba(34,211,238,.18); }
  .cbdg-com  { background:rgba(255,255,255,.05); color:#94a3b8; border:1px solid rgba(255,255,255,.1); }
  .cbdg-low  { background:rgba(52,211,153,.08);  color:#6ee7b7; border:1px solid rgba(52,211,153,.18); }
  .cbdg-med  { background:rgba(251,191,36,.08);  color:#fcd34d; border:1px solid rgba(251,191,36,.18); }
  .comm-desc-txt { font-size:12px; color:#64748b; line-height:1.6; }
  .comm-metrics { display:flex; align-items:stretch; background:rgba(255,255,255,.02); border:1px solid rgba(255,255,255,.04); border-radius:9px; overflow:hidden; }
  .comm-metric { flex:1; padding:8px 6px; text-align:center; border-right:1px solid rgba(255,255,255,.04); }
  .comm-metric:last-child { border-right:none; }
  .cmv { display:block; font-size:14px; font-weight:700; color:#f1f5f9; font-family:'JetBrains Mono',monospace; margin-bottom:1px; }
  .cml { font-size:9px; color:#2d3a4e; text-transform:uppercase; letter-spacing:.07em; }
  .comm-foot { display:flex; gap:8px; padding:14px 18px; border-top:1px solid rgba(255,255,255,.04); margin-top:4px; position:relative; }
  .btn-join { flex:1; background:var(--cc-dim,rgba(128,180,253,.08)); border:1px solid var(--cc-bdr,rgba(128,180,253,.22)); color:var(--cc,#80b4fd); font-size:12px; font-weight:600; padding:8px 14px; border-radius:8px; cursor:pointer; text-align:center; text-decoration:none; transition:background .14s; }
  .btn-join:hover { filter:brightness(1.15); }
  .btn-view { background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.07); color:#475569; font-size:12px; font-weight:500; padding:8px 12px; border-radius:8px; cursor:pointer; text-decoration:none; transition:border-color .14s,color .14s; white-space:nowrap; }
  .btn-view:hover { border-color:rgba(255,255,255,.14); color:#94a3b8; }

  /* ── Topology map ────────────────────────────────────────────── */
  .topo-band { background:linear-gradient(180deg,#040610 0%,#060d24 50%,#040610 100%); border-top:1px solid rgba(128,180,253,.07); border-bottom:1px solid rgba(128,180,253,.07); padding:72px 0; }
  .topo-box { height:400px; position:relative; background:rgba(4,7,16,.92); border:1px solid rgba(128,180,253,.1); border-radius:18px; overflow:hidden; }
  #topo-canvas { position:absolute; inset:0; width:100%; height:100%; cursor:crosshair; }
  .topo-tip { position:absolute; pointer-events:none; opacity:0; background:rgba(8,14,28,.96); border:1px solid rgba(128,180,253,.22); border-radius:9px; padding:9px 13px; z-index:10; backdrop-filter:blur(8px); transition:opacity .12s; white-space:nowrap; }
  .topo-tip.vis { opacity:1; }
  .tt-nm { font-size:12px; font-weight:600; color:#f1f5f9; margin-bottom:2px; }
  .tt-sub { font-size:10.5px; color:#64748b; }
  .topo-legend { display:flex; gap:18px; flex-wrap:wrap; align-items:center; }
  .leg-item { display:flex; align-items:center; gap:7px; font-size:11px; color:#475569; }
  .leg-ln { width:20px; height:2px; border-radius:1px; }

  /* ── Network activity ────────────────────────────────────────── */
  .act-cols { display:grid; grid-template-columns:1fr 300px; gap:20px; align-items:start; }
