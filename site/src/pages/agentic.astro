// ── Charts ────────────────────────────────────────────────────────────────
Chart.defaults.color = C.lo;
Chart.defaults.borderColor = C.dim;
Chart.defaults.font.family = 'JetBrains Mono, monospace';
Chart.defaults.font.size = 11;

function buildCharts(data) {
  const vol = data.volume_series || SEED_VOL;
  const payments = data.payment_breakdown || { flex_credits: 45, x402_usdc: 30, l402_lightning: 25 };
  const agents = data.agent_activity || [
    {date:'2026-06-27',count:34},{date:'2026-06-28',count:51},{date:'2026-06-29',count:28},
    {date:'2026-06-30',count:63},{date:'2026-07-01',count:45},{date:'2026-07-02',count:72},{date:'2026-07-03',count:58},
  ];

  // Volume chart
  const volCtx = document.getElementById('chart-volume');
  if (volCtx) new Chart(volCtx, {
    type: 'line',
    data: {
      labels: vol.map(d => d.date.slice(5)),
      datasets: [{
        label: 'Volume USD',
        data: vol.map(d => d.volume_usd),
        borderColor: C.green,
        backgroundColor: 'rgba(16,185,129,.08)',
        borderWidth: 2,
        fill: true,
        tension: .4,
        pointRadius: 3,
        pointBackgroundColor: C.green,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => `$${c.parsed.y.toFixed(2)}` } } },
      scales: {
        x: { grid: { color: 'rgba(31,41,55,.6)' } },
        y: { grid: { color: 'rgba(31,41,55,.6)' }, ticks: { callback: v => `$${v}` } }
      }
    }
  });

  // Payments doughnut
  const payCtx = document.getElementById('chart-payments');
  if (payCtx) new Chart(payCtx, {
    type: 'doughnut',
    data: {
      labels: ['Flex Credits', 'x402 USDC', 'L402 ⚡'],
      datasets: [{
        data: [payments.flex_credits || 45, payments.x402_usdc || 30, payments.l402_lightning || 25],
        backgroundColor: [C.cyan, C.violet, C.amber],
        borderColor: '#0d1017',
        borderWidth: 3,
      }]
    },
    options: {
      responsive: true,
      cutout: '65%',
      plugins: { legend: { position: 'bottom', labels: { padding: 12, boxWidth: 10 } } }
    }
  });

  // Agent activity bar
  const agCtx = document.getElementById('chart-agents');
  if (agCtx) new Chart(agCtx, {
    type: 'bar',
    data: {
      labels: agents.map(d => d.date ? d.date.slice(5) : ''),
      datasets: [{
        label: 'New agents',
        data: agents.map(d => d.count),
        backgroundColor: 'rgba(14,207,255,.3)',
        borderColor: C.cyan,
        borderWidth: 1,
        borderRadius: 3,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: { x: { grid: { display: false } }, y: { grid: { color: 'rgba(31,41,55,.6)' } } }
    }
  });
}

// Try to get real chart data, fall back to seed
async function loadCharts() {
  try {
    const r = await fetch(`${API_URL}/marketplace/analytics/chart-data?period_days=7`, { signal: AbortSignal.timeout(4000) });
    if (r.ok) { buildCharts(await r.json()); return; }
  } catch {}
  buildCharts({});
}
loadCharts();

// ── Agent table filter ─────────────────────────────────────────────────────
const agentSearch = document.getElementById('agent-search');
const agentsBody  = document.getElementById('agents-body');
let   kyaFilter   = 'all';

document.querySelectorAll('[data-kya]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('[data-kya]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    kyaFilter = btn.dataset.kya;
    filterAgents();
  });
});

if (agentSearch) agentSearch.addEventListener('input', filterAgents);

function filterAgents() {
  const q = (agentSearch ? agentSearch.value : '').toLowerCase();
  if (!agentsBody) return;
  agentsBody.querySelectorAll('tr').forEach(tr => {
    const kya = tr.dataset.kya || '';
    const txt = tr.textContent.toLowerCase();
    const show = (kyaFilter === 'all' || kya === kyaFilter) && (!q || txt.includes(q));
    tr.style.display = show ? '' : 'none';
  });
}

// ── Tool table filter ──────────────────────────────────────────────────────
const toolSearch = document.getElementById('tool-search');
const toolsBody  = document.getElementById('tools-body');
let   catFilter  = 'all';

document.querySelectorAll('[data-cat]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('[data-cat]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    catFilter = btn.dataset.cat;
    filterTools();
  });
});

if (toolSearch) toolSearch.addEventListener('input', filterTools);

function filterTools() {
  const q = (toolSearch ? toolSearch.value : '').toLowerCase();
  if (!toolsBody) return;
  toolsBody.querySelectorAll('tr').forEach(tr => {
    const cat = tr.dataset.cat || '';
    const txt = tr.textContent.toLowerCase();
    const show = (catFilter === 'all' || cat === catFilter) && (!q || txt.includes(q));
    tr.style.display = show ? '' : 'none';
  });
}

// ── Live stats refresh ─────────────────────────────────────────────────────
async function refreshStats() {
  try {
    const r = await fetch(`${API_URL}/marketplace/analytics/summary`, { signal: AbortSignal.timeout(3000) });
    if (!r.ok) return;
    const s = await r.json();
    const el = (id, val) => { const e = document.getElementById(id); if (e) e.textContent = val; };
    if (s.total_volume_usd) el('st-vol', `$${Number(s.total_volume_usd).toLocaleString()}`);
    if (s.total_trades)     el('st-trades', Number(s.total_trades).toLocaleString());
    if (s.registered_agents) el('st-agents', Number(s.registered_agents).toLocaleString());
    if (s.active_listings)  el('st-listings', Number(s.active_listings).toLocaleString());
  } catch {}
}
refreshStats();
setInterval(refreshStats, 30000);

// ── Scroll reveal ──────────────────────────────────────────────────────────
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.style.opacity='1'; e.target.style.transform='none'; io.unobserve(e.target); } });
}, {threshold: 0.08});
document.querySelectorAll('.chart-card,.auction-card,.pay-card,.sec-card,.endpoint').forEach(el => {
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    el.style.opacity='0'; el.style.transform='translateY(16px)'; el.style.transition='opacity .45s ease, transform .45s ease';
  }
  io.observe(el);
});

})();
</script>

