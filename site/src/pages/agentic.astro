let loopTimer;
function runTerm() {
  term.innerHTML = '';
  SEQ.forEach(([t, cls, txt], i) => {
    const prev = i > 0 ? SEQ[i-1][0] : 0;
    setTimeout(() => {
      const s = document.createElement('span');
      s.className = 't-' + cls;
      s.textContent = txt;
      term.appendChild(s);
      term.scrollTop = term.scrollHeight;
    }, t);
  });
  const last = SEQ[SEQ.length-1][0] + 300;
  setTimeout(() => {
    const c = document.createElement('span'); c.className = 'tcur'; term.appendChild(c);
  }, last);
  loopTimer = setTimeout(runTerm, last + 3500);
}
const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
