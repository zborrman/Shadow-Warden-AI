---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Shadow Warden AI">
  <div class="pt-14 min-h-screen flex items-center justify-center">
    <div class="text-center px-4">
      <div class="text-[80px] font-black leading-none mb-4" style="color:#1e1e2a">404</div>
      <h1 class="text-[24px] font-bold mb-3" style="color:#f1f5f9">Page not found</h1>
      <p class="text-[15px] mb-8" style="color:#64748b">This page was either blocked by the pipeline or doesn't exist.</p>
      <a href="/" class="btn-primary inline-block px-6 py-3 no-underline">Back to Home</a>
    </div>
  </div>
</BaseLayout>
