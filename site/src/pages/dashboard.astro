---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Dashboard — Shadow Warden AI"
            description="Full-stack AI security observability. OTel tracing, Prometheus/Grafana, SOC event log. See your ROI in 5 seconds.">
  <div class="pt-14">

    <!-- ── Hero ── -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 pointer-events-none"
           style="background-image:linear-gradient(rgba(10,132,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(10,132,255,0.03) 1px,transparent 1px);background-size:56px 56px"></div>
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[900px] h-[500px] pointer-events-none"
           style="background:radial-gradient(ellipse,rgba(10,132,255,0.07) 0%,transparent 65%)"></div>

      <div class="relative z-10 mx-auto max-w-5xl px-6 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6 text-[11px] font-bold tracking-widest uppercase"
             style="color:#0A84FF;background:rgba(10,132,255,0.08);border:1px solid rgba(10,132,255,0.2)">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#0A84FF"></span>
          Full-Stack Observability
        </div>
        <h1 class="text-[clamp(36px,5vw,68px)] font-black leading-[1.05] tracking-tight mb-5" style="color:#f1f5f9">
          See Everything.<br/>
          <span style="background:linear-gradient(135deg,#0A84FF,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
            Miss Nothing.
          </span>
        </h1>
        <p class="text-[17px] leading-relaxed max-w-2xl mx-auto mb-8" style="color:#94a3b8">
          OTel distributed tracing, Prometheus SLOs, live SOC event log,
          threat intelligence, and evidence vault — all in one place.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="https://portal.shadow-warden-ai.com" target="_blank"
             class="px-6 py-3 rounded-xl text-[14px] font-semibold transition-all"
             style="background:linear-gradient(135deg,#0A84FF,#06b6d4);color:#fff">
            Open SOC Dashboard →
          </a>
          <a href="/doc/quick-start"
             class="px-6 py-3 rounded-xl text-[14px] font-medium transition-colors"
             style="color:#94a3b8;border:1px solid rgba(255,255,255,0.08)">
            Quick Start
          </a>
        </div>
      </div>
    </section>

    <!-- ── Stats strip ── -->
    <section class="py-10 border-y" style="border-color:rgba(255,255,255,0.06);background:#0a0a0f">
      <div class="mx-auto max-w-5xl px-4 lg:px-8">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-px rounded-2xl overflow-hidden"
             style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.06)">
          {[
            { val:'9',      label:'Pipeline stages traced', color:'#0A84FF' },
            { val:'P99',    label:'< 50ms SLA',             color:'#10b981' },
            { val:'99.95%', label:'Enterprise uptime',      color:'#06b6d4' },
            { val:'782×',   label:'Pro plan ROI (IBM 2024)',  color:'#f59e0b' },
          ].map(s => (
            <div class="px-5 py-5 text-center" style="background:#0a0a0f">
              <div class="text-[26px] font-black leading-none mb-1" style={`color:${s.color}`}>{s.val}</div>
              <div class="text-[10px] font-semibold uppercase tracking-wider" style="color:#475569">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
         ROI CALCULATOR — "See your ROI in 5 seconds"
         ══════════════════════════════════════════════════════════ -->
    <section class="py-24" id="roi">
      <div class="mx-auto max-w-5xl px-4 lg:px-8">

        <!-- Section header -->
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4 text-[11px] font-semibold"
               style="color:#f59e0b;background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.2)">
            💰 ROI Calculator
          </div>
          <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold mb-3" style="color:#f1f5f9">
            See Your ROI in 5 Seconds
          </h2>
          <p class="text-[15px] max-w-xl mx-auto" style="color:#94a3b8">
            Based on IBM Cost of a Data Breach Report 2024. Adjust the sliders — results update instantly.
          </p>
        </div>

        <!-- Calculator card -->
        <div class="rounded-2xl overflow-hidden" style="background:#0d0d16;border:1px solid rgba(245,158,11,0.2)">
          <div class="grid lg:grid-cols-2">

            <!-- Left: inputs -->
            <div class="p-8 lg:p-10 border-b lg:border-b-0 lg:border-r" style="border-color:rgba(255,255,255,0.07)">

              <!-- Industry -->
              <div class="mb-7">
                <label class="block text-[11px] font-bold tracking-widest uppercase mb-3" style="color:#475569">
                  Industry
                </label>
                <div class="grid grid-cols-2 gap-2" id="industry-grid">
                  {[
                    { key:'healthcare',  label:'Healthcare',    mult:1.7,  icon:'🏥' },
                    { key:'finance',     label:'Finance',       mult:1.6,  icon:'🏦' },
                    { key:'technology',  label:'Technology',    mult:1.3,  icon:'💻' },
                    { key:'retail',      label:'Retail',        mult:1.1,  icon:'🛍️' },
                    { key:'education',   label:'Education',     mult:1.0,  icon:'🎓' },
                    { key:'other',       label:'Other',         mult:1.0,  icon:'🏢' },
                  ].map((ind, i) => (
                    <button
                      class="ind-btn flex items-center gap-2 px-3 py-2.5 rounded-xl text-[12px] font-medium text-left transition-all"
                      data-mult={ind.mult}
                      data-key={ind.key}
                      style={`background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);color:#94a3b8;${i === 0 ? 'background:rgba(245,158,11,0.12);border-color:rgba(245,158,11,0.4);color:#f59e0b' : ''}`}>
                      <span>{ind.icon}</span> {ind.label}
                      {ind.mult > 1 && <span class="ml-auto text-[10px] opacity-60">{ind.mult}×</span>}
                    </button>
                  ))}
                </div>
              </div>

              <!-- Monthly requests -->
              <div class="mb-7">
                <div class="flex items-center justify-between mb-2">
                  <label class="text-[11px] font-bold tracking-widest uppercase" style="color:#475569">
                    Monthly AI Requests
                  </label>
                  <span id="req-display" class="text-[13px] font-bold" style="color:#0A84FF">10,000</span>
                </div>
                <input id="req-slider" type="range" min="1000" max="500000" step="1000" value="10000"
                  class="roi-slider w-full h-1.5 rounded-full appearance-none cursor-pointer"
                  style="background:linear-gradient(90deg,#0A84FF 2%,rgba(255,255,255,0.1) 2%)"
                  aria-label="Monthly AI requests" />
                <div class="flex justify-between mt-1.5 text-[10px]" style="color:#334155">
                  <span>1K</span><span>50K</span><span>100K</span><span>250K</span><span>500K</span>
                </div>
              </div>

              <!-- Threat block rate -->
              <div class="mb-2">
                <div class="flex items-center justify-between mb-2">
                  <label class="text-[11px] font-bold tracking-widest uppercase" style="color:#475569">
                    Estimated Threat Rate
                  </label>
                  <span id="rate-display" class="text-[13px] font-bold" style="color:#ef4444">3%</span>
                </div>
                <input id="rate-slider" type="range" min="1" max="15" step="1" value="3"
                  class="roi-slider w-full h-1.5 rounded-full appearance-none cursor-pointer"
                  style="background:linear-gradient(90deg,#ef4444 20%,rgba(255,255,255,0.1) 20%)"
                  aria-label="Threat rate percentage" />
                <div class="flex justify-between mt-1.5 text-[10px]" style="color:#334155">
                  <span>1%</span><span>4%</span><span>8%</span><span>12%</span><span>15%</span>
                </div>
              </div>

            </div>

            <!-- Right: results -->
            <div class="p-8 lg:p-10 flex flex-col gap-5">

              <!-- Headline ROI -->
              <div class="rounded-xl p-5 text-center" style="background:rgba(245,158,11,0.06);border:1px solid rgba(245,158,11,0.18)">
                <div class="text-[11px] font-bold tracking-widest uppercase mb-1" style="color:#475569">Your Annual ROI</div>
                <div id="roi-multiple" class="text-[52px] font-black leading-none" style="color:#f59e0b">782×</div>
                <div class="text-[12px] mt-1" style="color:#64748b">vs. Pro plan cost ($828/yr)</div>
              </div>

              <!-- Key metrics -->
              <div class="grid grid-cols-2 gap-3">
                <div class="rounded-xl p-4" style="background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.12)">
                  <div class="text-[10px] font-semibold uppercase tracking-wider mb-1" style="color:#475569">Threats Blocked / yr</div>
                  <div id="roi-blocked" class="text-[22px] font-black" style="color:#ef4444">3,600</div>
                </div>
                <div class="rounded-xl p-4" style="background:rgba(16,185,129,0.06);border:1px solid rgba(16,185,129,0.12)">
                  <div class="text-[10px] font-semibold uppercase tracking-wider mb-1" style="color:#475569">Risk Exposure Averted</div>
                  <div id="roi-risk" class="text-[22px] font-black" style="color:#10b981">$648K</div>
                </div>
                <div class="rounded-xl p-4" style="background:rgba(10,132,255,0.06);border:1px solid rgba(10,132,255,0.12)">
                  <div class="text-[10px] font-semibold uppercase tracking-wider mb-1" style="color:#475569">Breach Probability ↓</div>
                  <div id="roi-prob" class="text-[22px] font-black" style="color:#0A84FF">−73%</div>
                </div>
                <div class="rounded-xl p-4" style="background:rgba(139,92,246,0.06);border:1px solid rgba(139,92,246,0.12)">
                  <div class="text-[10px] font-semibold uppercase tracking-wider mb-1" style="color:#475569">Net Annual Saving</div>
                  <div id="roi-saving" class="text-[22px] font-black" style="color:#8b5cf6">$647K</div>
                </div>
              </div>

              <!-- IBM source note -->
              <p class="text-[10px] leading-relaxed" style="color:#334155">
                Methodology: IBM 2024 avg. breach cost $4.88M × industry multiplier × threat-to-incident conversion rate (1-in-180 threats escalates to breach) × your block rate.
                <a href="https://www.ibm.com/reports/data-breach" target="_blank" rel="noopener"
                   class="underline ml-1" style="color:#475569">IBM Source →</a>
              </p>

              <a href="https://portal.shadow-warden-ai.com" target="_blank"
                 class="block text-center py-3 rounded-xl text-[13px] font-semibold transition-all"
                 style="background:linear-gradient(135deg,#f59e0b,#f97316);color:#000">
                Start Free Trial — See Live Numbers →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Feature grid ── -->
    <section class="pb-24">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold mb-3" style="color:#f1f5f9">
            Full Observability Stack
          </h2>
          <p class="text-[15px] max-w-xl mx-auto" style="color:#94a3b8">
            Every metric, every trace, every event — wired and ready.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {[
            {
              icon:'📋', color:'#0A84FF',
              title:'SOC Event Log',
              desc:'Per-request detail, verdict breakdown, stage timing, XAI causal chain. Filter by tenant, verdict, score range.',
            },
            {
              icon:'🔍', color:'#ef4444',
              title:'Threat Intelligence',
              desc:'ArXiv LLM-attack paper hunter + OSV CVE dependency scanner. Auto-synced every 6h by SOVA.',
            },
            {
              icon:'💰', color:'#f59e0b',
              title:'Financial Impact',
              desc:'IBM 2024 benchmarks, industry multipliers, ROI tiers. Generate proposals for your board in one click.',
            },
            {
              icon:'📡', color:'#06b6d4',
              title:'OTel Distributed Tracing',
              desc:'9 pipeline stage spans with GDPR-safe attributes. Jaeger UI pre-configured at :16686.',
            },
            {
              icon:'📊', color:'#10b981',
              title:'Prometheus + Grafana',
              desc:'SLO alerts: P99 latency, 5xx rate, shadow ban rate, corpus drift. Pre-built Grafana dashboards at :3000.',
            },
            {
              icon:'📤', color:'#8b5cf6',
              title:'SIEM Integration',
              desc:'Splunk HEC + Elastic ECS export. Real-time event push on BLOCK/HIGH verdicts.',
            },
            {
              icon:'🗄️', color:'#ec4899',
              title:'Evidence Vault',
              desc:'MinIO session bundles. STIX 2.1 audit chain export for SOC 2 Type II auditors. Date-partitioned.',
            },
            {
              icon:'🟢', color:'#30D158',
              title:'Uptime Monitor',
              desc:'HTTP/SSL/DNS/TCP checks. TimescaleDB aggregates. Slack + PagerDuty alerts. P99 < 50ms SLA guard.',
            },
          ].map(f => (
            <div class="p-5 rounded-2xl" style="background:#111118;border:1px solid rgba(255,255,255,0.07)">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[18px] mb-3"
                   style={`background:${f.color}18`}>{f.icon}</div>
              <h3 class="text-[14px] font-semibold mb-1.5" style="color:#f1f5f9">{f.title}</h3>
              <p class="text-[12px] leading-relaxed" style="color:#64748b">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Mock dashboard preview ── -->
    <section class="pb-24">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="rounded-2xl overflow-hidden" style="background:#0a0a0f;border:1px solid rgba(255,255,255,0.07)">

          <!-- Fake browser chrome -->
          <div class="flex items-center gap-2 px-4 py-3 border-b" style="border-color:rgba(255,255,255,0.06);background:#111118">
            <span class="w-3 h-3 rounded-full" style="background:#ef4444"></span>
            <span class="w-3 h-3 rounded-full" style="background:#f59e0b"></span>
            <span class="w-3 h-3 rounded-full" style="background:#10b981"></span>
            <span class="ml-3 text-[11px] font-mono px-3 py-1 rounded" style="color:#334155;background:rgba(255,255,255,0.03)">
              dashboard.shadow-warden-ai.com
            </span>
          </div>

          <!-- SOC mock UI -->
          <div class="p-6 grid lg:grid-cols-4 gap-4">

            <!-- Stat cards -->
            {[
              { label:'Requests today', val:'24,891',   delta:'+12%', color:'#0A84FF' },
              { label:'Threats blocked', val:'847',     delta:'+4%',  color:'#ef4444' },
              { label:'Avg score',       val:'0.23',    delta:'−8%',  color:'#10b981' },
              { label:'P99 latency',     val:'1.7ms',   delta:'−3%',  color:'#06b6d4' },
            ].map(s => (
              <div class="p-4 rounded-xl" style="background:#111118;border:1px solid rgba(255,255,255,0.06)">
                <div class="text-[10px] font-semibold uppercase tracking-wider mb-2" style="color:#475569">{s.label}</div>
                <div class="text-[24px] font-black mb-0.5" style={`color:${s.color}`}>{s.val}</div>
                <div class="text-[11px]" style="color:#334155">{s.delta} vs yesterday</div>
              </div>
            ))}

            <!-- Mini area chart (SVG) -->
            <div class="lg:col-span-3 p-4 rounded-xl" style="background:#111118;border:1px solid rgba(255,255,255,0.06)">
              <div class="text-[11px] font-semibold mb-3" style="color:#475569">Request volume — last 24h</div>
              <svg viewBox="0 0 600 80" class="w-full" style="height:80px" aria-hidden="true">
                <defs>
                  <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#0A84FF" stop-opacity="0.3"/>
                    <stop offset="100%" stop-color="#0A84FF" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path d="M0,60 C30,55 60,40 90,35 C120,30 150,45 180,38 C210,31 240,20 270,18 C300,16 330,28 360,22 C390,16 420,10 450,8 C480,6 510,14 540,12 L570,10 L600,8 L600,80 L0,80 Z"
                      fill="url(#areaGrad)"/>
                <path d="M0,60 C30,55 60,40 90,35 C120,30 150,45 180,38 C210,31 240,20 270,18 C300,16 330,28 360,22 C390,16 420,10 450,8 C480,6 510,14 540,12 L570,10 L600,8"
                      fill="none" stroke="#0A84FF" stroke-width="2"/>
              </svg>
            </div>

            <!-- Verdict breakdown -->
            <div class="p-4 rounded-xl" style="background:#111118;border:1px solid rgba(255,255,255,0.06)">
              <div class="text-[11px] font-semibold mb-3" style="color:#475569">Verdicts</div>
              <div class="space-y-2">
                {[
                  { label:'PASS',  pct:96.6, color:'#10b981' },
                  { label:'FLAG',  pct: 2.0, color:'#f59e0b' },
                  { label:'BLOCK', pct: 1.4, color:'#ef4444' },
                ].map(v => (
                  <div>
                    <div class="flex justify-between text-[10px] mb-1">
                      <span style={`color:${v.color}`}>{v.label}</span>
                      <span style="color:#334155">{v.pct}%</span>
                    </div>
                    <div class="h-1.5 rounded-full" style="background:rgba(255,255,255,0.06)">
                      <div class="h-1.5 rounded-full" style={`width:${v.pct}%;background:${v.color}`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Recent events table -->
            <div class="lg:col-span-4 p-4 rounded-xl" style="background:#111118;border:1px solid rgba(255,255,255,0.06)">
              <div class="text-[11px] font-semibold mb-3" style="color:#475569">Recent events</div>
              <div class="overflow-x-auto">
                <table class="w-full text-[11px]">
                  <thead>
                    <tr style="color:#334155">
                      <th class="text-left pb-2 font-medium">Time</th>
                      <th class="text-left pb-2 font-medium">Stage</th>
                      <th class="text-left pb-2 font-medium">Verdict</th>
                      <th class="text-right pb-2 font-medium">Score</th>
                      <th class="text-right pb-2 font-medium">Latency</th>
                    </tr>
                  </thead>
                  <tbody>
                    {[
                      { time:'just now',  stage:'brain',    verdict:'BLOCK', score:'0.94', lat:'1.8ms', color:'#ef4444' },
                      { time:'2s ago',    stage:'pass',     verdict:'PASS',  score:'0.11', lat:'1.2ms', color:'#10b981' },
                      { time:'5s ago',    stage:'causal',   verdict:'FLAG',  score:'0.68', lat:'2.1ms', color:'#f59e0b' },
                      { time:'8s ago',    stage:'topology', verdict:'BLOCK', score:'0.91', lat:'0.9ms', color:'#ef4444' },
                      { time:'12s ago',   stage:'pass',     verdict:'PASS',  score:'0.08', lat:'1.1ms', color:'#10b981' },
                    ].map(e => (
                      <tr style="border-top:1px solid rgba(255,255,255,0.04)">
                        <td class="py-1.5 pr-4" style="color:#334155">{e.time}</td>
                        <td class="py-1.5 pr-4 font-mono" style="color:#475569">{e.stage}</td>
                        <td class="py-1.5 pr-4">
                          <span class="px-2 py-0.5 rounded text-[10px] font-bold" style={`color:${e.color};background:${e.color}15`}>
                            {e.verdict}
                          </span>
                        </td>
                        <td class="py-1.5 pr-4 text-right font-mono" style={`color:${e.color}`}>{e.score}</td>
                        <td class="py-1.5 text-right" style="color:#334155">{e.lat}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="py-20 border-t" style="border-color:rgba(255,255,255,0.06)">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-black mb-4" style="color:#f1f5f9">
          Your SOC dashboard is ready
        </h2>
        <p class="text-[15px] mb-8" style="color:#94a3b8">
          14-day Pro trial · No credit card · Live data in 60 seconds
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="https://portal.shadow-warden-ai.com" target="_blank"
             class="px-6 py-3 rounded-xl text-[14px] font-semibold transition-all"
             style="background:linear-gradient(135deg,#0A84FF,#06b6d4);color:#fff">
            Open Dashboard →
          </a>
          <a href="#roi"
             class="px-6 py-3 rounded-xl text-[14px] font-medium transition-colors"
             style="color:#94a3b8;border:1px solid rgba(255,255,255,0.08)">
            Calculate My ROI
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* Slider track fill + thumb */
  .roi-slider { outline: none; }
  .roi-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px; height: 16px;
    border-radius: 50%;
    background: #f59e0b;
    border: 2px solid #0d0d16;
    box-shadow: 0 0 6px rgba(245,158,11,0.5);
    cursor: pointer;
    margin-top: -5px;
  }
  .roi-slider::-moz-range-thumb {
    width: 16px; height: 16px;
    border-radius: 50%;
    background: #f59e0b;
    border: 2px solid #0d0d16;
    cursor: pointer;
  }
  .roi-slider::-webkit-slider-runnable-track {
    height: 6px; border-radius: 3px;
  }
  .roi-slider::-moz-range-track {
    height: 6px; border-radius: 3px;
    background: rgba(255,255,255,0.1);
  }
</style>

<script>
(function() {

  // ── IBM 2024 baseline ──────────────────────────────────────────
  var BASE_BREACH_COST = 4880000;     // $4.88M avg
  var THREAT_TO_BREACH_RATE = 1/180; // 1 in 180 threats becomes a breach
  var PLAN_COST_ANNUAL = 828;         // Pro $69/mo × 12
  var BREACH_PROB_REDUCTION = 0.73;   // 73% lower breach probability with AI gateway

  // State
  var multiplier  = 1.7;  // healthcare default (first selected)
  var reqMonth    = 10000;
  var threatRatePct = 3;

  function fmt(n) {
    if (n >= 1000000) return '$' + (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000)    return '$' + Math.round(n / 1000) + 'K';
    return '$' + Math.round(n);
  }
  function fmtNum(n) {
    return n >= 1000 ? (n >= 1000000 ? (n/1000000).toFixed(1)+'M' : Math.round(n/1000)+'K') : String(n);
  }

  function recalc() {
    var reqYear     = reqMonth * 12;
    var threats     = Math.round(reqYear * (threatRatePct / 100));
    var breachSaved = threats * THREAT_TO_BREACH_RATE * BASE_BREACH_COST * multiplier;
    var roiMult     = Math.round(breachSaved / PLAN_COST_ANNUAL);
    var netSaving   = breachSaved - PLAN_COST_ANNUAL;

    document.getElementById('roi-multiple').textContent = roiMult.toLocaleString() + '×';
    document.getElementById('roi-blocked').textContent  = fmtNum(threats);
    document.getElementById('roi-risk').textContent     = fmt(breachSaved);
    document.getElementById('roi-saving').textContent   = fmt(netSaving);
  }

  // ── Industry buttons ──────────────────────────────────────────
  var indBtns = document.querySelectorAll('.ind-btn');
  for (var i = 0; i < indBtns.length; i++) {
    indBtns[i].addEventListener('click', function() {
      for (var j = 0; j < indBtns.length; j++) {
        indBtns[j].style.background    = 'rgba(255,255,255,0.03)';
        indBtns[j].style.borderColor   = 'rgba(255,255,255,0.08)';
        indBtns[j].style.color         = '#94a3b8';
      }
      this.style.background  = 'rgba(245,158,11,0.12)';
      this.style.borderColor = 'rgba(245,158,11,0.4)';
      this.style.color       = '#f59e0b';
      multiplier = parseFloat(this.getAttribute('data-mult'));
      recalc();
    });
  }

  // ── Request slider ──────────────────────────────────────────
  var reqSlider = document.getElementById('req-slider');
  var reqDisplay = document.getElementById('req-display');
  reqSlider.addEventListener('input', function() {
    reqMonth = parseInt(this.value);
    var pct  = ((reqMonth - 1000) / (500000 - 1000)) * 100;
    this.style.background = 'linear-gradient(90deg,#0A84FF ' + pct + '%,rgba(255,255,255,0.1) ' + pct + '%)';
    reqDisplay.textContent = reqMonth >= 1000 ? (reqMonth/1000).toFixed(reqMonth % 1000 === 0 ? 0 : 1) + 'K' : String(reqMonth);
    recalc();
  });

  // ── Threat rate slider ────────────────────────────────────────
  var rateSlider  = document.getElementById('rate-slider');
  var rateDisplay = document.getElementById('rate-display');
  rateSlider.addEventListener('input', function() {
    threatRatePct = parseInt(this.value);
    var pct = ((threatRatePct - 1) / 14) * 100;
    this.style.background = 'linear-gradient(90deg,#ef4444 ' + pct + '%,rgba(255,255,255,0.1) ' + pct + '%)';
    rateDisplay.textContent = threatRatePct + '%';
    recalc();
  });

  // Initial calculation
  recalc();

})();
</script>
