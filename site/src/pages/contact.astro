---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Shadow Warden AI"
  description="Get in touch with the Shadow Warden AI team. Sales, support, partnerships, and security inquiries."
>
  <div class="pt-14 min-h-screen" style="background:#03050f">
    <div class="mx-auto max-w-3xl px-4 lg:px-8 py-20">

      <!-- Header -->
      <div class="mb-14">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-5 text-[11px] font-bold tracking-widest uppercase"
             style="color:#6366f1;background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.2)">
          ◇ Get In Touch
        </div>
        <h1 class="text-[clamp(28px,4vw,44px)] font-black leading-tight tracking-tight mb-3" style="color:#f1f5f9">
          Contact Us
        </h1>
        <p class="text-[15px] leading-relaxed max-w-lg" style="color:#64748b">
          We typically respond within one business day. For urgent security incidents, use the emergency contact below.
        </p>
      </div>

      <!-- Contact cards -->
      <div class="grid sm:grid-cols-2 gap-4 mb-12">
        {[
          {
            icon: '💼',
            title: 'Sales & Pricing',
            desc: 'Enterprise plans, custom contracts, volume pricing, and partnership opportunities.',
            email: 'sales@shadow-warden-ai.com',
            color: '#6366f1',
          },
          {
            icon: '🛠️',
            title: 'Technical Support',
            desc: 'Integration help, bug reports, API questions, and deployment guidance.',
            email: 'support@shadow-warden-ai.com',
            color: '#10b981',
          },
          {
            icon: '🔒',
            title: 'Security & Compliance',
            desc: 'Responsible disclosure, GDPR requests, SOC 2 evidence, and security audits.',
            email: 'security@shadow-warden-ai.com',
            color: '#f59e0b',
          },
          {
            icon: '📰',
            title: 'Press & Media',
            desc: 'Press kit, analyst briefings, media inquiries, and partnership announcements.',
            email: 'press@shadow-warden-ai.com',
            color: '#8b5cf6',
          },
        ].map(({ icon, title, desc, email, color }) => (
          <div class="rounded-2xl p-5"
               style={`background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07)`}>
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 rounded-xl flex items-center justify-center text-[18px]"
                   style={`background:${color}12;border:1px solid ${color}25`}>
                {icon}
              </div>
              <div class="text-[14px] font-bold" style="color:#f1f5f9">{title}</div>
            </div>
            <p class="text-[12px] leading-relaxed mb-4" style="color:#64748b">{desc}</p>
            <a href={`mailto:${email}`}
               class="inline-flex items-center gap-1.5 text-[12px] font-semibold transition-opacity hover:opacity-70"
               style={`color:${color}`}>
              {email}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
          </div>
        ))}
      </div>

      <!-- Divider -->
      <div class="border-t mb-12" style="border-color:rgba(255,255,255,0.06)"></div>

      <!-- Quick links -->
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { label: 'Documentation', href: '/doc', icon: '📖', desc: 'Quick Start, API Reference, Compliance guides' },
          { label: 'Status & SLA',  href: '/doc/compliance', icon: '📊', desc: 'SOC 2, GDPR, uptime & SLA details' },
          { label: 'GitHub',        href: 'https://github.com/zborrman/Shadow-Warden-AI', icon: '⭐', desc: 'Open issues, star the repo, contribute' },
        ].map(({ label, href, icon, desc }) => (
          <a href={href}
             target={href.startsWith('http') ? '_blank' : undefined}
             rel={href.startsWith('http') ? 'noopener' : undefined}
             class="flex flex-col gap-2 rounded-2xl p-4 transition-colors"
             style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07)"
             onmouseover="this.style.borderColor='rgba(99,102,241,0.3)'"
             onmouseout="this.style.borderColor='rgba(255,255,255,0.07)'">
            <div class="text-[20px]">{icon}</div>
            <div class="text-[13px] font-semibold" style="color:#f1f5f9">{label}</div>
            <div class="text-[11px] leading-relaxed" style="color:#475569">{desc}</div>
          </a>
        ))}
      </div>

      <!-- Emergency -->
      <div class="mt-10 rounded-2xl px-5 py-4 flex items-start gap-3"
           style="background:rgba(239,68,68,0.04);border:1px solid rgba(239,68,68,0.15)">
        <span class="text-[18px] flex-shrink-0 mt-0.5">🚨</span>
        <div>
          <div class="text-[12px] font-bold mb-0.5" style="color:#ef4444">Security Emergency</div>
          <div class="text-[12px] leading-relaxed" style="color:#64748b">
            For active security incidents or zero-day vulnerability reports, email
            <a href="mailto:security@shadow-warden-ai.com" style="color:#ef4444;font-weight:600">
              security@shadow-warden-ai.com
            </a>
            with subject <span class="font-mono text-[11px]" style="color:#94a3b8">[URGENT]</span>.
            Enterprise customers have a dedicated emergency line in their SLA.
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
