---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Cyber Security — Shadow Warden AI">
  <div class="pt-14">

    <!-- ── Hero ── -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 pointer-events-none"
           style="background-image:linear-gradient(rgba(239,68,68,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(239,68,68,0.03) 1px,transparent 1px);background-size:56px 56px"></div>
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[900px] h-[500px] pointer-events-none"
           style="background:radial-gradient(ellipse,rgba(239,68,68,0.07) 0%,transparent 65%)"></div>

      <div class="relative z-10 mx-auto max-w-5xl px-6 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6 text-[11px] font-bold tracking-widest uppercase"
             style="color:#FF2D55;background:rgba(255,45,85,0.08);border:1px solid rgba(255,45,85,0.2)">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#FF2D55"></span>
          9-Stage Defense Pipeline
        </div>
        <h1 class="text-[clamp(36px,5vw,68px)] font-black leading-[1.05] tracking-tight mb-5" style="color:#f1f5f9">
          AI Security That<br/>
          <span style="background:linear-gradient(135deg,#FF2D55,#f97316);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
            Thinks Ahead
          </span>
        </h1>
        <p class="text-[17px] leading-relaxed max-w-2xl mx-auto mb-4" style="color:#94a3b8">
          Every AI request passes through 9 causal defense layers in under 2ms.
          Self-improving rules, autonomous SOC agent, post-quantum crypto.
        </p>
      </div>
    </section>

    <!-- ── Pipeline ── -->
    <section class="py-12 border-y" style="border-color:rgba(255,255,255,0.06);background:#0a0a0f">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-9 gap-2">
          {[
            { n:'01', name:'Topology',    icon:'📐', color:'#ef4444', desc:'Betti β₀/β₁' },
            { n:'02', name:'Obfuscation', icon:'🔄', color:'#f97316', desc:'depth-3 decode' },
            { n:'03', name:'Secrets',     icon:'🔑', color:'#f59e0b', desc:'15 patterns + entropy' },
            { n:'04', name:'Rules',       icon:'📏', color:'#10b981', desc:'compound risk' },
            { n:'05', name:'Brain',       icon:'🧠', color:'#06b6d4', desc:'MiniLM + Poincaré' },
            { n:'06', name:'Causal',      icon:'🎯', color:'#6366f1', desc:'Bayesian DAG' },
            { n:'07', name:'Phish',       icon:'🎣', color:'#8b5cf6', desc:'URL + SE-Arbiter' },
            { n:'08', name:'ERS',         icon:'🚫', color:'#ec4899', desc:'shadow ban' },
            { n:'09', name:'Decision',    icon:'✅', color:'#10b981', desc:'verdict + XAI' },
          ].map((s, i) => (
            <div class="flex flex-col items-center gap-1.5 p-3 rounded-xl text-center"
                 style="background:#111118;border:1px solid rgba(255,255,255,0.07)">
              <div class="text-[9px] font-bold" style="color:#475569">{s.n}</div>
              <div class="text-[20px]">{s.icon}</div>
              <div class="text-[10px] font-semibold leading-tight" style={`color:${s.color}`}>{s.name}</div>
              <div class="text-[9px]" style="color:#334155">{s.desc}</div>
            </div>
          ))}
        </div>
        <div class="flex justify-center mt-5">
          <span class="text-[13px] font-semibold px-4 py-1.5 rounded-full"
                style="color:#FF2D55;background:rgba(255,45,85,0.1);border:1px solid rgba(255,45,85,0.2)">
            Total latency &lt; 2ms
          </span>
        </div>
      </div>
    </section>

    <!-- ── SOVA Agent — Featured ── -->
    <section class="py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="rounded-2xl overflow-hidden" style="background:#0d0d16;border:1px solid rgba(99,102,241,0.2)">
          <div class="grid lg:grid-cols-2">

            <!-- Left: description -->
            <div class="p-10 lg:p-14">
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-[11px] font-bold tracking-widest uppercase"
                   style="color:#6366f1;background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.2)">
                ⚡ SOVA Agent
              </div>
              <h2 class="text-[clamp(1.5rem,3vw,2.2rem)] font-black leading-tight mb-4" style="color:#f1f5f9">
                Autonomous SOC<br/>Operations Agent
              </h2>
              <p class="text-[15px] leading-relaxed mb-8" style="color:#94a3b8">
                SOVA (Shadow Operations Vigilance Agent) is a Claude Opus 4.6 agentic loop that runs
                your SOC autonomously — threat syncs, key rotation, visual patrol, morning briefs —
                all on a cron schedule with 30 specialist tools.
              </p>

              <div class="grid grid-cols-2 gap-3 mb-8">
                {[
                  { val:'30',      label:'Specialist tools' },
                  { val:'7',       label:'ARQ cron schedules' },
                  { val:'≤10',     label:'Agentic iterations' },
                  { val:'6h TTL',  label:'Redis memory' },
                ].map(s => (
                  <div class="p-4 rounded-xl" style="background:rgba(99,102,241,0.06);border:1px solid rgba(99,102,241,0.12)">
                    <div class="text-[22px] font-black mb-0.5" style="color:#6366f1">{s.val}</div>
                    <div class="text-[11px]" style="color:#475569">{s.label}</div>
                  </div>
                ))}
              </div>

              <a href="https://portal.shadow-warden-ai.com" target="_blank"
                 class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-[13px] font-semibold transition-all"
                 style="background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff">
                Try SOVA →
              </a>
            </div>

            <!-- Right: schedule cards -->
            <div class="border-l p-10 lg:p-14" style="border-color:rgba(255,255,255,0.07)">
              <p class="text-[11px] font-bold tracking-widest uppercase mb-6" style="color:#475569">
                Scheduled cron jobs
              </p>
              <div class="space-y-2.5">
                {[
                  { job:'sova_morning_brief',  time:'08:00 UTC daily',              icon:'☀️', desc:'Threat summary + SLA health' },
                  { job:'sova_threat_sync',    time:'Every 6h',                     icon:'🔍', desc:'CVE scan + ArXiv intel' },
                  { job:'sova_rotation_check', time:'02:00 UTC daily',              icon:'🔑', desc:'Automated key rotation' },
                  { job:'sova_sla_report',     time:'Monday 09:00 UTC',             icon:'📊', desc:'Weekly SLA + ROI report' },
                  { job:'sova_upgrade_scan',   time:'Sunday 10:00 UTC',             icon:'⬆️', desc:'Dependency upgrade check' },
                  { job:'sova_corpus_watchdog',time:'Every 30 min',                 icon:'🛡️', desc:'ML corpus drift detector' },
                  { job:'sova_visual_patrol',  time:'03:00 UTC daily',              icon:'👁️', desc:'Claude Vision page audit' },
                ].map(j => (
                  <div class="flex items-start gap-3 px-4 py-3 rounded-xl"
                       style="background:rgba(255,255,255,0.025);border:1px solid rgba(255,255,255,0.05)">
                    <span class="text-[16px] shrink-0 mt-0.5">{j.icon}</span>
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center justify-between gap-2">
                        <code class="text-[11px] font-mono" style="color:#6366f1">{j.job}</code>
                        <span class="text-[10px] shrink-0" style="color:#334155">{j.time}</span>
                      </div>
                      <p class="text-[11px] mt-0.5" style="color:#475569">{j.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Feature grid ── -->
    <section class="pb-24">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold mb-3" style="color:#f1f5f9">
            Full Security Stack
          </h2>
          <p class="text-[15px] max-w-xl mx-auto" style="color:#94a3b8">
            Every defense layer, observable and tunable.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {[
            {
              icon:'📐', color:'#ef4444',
              title:'Topological Gatekeeper',
              tier:'All tiers',
              desc:'Betti numbers β₀/β₁ from n-gram point clouds. Detects structural attack patterns invisible to regex in < 2ms.',
            },
            {
              icon:'🔄', color:'#f97316',
              title:'Obfuscation Decoder',
              tier:'All tiers',
              desc:'Depth-3 recursive decoder: base64, hex, ROT13, Caesar, word-split, UUencode, unicode homoglyphs. Nothing hides.',
            },
            {
              icon:'🔑', color:'#f59e0b',
              title:'Secret Redactor',
              tier:'All tiers',
              desc:'15 regex patterns + Shannon entropy scan. Zero plaintext in memory — Fernet-encrypted vault, HMAC reverse map.',
            },
            {
              icon:'🧠', color:'#06b6d4',
              title:'ML Jailbreak Detection',
              tier:'All tiers',
              desc:'MiniLM → Poincaré ball projection. 70% cosine + 30% hyperbolic blend. Adversarial suffix stripping built in.',
            },
            {
              icon:'🎯', color:'#6366f1',
              title:'Causal Arbiter',
              tier:'Pro · Enterprise',
              desc:'Bayesian DAG causal inference. Pearl do-calculus + backdoor correction. Gray-zone decisions with full audit trail.',
            },
            {
              icon:'🎣', color:'#8b5cf6',
              title:'PhishGuard + SE-Arbiter',
              tier:'All tiers',
              desc:'URL phishing analysis + social engineering detection (SEC-GAP-002). Stops impersonation and trust exploitation.',
            },
            {
              icon:'🕵️', color:'#ec4899',
              title:'Shadow AI Discovery',
              tier:'Pro · Add-on',
              desc:'18 AI providers. Async /24 subnet probe, DNS telemetry classifier. Finds unauthorised AI use before it becomes a breach.',
            },
            {
              icon:'🔬', color:'#10b981',
              title:'Explainable AI (XAI)',
              tier:'Individual+ · Add-on',
              desc:'9-stage causal chain per decision. HTML + PDF reports. Counterfactual remediations. Full audit trail for compliance.',
            },
            {
              icon:'🧬', color:'#f59e0b',
              title:'Evolution Engine',
              tier:'Pro · Enterprise',
              desc:'Claude Opus auto-generates detection rules from blocked requests. ArXiv paper synthesis. Hot-reload without restart.',
            },
            {
              icon:'🛡️', color:'#ef4444',
              title:'Data Poisoning Guard',
              tier:'Pro · Enterprise',
              desc:'CPT drift gate rejects corpus updates shifting any parameter > 25% from prior. Prevents slow-burn poisoning attacks.',
            },
            {
              icon:'🤖', color:'#6366f1',
              title:'SOVA Agent',
              tier:'All tiers',
              desc:'Claude Opus 4.6 agentic loop. 30 tools, 7 cron schedules. Autonomous morning briefs, threat syncs, visual patrol.',
            },
            {
              icon:'👥', color:'#8b5cf6',
              title:'MasterAgent',
              tier:'Pro · Enterprise',
              desc:'4 specialist sub-agents (ThreatHunter, ForensicsAgent, ComplianceAgent, SOVAOperator). HMAC task tokens. Human-in-the-loop.',
            },
          ].map(f => (
            <div class="p-6 rounded-2xl" style="background:#111118;border:1px solid rgba(255,255,255,0.07)">
              <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[18px]"
                     style={`background:${f.color}18`}>{f.icon}</div>
                <span class="text-[10px] font-semibold px-2 py-0.5 rounded-md"
                      style="color:#475569;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06)">
                  {f.tier}
                </span>
              </div>
              <h3 class="text-[14px] font-semibold mb-2" style="color:#f1f5f9">{f.title}</h3>
              <p class="text-[12px] leading-relaxed" style="color:#64748b">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="py-20 border-t" style="border-color:rgba(255,255,255,0.06)">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-black mb-4" style="color:#f1f5f9">
          Start protecting your AI today
        </h2>
        <p class="text-[15px] mb-8" style="color:#94a3b8">
          14-day Pro trial · No credit card · Deployed in 60 seconds
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="https://portal.shadow-warden-ai.com" target="_blank"
             class="px-6 py-3 rounded-xl text-[14px] font-semibold transition-all"
             style="background:linear-gradient(135deg,#FF2D55,#f97316);color:#fff">
            Start Free Trial
          </a>
          <a href="/doc/quick-start"
             class="px-6 py-3 rounded-xl text-[14px] font-medium transition-colors"
             style="color:#94a3b8;border:1px solid rgba(255,255,255,0.08)">
            Read the Docs
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
