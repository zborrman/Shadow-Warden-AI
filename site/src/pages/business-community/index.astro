<!-- ── Live stats fetch ── -->
<script>
  async function fetchStats() {
    try {
      const r = await fetch('/api/public/community', { signal: AbortSignal.timeout(3000) });
      if (!r.ok) return;
      const d = await r.json();
      const map = {
        members_count:     d.members_count,
        monthly_transfers: d.monthly_transfers,
        published_ueciid:  d.published_ueciid,
        avg_reputation:    d.average_reputation,
      };
      document.querySelectorAll('[data-stat]').forEach(el => {
        const val = map[el.dataset.stat];
        if (val != null) el.textContent = typeof val === 'number' && val > 100
          ? val.toLocaleString()
          : String(val);
      });
    } catch {
      // fail-open: static values remain
    }
  }
  fetchStats();
</script>

