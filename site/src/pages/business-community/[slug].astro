---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureList from '../../components/FeatureList.astro';
import roadmap from '../../data/roadmap.json';

export function getStaticPaths() {
  const features = roadmap.filter(r => r.category === 'Business Community');
  const subcats = [...new Set(features.map(r => r.subcategory))];
  function slugify(s: string) { return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''); }
  return subcats.map(sub => ({ params: { slug: slugify(sub) }, props: { sub } }));
}

const { sub } = Astro.props;
const features = roadmap.filter(r => r.category === 'Business Community' && r.subcategory === sub);
---

<BaseLayout title={`${sub} — Business Community — Shadow Warden AI`}>
  <div class="pt-14">
    <div class="border-b" style="border-color:rgba(255,255,255,0.06);background:#111118">
      <div class="mx-auto max-w-7xl px-4 lg:px-8 py-14">
        <div class="flex items-center gap-2 mb-4">
          <a href="/" class="text-[13px] hover:text-white transition-colors" style="color:#475569">Home</a>
          <span style="color:#1e1e2a">/</span>
          <a href="/business-community" class="text-[13px] hover:text-white transition-colors" style="color:#475569">Business Community</a>
          <span style="color:#1e1e2a">/</span>
          <span class="text-[13px]" style="color:#94a3b8">{sub}</span>
        </div>
        <h1 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold mb-2" style="color:#f1f5f9">{sub}</h1>
        <p class="text-[14px]" style="color:#475569">{features.length} features</p>
      </div>
    </div>
    <div class="mx-auto max-w-7xl px-4 lg:px-8 py-10">
      <FeatureList features={features} accent="#8b5cf6" />
    </div>
  </div>
</BaseLayout>
