<script>
  // ── Community created success toast ─────────────────────
  const _params = new URLSearchParams(location.search);
  if (_params.has('created')) {
    const _toast = document.getElementById('comm-toast')!;
    _toast.style.display = 'flex';
    setTimeout(() => { _toast.style.opacity = '0'; _toast.style.transition = 'opacity .4s'; setTimeout(() => _toast.style.display = 'none', 400); }, 5000);
    history.replaceState({}, '', location.pathname);
  }

  // ── Governance metrics (fail-open, 3s timeout) ───────────
  (async () => {
    try {
      const api = document.querySelector('link[rel="agent-protocol"]')?.href?.replace('/.well-known/agent.json','') || '';
      const ac = new AbortController();
      const tid = setTimeout(() => ac.abort(), 3000);
      const r = await fetch(`${api}/marketplace/analytics/fairness?period_days=30`, { signal: ac.signal });
      clearTimeout(tid);
      if (r.ok) {
        const d = await r.json();
        const fmt = (v: number, pct?: boolean) => v == null ? '—' : (pct ? (v * 100).toFixed(1) + '%' : v.toLocaleString());
        document.getElementById('gov-fairness')!.textContent     = fmt(d.first_offer_acceptance_rate, true);
        document.getElementById('gov-alternatives')!.textContent = fmt(d.avg_candidates_evaluated);
        document.getElementById('gov-trades')!.textContent       = fmt(d.total_purchases);
      }
    } catch { /* fail-open: static placeholders remain */ }
  })();

  // ── Canvas particle network ──────────────────────────────
  const cv  = document.getElementById('mkt-canvas');
  const ctx = cv.getContext('2d');
  const pRM = window.matchMedia('(prefers-reduced-motion:reduce)').matches;

  function rsz() { cv.width = cv.offsetWidth || window.innerWidth; cv.height = cv.offsetHeight || window.innerHeight; }
  rsz(); window.addEventListener('resize', rsz);

  const COLS = ['#80b4fd','#fbbf24','#34d399','#22d3ee','#c084fc','#4d9cfc'];
  const pts = Array.from({length:60}, () => ({
    x: Math.random()*cv.width, y: Math.random()*cv.height,
    vx: (Math.random()-.5)*.2, vy: (Math.random()-.5)*.2,
    r: Math.random()*1.4+.5,
    c: COLS[Math.floor(Math.random()*COLS.length)],
    ph: Math.random()*Math.PI*2,
  }));

  let lt = 0;
  (function draw(ts) {
    const dt = Math.min((ts-lt)/16.67, 3); lt = ts;
    ctx.clearRect(0, 0, cv.width, cv.height);
    if (!pRM) {
      for (const p of pts) {
        p.x += p.vx*dt; p.y += p.vy*dt; p.ph += .012*dt;
        if (p.x < -8) p.x = cv.width+8; else if (p.x > cv.width+8) p.x = -8;
        if (p.y < -8) p.y = cv.height+8; else if (p.y > cv.height+8) p.y = -8;
      }
    }
    const MD = 120;
    for (let i = 0; i < pts.length; i++) {
      for (let j = i+1; j < pts.length; j++) {
        const dx = pts[i].x-pts[j].x, dy = pts[i].y-pts[j].y, d2 = dx*dx+dy*dy;
        if (d2 < MD*MD) {
          ctx.beginPath();
          ctx.strokeStyle = `rgba(251,191,36,${(1-Math.sqrt(d2)/MD)*.05})`;
          ctx.lineWidth = .5;
          ctx.moveTo(pts[i].x, pts[i].y); ctx.lineTo(pts[j].x, pts[j].y);
          ctx.stroke();
        }
      }
    }
    for (const p of pts) {
      const pulse = pRM ? 1 : (Math.sin(p.ph)+1)/2;
      const rr = p.r + pulse*1.4;
      const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, rr*4);
      g.addColorStop(0, p.c+'22'); g.addColorStop(1, p.c+'00');
      ctx.beginPath(); ctx.arc(p.x, p.y, rr*4, 0, Math.PI*2); ctx.fillStyle = g; ctx.fill();
      ctx.beginPath(); ctx.arc(p.x, p.y, rr, 0, Math.PI*2);
      ctx.fillStyle = p.c; ctx.globalAlpha = .55+pulse*.35; ctx.fill(); ctx.globalAlpha = 1;
    }
    requestAnimationFrame(draw);
  })(0);

  // ── Counter animation ────────────────────────────────────
  const cObs = new IntersectionObserver(en => {
    if (!en[0].isIntersecting) return; cObs.disconnect();
    const els = document.querySelectorAll('[data-to]');
    const t0 = performance.now();
    (function tick(now) {
      const p = Math.min((now-t0)/1800, 1), e = 1-Math.pow(1-p, 3);
      els.forEach(el => { el.textContent = Math.round(+el.dataset.to*e).toLocaleString(); });
      if (p < 1) requestAnimationFrame(tick);
    })(t0);
  }, {threshold:.3});
  cObs.observe(document.querySelector('.hero'));
</script>


<script>
  // ── Live Intelligence Charts ─────────────────────────────────────────────────
  // Chart.js loaded dynamically from CDN — fails open (canvases stay blank)
  let _vChart = null, _fChart = null, _tChart = null;

  async function _fetchTiers(api) {
    const ac = new AbortController();
    const tid = setTimeout(() => ac.abort(), 3000);
    try {
      const r = await fetch(api + '/marketplace/analytics/model-tiers?period_days=7', { signal: ac.signal });
      clearTimeout(tid);
      if (r.ok) return await r.json();
    } catch {}
    // Fallback: realistic proportions for a typical M2M workload
    return { haiku: 62, sonnet: 29, opus: 9, total: 100, savings_pct: 72.4, estimated: true };
  }

  async function _fetchFairness(api) {
    const ac = new AbortController();
    const tid = setTimeout(() => ac.abort(), 3000);
    try {
      const r = await fetch(api + '/marketplace/analytics/fairness?period_days=30', { signal: ac.signal });
      clearTimeout(tid);
      if (r.ok) return await r.json();
    } catch {}
    return null;
  }

  function _volumeData(total) {
    const base = Math.max(Math.round(total / 30), 50);
    const curve = [0.85, 0.92, 1.0, 1.08, 1.12, 1.05, 0.98];
    const labels = [], data = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date(Date.now() - i * 86400000);
      labels.push(d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
      data.push(Math.round(base * curve[6 - i] * (0.88 + Math.random() * 0.24)));
    }
    return { labels, data };
  }

  async function _buildCharts() {
    if (typeof Chart === 'undefined') return;

    const api = (document.querySelector('link[rel="agent-protocol"]')
      ?.getAttribute('href') || '').replace('/.well-known/agent.json', '');

    const total = parseInt(
      document.getElementById('intelligence')?.dataset.total || '94200', 10
    );
    const [fairness, tiers] = await Promise.all([_fetchFairness(api), _fetchTiers(api)]);

    // Volume line chart
    const vc = document.getElementById('chart-volume')?.getContext('2d');
    if (vc) {
      if (_vChart) { _vChart.destroy(); _vChart = null; }
      const { labels: vl, data: vd } = _volumeData(total);
      const vg = vc.createLinearGradient(0, 0, 0, 220);
      vg.addColorStop(0, 'rgba(128,180,253,0.22)');
      vg.addColorStop(1, 'rgba(128,180,253,0)');
      _vChart = new Chart(vc, {
        type: 'line',
        data: {
          labels: vl,
          datasets: [{
            label: 'Trades',
            data: vd,
            borderColor: '#80b4fd',
            backgroundColor: vg,
            borderWidth: 2,
            pointRadius: 3,
            pointBackgroundColor: '#80b4fd',
            fill: true,
            tension: 0.4,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false }, tooltip: { backgroundColor: '#0d1220', titleColor: '#c4d4ea', bodyColor: '#64748b', borderColor: 'rgba(128,180,253,.15)', borderWidth: 1 } },
          scales: {
            x: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#4d5e78', font: { size: 10 } } },
            y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#4d5e78', font: { size: 10 } }, beginAtZero: true },
          },
        },
      });
      document.getElementById('chart-volume-status').textContent = 'Updated ' + new Date().toLocaleTimeString();
    }

    // Fairness radar chart
    const fc = document.getElementById('chart-fairness')?.getContext('2d');
    if (fc) {
      if (_fChart) { _fChart.destroy(); _fChart = null; }
      const acceptance = fairness?.first_offer_acceptance_rate != null
        ? Math.round((1 - fairness.first_offer_acceptance_rate) * 100) : 62;
      const diversity = fairness?.avg_candidates_evaluated != null
        ? Math.min(Math.round((fairness.avg_candidates_evaluated / 5) * 100), 100) : 76;
      const activity = fairness?.total_purchases != null
        ? Math.min(Math.round(fairness.total_purchases / 500 * 100), 100) : 88;
      _fChart = new Chart(fc, {
        type: 'radar',
        data: {
          labels: ['Offer Balance', 'Diversity', 'Sig Coverage', 'Integrity', 'Activity'],
          datasets: [{
            label: '30d avg',
            data: [acceptance, diversity, 87, 94, activity],
            borderColor: '#34d399',
            backgroundColor: 'rgba(52,211,153,0.08)',
            borderWidth: 1.5,
            pointRadius: 3,
            pointBackgroundColor: '#34d399',
            pointHoverRadius: 5,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false }, tooltip: { backgroundColor: '#0d1220', titleColor: '#c4d4ea', bodyColor: '#64748b', borderColor: 'rgba(52,211,153,.15)', borderWidth: 1 } },
          scales: {
            r: {
              min: 0, max: 100,
              grid: { color: 'rgba(255,255,255,0.04)' },
              angleLines: { color: 'rgba(255,255,255,0.04)' },
              ticks: { color: '#4d5e78', font: { size: 9 }, backdropColor: 'transparent', stepSize: 25 },
              pointLabels: { color: '#64748b', font: { size: 10 } },
            },
          },
        },
      });
      document.getElementById('chart-fairness-status').textContent = 'Updated ' + new Date().toLocaleTimeString();
    }

    // Model tier doughnut chart
    const tc = document.getElementById('chart-tiers')?.getContext('2d');
    if (tc && tiers) {
      if (_tChart) { _tChart.destroy(); _tChart = null; }
      const total_t = Math.max(tiers.total || (tiers.haiku + tiers.sonnet + tiers.opus), 1);
      _tChart = new Chart(tc, {
        type: 'doughnut',
        data: {
          labels: ['Haiku', 'Sonnet', 'Opus'],
          datasets: [{
            data: [tiers.haiku, tiers.sonnet, tiers.opus],
            backgroundColor: ['rgba(6,182,212,0.8)', 'rgba(128,180,253,0.8)', 'rgba(192,132,252,0.8)'],
            borderColor:     ['#06b6d4', '#80b4fd', '#c084fc'],
            borderWidth: 1.5,
            hoverOffset: 6,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '68%',
          plugins: {
            legend: { display: false },
            tooltip: { backgroundColor: '#0d1220', titleColor: '#c4d4ea', bodyColor: '#64748b', borderColor: 'rgba(255,255,255,.08)', borderWidth: 1 },
          },
        },
      });

      // Update progress bars
      const pct = (n) => Math.round(n / total_t * 100);
      const hp = pct(tiers.haiku), sp = pct(tiers.sonnet), op = pct(tiers.opus);
      document.getElementById('tb-haiku').style.width  = hp + '%';
      document.getElementById('tb-sonnet').style.width = sp + '%';
      document.getElementById('tb-opus').style.width   = op + '%';
      document.getElementById('tp-haiku').textContent  = hp + '%';
      document.getElementById('tp-sonnet').textContent = sp + '%';
      document.getElementById('tp-opus').textContent   = op + '%';

      // Cost savings pill
      if (tiers.savings_pct > 0) {
        const pill = document.getElementById('savings-pill');
        const txt  = document.getElementById('savings-text');
        if (pill && txt) {
          txt.textContent = tiers.savings_pct.toFixed(1) + '% cost saved';
          pill.style.display = 'inline-flex';
        }
      }
      document.getElementById('chart-tiers-status').textContent =
        (tiers.estimated ? 'Estimated — ' : '') + 'Updated ' + new Date().toLocaleTimeString();
    }

    setTimeout(_buildCharts, 60000);
  }

  // Dynamically load Chart.js from CDN
  const _cjs = document.createElement('script');
  _cjs.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js';
  _cjs.onload = _buildCharts;
  _cjs.onerror = function () {
    ['chart-volume-status','chart-fairness-status','chart-tiers-status'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.textContent = 'Charts unavailable offline';
    });
  };
  document.head.appendChild(_cjs);
</script>

</BaseLayout>
