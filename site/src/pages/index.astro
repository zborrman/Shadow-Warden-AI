    s.onload = function () {
      var canvas = document.getElementById('incidentChart');
      if (!canvas) return;
      new Chart(canvas.getContext('2d'), {
        type: 'line',
        data: {
          labels: ['Month 1', 'Month 2', 'Month 3', 'Month 4', 'Month 5', 'Month 6'],
          datasets: [
            {
