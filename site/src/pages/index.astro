              pointRadius: 3,
              pointHoverRadius: 5,
            },
            {
              label: 'After deployment',
              data: [142, 89, 54, 31, 18, 11],
              borderColor: '#34d399',
              backgroundColor: 'rgba(52,211,153,0.05)',
              borderWidth: 2,
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#34d399',
              pointRadius: 3,
              pointHoverRadius: 5,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#0c1020',
              borderColor: 'rgba(128,180,253,0.15)',
              borderWidth: 1,
              titleColor: '#f0f4fc',
              bodyColor: '#a8b8d0',
              padding: 10,
            },
          },
          scales: {
            x: {
              grid: { color: 'rgba(128,180,253,0.05)' },
              ticks: { color: '#6b7c96', font: { size: 11 } },
            },
            y: {
              grid: { color: 'rgba(128,180,253,0.05)' },
              ticks: { color: '#6b7c96', font: { size: 11 } },
              title: { display: true, text: 'AI incidents per month', color: '#6b7c96', font: { size: 10 } },
            },
          },
        },
      });
    };
    document.head.appendChild(s);

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.06 });

    document.querySelectorAll('.fade-in-section').forEach(function (el) {
      observer.observe(el);
    });
  })();
</script>

