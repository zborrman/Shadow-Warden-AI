<script is:inline>
  (function () {
    // Load Chart.js from CDN then init chart
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js';
    s.onload = function () {
      var canvas = document.getElementById('incidentChart');
      if (!canvas) return;
      new Chart(canvas.getContext('2d'), {
        type: 'line',
        data: {
          labels: ['Месяц 1', 'Месяц 2', 'Месяц 3', 'Месяц 4', 'Месяц 5', 'Месяц 6'],
          datasets: [
            {
              label: 'До Shadow Warden',
              data: [142, 158, 167, 149, 163, 155],
              borderColor: '#ef4444',
              backgroundColor: 'rgba(239,68,68,0.07)',
              borderWidth: 2.5,
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#ef4444',
              pointRadius: 4,
              pointHoverRadius: 6,
            },
            {
              label: 'После внедрения',
              data: [142, 89, 54, 31, 18, 11],
              borderColor: '#10b981',
              backgroundColor: 'rgba(16,185,129,0.07)',
              borderWidth: 2.5,
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#10b981',
              pointRadius: 4,
              pointHoverRadius: 6,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#0d0d14',
              borderColor: 'rgba(255,255,255,0.1)',
              borderWidth: 1,
              titleColor: '#f1f5f9',
              bodyColor: '#94a3b8',
              padding: 10,
            },
          },
          scales: {
            x: {
              grid: { color: 'rgba(255,255,255,0.04)' },
              ticks: { color: '#475569', font: { size: 12 } },
            },
            y: {
              grid: { color: 'rgba(255,255,255,0.04)' },
              ticks: { color: '#475569', font: { size: 12 } },
              title: { display: true, text: 'AI-инциденты в месяц', color: '#475569', font: { size: 11 } },
            },
          },
        },
      });
    };
    document.head.appendChild(s);

    // Intersection Observer fade-in
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.06 });

    document.querySelectorAll('.fade-in-section').forEach(function (el) {
      observer.observe(el);
    });
  })();
</script>

<style is:global>
  .fade-in-section {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .fade-in-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

