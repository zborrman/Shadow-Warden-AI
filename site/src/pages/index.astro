---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsoleSection from '../components/ConsoleSection.astro';
import roadmap from '../data/roadmap.json';

const shipped = roadmap.filter(r => r.status === 'shipped').length;
const categories = ['Business Community', 'Cyber Security', 'Dashboard', 'Settings', 'Docs', 'Price'];
const featCount = (cat: string) => roadmap.filter(r => r.category === cat).length;

const catCards = [
  {
    label: 'Business Community',
    href: '/business-community',
    color: '#8b5cf6',
    tint: 'rgba(139,92,246,.1)',
    icon: '◈',
    desc: 'Federated knowledge networks with cryptographic identity, sovereign data residency, and tamper-evident audit chains.',
    count: featCount('Business Community'),
    pills: ['SEP / UECIID', 'Peering', 'Reputation', 'Obsidian Plugin'],
  },
  {
    label: 'Cyber Security',
    href: '/cyber-security',
    color: '#ef4444',
    tint: 'rgba(239,68,68,.1)',
    icon: '⬡',
    desc: '9-stage causal defense pipeline. Every AI request is topologically analyzed, obfuscated decoded, and ML-scored in <2ms.',
    count: featCount('Cyber Security'),
    pills: ['SOVA Agent', 'MasterAgent', 'PQC', 'XAI Reports'],
  },
  {
    label: 'Dashboard',
    href: '/dashboard',
    color: '#6366f1',
    tint: 'rgba(99,102,241,.1)',
    icon: '▣',
    desc: 'Full-stack observability — OTel tracing, Prometheus/Grafana, Jaeger, SOC event log, and uptime monitoring.',
    count: featCount('Dashboard'),
    pills: ['Grafana', 'Jaeger', 'OTel Tracing', 'SOC Log'],
  },
  {
    label: 'Settings',
    href: '/settings',
    color: '#30D158',
    tint: 'rgba(48,209,88,.1)',
    icon: '⚙',
    desc: 'Secrets governance, sovereign data routing, GDPR controls, multi-tenant auth, and live config tuning without restarts.',
    count: featCount('Settings'),
    pills: ['Secrets Vault', 'GDPR', 'Sovereign Routing', 'Key Rotation'],
  },
  {
    label: 'Docs',
    href: '/doc/quick-start',
    color: '#f59e0b',
    tint: 'rgba(245,158,11,.1)',
    icon: '📄',
    desc: 'Quick start, full API reference, architecture deep-dive, GDPR DPIA, SOC 2 Type II controls, and integration guides.',
    count: featCount('Docs'),
    pills: ['Quick Start', 'API Reference', 'Security Model', 'SOC 2 Type II'],
  },
  {
    label: 'Price',
    href: '/price',
    color: '#f97316',
    tint: 'rgba(249,115,22,.1)',
    icon: '◇',
    desc: 'Starter to Enterprise. IBM 2024 breach data shows Pro plan ROI of 782×. 14-day trial, no card required.',
    count: roadmap.filter(r => r.category === 'Price').length,
    pills: ['Starter $0', 'Pro $69', 'Enterprise $249', 'Add-ons'],
  },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative min-h-screen flex flex-col items-center justify-center pt-14 overflow-hidden">
    <!-- Grid bg -->
    <div class="absolute inset-0 pointer-events-none"
         style="background-image:linear-gradient(rgba(99,102,241,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,0.03) 1px,transparent 1px);background-size:64px 64px"></div>
    <!-- Radials -->
    <div class="absolute pointer-events-none" style="top:10%;left:50%;transform:translateX(-50%);width:900px;height:600px;background:radial-gradient(ellipse,rgba(99,102,241,0.08) 0%,transparent 65%)"></div>
    <div class="absolute pointer-events-none" style="bottom:5%;right:5%;width:500px;height:400px;background:radial-gradient(ellipse,rgba(139,92,246,0.06) 0%,transparent 65%)"></div>

    <div class="relative z-10 mx-auto max-w-5xl px-4 lg:px-8 py-20 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-[12px] font-semibold"
           style="color:#6366f1;background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.2)">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#6366f1"></span>
        v4.19 · {shipped} features shipped · Production-ready
      </div>

      <h1 class="text-[clamp(40px,6vw,80px)] font-black leading-[1.05] tracking-tight mb-6"
          style="color:#f1f5f9;letter-spacing:-2px">
        Your AI. Your Rules.<br/>
        <span class="text-gradient">Your Fortress.</span>
      </h1>

      <p class="text-[18px] leading-relaxed max-w-2xl mx-auto mb-10 font-light" style="color:#94a3b8">
        14-layer real-time defense pipeline. Self-improving ML. Agentic SOC. Post-quantum cryptography.
        Sovereign AI Cloud across 8 jurisdictions.
        <span style="color:#f1f5f9;font-weight:400"> Deployed in 60 seconds.</span>
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 mb-16">
        <a href="https://portal.shadow-warden-ai.com" target="_blank" class="btn-primary text-[14px] px-6 py-3">
          Start Free Trial — $0
        </a>
        <a href="/doc/quick-start" class="btn-ghost text-[14px] px-6 py-3">
          Read the Docs
        </a>
        <a href="https://github.com/zborrman/Shadow-Warden-AI" target="_blank" rel="noopener"
           class="flex items-center gap-2 px-6 py-3 rounded-lg text-[14px] font-medium transition-colors"
           style="color:#94a3b8;border:1px solid rgba(255,255,255,0.08)"
           onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#f1f5f9'"
           onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.color='#94a3b8'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color:inherit">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Stats bar -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px rounded-2xl overflow-hidden max-w-2xl mx-auto"
           style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.06)">
        {[
          { val: '<2ms',  label: 'Pipeline Latency', color: '#6366f1' },
          { val: '9',     label: 'Defense Layers',   color: '#ef4444' },
          { val: '99.95%',label: 'Uptime SLA',       color: '#10b981' },
          { val: '782×',  label: 'Pro ROI (IBM 2024)', color: '#f59e0b' },
        ].map(s => (
          <div class="px-5 py-4 text-center" style="background:#0a0a0f">
            <div class="text-[24px] font-black leading-none mb-1" style={`color:${s.color}`}>{s.val}</div>
            <div class="text-[10px] font-semibold uppercase tracking-wider" style="color:#475569">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ConsoleSection />

  <!-- Category cards -->
  <section class="py-24 relative">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold mb-3" style="color:#f1f5f9">
          Everything You Need to Secure AI
        </h2>
        <p class="text-[15px] max-w-xl mx-auto" style="color:#94a3b8">
          From detection pipeline to community federation — every feature built and shipped.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {catCards.map(c => (
          <a href={c.href}
             class="group block rounded-2xl p-6 transition-all duration-200 no-underline"
             style={`background:#111118;border:1px solid rgba(255,255,255,0.07)`}
             onmouseover={`this.style.borderColor='${c.color}40';this.style.transform='translateY(-2px)'`}
             onmouseout="this.style.borderColor='rgba(255,255,255,0.07)';this.style.transform='translateY(0)'">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[18px] font-bold"
                     style={`background:${c.tint};color:${c.color}`}>
                  {c.icon}
                </div>
                <div>
                  <div class="text-[15px] font-semibold" style="color:#f1f5f9">{c.label}</div>
                  <div class="text-[11px]" style="color:#475569">{c.count} features</div>
                </div>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                   style="color:#475569" class="mt-1 group-hover:translate-x-1 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
            <p class="text-[13px] leading-relaxed mb-4" style="color:#94a3b8">{c.desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {c.pills.map(p => (
                <span class="text-[11px] px-2 py-0.5 rounded-md font-medium"
                      style={`color:${c.color};background:${c.tint}`}>{p}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- OWASP LLM coverage strip -->
  <section class="py-16 border-y" style="border-color:rgba(255,255,255,0.06);background:#111118">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="text-center mb-8">
        <span class="text-[12px] font-semibold tracking-widest uppercase" style="color:#475569">
          OWASP LLM Top 10 Coverage
        </span>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          'LLM01 Prompt Injection','LLM02 Insecure Output','LLM03 Training Data Poisoning',
          'LLM04 Model DoS','LLM05 Supply Chain','LLM06 Sensitive Info',
          'LLM07 Insecure Plugin','LLM08 Excessive Agency','LLM09 Overreliance','LLM10 Model Theft'
        ].map(item => (
          <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-[12px] font-medium"
               style="color:#10b981;background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.15)">
            <span>✓</span> {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pipeline overview -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4 text-[11px] font-semibold"
             style="color:#ef4444;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2)">
          ⬡ 9-Stage Defense Pipeline
        </div>
        <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold mb-3" style="color:#f1f5f9">
          Every Request. Every Time.
        </h2>
      </div>
      <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-9 gap-2">
        {[
          { n: '01', name: 'Topology',    icon: '📐', color: '#ef4444' },
          { n: '02', name: 'Obfuscation', icon: '🔄', color: '#f97316' },
          { n: '03', name: 'Secrets',     icon: '🔑', color: '#f59e0b' },
          { n: '04', name: 'Rules',       icon: '📏', color: '#10b981' },
          { n: '05', name: 'Brain',       icon: '🧠', color: '#06b6d4' },
          { n: '06', name: 'Causal',      icon: '🎯', color: '#6366f1' },
          { n: '07', name: 'Phish',       icon: '🎣', color: '#8b5cf6' },
          { n: '08', name: 'ERS',         icon: '🚫', color: '#ec4899' },
          { n: '09', name: 'Decision',    icon: '✅', color: '#10b981' },
        ].map((s, i) => (
          <div class="flex flex-col items-center gap-2 p-3 rounded-xl text-center transition-colors"
               style="background:#111118;border:1px solid rgba(255,255,255,0.06)">
            <div class="text-[9px] font-bold" style="color:#475569">{s.n}</div>
            <div class="text-[22px]">{s.icon}</div>
            <div class="text-[10px] font-semibold leading-tight" style={`color:${s.color}`}>{s.name}</div>
          </div>
        ))}
      </div>
      <div class="text-center mt-6">
        <span class="text-[13px] font-semibold px-4 py-1.5 rounded-full"
              style="color:#ef4444;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2)">
          Total latency &lt; 2ms
        </span>
      </div>
    </div>
  </section>

  <!-- ── EU Accessibility Widget (main page only) ── -->
  <div id="a11y-widget" aria-label="Accessibility options" role="region">

    <!-- Toggle button -->
    <button id="a11y-toggle"
      aria-expanded="false"
      aria-controls="a11y-panel"
      aria-label="Open accessibility options"
      style="position:fixed;bottom:24px;right:24px;z-index:9999;width:46px;height:46px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,0.5);background:linear-gradient(135deg,#6366f1,#8b5cf6);transition:transform .2s,box-shadow .2s"
      onmouseover="this.style.transform='scale(1.08)';this.style.boxShadow='0 6px 28px rgba(99,102,241,0.45)'"
      onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.5)'">
      <!-- Universal accessibility icon -->
      <svg width="22" height="22" viewBox="0 0 24 24" fill="white" aria-hidden="true">
        <circle cx="12" cy="4" r="2"/>
        <path d="M12 7c-2.21 0-4 1.79-4 4v5h2v5h4v-5h2v-5c0-2.21-1.79-4-4-4z"/>
      </svg>
    </button>

    <!-- Panel -->
    <div id="a11y-panel" role="dialog" aria-label="Accessibility settings" aria-modal="false"
      style="position:fixed;bottom:80px;right:24px;z-index:9998;width:300px;border-radius:16px;padding:0;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.6);background:#0d0d16;border:1px solid rgba(99,102,241,0.25);display:none;opacity:0;transform:translateY(8px) scale(0.97);transition:opacity .2s,transform .2s">

      <!-- Header -->
      <div style="padding:16px 18px 14px;border-bottom:1px solid rgba(255,255,255,0.07)">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div>
            <p style="font-size:14px;font-weight:700;color:#f1f5f9;margin:0 0 2px">Accessibility</p>
            <p style="font-size:10px;color:#475569;margin:0">EAA 2019/882 · WCAG 2.1 AA · EN 301 549</p>
          </div>
          <!-- EU flag badge -->
          <div style="display:flex;align-items:center;gap:5px;padding:4px 8px;border-radius:6px;background:rgba(0,51,153,0.15);border:1px solid rgba(0,51,153,0.3)">
            <span style="font-size:14px" aria-label="EU flag">🇪🇺</span>
            <span style="font-size:10px;font-weight:600;color:#4d7cfe">Compliant</span>
          </div>
        </div>
      </div>

      <!-- Controls -->
      <div style="padding:14px 18px;display:flex;flex-direction:column;gap:10px">

        <!-- Text size -->
        <div style="display:flex;align-items:center;justify-content:space-between">
          <span style="font-size:12px;color:#94a3b8;font-weight:500">Text size</span>
          <div style="display:flex;align-items:center;gap:4px">
            <button class="a11y-btn" data-action="font-down" aria-label="Decrease text size"
              style="width:30px;height:30px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.04);color:#94a3b8;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700">A−</button>
            <button class="a11y-btn" data-action="font-reset" aria-label="Reset text size"
              style="width:30px;height:30px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.04);color:#94a3b8;font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700">A</button>
            <button class="a11y-btn" data-action="font-up" aria-label="Increase text size"
              style="width:30px;height:30px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.04);color:#94a3b8;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700">A+</button>
          </div>
        </div>

        <!-- High contrast -->
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div>
            <span style="font-size:12px;color:#94a3b8;font-weight:500;display:block">High contrast</span>
            <span style="font-size:10px;color:#334155">WCAG 1.4.6 Enhanced</span>
          </div>
          <button class="a11y-toggle-btn" data-action="high-contrast" aria-pressed="false" aria-label="Toggle high contrast"
            style="width:42px;height:24px;border-radius:12px;border:none;cursor:pointer;background:rgba(255,255,255,0.1);position:relative;transition:background .2s">
            <span class="toggle-knob" style="position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;transform:translateX(0)"></span>
          </button>
        </div>

        <!-- Reduce motion -->
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div>
            <span style="font-size:12px;color:#94a3b8;font-weight:500;display:block">Reduce motion</span>
            <span style="font-size:10px;color:#334155">WCAG 2.3.3 Animation</span>
          </div>
          <button class="a11y-toggle-btn" data-action="reduce-motion" aria-pressed="false" aria-label="Toggle reduce motion"
            style="width:42px;height:24px;border-radius:12px;border:none;cursor:pointer;background:rgba(255,255,255,0.1);position:relative;transition:background .2s">
            <span class="toggle-knob" style="position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;transform:translateX(0)"></span>
          </button>
        </div>

        <!-- Dyslexia font -->
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div>
            <span style="font-size:12px;color:#94a3b8;font-weight:500;display:block">Dyslexia-friendly font</span>
            <span style="font-size:10px;color:#334155">OpenDyslexic typeface</span>
          </div>
          <button class="a11y-toggle-btn" data-action="dyslexia" aria-pressed="false" aria-label="Toggle dyslexia-friendly font"
            style="width:42px;height:24px;border-radius:12px;border:none;cursor:pointer;background:rgba(255,255,255,0.1);position:relative;transition:background .2s">
            <span class="toggle-knob" style="position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;transform:translateX(0)"></span>
          </button>
        </div>

        <!-- Focus indicators -->
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div>
            <span style="font-size:12px;color:#94a3b8;font-weight:500;display:block">Enhanced focus</span>
            <span style="font-size:10px;color:#334155">WCAG 2.4.11 Focus Appearance</span>
          </div>
          <button class="a11y-toggle-btn" data-action="focus" aria-pressed="false" aria-label="Toggle enhanced focus indicators"
            style="width:42px;height:24px;border-radius:12px;border:none;cursor:pointer;background:rgba(255,255,255,0.1);position:relative;transition:background .2s">
            <span class="toggle-knob" style="position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;transform:translateX(0)"></span>
          </button>
        </div>

        <!-- Reset -->
        <button id="a11y-reset" aria-label="Reset all accessibility settings"
          style="width:100%;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.08);background:transparent;color:#475569;font-size:11px;cursor:pointer;transition:color .2s,border-color .2s;margin-top:2px"
          onmouseover="this.style.color='#94a3b8';this.style.borderColor='rgba(255,255,255,0.15)'"
          onmouseout="this.style.color='#475569';this.style.borderColor='rgba(255,255,255,0.08)'">
          Reset all settings
        </button>
      </div>

      <!-- Footer -->
      <div style="padding:10px 18px 14px;border-top:1px solid rgba(255,255,255,0.05)">
        <p style="font-size:10px;color:#334155;margin:0;text-align:center;line-height:1.5">
          European Accessibility Act · Directive (EU) 2019/882<br/>
          WCAG 2.1 Level AA · EN 301 549 v3.2.1
        </p>
      </div>
    </div>
  </div>

  <!-- Dyslexia font CSS (loaded only when activated) -->
  <style id="a11y-styles">
    .a11y-high-contrast { filter: contrast(1.6) brightness(1.1); }
    .a11y-reduce-motion *, .a11y-reduce-motion *::before, .a11y-reduce-motion *::after {
      animation-duration: 0.001ms !important;
      transition-duration: 0.001ms !important;
    }
    .a11y-focus *:focus-visible {
      outline: 3px solid #6366f1 !important;
      outline-offset: 3px !important;
      border-radius: 4px !important;
    }
    @font-face {
      font-family: 'OpenDyslexic';
      src: url('https://cdn.jsdelivr.net/npm/open-dyslexic@1.0.3/open-dyslexic-regular.woff') format('woff');
      font-display: swap;
    }
    .a11y-dyslexia, .a11y-dyslexia * { font-family: 'OpenDyslexic', sans-serif !important; }
  </style>

<script>
(function () {
  const STORAGE_KEY = 'sw_a11y';
  const html = document.documentElement;

  let state = { fontScale: 0, highContrast: false, reduceMotion: false, dyslexia: false, focus: false };
  try { Object.assign(state, JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}')); } catch {}

  function save() { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }

  function applyFont() {
    const sizes = [0.85, 0.925, 1, 1.1, 1.2];
    const idx = Math.min(Math.max(state.fontScale + 2, 0), sizes.length - 1);
    html.style.fontSize = (sizes[idx] * 16) + 'px';
  }

  function applyAll() {
    html.classList.toggle('a11y-high-contrast', state.highContrast);
    html.classList.toggle('a11y-reduce-motion', state.reduceMotion);
    html.classList.toggle('a11y-dyslexia',      state.dyslexia);
    html.classList.toggle('a11y-focus',         state.focus);
    applyFont();
  }

  function setSwitch(btn, on) {
    btn.setAttribute('aria-pressed', String(on));
    btn.style.background = on ? 'rgba(99,102,241,0.7)' : 'rgba(255,255,255,0.1)';
    const knob = btn.querySelector('.toggle-knob');
    if (knob) knob.style.transform = on ? 'translateX(18px)' : 'translateX(0)';
  }

  function syncSwitches() {
    const map = {
      'high-contrast': state.highContrast,
      'reduce-motion': state.reduceMotion,
      'dyslexia':      state.dyslexia,
      'focus':         state.focus,
    };
    document.querySelectorAll('.a11y-toggle-btn').forEach(function(btn) {
      const action = btn.dataset.action;
      if (action in map) setSwitch(btn, map[action]);
    });
  }

  applyAll();
  syncSwitches();

  const toggleBtn = document.getElementById('a11y-toggle');
  const panel     = document.getElementById('a11y-panel');
  let open = false;

  function openPanel() {
    open = true;
    panel.style.display = 'block';
    requestAnimationFrame(function() {
      panel.style.opacity = '1';
      panel.style.transform = 'translateY(0) scale(1)';
    });
    toggleBtn.setAttribute('aria-expanded', 'true');
  }
  function closePanel() {
    open = false;
    panel.style.opacity = '0';
    panel.style.transform = 'translateY(8px) scale(0.97)';
    setTimeout(function() { if (!open) panel.style.display = 'none'; }, 200);
    toggleBtn.setAttribute('aria-expanded', 'false');
    toggleBtn.focus();
  }

  toggleBtn.addEventListener('click', function() { open ? closePanel() : openPanel(); });

  document.addEventListener('click', function(e) {
    if (open && !panel.contains(e.target) && e.target !== toggleBtn) closePanel();
  });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && open) closePanel(); });

  document.querySelectorAll('.a11y-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const action = btn.dataset.action;
      if (action === 'font-up')    state.fontScale = Math.min(state.fontScale + 1, 2);
      if (action === 'font-down')  state.fontScale = Math.max(state.fontScale - 1, -2);
      if (action === 'font-reset') state.fontScale = 0;
      applyFont(); save();
    });
  });

  document.querySelectorAll('.a11y-toggle-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const action = btn.dataset.action;
      if (action === 'high-contrast') state.highContrast = !state.highContrast;
      if (action === 'reduce-motion') state.reduceMotion = !state.reduceMotion;
      if (action === 'dyslexia')      state.dyslexia     = !state.dyslexia;
      if (action === 'focus')         state.focus        = !state.focus;
      applyAll(); syncSwitches(); save();
    });
  });

  document.getElementById('a11y-reset').addEventListener('click', function() {
    state = { fontScale: 0, highContrast: false, reduceMotion: false, dyslexia: false, focus: false };
    applyAll(); syncSwitches(); save();
  });
})();
</script>
</BaseLayout>

