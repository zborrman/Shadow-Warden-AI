---
import BaseLayout from '../layouts/BaseLayout.astro';
import roadmap from '../data/roadmap.json';

const shipped = roadmap.filter(r => r.status === 'shipped').length;
---

<BaseLayout>

<!-- ── 1. HERO ──────────────────────────────────────────────────────────── -->
<section class="relative min-h-screen flex flex-col items-center justify-center pt-14 overflow-hidden fade-in-section is-visible">
  <div class="absolute inset-0 pointer-events-none"
       style="background-image:linear-gradient(rgba(99,102,241,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,0.03) 1px,transparent 1px);background-size:64px 64px"></div>
  <div class="absolute pointer-events-none"
       style="top:10%;left:50%;transform:translateX(-50%);width:900px;height:600px;background:radial-gradient(ellipse,rgba(99,102,241,0.10) 0%,transparent 65%)"></div>
  <div class="absolute pointer-events-none"
       style="bottom:5%;right:5%;width:500px;height:400px;background:radial-gradient(ellipse,rgba(139,92,246,0.07) 0%,transparent 65%)"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-4 lg:px-8 py-20 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-[12px] font-semibold"
         style="color:#6366f1;background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.2)">
      <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#6366f1"></span>
      v4.30 · {shipped} features shipped · GDPR · SOC 2 · ISO 27001
    </div>

    <h1 class="text-[clamp(36px,5.5vw,74px)] font-black leading-[1.05] tracking-tight mb-6"
        style="color:#f1f5f9;letter-spacing:-2px">
      Shadow Warden AI —<br/>
      <span class="text-gradient">Полная защита вашего ИИ‑стека</span>
    </h1>

    <p class="text-[18px] leading-relaxed max-w-2xl mx-auto mb-10 font-light" style="color:#94a3b8">
      9-слойный фильтр реального времени. Блокировка джейлбрейков, утечек секретов и PII.
      Самообучающийся ML-движок.
      <span style="color:#f1f5f9;font-weight:400"> Развёрнут за 60 секунд.</span>
    </p>

    <div class="flex flex-wrap items-center justify-center gap-3 mb-16">
      <a href="https://portal.shadow-warden-ai.com" target="_blank" class="btn-primary text-[14px] px-7 py-3.5">
        Начать бесплатно — $0
      </a>
      <a href="mailto:zbrvladimir@gmail.com?subject=Demo%20Request%20—%20Shadow%20Warden%20AI"
         class="btn-ghost text-[14px] px-7 py-3.5">
        Запланировать демо
      </a>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-px rounded-2xl overflow-hidden max-w-2xl mx-auto"
         style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.06)">
      {[
        { val: '9',      label: 'Слоёв защиты',  color: '#6366f1' },
        { val: '<2ms',   label: 'Латентность',   color: '#ef4444' },
        { val: '99.95%', label: 'Uptime SLA',    color: '#10b981' },
        { val: '782×',   label: 'ROI (IBM 2024)', color: '#f59e0b' },
      ].map(s => (
        <div class="px-5 py-4 text-center" style="background:#0a0a0f">
          <div class="text-[24px] font-black leading-none mb-1" style={`color:${s.color}`}>{s.val}</div>
          <div class="text-[10px] font-semibold uppercase tracking-wider" style="color:#475569">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ── 2. KEY NUMBERS ───────────────────────────────────────────────────── -->
<section class="py-20 fade-in-section" style="background:#111118;border-top:1px solid rgba(255,255,255,0.06)">
  <div class="mx-auto max-w-6xl px-4 lg:px-8">
    <div class="text-center mb-12">
      <div class="text-[12px] font-bold uppercase tracking-widest mb-3" style="color:#475569">Почему Shadow Warden</div>
      <h2 class="text-[clamp(1.4rem,3vw,2rem)] font-bold" style="color:#f1f5f9">Цифры говорят сами за себя</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        { val: '9',   unit: 'слоёв',    icon: '🛡️', color: '#6366f1',
          desc: 'Топология, деобфускация, ML, причинный вывод — всё в одном пайплайне' },
        { val: '<2',  unit: 'мс',       icon: '⚡', color: '#ef4444',
          desc: 'Полный цикл фильтра включая MiniLM и Betti-числа — быстрее сетевого RTT' },
        { val: '30+', unit: 'инструм.', icon: '🤖', color: '#8b5cf6',
          desc: 'SOVA-агент управляет SOC: сканирование, визуальный патруль, Redis-память' },
        { val: '82%', unit: 'покрытие', icon: '✅', color: '#10b981',
          desc: '126+ SMB-тестов, мутационное тестирование, adversarial-сьюты' },
      ].map(s => (
        <div class="rounded-2xl p-6 text-center transition-transform hover:-translate-y-1 duration-200"
             style="background:#0d0d14;border:1px solid rgba(255,255,255,0.07)">
          <div class="text-3xl mb-3">{s.icon}</div>
          <div class="flex items-end justify-center gap-1 mb-1">
            <span class="text-[42px] font-black leading-none" style={`color:${s.color}`}>{s.val}</span>
            <span class="text-[15px] font-bold pb-1.5" style="color:#94a3b8">{s.unit}</span>
          </div>
          <p class="text-[12px] leading-relaxed mt-2" style="color:#64748b">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ── 3. PAIN → SOLUTION ───────────────────────────────────────────────── -->
<section class="py-24 fade-in-section">
  <div class="mx-auto max-w-6xl px-4 lg:px-8">
    <div class="text-center mb-14">
      <div class="text-[12px] font-bold uppercase tracking-widest mb-3" style="color:#475569">Проблемы и решения</div>
      <h2 class="text-[clamp(1.4rem,3vw,2rem)] font-bold" style="color:#f1f5f9">Узнаёте свои боли?</h2>
      <p class="text-[15px] mt-3 max-w-lg mx-auto" style="color:#94a3b8">
        Shadow Warden решает их без изменения кода
      </p>
    </div>
    <div class="grid sm:grid-cols-2 gap-5">
      {[
        {
          pain:     '😰 Утечки данных через AI',
          solution: 'SecretRedactor',
          desc:     '15 regex-паттернов + Shannon entropy сканирование. API-ключи, JWT, пароли, PII удаляются до отправки в LLM.',
          color: '#ef4444', tint: 'rgba(239,68,68,.06)', href: '/cyber-security',
        },
        {
          pain:     '💸 Неконтролируемые AI-расходы',
          solution: 'Cost Allocation',
          desc:     'Отслеживание затрат по отделам и вендорам. Бюджетные лимиты, алерты, workflow согласования.',
          color: '#f59e0b', tint: 'rgba(245,158,11,.06)', href: '/business-community',
        },
        {
          pain:     '📋 GDPR и вендорский хаос',
          solution: 'Vendor Governance',
          desc:     'Реестр AI-вендоров, статусы DPA, алерты об истечении срока, скоринг compliance — автоматически.',
          color: '#6366f1', tint: 'rgba(99,102,241,.06)', href: '/business-community',
        },
        {
          pain:     '🔍 Непрозрачные AI-инциденты',
          solution: 'Incident Register + STIX + XAI',
          desc:     'Каждый инцидент в STIX 2.1 audit chain с причинной цепочкой XAI. Полная аудиторская тропа.',
          color: '#8b5cf6', tint: 'rgba(139,92,246,.06)', href: '/cyber-security',
        },
      ].map(c => (
        <a href={c.href}
           class="block rounded-2xl p-7 no-underline transition-all duration-200"
           style={`background:${c.tint};border:1px solid rgba(255,255,255,0.07)`}
           onmouseover={`this.style.borderColor='${c.color}50'`}
           onmouseout="this.style.borderColor='rgba(255,255,255,0.07)'">
          <div class="text-[17px] font-semibold mb-3" style="color:#94a3b8">{c.pain}</div>
          <div class="flex items-center gap-2 mb-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                 style={`color:${c.color}`}>
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
            <span class="text-[16px] font-bold" style={`color:${c.color}`}>{c.solution}</span>
          </div>
          <p class="text-[13px] leading-relaxed" style="color:#94a3b8">{c.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- ── 4. SVG PIPELINE ──────────────────────────────────────────────────── -->
<section class="py-24 fade-in-section" style="background:#111118;border-top:1px solid rgba(255,255,255,0.06)">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4 text-[11px] font-semibold"
           style="color:#ef4444;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2)">
        ⬡ 9-Stage Defense Pipeline
      </div>
      <h2 class="text-[clamp(1.4rem,3vw,2rem)] font-bold mb-2" style="color:#f1f5f9">
        Каждый запрос. Каждый раз.
      </h2>
      <p class="text-[14px]" style="color:#64748b">
        Полный цикл &lt;2мс — быстрее, чем сетевой RTT
      </p>
    </div>

    <div class="overflow-x-auto -mx-4 px-4 pb-2">
      <svg viewBox="0 0 970 100" width="970" style="min-width:970px;display:block;margin:0 auto"
           xmlns="http://www.w3.org/2000/svg" aria-label="Shadow Warden 9-stage defense pipeline diagram">
        <defs>
          <marker id="arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
            <path d="M0,0 L7,3 L0,6 Z" fill="#334155"/>
          </marker>
        </defs>

        <!-- Node 1: TopologicalGatekeeper -->
        <rect x="2" y="16" width="86" height="68" rx="6" fill="#0d0d14" stroke="#ef4444" stroke-width="1.5" stroke-opacity="0.7"/>
        <text x="45" y="32" text-anchor="middle" fill="#ef4444" font-family="monospace" font-size="9" opacity="0.8">01</text>
        <text x="45" y="53" text-anchor="middle" fill="#f1f5f9" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Topology</text>
        <text x="45" y="66" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="8">Gatekeeper</text>
        <circle cx="45" cy="76" r="3" fill="#ef4444" opacity="0.7"/>

        <!-- Arrow 1→2 -->
        <line x1="90" y1="50" x2="109" y2="50" stroke="#334155" stroke-width="1.5" marker-end="url(#arr)"/>

        <!-- Node 2: ObfuscationDecoder -->
        <rect x="112" y="16" width="86" height="68" rx="6" fill="#0d0d14" stroke="#f97316" stroke-width="1.5" stroke-opacity="0.7"/>
        <text x="155" y="32" text-anchor="middle" fill="#f97316" font-family="monospace" font-size="9" opacity="0.8">02</text>
        <text x="155" y="53" text-anchor="middle" fill="#f1f5f9" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Obfuscation</text>
        <text x="155" y="66" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="8">Decoder</text>
        <circle cx="155" cy="76" r="3" fill="#f97316" opacity="0.7"/>

        <!-- Arrow 2→3 -->
        <line x1="200" y1="50" x2="219" y2="50" stroke="#334155" stroke-width="1.5" marker-end="url(#arr)"/>

        <!-- Node 3: SecretRedactor -->
        <rect x="222" y="16" width="86" height="68" rx="6" fill="#0d0d14" stroke="#f59e0b" stroke-width="1.5" stroke-opacity="0.7"/>
        <text x="265" y="32" text-anchor="middle" fill="#f59e0b" font-family="monospace" font-size="9" opacity="0.8">03</text>
        <text x="265" y="53" text-anchor="middle" fill="#f1f5f9" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Secret</text>
        <text x="265" y="66" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="8">Redactor</text>
        <circle cx="265" cy="76" r="3" fill="#f59e0b" opacity="0.7"/>

        <!-- Arrow 3→4 -->
        <line x1="310" y1="50" x2="329" y2="50" stroke="#334155" stroke-width="1.5" marker-end="url(#arr)"/>

        <!-- Node 4: SemanticGuard -->
        <rect x="332" y="16" width="86" height="68" rx="6" fill="#0d0d14" stroke="#10b981" stroke-width="1.5" stroke-opacity="0.7"/>
        <text x="375" y="32" text-anchor="middle" fill="#10b981" font-family="monospace" font-size="9" opacity="0.8">04</text>
        <text x="375" y="53" text-anchor="middle" fill="#f1f5f9" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Semantic</text>
        <text x="375" y="66" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="8">Guard</text>
        <circle cx="375" cy="76" r="3" fill="#10b981" opacity="0.7"/>

        <!-- Arrow 4→5 -->
        <line x1="420" y1="50" x2="439" y2="50" stroke="#334155" stroke-width="1.5" marker-end="url(#arr)"/>

        <!-- Node 5: HyperbolicBrain -->
        <rect x="442" y="16" width="86" height="68" rx="6" fill="#0d0d14" stroke="#06b6d4" stroke-width="1.5" stroke-opacity="0.7"/>
        <text x="485" y="32" text-anchor="middle" fill="#06b6d4" font-family="monospace" font-size="9" opacity="0.8">05</text>
        <text x="485" y="53" text-anchor="middle" fill="#f1f5f9" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Hyperbolic</text>
        <text x="485" y="66" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="8">Brain</text>
        <circle cx="485" cy="76" r="3" fill="#06b6d4" opacity="0.7"/>

        <!-- Arrow 5→6 -->
        <line x1="530" y1="50" x2="549" y2="50" stroke="#334155" stroke-width="1.5" marker-end="url(#arr)"/>

        <!-- Node 6: CausalArbiter -->
        <rect x="552" y="16" width="86" height="68" rx="6" fill="#0d0d14" stroke="#6366f1" stroke-width="1.5" stroke-opacity="0.7"/>
        <text x="595" y="32" text-anchor="middle" fill="#6366f1" font-family="monospace" font-size="9" opacity="0.8">06</text>
        <text x="595" y="53" text-anchor="middle" fill="#f1f5f9" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Causal</text>
        <text x="595" y="66" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="8">Arbiter</text>
        <circle cx="595" cy="76" r="3" fill="#6366f1" opacity="0.7"/>

        <!-- Arrow 6→7 -->
        <line x1="640" y1="50" x2="659" y2="50" stroke="#334155" stroke-width="1.5" marker-end="url(#arr)"/>

        <!-- Node 7: PhishGuard -->
        <rect x="662" y="16" width="86" height="68" rx="6" fill="#0d0d14" stroke="#8b5cf6" stroke-width="1.5" stroke-opacity="0.7"/>
        <text x="705" y="32" text-anchor="middle" fill="#8b5cf6" font-family="monospace" font-size="9" opacity="0.8">07</text>
        <text x="705" y="53" text-anchor="middle" fill="#f1f5f9" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Phish</text>
        <text x="705" y="66" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="8">Guard</text>
        <circle cx="705" cy="76" r="3" fill="#8b5cf6" opacity="0.7"/>

        <!-- Arrow 7→8 -->
        <line x1="750" y1="50" x2="769" y2="50" stroke="#334155" stroke-width="1.5" marker-end="url(#arr)"/>

        <!-- Node 8: ERS -->
        <rect x="772" y="16" width="86" height="68" rx="6" fill="#0d0d14" stroke="#ec4899" stroke-width="1.5" stroke-opacity="0.7"/>
        <text x="815" y="32" text-anchor="middle" fill="#ec4899" font-family="monospace" font-size="9" opacity="0.8">08</text>
        <text x="815" y="53" text-anchor="middle" fill="#f1f5f9" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">ERS</text>
        <text x="815" y="66" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="8">Shadow Ban</text>
        <circle cx="815" cy="76" r="3" fill="#ec4899" opacity="0.7"/>

        <!-- Arrow 8→9 -->
        <line x1="860" y1="50" x2="879" y2="50" stroke="#334155" stroke-width="1.5" marker-end="url(#arr)"/>

        <!-- Node 9: Decision -->
        <rect x="882" y="16" width="86" height="68" rx="6" fill="#0d0d14" stroke="#10b981" stroke-width="1.5" stroke-opacity="0.9"/>
        <text x="925" y="32" text-anchor="middle" fill="#10b981" font-family="monospace" font-size="9" opacity="0.8">09</text>
        <text x="925" y="53" text-anchor="middle" fill="#f1f5f9" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Decision</text>
        <text x="925" y="66" text-anchor="middle" fill="#64748b" font-family="system-ui,sans-serif" font-size="8">ALLOW / BLOCK</text>
        <circle cx="925" cy="76" r="3" fill="#10b981" opacity="0.9"/>
      </svg>
    </div>

    <div class="flex justify-center mt-8">
      <span class="text-[13px] font-semibold px-5 py-2 rounded-full"
            style="color:#ef4444;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.25)">
        Суммарная задержка &lt; 2мс · Покрывает OWASP LLM Top 10
      </span>
    </div>
  </div>
</section>


<!-- ── 5. HOW IT WORKS ──────────────────────────────────────────────────── -->
<section class="py-24 fade-in-section">
  <div class="mx-auto max-w-5xl px-4 lg:px-8">
    <div class="text-center mb-14">
      <div class="text-[12px] font-bold uppercase tracking-widest mb-3" style="color:#475569">Интеграция за 3 шага</div>
      <h2 class="text-[clamp(1.4rem,3vw,2rem)] font-bold" style="color:#f1f5f9">Как это работает</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        {
          n: '01', icon: '🔌', color: '#6366f1',
          title: 'Подключите AI-сервисы',
          desc:  'Настройте Shadow Warden как proxy для OpenAI, Anthropic, Gemini или любого LLM. Один URL — никаких изменений кода.',
        },
        {
          n: '02', icon: '🛡️', color: '#8b5cf6',
          title: 'Трафик через Shadow Warden',
          desc:  '9-слойный фильтр обрабатывает каждый запрос: блокирует джейлбрейки, удаляет секреты, пишет инциденты в STIX-цепочку.',
        },
        {
          n: '03', icon: '📊', color: '#10b981',
          title: 'Алерты и отчёты',
          desc:  'Slack/Teams/PagerDuty в реальном времени. Grafana-дашборд, XAI-объяснения, SOC 2 доказательства — готовы к аудиту.',
        },
      ].map(s => (
        <div class="rounded-2xl p-6 h-full" style="background:#111118;border:1px solid rgba(255,255,255,0.07)">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center text-2xl flex-shrink-0"
                 style="background:rgba(99,102,241,.1)">
              {s.icon}
            </div>
            <span class="text-[11px] font-bold font-mono" style={`color:${s.color}`}>STEP {s.n}</span>
          </div>
          <h3 class="text-[17px] font-bold mb-3" style="color:#f1f5f9">{s.title}</h3>
          <p class="text-[13px] leading-relaxed" style="color:#94a3b8">{s.desc}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/doc/quick-start" class="inline-flex items-center gap-2 text-[14px] font-semibold"
         style="color:#6366f1">
        Читать Quick Start Guide
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>


<!-- ── 6. CHART.JS INCIDENT REDUCTION ──────────────────────────────────── -->
<section class="py-24 fade-in-section" style="background:#111118;border-top:1px solid rgba(255,255,255,0.06)">
  <div class="mx-auto max-w-4xl px-4 lg:px-8">
    <div class="text-center mb-12">
      <div class="text-[12px] font-bold uppercase tracking-widest mb-3" style="color:#475569">Реальный эффект</div>
      <h2 class="text-[clamp(1.4rem,3vw,2rem)] font-bold" style="color:#f1f5f9">
        Снижение AI-инцидентов после внедрения
      </h2>
      <p class="text-[14px] mt-2" style="color:#64748b">
        Среднее снижение по SMB-клиентам, первые 6 месяцев
      </p>
    </div>
    <div class="rounded-2xl p-6" style="background:#0d0d14;border:1px solid rgba(255,255,255,0.07)">
      <canvas id="incidentChart"></canvas>
    </div>
    <div class="flex items-center justify-center gap-8 mt-5 text-[13px]">
      <div class="flex items-center gap-2">
        <span class="inline-block w-5 h-0.5 rounded-full" style="background:#ef4444"></span>
        <span style="color:#94a3b8">До Shadow Warden</span>
