---
import BaseLayout from '../layouts/BaseLayout.astro';
import roadmap from '../data/roadmap.json';

const shipped = roadmap.filter(r => r.status === 'shipped').length;
---

<BaseLayout>

<!-- ── 1. HERO ──────────────────────────────────────────────────────────── -->
<section class="relative min-h-screen flex flex-col items-center justify-center pt-14 overflow-hidden fade-in-section is-visible">
  <div class="absolute inset-0 pointer-events-none"
       style="background:radial-gradient(ellipse 70% 40% at 50% 0%,rgba(128,180,253,0.06) 0%,transparent 70%)"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-4 lg:px-8 py-20 text-center">
    <div class="text-[12px] font-medium mb-5" style="color:#6b7c96;letter-spacing:0.01em">
      v7.4 · {shipped} features shipped · GDPR · SOC 2 · ISO 27001
    </div>

    <h1 class="font-black leading-[1.08] tracking-tight mb-5 text-balance"
        style="font-size:clamp(2rem,4.5vw,3.5rem);color:#f0f4fc;letter-spacing:-0.03em">
      The Internet's Native<br/>
      <span style="color:#06b6d4">Agentic Marketplace</span>
    </h1>

    <p class="leading-relaxed max-w-2xl mx-auto mb-10 font-light"
       style="font-size:15px;color:#a8b8d0">
      Deploy autonomous AI agents to buy, sell, and negotiate digital assets.
      <span style="color:#f0f4fc;font-weight:400"> Secured by military-grade cryptographic guardrails.</span>
    </p>

    <div class="flex flex-wrap items-center justify-center gap-3 mb-16">
      <a href="https://portal.shadow-warden-ai.com" target="_blank" class="btn-primary text-[14px] px-7 py-3">
        Start Free — $0
      </a>
      <a href="mailto:zbrvladimir@gmail.com?subject=Demo%20Request%20—%20Shadow%20Warden%20AI"
         class="btn-ghost text-[14px] px-7 py-3">
        Schedule a Demo
      </a>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-px max-w-2xl mx-auto rounded-lg overflow-hidden"
         style="background:rgba(6,182,212,0.08);border:1px solid rgba(6,182,212,0.15)">
      {[
        { val: '2,847',  label: 'Communities',   color: '#06b6d4' },
        { val: '18,400', label: 'Assets Listed',  color: '#10b981' },
        { val: '94,200', label: 'Trades',         color: '#80b4fd' },
        { val: '99%',    label: 'Auto-Imported',  color: '#fbbf24' },
      ].map(s => (
        <div class="px-5 py-4 text-center" style="background:#070910">
          <div class="text-[22px] font-black leading-none mb-1" style={`color:${s.color}`}>{s.val}</div>
          <div class="text-[10px] font-semibold uppercase tracking-wider" style="color:#404e66">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ── 2. KEY NUMBERS ───────────────────────────────────────────────────── -->
<section class="py-20 fade-in-section" style="background:#0c1020;border-top:1px solid rgba(128,180,253,0.08)">
  <div class="mx-auto max-w-6xl px-4 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-[20px] font-bold" style="color:#f0f4fc">Marketplace at a glance</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        { val: '2,847', unit: 'communities', color: '#06b6d4',
          desc: 'Business communities exchanging AI assets under SEP protocol with UECIID provenance tracking' },
        { val: '1.5%',  unit: 'take rate',   color: '#10b981',
          desc: 'Platform commission on cleared M2M transactions — computed with Decimal math, zero float drift' },
        { val: '<20',   unit: 'ms',          color: '#ef4444',
          desc: 'Causal Transfer Guard evaluates every trade — blocks exfiltration at P ≥ 0.70 in under 20ms' },
        { val: '30+',   unit: 'tools',       color: '#80b4fd',
          desc: 'SOVA agent manages your marketplace SOC: visual patrol, shadow AI discovery, corpus watchdog' },
      ].map(s => (
        <div class="rounded-lg p-5 border"
             style="background:#070910;border-color:rgba(6,182,212,0.09)">
          <div class="flex items-end gap-1 mb-2">
            <span class="text-[32px] font-black leading-none" style={`color:${s.color}`}>{s.val}</span>
            <span class="text-[13px] font-semibold pb-1" style="color:#6b7c96">{s.unit}</span>
          </div>
          <p class="text-[12px] leading-relaxed" style="color:#404e66">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ── 3. PAIN → SOLUTION ───────────────────────────────────────────────── -->
<section class="py-20 fade-in-section">
  <div class="mx-auto max-w-6xl px-4 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-[20px] font-bold mb-2" style="color:#f0f4fc">Recognize these pain points?</h2>
      <p style="font-size:14px;color:#6b7c96">
        Shadow Warden solves them without changing a line of your code.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 gap-4">
      {[
        {
          pain:     'Data leaks through AI',
          solution: 'SecretRedactor',
          desc:     '15 regex patterns + Shannon entropy scanning. API keys, JWTs, passwords, PII — stripped before reaching the LLM.',
          color: '#ef4444', href: '/cyber-security',
        },
        {
          pain:     'Uncontrolled AI spend',
          solution: 'Cost Allocation',
          desc:     'Per-department and per-vendor spend tracking. Budget caps, threshold alerts, and approval workflows built in.',
          color: '#fbbf24', href: '/business-community',
        },
        {
          pain:     'GDPR and vendor chaos',
          solution: 'Vendor Governance',
          desc:     'AI vendor registry, DPA status tracking, expiry alerts, and compliance scoring — fully automated.',
          color: '#80b4fd', href: '/business-community',
        },
        {
          pain:     'Opaque AI incidents',
          solution: 'Incident Register + STIX + XAI',
          desc:     'Every incident logged into a STIX 2.1 tamper-evident audit chain with a causal XAI explanation attached.',
          color: '#4d9cfc', href: '/cyber-security',
        },
      ].map(c => (
        <a href={c.href}
           class="block rounded-lg p-6 no-underline border transition-all duration-200"
           style={`background:#070910;border-color:rgba(128,180,253,0.09)`}
           onmouseover={`this.style.borderColor='${c.color}40'`}
           onmouseout="this.style.borderColor='rgba(128,180,253,0.09)'">
          <div class="text-[12px] font-medium mb-3 uppercase tracking-wider" style="color:#6b7c96">{c.pain}</div>
          <div class="flex items-center gap-2 mb-2">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                 style={`color:${c.color}`}>
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
            <span class="text-[15px] font-bold" style={`color:${c.color}`}>{c.solution}</span>
          </div>
          <p class="text-[13px] leading-relaxed" style="color:#6b7c96">{c.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- ── 3b. SECURITY MOAT ─────────────────────────────────────────────────── -->
<section class="py-20 fade-in-section" style="background:#070d1a;border-top:1px solid rgba(6,182,212,0.10)">
  <div class="mx-auto max-w-6xl px-4 lg:px-8">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded mb-4 text-[11px] font-semibold font-mono"
           style="color:#06b6d4;background:rgba(6,182,212,0.08);border:1px solid rgba(6,182,212,0.18)">
        Security Guarantee
      </div>
      <h2 class="text-[22px] font-bold mb-2" style="color:#f0f4fc">
        Marketplace-grade security built into every trade
      </h2>
      <p class="max-w-xl mx-auto" style="font-size:13px;color:#6b7c96">
        Every M2M transaction passes through a 9-layer cryptographic guardrail. Agents cannot collude, exfiltrate, or bypass governance — by design.
      </p>
    </div>

    <div class="grid sm:grid-cols-3 gap-4">
      <div class="rounded-xl p-6 border" style="background:rgba(6,182,212,0.04);border-color:rgba(6,182,212,0.15)">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center text-[16px] flex-shrink-0"
                style="background:rgba(6,182,212,0.12);border:1px solid rgba(6,182,212,0.25)">🔐</span>
          <span class="text-[13px] font-bold" style="color:#f0f4fc">Post-Quantum Cryptography</span>
        </div>
        <p class="text-[12px] leading-relaxed mb-3" style="color:#6b7c96">
          ML-DSA-65 (FIPS 204) hybrid signatures on every M2M trade proof. X25519 + ML-KEM-768 key encapsulation. Quantum-resistant by default on Enterprise.
        </p>
        <code class="text-[10px] font-mono px-2 py-1 rounded" style="color:#06b6d4;background:rgba(6,182,212,0.08)">
          HybridSigner · ML-DSA-65
        </code>
      </div>

      <div class="rounded-xl p-6 border" style="background:rgba(16,185,129,0.04);border-color:rgba(16,185,129,0.15)">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center text-[16px] flex-shrink-0"
                style="background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.25)">🛡</span>
          <span class="text-[13px] font-bold" style="color:#f0f4fc">Zero-Trust MCP Routing</span>
        </div>
        <p class="text-[12px] leading-relaxed mb-3" style="color:#6b7c96">
          Every agent request is authenticated, rate-limited, and jurisdiction-routed through MASQUE tunnels. No implicit trust — every hop is attested.
        </p>
        <code class="text-[10px] font-mono px-2 py-1 rounded" style="color:#10b981;background:rgba(16,185,129,0.08)">
          MASQUETunnel · SovereigntyAttestation
        </code>
      </div>

      <div class="rounded-xl p-6 border" style="background:rgba(139,92,246,0.04);border-color:rgba(139,92,246,0.15)">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center text-[16px] flex-shrink-0"
                style="background:rgba(139,92,246,0.12);border:1px solid rgba(139,92,246,0.25)">🤖</span>
          <span class="text-[13px] font-bold" style="color:#f0f4fc">SOVA Threat Analyst</span>
        </div>
        <p class="text-[12px] leading-relaxed mb-3" style="color:#6b7c96">
          Autonomous SOC operator running 24/7. Monitors agent collusion, goal misalignment, and model poisoning via the MAESTRO detector suite.
        </p>
        <code class="text-[10px] font-mono px-2 py-1 rounded" style="color:#8b5cf6;background:rgba(139,92,246,0.08)">
          SOVA · MAESTRO · WardenHealer
        </code>
      </div>
    </div>

    <div class="mt-8 rounded-xl p-5 flex flex-wrap items-center gap-4"
         style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06)">
      {[
        { label: 'GDPR Art. 35 DPIA', color: '#38bdf8' },
        { label: 'SOC 2 Type II', color: '#818cf8' },
        { label: 'ISO 27001:2022', color: '#f59e0b' },
        { label: 'OWASP LLM Top 10', color: '#10b981' },
        { label: 'PQC FIPS 203/204', color: '#06b6d4' },
        { label: 'Causal Transfer Guard', color: '#ef4444' },
      ].map(b => (
        <span class="text-[10px] font-bold px-3 py-1 rounded-full"
              style={`color:${b.color};background:${b.color}14;border:1px solid ${b.color}28`}>
          {b.label}
        </span>
      ))}
    </div>
  </div>
</section>


<!-- ── 4. SVG PIPELINE ──────────────────────────────────────────────────── -->
<section class="py-20 fade-in-section" style="background:#0c1020;border-top:1px solid rgba(128,180,253,0.08)">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded mb-4 text-[11px] font-semibold font-mono"
           style="color:#80b4fd;background:rgba(128,180,253,0.08);border:1px solid rgba(128,180,253,0.16)">
        9-Stage Defense Pipeline
      </div>
      <h2 class="text-[20px] font-bold mb-1" style="color:#f0f4fc">
        Every request. Every time.
      </h2>
      <p style="font-size:13px;color:#6b7c96">Full cycle &lt;2ms — faster than your network RTT</p>
    </div>

    <div class="overflow-x-auto -mx-4 px-4 pb-2">
      <svg viewBox="0 0 970 100" width="970" style="min-width:970px;display:block;margin:0 auto"
           xmlns="http://www.w3.org/2000/svg" aria-label="Shadow Warden 9-stage defense pipeline">
        <defs>
          <marker id="arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
            <path d="M0,0 L7,3 L0,6 Z" fill="#404e66"/>
          </marker>
        </defs>

        <rect x="2" y="16" width="86" height="68" rx="3" fill="#0c1020" stroke="#ef4444" stroke-width="1" stroke-opacity="0.6"/>
        <text x="45" y="32" text-anchor="middle" fill="#ef4444" font-family="monospace" font-size="9" opacity="0.7">01</text>
        <text x="45" y="53" text-anchor="middle" fill="#f0f4fc" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Topology</text>
        <text x="45" y="66" text-anchor="middle" fill="#6b7c96" font-family="system-ui,sans-serif" font-size="8">Gatekeeper</text>
        <circle cx="45" cy="76" r="2.5" fill="#ef4444" opacity="0.6"/>
        <line x1="90" y1="50" x2="109" y2="50" stroke="#404e66" stroke-width="1.5" marker-end="url(#arr)"/>

        <rect x="112" y="16" width="86" height="68" rx="3" fill="#0c1020" stroke="#fb923c" stroke-width="1" stroke-opacity="0.6"/>
        <text x="155" y="32" text-anchor="middle" fill="#fb923c" font-family="monospace" font-size="9" opacity="0.7">02</text>
        <text x="155" y="53" text-anchor="middle" fill="#f0f4fc" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Obfuscation</text>
        <text x="155" y="66" text-anchor="middle" fill="#6b7c96" font-family="system-ui,sans-serif" font-size="8">Decoder</text>
        <circle cx="155" cy="76" r="2.5" fill="#fb923c" opacity="0.6"/>
        <line x1="200" y1="50" x2="219" y2="50" stroke="#404e66" stroke-width="1.5" marker-end="url(#arr)"/>

        <rect x="222" y="16" width="86" height="68" rx="3" fill="#0c1020" stroke="#fbbf24" stroke-width="1" stroke-opacity="0.6"/>
        <text x="265" y="32" text-anchor="middle" fill="#fbbf24" font-family="monospace" font-size="9" opacity="0.7">03</text>
        <text x="265" y="53" text-anchor="middle" fill="#f0f4fc" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Secret</text>
        <text x="265" y="66" text-anchor="middle" fill="#6b7c96" font-family="system-ui,sans-serif" font-size="8">Redactor</text>
        <circle cx="265" cy="76" r="2.5" fill="#fbbf24" opacity="0.6"/>
        <line x1="310" y1="50" x2="329" y2="50" stroke="#404e66" stroke-width="1.5" marker-end="url(#arr)"/>

        <rect x="332" y="16" width="86" height="68" rx="3" fill="#0c1020" stroke="#34d399" stroke-width="1" stroke-opacity="0.6"/>
        <text x="375" y="32" text-anchor="middle" fill="#34d399" font-family="monospace" font-size="9" opacity="0.7">04</text>
        <text x="375" y="53" text-anchor="middle" fill="#f0f4fc" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Semantic</text>
        <text x="375" y="66" text-anchor="middle" fill="#6b7c96" font-family="system-ui,sans-serif" font-size="8">Guard</text>
        <circle cx="375" cy="76" r="2.5" fill="#34d399" opacity="0.6"/>
        <line x1="420" y1="50" x2="439" y2="50" stroke="#404e66" stroke-width="1.5" marker-end="url(#arr)"/>

        <rect x="442" y="16" width="86" height="68" rx="3" fill="#0c1020" stroke="#38bdf8" stroke-width="1" stroke-opacity="0.6"/>
        <text x="485" y="32" text-anchor="middle" fill="#38bdf8" font-family="monospace" font-size="9" opacity="0.7">05</text>
        <text x="485" y="53" text-anchor="middle" fill="#f0f4fc" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Hyperbolic</text>
        <text x="485" y="66" text-anchor="middle" fill="#6b7c96" font-family="system-ui,sans-serif" font-size="8">Brain</text>
        <circle cx="485" cy="76" r="2.5" fill="#38bdf8" opacity="0.6"/>
        <line x1="530" y1="50" x2="549" y2="50" stroke="#404e66" stroke-width="1.5" marker-end="url(#arr)"/>

        <rect x="552" y="16" width="86" height="68" rx="3" fill="#0c1020" stroke="#80b4fd" stroke-width="1" stroke-opacity="0.7"/>
        <text x="595" y="32" text-anchor="middle" fill="#80b4fd" font-family="monospace" font-size="9" opacity="0.8">06</text>
        <text x="595" y="53" text-anchor="middle" fill="#f0f4fc" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Causal</text>
        <text x="595" y="66" text-anchor="middle" fill="#6b7c96" font-family="system-ui,sans-serif" font-size="8">Arbiter</text>
        <circle cx="595" cy="76" r="2.5" fill="#80b4fd" opacity="0.7"/>
        <line x1="640" y1="50" x2="659" y2="50" stroke="#404e66" stroke-width="1.5" marker-end="url(#arr)"/>

        <rect x="662" y="16" width="86" height="68" rx="3" fill="#0c1020" stroke="#4d9cfc" stroke-width="1" stroke-opacity="0.6"/>
        <text x="705" y="32" text-anchor="middle" fill="#4d9cfc" font-family="monospace" font-size="9" opacity="0.7">07</text>
        <text x="705" y="53" text-anchor="middle" fill="#f0f4fc" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Phish</text>
        <text x="705" y="66" text-anchor="middle" fill="#6b7c96" font-family="system-ui,sans-serif" font-size="8">Guard</text>
        <circle cx="705" cy="76" r="2.5" fill="#4d9cfc" opacity="0.6"/>
        <line x1="750" y1="50" x2="769" y2="50" stroke="#404e66" stroke-width="1.5" marker-end="url(#arr)"/>

        <rect x="772" y="16" width="86" height="68" rx="3" fill="#0c1020" stroke="#a78bfa" stroke-width="1" stroke-opacity="0.6"/>
        <text x="815" y="32" text-anchor="middle" fill="#a78bfa" font-family="monospace" font-size="9" opacity="0.7">08</text>
        <text x="815" y="53" text-anchor="middle" fill="#f0f4fc" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">ERS</text>
        <text x="815" y="66" text-anchor="middle" fill="#6b7c96" font-family="system-ui,sans-serif" font-size="8">Shadow Ban</text>
        <circle cx="815" cy="76" r="2.5" fill="#a78bfa" opacity="0.6"/>
        <line x1="860" y1="50" x2="879" y2="50" stroke="#404e66" stroke-width="1.5" marker-end="url(#arr)"/>

        <rect x="882" y="16" width="86" height="68" rx="3" fill="#0c1020" stroke="#34d399" stroke-width="1.5" stroke-opacity="0.9"/>
        <text x="925" y="32" text-anchor="middle" fill="#34d399" font-family="monospace" font-size="9" opacity="0.8">09</text>
        <text x="925" y="53" text-anchor="middle" fill="#f0f4fc" font-family="system-ui,sans-serif" font-size="9.5" font-weight="600">Decision</text>
        <text x="925" y="66" text-anchor="middle" fill="#6b7c96" font-family="system-ui,sans-serif" font-size="8">ALLOW / BLOCK</text>
        <circle cx="925" cy="76" r="2.5" fill="#34d399" opacity="0.9"/>
      </svg>
    </div>

    <div class="flex justify-center mt-8">
      <span class="text-[12px] font-mono px-4 py-1.5 rounded"
            style="color:#ef4444;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.20)">
        Total latency &lt; 2ms · Covers OWASP LLM Top 10
      </span>
    </div>
  </div>
</section>


<!-- ── 5. HOW IT WORKS ──────────────────────────────────────────────────── -->
<section class="py-20 fade-in-section">
  <div class="mx-auto max-w-5xl px-4 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-[20px] font-bold" style="color:#f0f4fc">Integration in 3 steps</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-4">
      {[
        {
          n: '01', color: '#80b4fd',
          title: 'Connect your AI services',
          desc:  'Point Shadow Warden as a proxy for OpenAI, Anthropic, Gemini, or any LLM. Change one URL — no code changes required.',
        },
        {
          n: '02', color: '#4d9cfc',
          title: 'Traffic flows through Shadow Warden',
          desc:  'The 9-layer filter processes every request: blocks jailbreaks, strips secrets, and writes incidents into the STIX audit chain.',
        },
        {
          n: '03', color: '#34d399',
          title: 'Alerts and reports',
          desc:  'Real-time Slack/Teams/PagerDuty notifications. Grafana dashboard, XAI explanations, SOC 2 evidence — audit-ready from day one.',
        },
      ].map(s => (
        <div class="rounded-lg p-6 border" style="background:#0c1020;border-color:rgba(128,180,253,0.09)">
          <div class="text-[11px] font-semibold font-mono mb-4" style={`color:${s.color}`}>STEP {s.n}</div>
          <h3 class="text-[15px] font-semibold mb-2" style="color:#f0f4fc">{s.title}</h3>
          <p class="text-[13px] leading-relaxed" style="color:#6b7c96">{s.desc}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/doc/quick-start" class="inline-flex items-center gap-2 text-[13px] font-semibold"
         style="color:#80b4fd">
        Quick Start Guide
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>


