---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Enterprise Integration &amp; Deployment Guide v4.3 — Shadow Warden AI"
  description="Complete enterprise deployment guide for Shadow Warden AI v4.3. Architecture, configuration, Agentic SOC, Post-Quantum Crypto, Shadow AI Governance, XAI 2.0, compliance."
>
<div class="bg-[#03050F] text-[#F5F5F7] min-h-screen" style="font-family:'Inter',system-ui,sans-serif">

  <!-- Top bar -->
  <header class="fixed top-0 left-0 right-0 z-50 h-14 border-b border-white/[0.07]"
          style="background:rgba(3,5,15,0.95);backdrop-filter:blur(20px)">
    <div class="max-w-[1100px] mx-auto px-6 h-full flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[#FF2D55] to-[#FF6B35] flex items-center justify-center text-xs"
               style="box-shadow:0 0 14px rgba(255,45,85,0.4)">🛡️</div>
          <span class="text-[13px] font-bold">Shadow Warden</span>
        </a>
        <div class="w-px h-4 bg-white/[0.12]"></div>
        <span class="text-[12px] text-[#8E8E9E]">Docs</span>
        <span class="text-[#48485A]">/</span>
        <span class="text-[12px] font-bold">Enterprise Guide</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-[9px] font-bold px-2.5 py-1 rounded-full bg-[#FF2D55]/15 text-[#FF2D55] border border-[#FF2D55]/30 uppercase tracking-[1.5px]">v4.3</span>
        <a href="/" class="text-[12px] text-[#8E8E9E] hover:text-white transition-colors">← Back</a>
        <button onclick="window.print()" class="text-[11px] px-3 py-1.5 rounded-lg border border-white/10 text-[#8E8E9E] hover:text-white hover:border-white/20 transition-colors">Save PDF</button>
      </div>
    </div>
  </header>

  <div class="max-w-[1100px] mx-auto px-6 pt-24 pb-20">

    <!-- Cover -->
    <div class="mb-16 pb-12 border-b border-white/[0.07]">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-[#FF2D55] to-[#FF6B35] flex items-center justify-center text-xl"
             style="box-shadow:0 0 24px rgba(255,45,85,0.35)">🛡️</div>
        <div>
          <div class="text-[11px] font-semibold tracking-[2px] uppercase text-[#FF2D55]">Shadow Warden AI</div>
          <div class="text-[12px] text-[#64748b]">Enterprise Documentation</div>
        </div>
      </div>
      <h1 class="text-[36px] font-bold leading-tight mb-3" style="letter-spacing:-0.5px">
        Enterprise Integration &amp;<br/>Deployment Guide
      </h1>
      <div class="flex items-center gap-4 mb-6">
        <span class="text-[13px] font-semibold text-[#FF2D55]">Version 4.3</span>
        <span class="text-[#48485A]">·</span>
        <span class="text-[13px] text-[#64748b]">May 2026</span>
        <span class="text-[#48485A]">·</span>
        <span class="text-[13px] text-[#64748b]">Confidential</span>
      </div>
      <p class="text-[15px] leading-relaxed max-w-[680px]" style="color:#94a3b8">
        Complete deployment playbook covering the 9-layer filter pipeline, Agentic SOC (SOVA + MasterAgent),
        Post-Quantum Cryptography, Shadow AI Governance, Explainable AI 2.0, Sovereign Cloud routing,
        SEP Communities, API integration, compliance, and high-availability configuration.
      </p>

      <!-- Key metrics row -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-10">
        {[
          ['97.3%', 'Detection Rate'],
          ['< 8 ms', 'P99 Latency'],
          ['9 Layers', 'Defense Depth'],
          ['SOC 2 + GDPR', 'Compliance'],
        ].map(([val, label]) => (
          <div class="rounded-xl p-4 border border-white/[0.07]" style="background:rgba(255,255,255,0.02)">
            <div class="text-[22px] font-bold text-white mb-1">{val}</div>
            <div class="text-[11px] text-[#64748b]">{label}</div>
          </div>
        ))}
      </div>

      <!-- TOC -->
      <div class="mt-10 rounded-2xl border border-white/[0.07] overflow-hidden" style="background:rgba(255,255,255,0.02)">
        <div class="px-6 py-4 border-b border-white/[0.06]">
          <div class="text-[11px] font-semibold tracking-[2px] uppercase text-[#64748b]">Table of Contents</div>
        </div>
        <div class="grid sm:grid-cols-2 p-6 gap-x-12 gap-y-2">
          {[
            ['1', 'Executive Summary & Business Case'],
            ['2', '9-Layer Defense Architecture'],
            ['3', 'Client Segment Playbooks'],
            ['4', 'Integration Patterns'],
            ['5', 'Deployment Architecture'],
            ['6', 'Dollar Impact Calculator'],
            ['7', 'Agentic SOC — SOVA & MasterAgent'],
            ['8', 'Deployment Sizing Guide'],
            ['9', 'GDPR & Compliance Checklist'],
            ['10', 'Configuration Reference'],
          ].map(([n, title]) => (
            <a href={`#s${n}`} class="flex items-baseline gap-3 py-1.5 group">
              <span class="text-[11px] font-mono text-[#FF2D55] w-5 flex-shrink-0">{n}</span>
              <span class="text-[13px] text-[#94a3b8] group-hover:text-white transition-colors">{title}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- SECTION 1 -->
    <section id="s1" class="mb-16 pb-12 border-b border-white/[0.07]">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-[11px] font-mono text-[#FF2D55]">01</span>
        <h2 class="text-[24px] font-bold">Executive Summary &amp; Business Case</h2>
      </div>
      <p class="text-[14px] leading-relaxed mb-8" style="color:#94a3b8">
        Shadow Warden AI is a zero-trust AI security gateway deployed inline between your application and every LLM call.
        It processes requests in under 8 ms P99, blocks 97.3% of adversarial prompts, strips secrets and PII before they
        reach third-party models, and self-improves through an automated Evolution Engine — all without sending sensitive
        data to external services.
      </p>
      <div class="grid sm:grid-cols-3 gap-4 mb-8">
        {[
          ['$2.3M', 'Average annual breach cost avoided (IBM 2024)', '#FF2D55'],
          ['340%', '3-year ROI for mid-market deployments', '#6366f1'],
          ['< 2 ms', 'Topological gatekeeper P50 latency', '#10b981'],
        ].map(([val, desc, color]) => (
          <div class="rounded-xl p-5 border border-white/[0.07]" style={`background:rgba(255,255,255,0.02);border-top:2px solid ${color}`}>
            <div class="text-[26px] font-bold mb-2" style={`color:${color}`}>{val}</div>
            <div class="text-[12px]" style="color:#94a3b8">{desc}</div>
          </div>
        ))}
      </div>
      <div class="rounded-xl p-6 border border-white/[0.07]" style="background:rgba(255,255,255,0.02)">
        <div class="text-[13px] font-semibold mb-4 text-white">v4.3 Key Additions</div>
        <div class="grid sm:grid-cols-2 gap-3">
          {[
            ['🤖', 'MasterAgent SOC Coordinator', 'Multi-agent supervisor with 4 specialized sub-agents, HMAC task tokens, and human-in-the-loop approval gate'],
            ['🧬', 'Post-Quantum Cryptography', 'Hybrid Ed25519 + ML-DSA-65 (FIPS 204) signatures; X25519 + ML-KEM-768 (FIPS 203) key encapsulation'],
            ['👁️', 'Shadow AI Discovery', '18-provider fingerprint database; async subnet probe; MONITOR / BLOCK / ALLOWLIST governance policies'],
            ['🔍', 'Explainable AI 2.0', '9-stage causal chain with primary cause attribution, counterfactual remediations, and PDF audit reports'],
          ].map(([icon, title, desc]) => (
            <div class="flex gap-3 p-3 rounded-lg" style="background:rgba(255,255,255,0.03)">
              <span class="text-[20px] flex-shrink-0">{icon}</span>
              <div>
                <div class="text-[12px] font-semibold text-white mb-0.5">{title}</div>
                <div class="text-[11px]" style="color:#64748b">{desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SECTION 2 -->
    <section id="s2" class="mb-16 pb-12 border-b border-white/[0.07]">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-[11px] font-mono text-[#FF2D55]">02</span>
        <h2 class="text-[24px] font-bold">9-Layer Defense Architecture</h2>
      </div>
      <p class="text-[14px] leading-relaxed mb-8" style="color:#94a3b8">
        Every request passes through a deterministic, ordered pipeline. Each layer fails open on non-fatal errors
        except the auth guard (fail-closed). Latency per layer is tracked via OpenTelemetry spans.
      </p>
      <div class="space-y-3">
        {[
          ['L1', 'Auth Guard', 'Per-tenant API keys (SHA-256 hash, constant-time compare). Fail-closed — missing key = 401.', '#FF2D55', '< 0.1 ms'],
          ['L2', 'Topological Gatekeeper', 'n-gram point cloud → β₀/β₁ Betti numbers via TDA. Rejects structurally anomalous prompts.', '#f59e0b', '< 2 ms'],
          ['L3', 'Obfuscation Decoder', 'Depth-3 recursive decode: base64, hex, ROT13, Caesar, word-split, UUencode, unicode homoglyphs.', '#10b981', '< 1 ms'],
          ['L4', 'Secret Redactor', '15 regex patterns (API keys, JWTs, SSH, credit cards, SSN) + Shannon entropy scan for unknown secrets.', '#6366f1', '< 0.5 ms'],
          ['L5', 'Semantic Rule Engine', 'Regex ruleset + compound risk escalation (3+ MEDIUM → HIGH). Hot-reload via dynamic_rules.json.', '#8b5cf6', '< 1 ms'],
          ['L6', 'ML Brain (MiniLM)', 'all-MiniLM-L6-v2 cosine similarity + Poincaré ball hyperbolic distance blend (70/30). Adversarial suffix stripping.', '#06b6d4', '3–6 ms'],
          ['L7', 'Causal Arbiter', 'Bayesian DAG — 5 nodes, Pearl do-calculus, backdoor correction. P(HIGH_RISK|evidence).', '#f59e0b', '< 0.5 ms'],
          ['L8', 'Phishing & SE Guard', 'URL phishing detection + social engineering classification (PhishGuard + SE-Arbiter).', '#10b981', '< 0.5 ms'],
          ['L9', 'ERS & Shadow Ban', 'Redis sliding-window rate limiter. Shadow-ban at score ≥ 0.75 — gaslight / delay / standard modes.', '#FF2D55', '< 0.3 ms'],
        ].map(([layer, name, desc, color, latency]) => (
          <div class="flex gap-4 p-4 rounded-xl border border-white/[0.07]" style="background:rgba(255,255,255,0.02)">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold flex-shrink-0"
                 style={`background:${color}20;color:${color};border:1px solid ${color}30`}>{layer}</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[13px] font-semibold text-white">{name}</span>
                <span class="text-[10px] px-1.5 py-0.5 rounded font-mono" style={`background:${color}15;color:${color}`}>{latency}</span>
              </div>
              <div class="text-[12px]" style="color:#64748b">{desc}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- SECTION 3 -->
    <section id="s3" class="mb-16 pb-12 border-b border-white/[0.07]">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-[11px] font-mono text-[#FF2D55]">03</span>
        <h2 class="text-[24px] font-bold">Client Segment Playbooks</h2>
      </div>
      <p class="text-[14px] leading-relaxed mb-8" style="color:#94a3b8">
        Six deployment profiles map organization type to recommended tier, configuration preset, and compliance posture.
      </p>
      <div class="grid sm:grid-cols-2 gap-4">
        {[
          { seg: 'A', title: 'FinTech / Banking', tier: 'Enterprise', color: '#f59e0b',
            highlights: ['PQC signing on all AI transactions', 'Sovereign routing — PHI stays US/EU only', 'SOC 2 Type II evidence vault', 'GDPR Art. 35 DPIA pre-filled'] },
          { seg: 'B', title: 'Healthcare / Life Sciences', tier: 'Enterprise', color: '#10b981',
            highlights: ['PHI data pod jurisdiction lock', 'HIPAA audit chain (STIX 2.1)', 'Secret redactor covers HL7/FHIR tokens', 'Causal Transfer Guard blocks exfiltration'] },
          { seg: 'C', title: 'SaaS / Multi-Tenant', tier: 'Pro', color: '#6366f1',
            highlights: ['Per-tenant API keys + rate limits', 'MasterAgent SOC coordinator', 'Shadow AI Discovery for rogue models', 'XAI audit reports per request'] },
          { seg: 'D', title: 'Government / Public Sector', tier: 'Enterprise', color: '#FF2D55',
            highlights: ['MASQUE H3 sovereign tunnels', '8-jurisdiction transfer matrix', 'Post-quantum key encapsulation (ML-KEM-768)', 'Air-gapped Evolution Engine mode'] },
          { seg: 'E', title: 'SMB / Startup', tier: 'Community Business', color: '#8b5cf6',
            highlights: ['Single Docker Compose deploy', 'SMB Governance Suite add-on', 'AI Budget Dashboard + Vendor Registry', 'Obsidian Plugin for note security'] },
          { seg: 'F', title: 'AI-Native / LLM Platform', tier: 'Pro + Add-ons', color: '#06b6d4',
            highlights: ['OpenAI-compatible proxy endpoint', 'LangChain WardenCallback', 'SOVA scheduled threat sync (every 6h)', 'Evolution Engine with ArXiv auto-synthesis'] },
        ].map(({ seg, title, tier, highlights, color }) => (
          <div class="rounded-xl p-5 border border-white/[0.07]" style="background:rgba(255,255,255,0.02)">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center text-[12px] font-bold flex-shrink-0"
                   style={`background:${color}20;color:${color};border:1px solid ${color}30`}>{seg}</div>
              <div>
                <div class="text-[13px] font-semibold text-white">{title}</div>
                <div class="text-[11px]" style={`color:${color}`}>{tier}</div>
              </div>
            </div>
            <ul class="space-y-1.5">
              {highlights.map(h => (
                <li class="flex items-start gap-2 text-[12px]" style="color:#94a3b8">
                  <span style={`color:${color}`} class="flex-shrink-0 mt-0.5">›</span>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- SECTION 4 -->
    <section id="s4" class="mb-16 pb-12 border-b border-white/[0.07]">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-[11px] font-mono text-[#FF2D55]">04</span>
        <h2 class="text-[24px] font-bold">Integration Patterns</h2>
      </div>
      <div class="space-y-5">
        {[
          {
            label: 'Pattern A — Direct REST Filter',
            desc: 'Send every AI request through POST /filter before passing to your LLM. Synchronous, <8 ms P99.',
            code: `curl -X POST https://api.shadow-warden-ai.com/filter \\
  -H "X-API-Key: $WARDEN_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{"content":"<user prompt>","tenant_id":"acme"}'
# → {"blocked":false,"risk_score":0.12,"redacted_content":"...","processing_ms":4.7}`,
          },
          {
            label: 'Pattern B — OpenAI-Compatible Proxy',
            desc: 'Drop-in replacement for the OpenAI base URL. Zero code changes. Supports streaming with 400-char fast-scan buffer.',
            code: `from openai import OpenAI
client = OpenAI(
    base_url="https://api.shadow-warden-ai.com/v1",
    api_key="your-openai-key"
)`,
          },
          {
            label: 'Pattern C — LangChain Callback',
            desc: 'Duck-typed callback handler. Attach to any LangChain chain or agent — no changes to existing code.',
            code: `from warden.integrations.langchain_callback import WardenCallback
chain = LLMChain(
    llm=chat,
    callbacks=[WardenCallback(api_key="...", tenant_id="acme")]
)`,
          },
          {
            label: 'Pattern D — Agentic SOC API (v4.0+)',
            desc: 'Trigger MasterAgent SOC investigation. Sub-agents run in parallel; high-impact actions require Slack approval.',
            code: `# Trigger MasterAgent
curl -X POST https://api.shadow-warden-ai.com/agent/master \\
  -H "X-API-Key: $WARDEN_KEY" \\
  -d '{"query":"Investigate bypass spike last 2h"}'

# Approve pending high-impact action
curl -X POST https://api.shadow-warden-ai.com/agent/approve/{token}?action=approve \\
  -H "X-API-Key: $WARDEN_KEY"`,
          },
        ].map(({ label, desc, code }) => (
          <div class="rounded-xl border border-white/[0.07] overflow-hidden">
            <div class="px-5 py-3 border-b border-white/[0.06]" style="background:rgba(255,255,255,0.03)">
              <span class="text-[12px] font-semibold text-white">{label}</span>
            </div>
            <div class="p-5">
              <p class="text-[12px] mb-4" style="color:#94a3b8">{desc}</p>
              <pre class="text-[11px] p-4 rounded-lg overflow-x-auto" style="background:#070913;color:#94a3b8;border:1px solid rgba(255,255,255,0.06)"><code>{code}</code></pre>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- SECTION 5 -->
    <section id="s5" class="mb-16 pb-12 border-b border-white/[0.07]">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-[11px] font-mono text-[#FF2D55]">05</span>
        <h2 class="text-[24px] font-bold">Deployment Architecture</h2>
      </div>
      <p class="text-[14px] leading-relaxed mb-6" style="color:#94a3b8">
        Shadow Warden runs as 11 Docker services behind a Caddy v2 reverse proxy with QUIC/HTTP3 support.
        All services are stateless except Redis and PostgreSQL.
      </p>
      <div class="rounded-xl border border-white/[0.07] overflow-hidden mb-6">
        <div class="overflow-x-auto">
          <table class="w-full text-[12px]">
            <thead>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.07);background:rgba(255,255,255,0.03)">
                <th class="px-5 py-3 text-left font-semibold" style="color:#64748b">Service</th>
                <th class="px-5 py-3 text-left font-semibold" style="color:#64748b">Port</th>
                <th class="px-5 py-3 text-left font-semibold" style="color:#64748b">Role</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['proxy (Caddy)', '80 / 443', 'TLS termination, HTTPS/3 QUIC, vhost routing'],
                ['warden', '8001', 'Core FastAPI gateway — all /filter, /agent, /sep endpoints'],
                ['app', '8000', 'Streamlit analytics dashboard'],
                ['analytics', '8002', 'Analytics REST adapter'],
                ['dashboard', '3002', 'Next.js 14 SOC Dashboard'],
                ['postgres', '5432', 'Persistent event store (optional)'],
                ['redis', '6379', 'ERS, shadow-ban, cache, SOVA memory'],
                ['prometheus', '9090', 'Metrics scrape'],
                ['grafana', '3000', 'Dashboards + SLO alerts'],
                ['minio', '9000 / 9001', 'S3-compatible object store — evidence vault, patrol video'],
                ['minio-init', '—', 'One-shot bucket provisioning init container'],
              ].map(([svc, port, role], i) => (
                <tr style={`border-bottom:1px solid rgba(255,255,255,0.04);background:${i%2===0?'rgba(255,255,255,0.01)':'transparent'}`}>
                  <td class="px-5 py-2.5 font-mono text-[#6366f1]">{svc}</td>
                  <td class="px-5 py-2.5 font-mono text-[#94a3b8]">{port}</td>
                  <td class="px-5 py-2.5 text-[#94a3b8]">{role}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <div class="rounded-xl p-5 border border-white/[0.07]" style="background:rgba(255,255,255,0.02)">
        <div class="text-[12px] font-semibold text-white mb-3">Quick Start</div>
        <pre class="text-[11px] overflow-x-auto" style="color:#94a3b8"><code>{`git clone https://github.com/shadow-warden-ai/shadow-warden.git
cp .env.example .env && nano .env
docker compose up --build -d
curl http://localhost:8001/health
# → {"status":"ok","version":"4.3.0","model_loaded":true}`}</code></pre>
      </div>
    </section>

    <!-- SECTION 6 -->
    <section id="s6" class="mb-16 pb-12 border-b border-white/[0.07]">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-[11px] font-mono text-[#FF2D55]">06</span>
        <h2 class="text-[24px] font-bold">Dollar Impact Calculator</h2>
      </div>
      <p class="text-[14px] leading-relaxed mb-8" style="color:#94a3b8">
        Financial impact is calculated across five independent cost models using IBM 2024 benchmarks.
        Run <code class="text-[#6366f1] bg-[#6366f1]/10 px-1 rounded">python scripts/impact_analysis.py --live --industry fintech</code> for real-time figures.
      </p>
      <div class="space-y-3 mb-8">
        {[
          ['Breach Prevention', 'Blocks average AI-enabled breach ($2.3M IBM median). Multiplier 1.6× for regulated industries.', '$2.3M – $3.7M', '#FF2D55'],
          ['Secret Leak Prevention', '15-pattern + entropy scan catches API keys, JWTs, PII before reaching third-party LLMs.', '$180K – $450K', '#f59e0b'],
          ['Compliance Penalty Avoidance', 'GDPR Art. 83 max €20M or 4% revenue. SOC 2 enables $500K–$2M contract eligibility.', '$20K – $2M', '#10b981'],
          ['Productivity Recovery', 'Eliminates manual prompt review. ~$1,200/employee/year at 1 FTE per 500 users.', '$120K – $600K', '#6366f1'],
          ['Shadow AI Cost Control', 'Detects unauthorized AI spend. Median $47K/yr untracked LLM costs per 200-person org.', '$47K – $190K', '#8b5cf6'],
        ].map(([model, desc, impact, color]) => (
          <div class="flex items-start gap-4 p-4 rounded-xl border border-white/[0.07]" style="background:rgba(255,255,255,0.02)">
            <div class="flex-1">
              <div class="text-[13px] font-semibold text-white mb-1">{model}</div>
              <div class="text-[12px]" style="color:#64748b">{desc}</div>
            </div>
            <div class="text-[13px] font-semibold flex-shrink-0" style={`color:${color}`}>{impact}</div>
          </div>
        ))}
      </div>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          ['Starter / SMB', '5-year NPV $380K', 'Shadow AI + breach prevention'],
          ['Mid-Market Pro', '3-year ROI 340%', 'Full 5-model stack'],
          ['Enterprise', 'Payback < 4 months', 'Regulated + PQC + Sovereign'],
        ].map(([tier, roi, note]) => (
          <div class="rounded-xl p-4 border border-white/[0.07] text-center" style="background:rgba(255,255,255,0.02)">
            <div class="text-[11px] text-[#64748b] mb-1">{tier}</div>
            <div class="text-[18px] font-bold text-white mb-1">{roi}</div>
            <div class="text-[11px] text-[#64748b]">{note}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- SECTION 7 -->
    <section id="s7" class="mb-16 pb-12 border-b border-white/[0.07]">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-[11px] font-mono text-[#FF2D55]">07</span>
        <h2 class="text-[24px] font-bold">Agentic SOC — SOVA &amp; MasterAgent</h2>
      </div>
      <p class="text-[14px] leading-relaxed mb-8" style="color:#94a3b8">
        Shadow Warden v4.3 ships two autonomous AI operators running on Claude Opus 4.6. SOVA handles scheduled
        threat intelligence and health tasks. MasterAgent decomposes complex SOC investigations into parallel
        sub-agent workstreams with human approval gates for high-impact actions.
      </p>
      <div class="grid sm:grid-cols-2 gap-6 mb-6">
        <div class="rounded-xl border border-white/[0.07] overflow-hidden">
          <div class="px-5 py-4 border-b border-white/[0.06]" style="background:rgba(255,255,255,0.03)">
