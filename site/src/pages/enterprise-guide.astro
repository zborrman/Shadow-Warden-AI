</style>

<script is:inline>
  /* Highlight active section in both sidebars */
  const links = document.querySelectorAll('aside a[href^="#"]');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        links.forEach(l => l.classList.remove('active'));
        document.querySelectorAll(`aside a[href="#${e.target.id}"]`).forEach(a => a.classList.add('active'));
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  document.querySelectorAll('div[id]').forEach(el => observer.observe(el));
</script>
