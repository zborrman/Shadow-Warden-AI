---
const title = 'Create Account — Shadow Warden AI';
const API = 'https://api.shadow-warden-ai.com';
---
<!doctype html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>{title}</title>
  <link rel="icon" href="/logo.png" type="image/png" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="agent-protocol" href="/.well-known/agent.json" type="application/json" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: #0a0a0f;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
      padding: 1.5rem;
    }

    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background:
        radial-gradient(ellipse 60% 50% at 50% -10%, rgba(6,182,212,.10) 0%, transparent 70%),
        radial-gradient(ellipse 40% 30% at 20% 80%, rgba(99,102,241,.06) 0%, transparent 60%);
      pointer-events: none;
    }

    .card {
      position: relative;
      width: 100%;
      max-width: 420px;
      background: #111118;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 2.5rem 2rem;
    }

    .logo-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 2rem;
    }
    .logo-wrap img { height: 44px; width: auto; }
    .logo-text {
      font-size: 14px;
      font-weight: 800;
      letter-spacing: -0.3px;
      color: #f1f5f9;
    }
    .logo-text span { color: #6366f1; }

    h1 {
      font-size: 20px;
      font-weight: 700;
      color: #f1f5f9;
      text-align: center;
      margin-bottom: 0.35rem;
      letter-spacing: -0.3px;
    }
    .subtitle {
      font-size: 13px;
      color: #64748b;
      text-align: center;
      margin-bottom: 1.75rem;
    }

    label {
      display: block;
      font-size: 12px;
      font-weight: 500;
      color: #94a3b8;
      margin-bottom: 6px;
    }
    input[type="email"],
    input[type="password"] {
      width: 100%;
      height: 40px;
      padding: 0 12px;
      background: #0d0e15;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      color: #f1f5f9;
      font-size: 14px;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
      margin-bottom: 1rem;
    }
    input[type="email"]:focus,
    input[type="password"]:focus {
      border-color: rgba(6,182,212,0.5);
      box-shadow: 0 0 0 3px rgba(6,182,212,.08);
    }
    input.error {
      border-color: rgba(239,68,68,0.5) !important;
      box-shadow: 0 0 0 3px rgba(239,68,68,.08) !important;
    }
    input::placeholder { color: #475569; }

    .field-hint {
      margin-top: -0.75rem;
      margin-bottom: 1rem;
      font-size: 11px;
      color: #ef4444;
      display: none;
    }
    .field-hint.visible { display: block; }

    .pw-strength {
      margin-top: -0.75rem;
      margin-bottom: 1rem;
      display: flex;
      gap: 4px;
      align-items: center;
    }
    .pw-bar {
      flex: 1;
      height: 3px;
      border-radius: 2px;
      background: rgba(255,255,255,0.08);
      transition: background 0.25s;
    }
    .pw-label {
      font-size: 10px;
      color: #64748b;
      white-space: nowrap;
      min-width: 32px;
      text-align: right;
    }

    .btn-primary {
      width: 100%;
      height: 40px;
      background: #06b6d4;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, opacity 0.15s;
      margin-top: 0.25rem;
    }
    .btn-primary:hover { background: #0891b2; }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

    #error-msg {
      display: none;
      margin-top: 0.75rem;
      padding: 10px 12px;
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 8px;
      color: #fca5a5;
      font-size: 13px;
      text-align: center;
    }

    .footer-link {
      display: block;
      text-align: center;
      margin-top: 1.5rem;
      font-size: 13px;
      color: #475569;
    }
    .footer-link a {
      color: #06b6d4;
      text-decoration: none;
      font-weight: 500;
    }
    .footer-link a:hover { color: #22d3ee; }

    .back-link {
      display: block;
      text-align: center;
      margin-top: 0.75rem;
      font-size: 12px;
      color: #334155;
      text-decoration: none;
      transition: color 0.15s;
    }
    .back-link:hover { color: #64748b; }

    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner {
      display: inline-block;
      width: 14px; height: 14px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo-wrap">
      <img src="/logo.png" alt="Shadow Warden AI" />
      <span class="logo-text">Shadow-<span>Warden</span>-AI</span>
    </div>

    <h1>Create your account</h1>
    <p class="subtitle">Zero-Trust AI Security Gateway</p>

    <form id="signup-form" novalidate>
      <label for="email">Email address</label>
      <input id="email" type="email" name="email" placeholder="you@company.com" autocomplete="email" required />

      <label for="password">Password</label>
      <input id="password" type="password" name="password" placeholder="Min. 8 characters" autocomplete="new-password" required />
      <!-- Strength indicator -->
      <div class="pw-strength" id="pw-strength" style="display:none">
        <div class="pw-bar" id="pw-bar-1"></div>
        <div class="pw-bar" id="pw-bar-2"></div>
        <div class="pw-bar" id="pw-bar-3"></div>
        <div class="pw-bar" id="pw-bar-4"></div>
        <span class="pw-label" id="pw-label"></span>
      </div>

      <label for="confirm">Confirm password</label>
      <input id="confirm" type="password" name="confirm" placeholder="Repeat your password" autocomplete="new-password" required />
      <div class="field-hint" id="confirm-hint">Passwords do not match.</div>

      <button id="submit-btn" class="btn-primary" type="submit">Create Account</button>
      <div id="error-msg"></div>
    </form>

    <p class="footer-link">Already have an account? <a href="/login">Sign in here</a></p>
    <a href="/" class="back-link">← Back to Shadow Warden AI</a>
  </div>

  <script define:vars={{ API }}>
    const form      = document.getElementById('signup-form');
    const submitBtn = document.getElementById('submit-btn');
    const errorMsg  = document.getElementById('error-msg');
    const pwInput   = document.getElementById('password');
    const confirmInput = document.getElementById('confirm');
    const confirmHint  = document.getElementById('confirm-hint');
    const pwStrength   = document.getElementById('pw-strength');
    const pwLabel      = document.getElementById('pw-label');
    const bars = [
      document.getElementById('pw-bar-1'),
      document.getElementById('pw-bar-2'),
      document.getElementById('pw-bar-3'),
      document.getElementById('pw-bar-4'),
    ];
    const COLORS = ['#ef4444', '#f97316', '#eab308', '#10b981'];
    const LABELS = ['Weak', 'Fair', 'Good', 'Strong'];

    // If already logged in, skip to marketplace
    fetch(API + '/auth/me', { credentials: 'include', signal: AbortSignal.timeout(3000) })
      .then(r => r.ok ? r.json() : null)
      .then(d => { if (d?.authenticated) window.location.replace('/agentic'); })
      .catch(() => {});

    // Password strength meter
    pwInput.addEventListener('input', () => {
      const v = pwInput.value;
      pwStrength.style.display = v ? 'flex' : 'none';
      let score = 0;
      if (v.length >= 8)  score++;
      if (v.length >= 12) score++;
      if (/[A-Z]/.test(v) && /[0-9]/.test(v)) score++;
      if (/[^A-Za-z0-9]/.test(v)) score++;
      bars.forEach((b, i) => {
        b.style.background = i <= score - 1 ? COLORS[score - 1] : 'rgba(255,255,255,0.08)';
      });
      pwLabel.textContent = score > 0 ? LABELS[score - 1] : '';
      pwLabel.style.color = score > 0 ? COLORS[score - 1] : '#64748b';
    });

    // Confirm password match check
    confirmInput.addEventListener('input', () => {
      const mismatch = confirmInput.value && confirmInput.value !== pwInput.value;
      confirmInput.classList.toggle('error', !!mismatch);
      confirmHint.classList.toggle('visible', !!mismatch);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email    = document.getElementById('email').value.trim();
      const password = pwInput.value;
      const confirm  = confirmInput.value;

      if (!email || !password || !confirm) {
        showError('Please fill in all fields.');
        return;
      }
      if (password !== confirm) {
        confirmInput.classList.add('error');
        confirmHint.classList.add('visible');
        return;
      }
      if (password.length < 8) {
        showError('Password must be at least 8 characters.');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner"></span>';
      errorMsg.style.display = 'none';

      try {
        const res = await fetch(API + '/auth/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email, password }),
        });

        if (res.ok) {
          window.location.replace('/agentic');
          return;
        }

        const data = await res.json().catch(() => ({}));
        if (res.status === 409) {
          showError('An account with this email already exists. Try signing in.');
        } else if (res.status === 422) {
          showError(data.detail || 'Please check your email and password.');
        } else if (res.status === 429) {
          showError('Too many attempts. Please wait a few minutes and try again.');
        } else {
          showError(data.detail || 'Registration failed. Please try again.');
        }
      } catch {
        showError('Could not reach the server. Check your connection.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Account';
      }
    });

    function showError(msg) {
      errorMsg.textContent = msg;
      errorMsg.style.display = 'block';
    }
  </script>
</body>
</html>
