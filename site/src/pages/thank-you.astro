---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Thank You — Shadow Warden AI"
  description="Your Shadow Warden AI subscription is active. Welcome to zero-trust AI security."
>
  <div class="min-h-screen flex flex-col items-center justify-center px-4 text-center pt-14">

    <!-- Success icon -->
    <div class="w-20 h-20 rounded-2xl flex items-center justify-center mb-6"
         style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2)">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
    </div>

    <h1 class="text-[36px] font-black mb-3" style="color:#f1f5f9">You're in!</h1>
    <p class="text-[16px] max-w-md mb-2" style="color:#94a3b8">
      Your Shadow Warden AI subscription is now active. Your fortress is ready.
    </p>
    <p id="order-info" class="text-[13px] mb-10" style="color:#475569"></p>

    <!-- Steps -->
    <div class="grid sm:grid-cols-3 gap-4 max-w-2xl w-full mb-12">
      {[
        { step: '01', icon: '⚙', title: 'Configure', desc: 'Visit Settings to connect integrations and tune your pipeline.' },
        { step: '02', icon: '🔑', title: 'Get your API key', desc: 'Find your key in Settings → Security → API Keys.' },
        { step: '03', icon: '🚀', title: 'Deploy', desc: 'Follow the Quick Start guide to go live in 60 seconds.' },
      ].map(s => (
        <div class="p-5 rounded-xl text-left" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07)">
          <div class="text-[10px] font-bold mb-2" style="color:#475569">{s.step}</div>
          <div class="text-[18px] mb-2">{s.icon}</div>
          <div class="text-[13px] font-semibold mb-1" style="color:#f1f5f9">{s.title}</div>
          <p class="text-[12px]" style="color:#64748b">{s.desc}</p>
        </div>
      ))}
    </div>

    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="/settings"
         class="px-6 py-3 rounded-xl text-[14px] font-semibold text-white"
         style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">
        Go to Settings
      </a>
      <a href="/doc/quick-start"
         class="px-6 py-3 rounded-xl text-[14px] font-medium"
         style="color:#94a3b8;border:1px solid rgba(255,255,255,0.08)">
        Quick Start Guide →
      </a>
    </div>

    <p class="text-[11px] mt-12" style="color:#1e293b">
      A confirmation email is on its way. Manage your subscription at any time in Settings → Billing.
    </p>
  </div>

  <script>
    // Display order ID from URL
    const params  = new URLSearchParams(window.location.search);
    const orderId = params.get('order_id');
    const el      = document.getElementById('order-info');
    if (orderId && el) el.textContent = `Order #${orderId}`;

    // Save customer_id if present (passed by Lemon Squeezy via success URL)
    const customerId = params.get('customer_id');
    if (customerId) localStorage.setItem('sw-customer-id', customerId);
  </script>
</BaseLayout>
