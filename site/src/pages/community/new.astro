---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="New Community — Shadow Warden AI"
  description="Create a new secure collaboration community."
>
  <section class="pt-28 pb-24 min-h-screen" style="background:#0a0a0f">
    <div class="mx-auto max-w-xl px-4 lg:px-8">

      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 mb-8 text-[13px]" style="color:#475569">
        <a href="/community" style="color:#64748b;text-decoration:none" onmouseover="this.style.color='#06b6d4'" onmouseout="this.style.color='#64748b'">Communities</a>
        <span>›</span>
        <span style="color:#94a3b8">New Community</span>
      </div>

      <!-- Form card -->
      <div style="background:#0d1220;border:1px solid rgba(255,255,255,0.08);border-radius:20px;padding:36px">
        <div class="flex items-center gap-3 mb-8">
          <div style="width:40px;height:40px;border-radius:12px;background:rgba(6,182,212,0.1);border:1px solid rgba(6,182,212,0.2);display:flex;align-items:center;justify-content:center;font-size:20px">
            🏛️
          </div>
          <div>
            <h1 class="text-[22px] font-black" style="color:#f1f5f9">Create Community</h1>
            <p class="text-[13px]" style="color:#475569">Your community gets a unique COMM-XXXX identifier</p>
          </div>
        </div>

        <form id="new-comm-form">
          <!-- Name -->
          <div class="mb-5">
            <label class="block text-[12px] font-semibold uppercase tracking-wider mb-2" style="color:#64748b">
              Community Name <span style="color:#FF2D55">*</span>
            </label>
            <input
              id="comm-name"
              type="text"
              required
              maxlength="60"
              placeholder="e.g. Security Research Hub"
              style="width:100%;box-sizing:border-box;background:#0a0a12;border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:12px 14px;color:#f1f5f9;font-size:14px;outline:none;transition:border-color 0.2s"
              onfocus="this.style.borderColor='rgba(6,182,212,0.5)'"
              onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
            />
          </div>

          <!-- Description -->
          <div class="mb-5">
            <label class="block text-[12px] font-semibold uppercase tracking-wider mb-2" style="color:#64748b">
              Description <span style="color:#334155">(optional)</span>
            </label>
            <textarea
              id="comm-desc"
              rows="3"
              maxlength="200"
              placeholder="What is this community for?"
              style="width:100%;box-sizing:border-box;background:#0a0a12;border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:12px 14px;color:#f1f5f9;font-size:14px;outline:none;resize:vertical;transition:border-color 0.2s;font-family:inherit"
              onfocus="this.style.borderColor='rgba(6,182,212,0.5)'"
              onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
            ></textarea>
          </div>

          <!-- Privacy notice -->
          <div class="mb-8 px-4 py-3 rounded-xl" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05)">
            <p class="text-[12px]" style="color:#475569;line-height:1.6">
              🔐 Community data is stored locally in your browser. Tunnel messages use end-to-end encrypted channels. No data is sent to external servers without your explicit action.
            </p>
          </div>

          <!-- Actions -->
          <div class="flex gap-3">
            <a href="/community"
               style="flex:1;text-align:center;padding:13px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:12px;color:#94a3b8;text-decoration:none;font-size:14px;font-weight:600;transition:all 0.15s"
               onmouseover="this.style.background='rgba(255,255,255,0.07)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'">
              Cancel
            </a>
            <button
              type="submit"
              style="flex:2;padding:13px;background:linear-gradient(135deg,#06b6d4,#0e7490);border:none;border-radius:12px;color:white;font-size:14px;font-weight:700;cursor:pointer;transition:opacity 0.15s"
              onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
              Create Community →
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <script>
    const COMM_KEY = 'sw_communities';

    function genCommId(): string {
      const bytes = crypto.getRandomValues(new Uint8Array(2));
      return 'COMM-' + Array.from(bytes).map(b => b.toString(16).padStart(2, '0')).join('').toUpperCase();
    }

    document.getElementById('new-comm-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('comm-name') as HTMLInputElement)?.value.trim();
      const desc = (document.getElementById('comm-desc') as HTMLTextAreaElement)?.value.trim();
      if (!name) return;

      const comms: any[] = (() => {
        try { return JSON.parse(localStorage.getItem(COMM_KEY) || '[]'); } catch { return []; }
      })();

      const id = genCommId();
      const newComm = { id, name, description: desc, members: [], created: new Date().toISOString() };
      comms.push(newComm);
      localStorage.setItem(COMM_KEY, JSON.stringify(comms));

      window.location.href = `/community/view?id=${encodeURIComponent(id)}`;
    });
  </script>
</BaseLayout>
