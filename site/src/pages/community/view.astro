<script>
(function () {
  /* ─── Constants ─────────────────────────────────────────── */
  const COMM_KEY   = 'sw_communities';
  const TIER_KEY   = 'sw_tier';
  const USER_KEY   = 'sw_user_id';
  const tKey = (id: string) => `sw_tunnel_${id}`;

  /* ─── State ─────────────────────────────────────────────── */
  let communityId = '';
  let myUserId    = '';
  let activeTab   = 'communities';

  /* ─── Helpers ───────────────────────────────────────────── */
  function qp(n: string) { return new URLSearchParams(window.location.search).get(n) || ''; }

  function esc(s: string) {
    return String(s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;');
  }

  function loadComms(): any[]  { try { return JSON.parse(localStorage.getItem(COMM_KEY)||'[]'); } catch { return []; } }
  function saveComms(a: any[]) { localStorage.setItem(COMM_KEY, JSON.stringify(a)); }
  function loadMsgs(id: string): any[]  { try { return JSON.parse(localStorage.getItem(tKey(id))||'[]'); } catch { return []; } }
  function saveMsgs(id: string, m: any[]){ localStorage.setItem(tKey(id), JSON.stringify(m)); }

  const AV_COLORS = ['#0891b2','#7c3aed','#2563eb','#16a34a','#b45309','#be185d','#0d9488','#9333ea','#dc2626','#0369a1'];
  function avColor(s: string) {
    const h = Array.from(s).reduce((a,c) => a + c.charCodeAt(0), 0);
    return AV_COLORS[h % AV_COLORS.length];
  }
  function initials(name: string) {
    return name.trim().split(/\s+/).slice(0,2).map(w=>w[0]||'').join('').toUpperCase() || '?';
  }
  function relTime(ts: number) {
    const d = (Date.now()-ts)/1000;
    if (d<60) return 'just now';
    if (d<3600) return `${Math.floor(d/60)}m ago`;
    if (d<86400) return `${Math.floor(d/3600)}h ago`;
    return `${Math.floor(d/86400)}d ago`;
  }
  function fmtDate(ts: number) {
    return new Date(ts).toLocaleDateString('en-US',{year:'numeric',month:'short',day:'2-digit'});
  }
  function ttlStr(ts: number, ms: number) {
    const left = ts + ms - Date.now();
    if (left<=0) return 'expired';
    const h = Math.floor(left/3600000), m = Math.floor((left%3600000)/60000);
    return `${h}h ${m}m left`;
  }
  function mkNonce() {
    return Math.random().toString(16).slice(2,10)+'...';
  }
  function mkFP() {
    const h = ()=>Math.floor(Math.random()*256).toString(16).padStart(2,'0');
    return Array.from({length:6},h).join(':');
  }
  function addLog(c: any, action: string, detail: string) {
    if (!c.activityLog) c.activityLog=[];
    c.activityLog.unshift({
      id:'evt_'+Math.random().toString(36).slice(2,6),
      ts:Date.now(), action, userId:myUserId, detail
    });
    if (c.activityLog.length>500) c.activityLog.length=500;
  }

  /* ─── Seed demo data ────────────────────────────────────── */
  function seed() {
    if (loadComms().length>0) return;
    const now = Date.now(), day = 86400000;
    const comms: any[] = [
      {
        id:'COMM-1024', name:'Acme Prod Engineering',
        description:'Production deployments, on-call rotation, AI security rules.',
        type:'public', created:now-124*day, joined:true,
        fingerprint:'a3:8f:c2:91:de:4b',
        disappearingMessages:'24h',
        members:[
          {id:'USR-0001',name:'Zach Borrman', email:'ops@shadowwarden.ai',role:'owner', joined:now-124*day},
          {id:'USR-0014',name:'Elena Wójcik', email:'elena.w@acme.com',  role:'admin', joined:now-93*day },
          {id:'USR-0018',name:'Devon Rojas',  email:'devon.r@acme.com',  role:'admin', joined:now-75*day },
          {id:'USR-0091',name:'Sora Itō',     email:'sora.i@acme.com',   role:'member',joined:now-30*day },
          {id:'USR-0042',name:'Priya Mehta',  email:'priya.m@acme.com',  role:'member',joined:now-28*day },
          {id:'USR-0055',name:'Kai Nakamura', email:'kai.n@acme.com',    role:'member',joined:now-20*day },
        ],
        join_requests:[
          {userId:'USR-2391',name:'Maya Krishna', email:'maya.k@acme.com',  ts:now-2*3600000, message:'New on the platform team — need access to deployment rules'},
          {userId:'USR-2482',name:'Jules Laurent',email:'jules.l@acme.com', ts:now-5*3600000, message:'Joining red-team rotation next sprint'},
          {userId:'USR-2418',name:'Rao Tanaka',   email:'rao.t@acme.com',   ts:now-26*3600000,message:'Auditor — read-only is fine'},
        ],
        activityLog:[
          {id:'evt_a91f',ts:now-1.5*3600000,action:'member_joined',   userId:'USR-0001',detail:'Sora Itō (USR-0091) joined the community · request approved by Zach Borrman (Owner)'},
          {id:'evt_a91e',ts:now-3*3600000,  action:'role_changed',    userId:'USR-0001',detail:'Role change · Devon Rojas (USR-0018) promoted from MEMBER → ADMIN by Owner'},
          {id:'evt_a91d',ts:now-6*3600000,  action:'gdpr_export',     userId:'USR-0001',detail:'GDPR export · Zach Borrman downloaded community-COMM-1024-export.json (4.2 MB)'},
          {id:'evt_a91c',ts:now-15*3600000, action:'key_exported',    userId:'USR-0014',detail:'Public key exported · Elena Wójcik downloaded public-USR-0014.asc (4 KB · ASCII-armored)'},
          {id:'evt_a91b',ts:now-22*3600000, action:'setting_changed', userId:'USR-0001',detail:'Disappearing messages window changed · off → 24h by Owner — 12 messages older than 24h purged from feed'},
          {id:'evt_a91a',ts:now-28*3600000, action:'join_requested',  userId:'USR-2391',detail:'Join request · Maya Krishna (USR-2391) requested access — pending review'},
          {id:'evt_a919',ts:now-50*3600000, action:'member_removed',  userId:'USR-0014',detail:'Member removed · Anonymized (USR-0044) by Elena Wójcik (Admin) — reason: "left the org"'},
        ]
      },
      {
        id:'COMM-1031',name:'Acme Security Council',
        description:'Incident triage and red-team review. Invite-only.',
        type:'private', created:now-90*day, joined:false, pending:true,
        fingerprint:'b7:2e:a1:45:cd:ff',
        members:[
          {id:'USR-0014',name:'Elena Wójcik',role:'owner',email:'elena.w@acme.com',joined:now-90*day},
          {id:'USR-0018',name:'Devon Rojas', role:'admin',email:'devon.r@acme.com',joined:now-85*day},
          {id:'USR-1001',name:'Aria Patel',  role:'member',email:'aria.p@acme.com',joined:now-60*day},
          {id:'USR-1002',name:'Sam Okafor',  role:'member',email:'sam.o@acme.com', joined:now-45*day},
          {id:'USR-1003',name:'Ryu Sato',    role:'member',email:'ryu.s@acme.com', joined:now-30*day},
          {id:'USR-1004',name:'Laila Nasser',role:'member',email:'laila.n@acme.com',joined:now-15*day},
        ],
        join_requests:[], activityLog:[]
      },
      {
        id:'COMM-1108',name:'Acme Customer Success',
        description:'Customer-facing AI prompt patterns and approved templates.',
        type:'public', created:now-60*day, joined:false,
        fingerprint:'c4:9f:12:88:ab:dc',
        members: Array.from({length:28},(_,i)=>({id:`USR-${(2000+i).toString().padStart(4,'0')}`,name:`Member ${i+1}`,email:`m${i+1}@acme.com`,role:i===0?'owner':'member',joined:now-(60-i)*day})),
        join_requests:[], activityLog:[]
      },
      {
        id:'COMM-1156',name:'Acme Research Lab',
        description:'Open-research: novel jailbreak attempts and rule contributions.',
        type:'public', created:now-45*day, joined:false,
        fingerprint:'d2:1e:77:3a:bc:94',
        members: Array.from({length:47},(_,i)=>({id:`USR-${(3000+i).toString().padStart(4,'0')}`,name:`Researcher ${i+1}`,email:`r${i+1}@lab.acme.com`,role:i===0?'owner':'member',joined:now-(45-i)*day})),
        join_requests:[], activityLog:[]
      },
    ];
    saveComms(comms);

    // Seed tunnel messages for COMM-1024
    const msgs = [
      {id:'msg001',sender:'USR-0014',senderName:'Elena Wójcik',ts:now-4.9*3600000,text:'Pushed the new `OBFUSCATION_DECODE` rule to staging. Catches 87% of base64-wrapped jailbreaks in the eval set.',nonce:'f3a91c'},
      {id:'msg002',sender:'USR-0018',senderName:'Devon Rojas', ts:now-3*3600000,  text:'Nice. p99 latency budget still `< 25ms`? Want to make sure we don\'t regress on the streaming endpoint.',nonce:'b81cf4'},
      {id:'msg003',sender:'USR-0001',senderName:'Zach Borrman',ts:now-30*60000,   text:'Confirmed — 22ms p99 on staging. Approving promotion to prod after 24h soak. Activity log entry on the way.',nonce:'de2701'},
    ];
    saveMsgs('COMM-1024', msgs);
    if (!localStorage.getItem(USER_KEY)) localStorage.setItem(USER_KEY,'USR-0001');
  }

  /* ─── Tab switching ─────────────────────────────────────── */
  function switchTab(tab: string) {
    activeTab = tab;
    document.querySelectorAll<HTMLElement>('.comm-tab').forEach(b => b.classList.toggle('active', b.dataset.tab===tab));
    document.querySelectorAll<HTMLElement>('.comm-panel').forEach(p => p.classList.toggle('hidden', p.id!==`panel-${tab}`));
    const url = new URL(window.location.href);
    url.searchParams.set('tab', tab);
    history.replaceState({}, '', url.toString());
    switch(tab) {
      case 'communities': renderComms(); break;
      case 'members':     renderMembers(); break;
      case 'tunnel':      renderTunnel(); break;
      case 'activity':    renderActivity(); break;
      case 'settings':    renderSettings(); break;
    }
  }

  /* ─── COMMUNITIES panel ─────────────────────────────────── */
  function renderComms() {
    const comms = loadComms();
    const q = ((document.getElementById('comm-search') as HTMLInputElement)?.value||'').toLowerCase().trim();
    const filtered = q ? comms.filter((c:any)=>c.name.toLowerCase().includes(q)||c.id.toLowerCase().includes(q)) : comms;

    const hdr = document.getElementById('results-hdr');
    if (hdr) {
      hdr.innerHTML = q
        ? `<span><strong style="color:#f1f5f9">${filtered.length} result${filtered.length!==1?'s':''}</strong> · matching "${esc(q)}"</span><span>${comms.length} communities total</span>`
        : `<span><strong style="color:#f1f5f9">${comms.length} communit${comms.length!==1?'ies':'y'}</strong></span>`;
    }

    const grid = document.getElementById('comm-card-grid');
    if (!grid) return;
    if (filtered.length===0) {
      grid.innerHTML = `<p style="color:#475569;font-size:13px;grid-column:1/-1;padding:20px 0">No communities match your search.</p>`;
      return;
    }

    grid.innerHTML = filtered.map((c: any) => {
      const abbr = c.name.split(' ').slice(0,2).map((w:string)=>w[0]).join('').toUpperCase();
      const mc   = (c.members||[]).length;
      const msgs = loadMsgs(c.id).length;
      const act  = c.joined ? `<span class="badge-joined">✓ Joined</span>`
                 : c.pending ? `<span class="badge-pending">Pending</span>`
                 : `<button class="btn-join" data-join="${esc(c.id)}">Join</button>`;
      return `
        <div class="comm-card" data-cid="${esc(c.id)}">
          <div class="card-top">
            <div class="card-av" style="background:${avColor(c.id)}">${abbr}</div>
            <div class="card-meta">
              <div class="card-name">${esc(c.name)}</div>
              <div class="card-id">${esc(c.id)} · ${c.type||'public'}</div>
            </div>
            <div class="card-act">${act}</div>
          </div>
          <div class="card-desc">${esc(c.description||'')}</div>
          <div class="card-stats">
            <span>👥 ${mc}</span>
            <span>💬 ${msgs}</span>
            <span class="e2ee-chip">E2EE</span>
          </div>
        </div>`;
    }).join('');

    // Click card → go to members of that community
    grid.querySelectorAll<HTMLElement>('.comm-card').forEach(card => {
      card.addEventListener('click', e => {
        if ((e.target as HTMLElement).classList.contains('btn-join')) return;
        communityId = card.dataset.cid||'';
        updateBreadcrumb(); updateBadges();
        switchTab('members');
      });
    });

    // Join button
    grid.querySelectorAll<HTMLElement>('.btn-join').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        const cid = btn.dataset.join||'';
        const cs = loadComms();
        const comm = cs.find((x:any)=>x.id===cid);
        if (!comm) return;
        if (!comm.join_requests) comm.join_requests=[];
        if (!comm.join_requests.find((r:any)=>r.userId===myUserId)) {
          comm.join_requests.push({userId:myUserId,name:'You',email:'',ts:Date.now(),message:'Requesting to join.'});
          addLog(comm,'join_requested','Join request submitted');
          comm.pending=true;
          saveComms(cs);
          renderComms();
        }
      });
    });

    // Sidebar stats
    const joined  = comms.filter((c:any)=>c.joined).length;
    const pending = comms.filter((c:any)=>c.pending&&!c.joined).length;
    const allMsgs = comms.reduce((s:number,c:any)=>s+loadMsgs(c.id).length,0);
    el('stat-joined','innerHTML',`<span class="stat-n">${joined}</span><span class="stat-lbl">Communities joined</span>`);
    el('stat-pending','innerHTML',`<span class="stat-n">${pending}</span><span class="stat-lbl">Pending requests</span>`);
    el('stat-msgs','innerHTML',`<span class="stat-n">${allMsgs}</span><span class="stat-lbl">Messages this week</span>`);

    const activeCom = comms.find((c:any)=>c.id===communityId);
    set('my-fp', activeCom?.fingerprint || mkFP());
  }

  /* ─── MEMBERS panel ─────────────────────────────────────── */
  function renderMembers() {
    const comms = loadComms();
    const c = comms.find((x:any)=>x.id===communityId);
    if (!c) {
      el('mtbody','innerHTML','<div style="padding:32px;text-align:center;color:#475569;font-size:13px">No community selected. Click a community card first.</div>');
      return;
    }

    set('members-path',`/COMMUNITY/MEMBERS?ID=${communityId}`);
    const members: any[] = c.members||[];
    const myMem   = members.find((m:any)=>m.id===myUserId);
    const myRole  = myMem?.role||'none';
    const canMgr  = myRole==='owner'||myRole==='admin';
    const filter  = ((document.getElementById('member-filter') as HTMLInputElement)?.value||'').toLowerCase();

    // Tab badge
    set('tab-members-count', String(members.length));

    // Join requests
    const reqs: any[] = c.join_requests||[];
    const jrSec = document.getElementById('join-req-section');
    const jrList= document.getElementById('jr-list');
    if (jrSec && canMgr && reqs.length>0) {
      jrSec.style.display='block';
      set('jr-count',`${reqs.length} pending`);
      if (jrList) {
        jrList.innerHTML = reqs.map((r:any,i:number)=>`
          <div class="jr-row">
            <div class="jr-av" style="background:${avColor(r.userId)}">${initials(r.name||r.userId)}</div>
            <div class="jr-info">
              <div class="jr-name">${esc(r.name||r.userId)}</div>
              <div class="jr-id">${esc(r.userId)} · ${esc(r.email||'')}</div>
              <div class="jr-msg">"${esc(r.message||'')}"</div>
            </div>
            <span class="jr-time">${relTime(r.ts)}</span>
            <div class="jr-acts">
              <button class="btn-decline" data-i="${i}" data-act="decline">Decline</button>
              <button class="btn-approve" data-i="${i}" data-act="approve">Approve</button>
            </div>
          </div>`).join('');

        jrList.querySelectorAll<HTMLElement>('[data-act]').forEach(btn=>{
          btn.addEventListener('click',()=>{
            const i=parseInt(btn.dataset.i||'0');
            const act=btn.dataset.act;
            const cs=loadComms(); const comm=cs.find((x:any)=>x.id===communityId);
            if(!comm) return;
            const reqs2=comm.join_requests||[];
            const req=reqs2[i]; if(!req) return;
            if(act==='approve'){
              if(!comm.members.find((m:any)=>m.id===req.userId))
                comm.members.push({id:req.userId,name:req.name||req.userId,email:req.email||'',role:'member',joined:Date.now()});
              addLog(comm,'member_joined',`${req.name||req.userId} (${req.userId}) joined the community · request approved by ${myMem?.name||myUserId} (Owner)`);
            } else {
              addLog(comm,'join_declined',`Declined join request from ${req.userId}`);
            }
            comm.join_requests=reqs2.filter((_:any,j:number)=>j!==i);
            saveComms(cs); renderMembers();
          });
        });
      }
    } else if (jrSec) { jrSec.style.display='none'; }

    // Member count
    set('mem-count-lbl',`${members.length} members`);
    set('sync-time','just now');

    // Member rows
    const filtered = filter
      ? members.filter((m:any)=>m.id.toLowerCase().includes(filter)||(m.name||'').toLowerCase().includes(filter)||m.role.includes(filter))
      : members;

    const tbody=document.getElementById('mtbody');
    if (!tbody) return;

    tbody.innerHTML=filtered.map((m:any)=>{
      const isMe   = m.id===myUserId;
      const isOwner= m.role==='owner';
      const color  = avColor(m.id);
      const ini    = initials(m.name||m.id);
      const jd     = fmtDate(m.joined||Date.now());
      const rbadge = isOwner
        ? `<span class="role-badge role-owner">⭐ OWNER</span>`
        : m.role==='admin'
        ? `<span class="role-badge role-admin">⬡ ADMIN</span>`
        : `<span class="role-badge role-member">▲ MEMBER</span>`;
      const manage = isOwner
        ? `<span class="btn-locked">🔒 locked</span>`
        : canMgr&&!isMe
        ? `<button class="btn-change" data-mid="${esc(m.id)}" data-cur="${esc(m.role)}">Change ↓</button>`
        : '';
      return `
        <div class="mrow">
          <div class="mc">
            <div class="mav" style="background:${color}">${ini}</div>
            <div>
              <div class="mav-name">${esc(m.name||m.id)}${isMe?` <span style="font-size:10px;color:#475569">you</span>`:''}</div>
              <div class="mav-sub">${esc(isMe?'ops@shadowwarden.ai':m.email||m.id)}</div>
            </div>
          </div>
          <div class="uc">${esc(m.id)}</div>
          <div class="jc">${jd}</div>
          <div class="rc">${rbadge}</div>
          <div class="gc">${manage}</div>
        </div>`;
    }).join('');

    tbody.querySelectorAll<HTMLElement>('.btn-change').forEach(btn=>{
      btn.addEventListener('click',()=>{
        const mid=btn.dataset.mid; const cur=btn.dataset.cur;
        const next=cur==='admin'?'member':'admin';
        const cs=loadComms(); const comm=cs.find((x:any)=>x.id===communityId);
        if(!comm) return;
        const target=comm.members.find((m:any)=>m.id===mid);
        if(target&&target.role!=='owner'){
          addLog(comm,'role_changed',`Role change · ${target.name||mid} (${mid}) promoted from ${cur!.toUpperCase()} → ${next.toUpperCase()} by Owner`);
          target.role=next; saveComms(cs); renderMembers();
        }
      });
    });
  }

  /* ─── TUNNEL panel ──────────────────────────────────────── */
  function renderTunnel() {
    const comms = loadComms();
    const c = comms.find((x:any)=>x.id===communityId);
    if (!c) return;

    set('tchan-comm', c.name||communityId);
    const fp=c.fingerprint||mkFP();
    set('tfp',`FP ${fp}:7c:2e:09:11:fd:33:48:5a:8e:c0 · verified`);
    set('pubkey-chip',`public-${myUserId}.asc`);

    const windowMap: Record<string,number> = {'1h':3600000,'6h':21600000,'24h':86400000,'7d':604800000,'30d':2592000000};
    const disappear=c.disappearingMessages||'off';
    const windowMs=windowMap[disappear]||0;

    let msgs=loadMsgs(communityId);
    const adBar=document.getElementById('ad-bar');
    if (windowMs>0&&adBar) {
      adBar.classList.remove('hidden');
      const cutoff=Date.now()-windowMs;
      const hidden=msgs.filter((m:any)=>m.ts<cutoff).length;
      msgs=msgs.filter((m:any)=>m.ts>=cutoff);
      set('ad-cnt',`${hidden} hidden · ${msgs.length} visible`);
    } else { adBar?.classList.add('hidden'); }

    const msgsEl=document.getElementById('tunnel-msgs');
    if (!msgsEl) return;

    const members:any[]=c.members||[];
    const myMem=members.find((m:any)=>m.id===myUserId);

    if (msgs.length===0) {
      msgsEl.innerHTML=`<div style="text-align:center;padding:60px 20px">
        <div style="font-size:48px;margin-bottom:12px">🔒</div>
        <div style="color:#475569;font-size:14px">No messages yet</div>
        <div style="color:#334155;font-size:12px;margin-top:6px">End-to-end encrypted · AES-256-GCM · keys never leave this browser</div>
      </div>`;
    } else {
      msgsEl.innerHTML=msgs.map((m:any)=>{
        const isMe=m.sender===myUserId;
        const senderMem=members.find((mb:any)=>mb.id===m.sender);
        const senderName=m.senderName||senderMem?.name||m.sender;
        const color=avColor(m.sender);
        const ini=initials(senderName);
        const timeStr=new Date(m.ts).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
        const role=isMe?myMem?.role:senderMem?.role||'';
        const roleLabel=role==='owner'?'(Owner)':role==='admin'?'(Admin)':'';
        const ttl=windowMs?ttlStr(m.ts,windowMs):'';
        const nonce=m.nonce||mkNonce();

        // Inline code/highlight
        const proc=(txt:string)=>esc(txt)
          .replace(/`([^`]+)`/g,(_:string,g:string)=>`<span class="ci">${g}</span>`)
          .replace(/&lt;([^&]+)&gt;/g,(_:string,g:string)=>`<span style="color:#f87171">&lt;${g}&gt;</span>`);

        if (isMe) return `
          <div class="tmsg mine">
            <div class="tmsg-av" style="background:${color}">${ini}</div>
            <div class="tmsg-body">
              <div class="tmsg-hdr">
                <span class="tmsg-time">${timeStr} · ${relTime(m.ts)}</span>
                <span class="tmsg-name">You</span>
                ${roleLabel?`<span class="tmsg-role">${roleLabel}</span>`:''}
              </div>
              <div class="tbubble tbubble-mine">${proc(m.text)}</div>
              <div class="tmsg-meta">🔒 AES-256-GCM · nonce ${nonce}${ttl?` · <span class="meta-ttl">⏱ ${ttl}</span>`:''}</div>
            </div>
          </div>`;
        return `
          <div class="tmsg">
            <div class="tmsg-av" style="background:${color}">${ini}</div>
            <div class="tmsg-body">
              <div class="tmsg-hdr">
                <span class="tmsg-name">${esc(senderName)}</span>
                ${roleLabel?`<span class="tmsg-role">${roleLabel}</span>`:''}
                <span class="tmsg-time">${timeStr} · ${relTime(m.ts)}</span>
              </div>
              <div class="tbubble tbubble-other">${proc(m.text)}</div>
              <div class="tmsg-meta">🔒 AES-256-GCM · 256-bit · nonce ${nonce}${ttl?` · <span class="meta-ttl">⏱ ${ttl}</span>`:''}</div>
            </div>
          </div>`;
      }).join('');
    }
    msgsEl.scrollTop=msgsEl.scrollHeight;

    // Compose (re-bind each render)
    const input=document.getElementById('tunnel-input') as HTMLInputElement;
    const sendBtn=document.getElementById('tunnel-send');
    const doSend=()=>{
      const txt=(input?.value||'').trim();
      if (!txt) return;
      const all=loadMsgs(communityId);
      all.push({id:'msg'+Date.now(),sender:myUserId,senderName:myMem?.name||'You',text:txt,ts:Date.now(),nonce:mkNonce()});
      saveMsgs(communityId,all);
      if (input) input.value='';
      renderTunnel();
    };
    sendBtn?.replaceWith(sendBtn.cloneNode(true)); // remove old listeners
    document.getElementById('tunnel-send')?.addEventListener('click',doSend);
    input?.addEventListener('keydown',(e:KeyboardEvent)=>{ if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();doSend();} });

    // Export public key
    document.getElementById('export-pubkey-btn')?.addEventListener('click',()=>{
      const content=`-----BEGIN SHADOW WARDEN PUBLIC KEY-----\nCommunity: ${communityId}\nAlgorithm: AES-256-GCM / Ed25519\nFingerprint: ${fp}\n\nSW-PUB-${fp}:7c:2e:09:11:fd:33:48:5a:8e:c0\n-----END SHADOW WARDEN PUBLIC KEY-----`;
      const a=document.createElement('a');
      a.href=URL.createObjectURL(new Blob([content],{type:'text/plain'}));
      a.download=`public-${myUserId}.asc`; a.click(); URL.revokeObjectURL(a.href);
    });
  }

  /* ─── ACTIVITY panel ────────────────────────────────────── */
  function renderActivity() {
    const comms=loadComms();
    const c=comms.find((x:any)=>x.id===communityId);
    if (!c) return;

    const log:any[]=c.activityLog||[];
    set('activity-path',`/COMMUNITY/ACTIVITY?ID=${communityId}`);
    set('act-event-cnt',String(log.length));
    set('tab-activity-count',String(log.length));

    const ICONS:Record<string,string>={member_joined:'👤',role_changed:'↕',gdpr_export:'↓',key_exported:'🔑',setting_changed:'⚙',join_requested:'📨',member_removed:'✕',messages_cleared:'🗑',join_declined:'✕',community_merged:'🔗',key_rotated:'🔑'};
    const logEl=document.getElementById('act-log');
    if (!logEl) return;
    if (log.length===0){
      logEl.innerHTML=`<div style="padding:40px;text-align:center;color:#475569;font-size:13px">No activity yet.</div>`;
      return;
    }
    logEl.innerHTML=log.map((e:any)=>{
      const icon=ICONS[e.action]||'●';
      const d=new Date(e.ts);
      const ts=`${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,'0')}-${String(d.getUTCDate()).padStart(2,'0')} · ${String(d.getUTCHours()).padStart(2,'0')}:${String(d.getUTCMinutes()).padStart(2,'0')}:${String(d.getUTCSeconds()).padStart(2,'0')} UTC · ${e.id||'—'}`;
      const desc=esc(e.detail||e.action)
        .replace(/USR-\d+/g,m=>`<span class="ah">${m}</span>`)
        .replace(/COMM-\d+/g,m=>`<span class="ah">${m}</span>`)
        .replace(/\bMEMBER\b/g,'<span class="arole arole-member">MEMBER</span>')
        .replace(/\bADMIN\b/g,'<span class="arole arole-admin">ADMIN</span>')
        .replace(/→/g,'<span style="color:#94a3b8">→</span>')
        .replace(/(community-[^\s]+\.json)/g,'<span class="ac">$1</span>')
        .replace(/(public-USR-[^\s]+\.asc)/g,'<span class="ac">$1</span>');
      return `<div class="alog-entry"><div class="alog-icon">${icon}</div><div class="alog-body"><div class="alog-desc">${desc}</div><div class="alog-meta">${ts}</div></div></div>`;
    }).join('');
  }

  /* ─── SETTINGS panel ────────────────────────────────────── */
  function renderSettings() {
    const comms=loadComms();
    const c=comms.find((x:any)=>x.id===communityId);
    if (!c) return;
    set('settings-path',`/COMMUNITY/SETTINGS?ID=${communityId}`);
    set('export-chip',`community-${communityId}-export.json`);
    const dis=c.disappearingMessages||'off';
    set('disappear-curr',dis);
    const selEl=document.getElementById('disappear-sel') as HTMLSelectElement;
    if (selEl) selEl.value=dis;
    set('curr-fp',c.fingerprint||'—');
    set('fp-created','Jan 04');
    set('fp-age',`${Math.floor((Date.now()-(c.created||Date.now()))/86400000)} days old`);
  }

  /* ─── Settings event binding (once) ────────────────────── */
  function bindSettings() {
    document.getElementById('disappear-sel')?.addEventListener('change',()=>{
      const val=(document.getElementById('disappear-sel') as HTMLSelectElement).value;
      const cs=loadComms(); const comm=cs.find((x:any)=>x.id===communityId);
      if(!comm) return;
      const old=comm.disappearingMessages||'off';
      comm.disappearingMessages=val;
      addLog(comm,'setting_changed',`Disappearing messages window changed · ${old} → ${val} by Owner — ${val!=='off'?'messages older than '+val+' purged from feed':'auto-delete disabled'}`);
      saveComms(cs); renderSettings();
    });

    document.getElementById('gdpr-export-btn')?.addEventListener('click',()=>{
      const cs=loadComms(); const comm=cs.find((x:any)=>x.id===communityId);
      if(!comm) return;
      const data={exported_at:new Date().toISOString(),community_id:communityId,community_name:comm.name,members:(comm.members||[]).map((m:any)=>({id:m.id,role:m.role,joined:m.joined})),message_count:loadMsgs(communityId).length,audit_log:comm.activityLog||[],gdpr_note:'Message bodies are never exported — metadata only. GDPR Article 20.'};
      const a=document.createElement('a');
      a.href=URL.createObjectURL(new Blob([JSON.stringify(data,null,2)],{type:'application/json'}));
      a.download=`community-${communityId}-export.json`; a.click(); URL.revokeObjectURL(a.href);
      addLog(comm,'gdpr_export',`GDPR export · ${comm.members?.find((m:any)=>m.id===myUserId)?.name||myUserId} downloaded community-${communityId}-export.json`);
      saveComms(cs);
    });

    document.getElementById('rotate-key-btn')?.addEventListener('click',()=>{
      if(!confirm('Generate a new keypair? All members will need to re-verify the new fingerprint.')) return;
      const cs=loadComms(); const comm=cs.find((x:any)=>x.id===communityId);
      if(!comm) return;
      comm.fingerprint=mkFP();
      addLog(comm,'key_rotated',`Public key rotated · new FP: ${comm.fingerprint}`);
      saveComms(cs); renderSettings();
    });

    document.getElementById('delete-comm-btn')?.addEventListener('click',()=>{
      const comm=loadComms().find((x:any)=>x.id===communityId);
      if(!confirm(`Delete "${comm?.name}"? This cannot be undone.`)) return;
      saveComms(loadComms().filter((x:any)=>x.id!==communityId));
      localStorage.removeItem(tKey(communityId));
      window.location.href='/community';
    });
  }

  /* ─── Breadcrumb + badge helpers ────────────────────────── */
  function updateBreadcrumb() {
    const c=loadComms().find((x:any)=>x.id===communityId);
    set('bc-name',c?c.name.toLowerCase().replace(/\s+/g,'-'):communityId||'—');
    if (c) document.title=`${c.name} — Shadow Warden AI`;
  }
  function updateBadges() {
    const c=loadComms().find((x:any)=>x.id===communityId);
    if(!c) return;
    set('tab-members-count',String((c.members||[]).length));
    set('tab-activity-count',String((c.activityLog||[]).length));
  }

  /* ─── Tiny DOM helpers ──────────────────────────────────── */
  function set(id: string, val: string) { const e=document.getElementById(id); if(e) e.textContent=val; }
  function el(id: string, prop: string, val: string) { const e=document.getElementById(id) as any; if(e) e[prop]=val; }

  /* ─── Init ──────────────────────────────────────────────── */
  function init() {
    seed();
    communityId = qp('id') || 'COMM-1024';
    myUserId    = localStorage.getItem(USER_KEY) || 'USR-0001';
    activeTab   = qp('tab') || 'communities';

    updateBreadcrumb();
    updateBadges();

    // User chip initials
    const comms=loadComms();
    const me=comms.find((c:any)=>c.id===communityId)?.members?.find((m:any)=>m.id===myUserId);
    if (me?.name) set('user-chip',initials(me.name));

    // Tab clicks
    document.querySelectorAll<HTMLElement>('.comm-tab').forEach(btn=>{
      btn.addEventListener('click',()=>switchTab(btn.dataset.tab||'communities'));
    });

    // Live search
    document.getElementById('comm-search')?.addEventListener('input',renderComms);
    document.getElementById('member-filter')?.addEventListener('input',renderMembers);

    // Settings events bound once
    bindSettings();

    // Activate initial tab
    switchTab(activeTab);
  }

  init();
})();
</script>
