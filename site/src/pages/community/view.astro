---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Community Portal — Shadow Warden AI"
  description="Secure community collaboration with end-to-end encrypted tunnel, member management, and GDPR controls."
>
<div class="comm-portal pt-14">

  <!-- ── BREADCRUMB TOPBAR ─────────────────────────────────── -->
  <div class="comm-topbar">
    <nav class="comm-breadcrumb">
      <a href="/" class="bc-brand">Shadow · Warden</a>
      <span class="bc-sep">/community</span>
      <span class="bc-arrow">›</span>
      <span class="bc-current" id="bc-name">—</span>
    </nav>
    <div class="comm-user-chip" id="user-chip">ZB</div>
  </div>

  <!-- ── TAB NAVIGATION ───────────────────────────────────── -->
  <div class="comm-tabnav">
    <button class="comm-tab" data-tab="communities">
      Communities
    </button>
    <button class="comm-tab" data-tab="members">
      Members <span class="tab-count" id="tab-members-count"></span>
    </button>
    <button class="comm-tab" data-tab="tunnel">
      Tunnel
    </button>
    <button class="comm-tab" data-tab="activity">
      Activity <span class="tab-count" id="tab-activity-count"></span>
    </button>
    <button class="comm-tab" data-tab="settings">
      Settings
    </button>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       PANEL: COMMUNITIES
  ══════════════════════════════════════════════════════════ -->
  <div id="panel-communities" class="comm-panel comm-two-col hidden">

    <!-- Left: search + results -->
    <div class="comm-main">
      <div class="section-header">
        <h2 class="section-title">Communities</h2>
        <span class="section-path">/COMMUNITY</span>
        <span class="section-hint ml-auto">Search by name or ID. Join requests sent to Owner/Admin.</span>
      </div>

      <div class="search-wrap">
        <span class="si">🔍</span>
        <input type="text" id="comm-search" class="comm-search-input" placeholder="Search communities…" autocomplete="off" />
        <span class="search-shortcut">⌘K</span>
      </div>

      <div class="results-hdr" id="results-hdr"></div>
      <div class="comm-card-grid" id="comm-card-grid"></div>
    </div>

    <!-- Right: Your activity sidebar -->
    <aside class="comm-sidebar">
      <div class="sidebar-card">
        <p class="sidebar-title">Your activity</p>

        <div class="act-stat">
          <span class="stat-n" id="stat-joined">—</span>
          <span class="stat-lbl">Communities joined</span>
        </div>
        <div class="act-stat">
          <span class="stat-n" id="stat-pending">—</span>
          <span class="stat-lbl">Pending requests</span>
        </div>
        <div class="act-stat">
          <span class="stat-n" id="stat-msgs">—</span>
          <span class="stat-lbl">Messages this week</span>
        </div>

        <div class="fp-block">
          <span class="fp-code" id="my-fp">—</span>
          <span class="fp-lbl">Your public-key fingerprint</span>
        </div>
      </div>
    </aside>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       PANEL: MEMBERS
  ══════════════════════════════════════════════════════════ -->
  <div id="panel-members" class="comm-panel hidden">
    <div class="section-header">
      <h2 class="section-title">Members</h2>
      <span class="section-path" id="members-path"></span>
      <span class="section-hint ml-auto">Owner can promote/demote anyone. Owner role is locked — never deletable.</span>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar">
      <span class="si" style="color:#475569">🔍</span>
      <input type="text" id="member-filter" class="filter-input"
             placeholder="Filter by USER-ID (e.g. USR-018) or role (owner/admin/member)…" />
      <span class="filter-hint">/</span>
    </div>

    <!-- Join requests (owner/admin only) -->
    <div id="join-req-section" style="display:none">
      <div class="jr-header">
        <span class="jr-icon">📨</span>
        <span class="jr-title">Join Requests</span>
        <span class="jr-count" id="jr-count">0 pending</span>
        <span class="jr-hint">visible to Owner / Admin · automatic notify enabled</span>
      </div>
      <div class="jr-list" id="jr-list"></div>
    </div>

    <!-- Members table -->
    <div class="members-wrap">
      <div class="members-hdr">
        <span id="mem-count-lbl" style="font-size:13px;font-weight:600;color:#f1f5f9">0 members</span>
        <span style="font-size:11px;color:#334155">Last sync: <span id="sync-time">just now</span></span>
      </div>
      <div class="mtable">
        <div class="mth">
          <div class="th mc">MEMBER</div>
          <div class="th uc">USER-ID</div>
          <div class="th jc">JOINED</div>
          <div class="th rc">ROLE</div>
          <div class="th gc">MANAGE</div>
        </div>
        <div id="mtbody"></div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       PANEL: TUNNEL
  ══════════════════════════════════════════════════════════ -->
  <div id="panel-tunnel" class="comm-panel tunnel-panel hidden">

    <!-- Channel header -->
    <div class="tunnel-hdr">
      <div class="tunnel-hdr-l">
        <div class="tlock">🔒</div>
        <div>
          <div class="tchan-name">
            <span id="tchan-comm">—</span>
            <span style="color:#64748b"> · #general</span>
            <span class="enc-badge">+ ENCRYPTED</span>
          </div>
          <div class="tfp" id="tfp">FP —</div>
        </div>
      </div>
      <div class="tunnel-hdr-r">
        <button class="btn-outline" id="export-pubkey-btn">↓ Export Public Key</button>
        <span class="pubkey-chip" id="pubkey-chip">public-USR-0001.asc</span>
      </div>
    </div>

    <div class="tunnel-sub-line">
      End-to-end encrypted · AES-256-GCM · keys never leave clients
    </div>

    <!-- Auto-delete banner -->
    <div class="ad-bar hidden" id="ad-bar">
      <span class="ad-dot">●</span>
      <span class="ad-text">24h auto-delete <strong>is ON</strong> — messages older than 24 hours are filtered on load</span>
      <span class="ad-cnt" id="ad-cnt"></span>
    </div>

    <!-- Messages -->
    <div class="tunnel-msgs" id="tunnel-msgs"></div>

    <!-- Compose -->
    <div class="tunnel-compose">
      <input type="text" id="tunnel-input" class="t-input"
             placeholder="Encrypted message · plain-text never leaves your browser…" />
      <button class="t-send-btn" id="tunnel-send">✈ Send</button>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       PANEL: ACTIVITY
  ══════════════════════════════════════════════════════════ -->
  <div id="panel-activity" class="comm-panel hidden">
    <div class="section-header">
      <h2 class="section-title">Activity log</h2>
      <span class="section-path" id="activity-path"></span>
      <span class="section-hint ml-auto">Append-only · <span id="act-event-cnt">0</span> events · last 24 hours</span>
    </div>
    <div class="act-log" id="act-log"></div>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       PANEL: SETTINGS · GDPR
  ══════════════════════════════════════════════════════════ -->
  <div id="panel-settings" class="comm-panel hidden">
    <div class="section-header">
      <h2 class="section-title">Settings · GDPR</h2>
      <span class="section-path" id="settings-path"></span>
      <span class="section-hint ml-auto">Export everything you control — content, members, audit, public keys. Private keys never leave the device.</span>
    </div>

    <div class="srows">

      <div class="srow">
        <div class="srow-info">
          <div class="srow-title">Export community data (GDPR Article 20)</div>
          <div class="srow-desc">Bundles community metadata, message metadata (not plaintext bodies), member roster with USER-IDs, role history, and audit log into a single JSON file.</div>
          <div class="srow-hint">Generated client-side · signed with your private key · private keys excluded</div>
        </div>
        <div class="srow-action">
          <button class="btn-export" id="gdpr-export-btn">↓ Export JSON</button>
          <span class="export-chip" id="export-chip">community-COMM-0000-export.json</span>
        </div>
      </div>

      <div class="srow">
        <div class="srow-info">
          <div class="srow-title">Disappearing messages</div>
          <div class="srow-desc">Auto-delete messages older than the chosen window. Already-decrypted messages on devices remain until the device refreshes.</div>
          <div class="srow-hint">Current: <span id="disappear-curr">off</span> · enforced on every tunnel load</div>
        </div>
        <div class="srow-action">
          <select class="srow-select" id="disappear-sel">
            <option value="off">Off</option>
            <option value="1h">1 hour</option>
            <option value="6h">6 hours</option>
            <option value="24h">24 hours</option>
            <option value="7d">7 days</option>
            <option value="30d">30 days</option>
          </select>
        </div>
      </div>

      <div class="srow">
        <div class="srow-info">
          <div class="srow-title">Rotate public key</div>
          <div class="srow-desc">Generate a new keypair and republish the public half. All members re-verify the new fingerprint on their next session.</div>
          <div class="srow-hint">Current FP: <span id="curr-fp">—</span> · created <span id="fp-created">—</span> · <span id="fp-age">—</span></div>
        </div>
        <div class="srow-action">
          <button class="btn-outline" id="rotate-key-btn">Rotate</button>
        </div>
      </div>

      <div class="srow danger-srow">
        <div class="srow-info">
          <div class="srow-title" style="color:#ef4444">Delete community</div>
          <div class="srow-desc">All messages, keys, and roles are wiped. USER-IDs of members are anonymized in the audit ledger. Irreversible.</div>
        </div>
        <div class="srow-action">
          <button class="btn-delete" id="delete-comm-btn">Delete community</button>
        </div>
      </div>

    </div>
  </div>

</div><!-- /comm-portal -->
</BaseLayout>

<style>
/* ── Reset / Portal shell ──────────────────────────────────── */
.comm-portal {
  min-height: 100vh;
  background: #0c1018;
  font-size: 14px;
  color: #e2e8f0;
}
.ml-auto { margin-left: auto; }
.hidden { display: none !important; }

/* ── Breadcrumb topbar ─────────────────────────────────────── */
.comm-topbar {
  position: sticky;
  top: 56px;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  height: 42px;
  background: #0f1420;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.comm-breadcrumb {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 13px;
}
.bc-brand { color: #f1f5f9; font-weight: 600; text-decoration: none; }
.bc-sep   { color: #334155; }
.bc-arrow { color: #334155; }
.bc-current { color: #94a3b8; font-weight: 500; }
.comm-user-chip {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: #4f46e5;
  color: white;
  font-size: 11px; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  cursor: default; user-select: none;
}

/* ── Tab nav ───────────────────────────────────────────────── */
.comm-tabnav {
  position: sticky;
  top: 98px;
  z-index: 29;
  display: flex;
  align-items: stretch;
  background: #0f1420;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  padding: 0 20px;
  overflow-x: auto;
}
.comm-tab {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 0 16px;
  height: 44px;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: #475569;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  transition: color 0.15s, border-color 0.15s;
}
.comm-tab:hover { color: #94a3b8; }
.comm-tab.active { color: #f1f5f9; border-bottom-color: #f1f5f9; }
.tab-count {
  font-size: 11px; font-weight: 700;
  padding: 1px 7px; border-radius: 99px;
  background: rgba(255,255,255,0.08); color: #64748b;
}
.comm-tab.active .tab-count { background: rgba(255,255,255,0.12); color: #94a3b8; }

/* ── Panel base ────────────────────────────────────────────── */
.comm-panel { padding: 24px; max-width: 1160px; margin: 0 auto; }

/* ── Section header ────────────────────────────────────────── */
.section-header {
  display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  margin-bottom: 18px;
}
.section-title { font-size: 18px; font-weight: 700; color: #f1f5f9; margin: 0; }
.section-path  { font-size: 11px; font-family: monospace; color: #334155; }
.section-hint  { font-size: 12px; color: #475569; }

/* ── Communities panel: two-col grid ───────────────────────── */
.comm-two-col {
  display: grid;
  grid-template-columns: 1fr 270px;
  gap: 20px;
  align-items: start;
}
.comm-main {}

/* Search */
.search-wrap {
  display: flex; align-items: center; gap: 10px;
  background: #131929; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px;
  padding: 10px 14px; margin-bottom: 12px;
}
.si { font-size: 14px; flex-shrink: 0; }
.comm-search-input {
  flex: 1; background: none; border: none; outline: none;
  color: #f1f5f9; font-size: 13px;
}
.comm-search-input::placeholder { color: #475569; }
.search-shortcut {
  font-size: 11px; color: #334155; font-family: monospace;
  padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.08);
}

.results-hdr {
  display: flex; align-items: center; justify-content: space-between;
  font-size: 12px; color: #64748b; margin-bottom: 12px;
}

/* Community card grid */
.comm-card-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}
.comm-card {
  background: #131929; border: 1px solid rgba(255,255,255,0.07);
  border-radius: 14px; padding: 16px; cursor: pointer;
  transition: border-color 0.15s;
}
.comm-card:hover { border-color: rgba(255,255,255,0.15); }
.card-top { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
.card-av {
  width: 36px; height: 36px; border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 800; color: white; flex-shrink: 0;
}
.card-meta { flex: 1; min-width: 0; }
.card-name { font-size: 14px; font-weight: 700; color: #f1f5f9; margin-bottom: 2px; }
.card-id   { font-size: 11px; color: #475569; font-family: monospace; }
.card-act  { flex-shrink: 0; }
.badge-joined  {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 11px; font-weight: 700; color: #10b981;
  background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.25);
  padding: 3px 10px; border-radius: 6px;
}
.badge-pending {
  font-size: 11px; font-weight: 700; color: #f59e0b;
  background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25);
  padding: 3px 10px; border-radius: 6px;
}
.btn-join {
  font-size: 11px; font-weight: 600; color: #94a3b8;
  background: transparent; border: 1px solid rgba(255,255,255,0.15);
  padding: 3px 12px; border-radius: 6px; cursor: pointer;
  transition: background 0.15s;
}
.btn-join:hover { background: rgba(255,255,255,0.06); }
.card-desc  { font-size: 12px; color: #64748b; line-height: 1.5; margin-bottom: 10px; }
.card-stats { display: flex; align-items: center; gap: 12px; font-size: 11px; color: #475569; }
.e2ee-chip  {
  font-size: 10px; font-weight: 700; color: #10b981;
  background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2);
  padding: 1px 7px; border-radius: 4px; font-family: monospace;
}

/* Sidebar */
.comm-sidebar { position: sticky; top: 160px; }
.sidebar-card {
  background: #131929; border: 1px solid rgba(255,255,255,0.07);
  border-radius: 14px; padding: 20px;
}
.sidebar-title { font-size: 13px; font-weight: 600; color: #94a3b8; margin: 0 0 18px; }
.act-stat { margin-bottom: 16px; }
.stat-n   { display: block; font-size: 36px; font-weight: 800; color: #f1f5f9; line-height: 1; margin-bottom: 4px; }
.stat-lbl { font-size: 12px; color: #475569; }
.fp-block {
  margin-top: 18px; padding-top: 16px;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.fp-code  { display: block; font-size: 13px; font-family: monospace; font-weight: 700; color: #f1f5f9; margin-bottom: 4px; word-break: break-all; }
.fp-lbl   { font-size: 11px; color: #475569; }

/* ── Filter bar ────────────────────────────────────────────── */
.filter-bar {
  display: flex; align-items: center; gap: 10px;
  background: #131929; border: 1px solid rgba(255,255,255,0.08);
  border-radius: 10px; padding: 10px 14px; margin-bottom: 16px;
}
.filter-input {
  flex: 1; background: none; border: none; outline: none;
  color: #f1f5f9; font-size: 13px;
}
.filter-input::placeholder { color: #475569; }
.filter-hint { font-size: 11px; color: #334155; font-family: monospace; }

/* ── Join requests ─────────────────────────────────────────── */
.jr-header {
  display: flex; align-items: center; gap: 8px; margin-bottom: 10px;
}
.jr-icon  { font-size: 14px; }
.jr-title { font-size: 14px; font-weight: 600; color: #f1f5f9; }
.jr-count { font-size: 12px; font-weight: 700; color: #f59e0b; }
.jr-hint  { font-size: 11px; color: #334155; margin-left: auto; }
.jr-list  {
  background: #131929; border: 1px solid rgba(255,255,255,0.07);
  border-radius: 14px; overflow: hidden; margin-bottom: 16px;
}
.jr-row {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.jr-row:last-child { border-bottom: none; }
.jr-av {
  width: 34px; height: 34px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; color: white; flex-shrink: 0;
}
.jr-info { flex: 1; min-width: 0; }
.jr-name { font-size: 13px; font-weight: 600; color: #f1f5f9; margin-bottom: 2px; }
.jr-id   { font-size: 11px; color: #475569; font-family: monospace; margin-bottom: 3px; }
.jr-msg  { font-size: 11px; color: #64748b; font-style: italic; }
.jr-time { font-size: 11px; color: #334155; white-space: nowrap; flex-shrink: 0; }
.jr-acts { display: flex; gap: 6px; flex-shrink: 0; }
.btn-decline {
  padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 600;
  color: #ef4444; background: rgba(239,68,68,0.08);
  border: 1px solid rgba(239,68,68,0.25); cursor: pointer;
  transition: background 0.15s;
}
.btn-decline:hover { background: rgba(239,68,68,0.16); }
.btn-approve {
  padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 600;
  color: white; background: #10b981; border: none; cursor: pointer;
  transition: opacity 0.15s;
}
.btn-approve:hover { opacity: 0.85; }

/* ── Members table ─────────────────────────────────────────── */
.members-wrap {
  background: #131929; border: 1px solid rgba(255,255,255,0.07);
  border-radius: 14px; overflow: hidden;
}
.members-hdr {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.06);
}
.mtable {}
.mth {
  display: grid;
  grid-template-columns: 2.5fr 1fr 1.2fr 1fr 1fr;
  padding: 8px 16px;
  background: rgba(255,255,255,0.015);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.th {
  font-size: 10px; font-weight: 700; letter-spacing: 0.07em;
  color: #334155; text-transform: uppercase;
}
.mrow {
  display: grid;
  grid-template-columns: 2.5fr 1fr 1.2fr 1fr 1fr;
  padding: 12px 16px; align-items: center;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.mrow:last-child { border-bottom: none; }
.mc { display: flex; align-items: center; gap: 10px; }
.mav {
  width: 32px; height: 32px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; color: white; flex-shrink: 0;
}
.mav-name { font-size: 13px; font-weight: 600; color: #f1f5f9; }
.mav-sub  { font-size: 11px; color: #475569; }
.uc { font-size: 12px; font-family: monospace; color: #64748b; }
.jc { font-size: 12px; color: #64748b; }
.rc {}
.gc {}
.role-badge {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 10px; font-weight: 700;
  padding: 3px 9px; border-radius: 6px;
}
.role-owner  { color: #fbbf24; background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.25); }
.role-admin  { color: #a78bfa; background: rgba(167,139,250,0.1); border: 1px solid rgba(167,139,250,0.25); }
.role-member { color: #64748b; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); }
.btn-locked { font-size: 11px; color: #475569; display: flex; align-items: center; gap: 4px; }
.btn-change {
  font-size: 12px; padding: 4px 12px;
  border-radius: 6px; background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.1); color: #94a3b8;
  cursor: pointer; transition: background 0.15s;
}
.btn-change:hover { background: rgba(255,255,255,0.08); }

/* ── Tunnel panel ──────────────────────────────────────────── */
.tunnel-panel {
  padding: 0;
  display: flex; flex-direction: column;
  height: calc(100vh - 144px);
}
.tunnel-hdr {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 24px; border-bottom: 1px solid rgba(255,255,255,0.07);
