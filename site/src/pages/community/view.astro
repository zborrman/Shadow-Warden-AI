---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Community Overview — Shadow Warden AI"
  description="View and manage your secure collaboration community."
>
  <section class="pt-28 pb-24 min-h-screen" style="background:#0a0a0f">
    <div class="mx-auto max-w-4xl px-4 lg:px-8">

      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 mb-6 text-[13px]" style="color:#475569">
        <a href="/community" style="color:#64748b;text-decoration:none" onmouseover="this.style.color='#06b6d4'" onmouseout="this.style.color='#64748b'">Communities</a>
        <span>›</span>
        <span id="bc-name" style="color:#94a3b8">Loading…</span>
      </div>

      <!-- Community header -->
      <div id="comm-header" style="background:#0d1220;border:1px solid rgba(255,255,255,0.08);border-radius:20px;padding:28px;margin-bottom:20px">
        <p class="text-[10px] font-mono font-bold tracking-widest uppercase mb-2" style="color:#06b6d4" id="comm-id-display">—</p>
        <h1 class="text-[clamp(24px,3vw,36px)] font-black tracking-tight mb-2" style="color:#f1f5f9" id="comm-name-display">—</h1>
        <p class="text-[14px] mb-5" style="color:#64748b" id="comm-desc-display"></p>
        <div class="flex items-center gap-4 flex-wrap">
          <span class="text-[12px] font-mono" style="color:#475569" id="comm-created">—</span>
          <span style="padding:3px 10px;border-radius:20px;background:rgba(6,182,212,0.08);border:1px solid rgba(6,182,212,0.18);font-size:11px;font-weight:700;color:#06b6d4;font-family:monospace" id="comm-member-count">0 members</span>
        </div>
      </div>

      <!-- Tab nav -->
      <div class="flex gap-2 mb-6" id="tab-nav" style="overflow-x:auto;padding-bottom:4px">
        <!-- Rendered by JS -->
      </div>

      <!-- Stats grid -->
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;margin-bottom:20px" id="stats-grid">
      </div>

      <!-- Quick actions -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px" id="quick-actions">
      </div>
    </div>
  </section>

  <script>
    const COMM_KEY = 'sw_communities';

    function getParam(name: string): string {
      return new URLSearchParams(window.location.search).get(name) || '';
    }

    function loadCommunities(): any[] {
      try { return JSON.parse(localStorage.getItem(COMM_KEY) || '[]'); } catch { return []; }
    }

    function esc(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function tunnelMsgCount(id: string): number {
      try { return JSON.parse(localStorage.getItem(`sw_tunnel_${id}`) || '[]').length; } catch { return 0; }
    }

    function render() {
      const id = getParam('id');
      if (!id) {
        document.getElementById('comm-header')!.innerHTML = `<p style="color:#FF2D55;font-size:14px">No community ID specified. <a href="/community" style="color:#06b6d4">Back to communities</a></p>`;
        return;
      }

      const comms = loadCommunities();
      const c = comms.find((x: any) => x.id === id);

      if (!c) {
        document.getElementById('comm-header')!.innerHTML = `<p style="color:#FF2D55;font-size:14px">Community <code>${esc(id)}</code> not found. <a href="/community" style="color:#06b6d4">Back to communities</a></p>`;
        return;
      }

      // Breadcrumb + header
      const bcEl = document.getElementById('bc-name');
      if (bcEl) bcEl.textContent = c.name;
      document.title = `${c.name} — Shadow Warden AI`;

      const idEl = document.getElementById('comm-id-display');
      const nameEl = document.getElementById('comm-name-display');
      const descEl = document.getElementById('comm-desc-display');
      const createdEl = document.getElementById('comm-created');
      const memberEl = document.getElementById('comm-member-count');

      if (idEl) idEl.textContent = c.id;
      if (nameEl) nameEl.textContent = c.name;
      if (descEl) descEl.textContent = c.description || '';
      if (createdEl) createdEl.textContent = `Created ${new Date(c.created).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}`;
      const mc = (c.members || []).length;
      if (memberEl) memberEl.textContent = `${mc} member${mc !== 1 ? 's' : ''}`;

      // Tab nav
      const tabs = [
        { label: '📋 Overview', href: `/community/view?id=${encodeURIComponent(id)}`, active: true },
        { label: '👥 Members', href: `/community/members?id=${encodeURIComponent(id)}` },
        { label: '🔒 Tunnel',       href: `/community/tunnel?id=${encodeURIComponent(id)}` },
        { label: '🔌 Integrations', href: `/community/integrations?id=${encodeURIComponent(id)}` },
        { label: '⚙️ Settings',     href: `/community/settings?id=${encodeURIComponent(id)}` },
      ];
      const tabNav = document.getElementById('tab-nav');
      if (tabNav) {
        tabNav.innerHTML = tabs.map(t => `
          <a href="${t.href}"
             style="padding:9px 16px;border-radius:10px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;
                    ${t.active ? 'background:rgba(6,182,212,0.15);border:1px solid rgba(6,182,212,0.3);color:#06b6d4'
                               : 'background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);color:#64748b'};
                    transition:all 0.15s"
             ${!t.active ? `onmouseover="this.style.color='#94a3b8';this.style.background='rgba(255,255,255,0.07)'" onmouseout="this.style.color='#64748b';this.style.background='rgba(255,255,255,0.03)'"` : ''}>
            ${t.label}
          </a>
        `).join('');
      }

      // Stats
      const msgCount = tunnelMsgCount(id);
      const statsGrid = document.getElementById('stats-grid');
      if (statsGrid) {
        statsGrid.innerHTML = [
          { label: 'Members', value: mc.toString(), color: '#06b6d4', icon: '👥' },
          { label: 'Tunnel Messages', value: msgCount.toString(), color: '#BF5AF2', icon: '🔒' },
          { label: 'Community ID', value: c.id, color: '#30D158', icon: '🪪', mono: true },
          { label: 'Status', value: 'Active', color: '#30D158', icon: '✅' },
        ].map(s => `
          <div style="background:#0d1220;border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:16px">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
              <span style="font-size:16px">${s.icon}</span>
              <span style="font-size:11px;color:#475569;text-transform:uppercase;letter-spacing:0.05em;font-weight:600">${s.label}</span>
            </div>
            <p style="font-size:${s.mono ? '12px' : '22px'};font-weight:700;color:${s.color};${s.mono ? 'font-family:monospace' : ''};margin:0">${s.value}</p>
          </div>
        `).join('');
      }

      // Quick actions
      const qa = document.getElementById('quick-actions');
      if (qa) {
        qa.innerHTML = `
          <a href="/community/tunnel?id=${encodeURIComponent(id)}"
             style="display:block;padding:20px;background:#0d1220;border:1px solid rgba(255,255,255,0.06);border-radius:16px;text-decoration:none;transition:border-color 0.2s"
             onmouseover="this.style.borderColor='rgba(6,182,212,0.25)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'">
            <p style="font-size:24px;margin-bottom:8px">🔒</p>
            <p style="font-size:15px;font-weight:700;color:#f1f5f9;margin:0 0 4px">Open Tunnel</p>
            <p style="font-size:12px;color:#64748b;margin:0">End-to-end encrypted channel${msgCount > 0 ? ` · ${msgCount} messages` : ''}</p>
          </a>
          <a href="/community/members?id=${encodeURIComponent(id)}"
             style="display:block;padding:20px;background:#0d1220;border:1px solid rgba(255,255,255,0.06);border-radius:16px;text-decoration:none;transition:border-color 0.2s"
             onmouseover="this.style.borderColor='rgba(191,90,242,0.25)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'">
            <p style="font-size:24px;margin-bottom:8px">👥</p>
            <p style="font-size:15px;font-weight:700;color:#f1f5f9;margin:0 0 4px">Manage Members</p>
            <p style="font-size:12px;color:#64748b;margin:0">Invite, remove, merge communities</p>
          </a>
        `;
      }
    }

    render();
  </script>
</BaseLayout>
