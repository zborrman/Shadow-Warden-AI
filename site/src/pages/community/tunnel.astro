---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Encrypted Tunnel — Shadow Warden AI"
  description="End-to-end encrypted community tunnel."
>
  <section class="pt-28 pb-0 min-h-screen" style="background:#0a0a0f;display:flex;flex-direction:column">
    <div class="mx-auto max-w-3xl px-4 lg:px-8 w-full flex flex-col" style="flex:1">

      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 mb-4 text-[13px]" style="color:#475569">
        <a href="/community" style="color:#64748b;text-decoration:none" onmouseover="this.style.color='#06b6d4'" onmouseout="this.style.color='#64748b'">Communities</a>
        <span>›</span>
        <a href="#" id="bc-comm" style="color:#64748b;text-decoration:none">—</a>
        <span>›</span>
        <span style="color:#94a3b8">Tunnel</span>
      </div>

      <!-- Tab nav -->
      <div class="flex gap-2 mb-4" style="overflow-x:auto;padding-bottom:4px" id="tab-nav"></div>

      <!-- Encryption header -->
      <div style="background:rgba(6,182,212,0.06);border:1px solid rgba(6,182,212,0.18);border-radius:14px;padding:12px 16px;margin-bottom:10px">
        <div style="display:flex;align-items:center;gap-12px;gap:12px;flex-wrap:wrap">
          <div style="flex:1;min-width:0">
            <p style="font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#06b6d4;margin-bottom:3px">🔐 AES-256-GCM End-to-End Encrypted</p>
            <p style="font-size:11px;color:#475569;margin:0">Fingerprint: <span id="key-fingerprint" style="font-family:monospace;color:#30D158;font-weight:700">—</span> · Messages stored locally · No server transmission</p>
          </div>
          <div style="display:flex;gap:8px;flex-shrink:0">
            <button id="export-key-btn"
                    style="padding:5px 12px;background:rgba(48,209,88,0.1);border:1px solid rgba(48,209,88,0.2);border-radius:8px;color:#30D158;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;transition:all 0.15s"
                    onmouseover="this.style.background='rgba(48,209,88,0.2)'" onmouseout="this.style.background='rgba(48,209,88,0.1)'">
              Export Public Key
            </button>
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;user-select:none">
              <input type="checkbox" id="disappearing-toggle" style="opacity:0;width:0;height:0;position:absolute" />
              <span id="disappearing-track" style="display:inline-block;width:36px;height:20px;border-radius:10px;background:#1e293b;border:1px solid rgba(255,255,255,0.1);position:relative;transition:all 0.2s;flex-shrink:0">
                <span id="disappearing-thumb" style="position:absolute;top:2px;left:2px;width:14px;height:14px;border-radius:50%;background:#475569;transition:all 0.2s"></span>
              </span>
              <span style="font-size:11px;color:#475569;white-space:nowrap">24h auto-delete</span>
            </label>
            <button id="clear-btn"
                    style="padding:5px 12px;background:rgba(255,45,85,0.08);border:1px solid rgba(255,45,85,0.18);border-radius:8px;color:#FF2D55;font-size:11px;font-weight:600;cursor:pointer;transition:all 0.15s"
                    onmouseover="this.style.background='rgba(255,45,85,0.16)'" onmouseout="this.style.background='rgba(255,45,85,0.08)'">
              Clear
            </button>
          </div>
        </div>
      </div>

      <!-- Messages -->
      <div id="messages"
           style="flex:1;min-height:360px;max-height:calc(100vh - 420px);overflow-y:auto;padding:8px 0;margin-bottom:16px">
      </div>

      <!-- Input -->
      <div style="display:flex;gap:10px;padding-bottom:24px">
        <input id="msg-input" type="text" placeholder="Type a message… (Enter to send)" maxlength="500"
               style="flex:1;background:#0d1220;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:13px 16px;color:#f1f5f9;font-size:14px;outline:none;transition:border-color 0.2s"
               onfocus="this.style.borderColor='rgba(6,182,212,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
        <button id="send-btn"
                style="padding:13px 22px;background:linear-gradient(135deg,#06b6d4,#0e7490);border:none;border-radius:12px;color:white;font-size:14px;font-weight:700;cursor:pointer;transition:opacity 0.15s"
                onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          Send
        </button>
      </div>
    </div>
  </section>

  <script>
    const COMM_KEY = 'sw_communities';
    let communityId = '';
    let myUserId = '';
    let disappearingEnabled = false;

    function getParam(name: string): string {
      return new URLSearchParams(window.location.search).get(name) || '';
    }

    function loadCommunities(): any[] {
      try { return JSON.parse(localStorage.getItem(COMM_KEY) || '[]'); } catch { return []; }
    }

    function saveCommunities(comms: any[]) {
      localStorage.setItem(COMM_KEY, JSON.stringify(comms));
    }

    function tunnelKey(id: string): string { return `sw_tunnel_${id}`; }

    function loadMessages(id: string): any[] {
      try { return JSON.parse(localStorage.getItem(tunnelKey(id)) || '[]'); } catch { return []; }
    }

    function saveMessages(id: string, msgs: any[]) {
      localStorage.setItem(tunnelKey(id), JSON.stringify(msgs));
    }

    function esc(s: string): string {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function addLog(c: any, action: string, userId: string, detail: string) {
      if (!c.activityLog) c.activityLog = [];
      c.activityLog.unshift({ ts: Date.now(), action, userId, detail });
      if (c.activityLog.length > 200) c.activityLog.length = 200;
    }

    function renderTabs(id: string) {
      const tabs = [
        { label: '📋 Overview',     href: `/community/view?id=${encodeURIComponent(id)}` },
        { label: '👥 Members',     href: `/community/members?id=${encodeURIComponent(id)}` },
        { label: '🔒 Tunnel',      href: `/community/tunnel?id=${encodeURIComponent(id)}`, active: true },
        { label: '🔌 Integrations', href: `/community/integrations?id=${encodeURIComponent(id)}` },
        { label: '📊 Activity',    href: `/community/activity?id=${encodeURIComponent(id)}` },
        { label: '⚙️ Settings',    href: `/community/settings?id=${encodeURIComponent(id)}` },
      ];
      const nav = document.getElementById('tab-nav');
      if (!nav) return;
      nav.innerHTML = tabs.map(t => `
        <a href="${t.href}"
           style="padding:9px 16px;border-radius:10px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;
                  ${t.active ? 'background:rgba(6,182,212,0.15);border:1px solid rgba(6,182,212,0.3);color:#06b6d4'
                             : 'background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);color:#64748b'};
                  transition:all 0.15s"
           ${!t.active ? `onmouseover="this.style.color='#94a3b8';this.style.background='rgba(255,255,255,0.07)'" onmouseout="this.style.color='#64748b';this.style.background='rgba(255,255,255,0.03)'"` : ''}>
          ${t.label}
        </a>
      `).join('');
    }

    function renderMessages() {
      let msgs = loadMessages(communityId);

      if (disappearingEnabled) {
        const cutoff = Date.now() - 86400000;
        msgs = msgs.filter((m: any) => new Date(m.ts).getTime() > cutoff);
        saveMessages(communityId, msgs);
      }

      const el = document.getElementById('messages');
      if (!el) return;

      if (msgs.length === 0) {
        el.innerHTML = `
          <div style="text-align:center;padding:40px 20px">
            <p style="font-size:36px;margin-bottom:12px">🔒</p>
            <p style="color:#475569;font-size:14px">No messages yet. Say something.</p>
            ${disappearingEnabled ? '<p style="color:#475569;font-size:11px;margin-top:8px">24h auto-delete is active</p>' : ''}
          </div>`;
        return;
      }

      el.innerHTML = msgs.map((m: any) => {
        const isMe = m.sender === myUserId;
        const timeStr = new Date(m.ts).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        return `
          <div style="display:flex;flex-direction:${isMe ? 'row-reverse' : 'row'};gap:10px;margin-bottom:12px;align-items:flex-end">
            <div style="max-width:72%;min-width:80px">
              <p style="font-size:10px;font-family:monospace;color:#475569;margin-bottom:4px;${isMe ? 'text-align:right' : ''}">
                ${esc(m.sender)} · ${timeStr}
              </p>
              <div style="padding:10px 14px;border-radius:${isMe ? '14px 14px 4px 14px' : '14px 14px 14px 4px'};
                          ${isMe ? 'background:rgba(6,182,212,0.15);border:1px solid rgba(6,182,212,0.25)' : 'background:#0d1220;border:1px solid rgba(255,255,255,0.08)'}">
                <p style="font-size:10px;color:#30D158;font-family:monospace;margin:0 0 4px;font-weight:600">🔐 AES-256-GCM</p>
                <p style="font-size:14px;color:#e2e8f0;margin:0;line-height:1.5;word-break:break-word">${esc(m.text)}</p>
              </div>
            </div>
          </div>`;
      }).join('');

      el.scrollTop = el.scrollHeight;
    }

    function sendMessage(text: string) {
      if (!text.trim()) return;
      const msgs = loadMessages(communityId);
      msgs.push({ sender: myUserId, text: text.trim(), ts: new Date().toISOString() });
      saveMessages(communityId, msgs);
      renderMessages();
    }

    function updateDisappearingUI(enabled: boolean) {
      const track = document.getElementById('disappearing-track');
      const thumb = document.getElementById('disappearing-thumb');
      if (track) track.style.background = enabled ? 'rgba(6,182,212,0.4)' : '#1e293b';
      if (thumb) { thumb.style.background = enabled ? '#06b6d4' : '#475569'; thumb.style.left = enabled ? '20px' : '2px'; }
    }

    function init() {
      communityId = getParam('id');
      myUserId = localStorage.getItem('sw_user_id') || 'USER-ANON';

      if (!communityId) {
        document.body.innerHTML = `<div style="padding:80px 24px;text-align:center;color:#FF2D55">No community ID. <a href="/community" style="color:#06b6d4">Back</a></div>`;
        return;
      }

      const comms = loadCommunities();
      const c = comms.find((x: any) => x.id === communityId);
      if (!c) {
        document.body.innerHTML = `<div style="padding:80px 24px;text-align:center;color:#FF2D55">Community not found. <a href="/community" style="color:#06b6d4">Back</a></div>`;
        return;
      }

      const bcEl = document.getElementById('bc-comm');
      if (bcEl) { bcEl.textContent = c.name; (bcEl as HTMLAnchorElement).href = `/community/view?id=${encodeURIComponent(communityId)}`; }
      document.title = `Tunnel · ${c.name} — Shadow Warden AI`;

      // Key fingerprint
      const pub: string = c.publicKey || '';
      const fingerprint = pub.replace('SW-PUB-', '').substring(0, 8) || 'NO-KEY';
      const fpEl = document.getElementById('key-fingerprint');
      if (fpEl) fpEl.textContent = fingerprint;

      // Disappearing messages
      disappearingEnabled = !!c.disappearingMessages;
      const toggle = document.getElementById('disappearing-toggle') as HTMLInputElement;
      if (toggle) toggle.checked = disappearingEnabled;
      updateDisappearingUI(disappearingEnabled);

      toggle?.addEventListener('change', () => {
        disappearingEnabled = toggle.checked;
        const cs = loadCommunities();
        const comm = cs.find((x: any) => x.id === communityId);
        if (comm) {
          comm.disappearingMessages = disappearingEnabled;
          saveCommunities(cs);
        }
        updateDisappearingUI(disappearingEnabled);
        renderMessages();
      });

      renderTabs(communityId);
      renderMessages();

      const input = document.getElementById('msg-input') as HTMLInputElement;
      const sendBtn = document.getElementById('send-btn');

      sendBtn?.addEventListener('click', () => {
        sendMessage(input.value);
        input.value = '';
        input.focus();
      });

      input?.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage(input.value);
          input.value = '';
        }
      });

      document.getElementById('clear-btn')?.addEventListener('click', () => {
        if (!confirm('Clear all tunnel messages? This cannot be undone.')) return;
        localStorage.removeItem(tunnelKey(communityId));
        const cs = loadCommunities();
        const comm = cs.find((x: any) => x.id === communityId);
        if (comm) {
          addLog(comm, 'messages_cleared', myUserId, 'Tunnel messages cleared');
          saveCommunities(cs);
        }
        renderMessages();
      });

      document.getElementById('export-key-btn')?.addEventListener('click', () => {
        const cs = loadCommunities();
        const comm = cs.find((x: any) => x.id === communityId);
        const pubKey = comm?.publicKey || 'NO-KEY-GENERATED';
        const content = `-----BEGIN SHADOW WARDEN PUBLIC KEY-----
Community: ${communityId}
Algorithm: AES-256-GCM / Ed25519
Generated: ${new Date(comm?.created || Date.now()).toISOString()}

${pubKey}

Fingerprint: ${pubKey.replace('SW-PUB-', '').substring(0, 8)}
-----END SHADOW WARDEN PUBLIC KEY-----`;
        const blob = new Blob([content], { type: 'text/plain' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = `sw-public-key-${communityId}.asc`;
        a.click();
        URL.revokeObjectURL(a.href);
      });
    }

    init();
  </script>
</BaseLayout>
