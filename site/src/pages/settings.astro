---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConfirmModal from '../components/ConfirmModal.astro';
import roadmap from '../data/roadmap.json';
import { BILLING_PORTAL, WORKER_API } from '../config/lemonsqueezy';

const secFeatures   = roadmap.filter(r => r.category === 'Settings' && r.subcategory === 'Security');
const gdprFeatures  = roadmap.filter(r => r.category === 'Settings' && r.subcategory === 'GDPR');
const integrations  = roadmap.filter(r => r.category === 'Settings' && r.subcategory === 'Integrations');

const statusBadge: Record<string, string> = {
  shipped:     'color:#10b981;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2)',
  'in-progress':'color:#f59e0b;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2)',
  planned:     'color:#6366f1;background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.2)',
  cancelled:   'color:#ef4444;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2)',
};
const statusIcon: Record<string, string> = {
  shipped: '✅', 'in-progress': '🔄', planned: '📋', cancelled: '❌',
};
---

<BaseLayout
  title="Settings — Shadow Warden AI"
  description="Configure your pipeline thresholds, manage API keys, GDPR controls, integrations, and account security."
>
  <div class="pt-14 min-h-screen" style="background:#03050f">

    <!-- Page header -->
    <div class="border-b" style="border-color:rgba(255,255,255,0.06);background:#0a0a14">
      <div class="mx-auto max-w-5xl px-4 lg:px-8 py-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-[16px]"
               style="background:rgba(48,209,88,0.1);border:1px solid rgba(48,209,88,0.2)">⚙</div>
          <h1 class="text-[22px] font-bold" style="color:#f1f5f9">Settings</h1>
        </div>
        <p class="text-[13px]" style="color:#64748b">Manage your project configuration, security, and integrations.</p>
      </div>
    </div>

    <div class="mx-auto max-w-5xl px-4 lg:px-8 py-8">

      <!-- Tab nav -->
      <div class="flex items-center gap-1 mb-8 overflow-x-auto pb-1"
           style="border-bottom:1px solid rgba(255,255,255,0.06)">
        {(['General','Appearance','Security','Integrations','GDPR','Billing','Danger Zone'] as const).map(tab => (
          <button
            class="tab-btn px-4 py-2.5 text-[13px] font-medium whitespace-nowrap rounded-t-lg transition-all"
            data-tab={tab.toLowerCase().replace(' ','-')}
            style="color:#64748b;border-bottom:2px solid transparent">
            {tab}
          </button>
        ))}
      </div>

      <!-- ── GENERAL ── -->
      <div id="tab-general" class="tab-panel">
        <div class="settings-card mb-5">
          <h2 class="settings-section-title">Project Identity</h2>
          <p class="settings-section-sub">Update the display name and description of your project.</p>
          <div class="mt-5 grid gap-4 max-w-lg">
            <div>
              <label class="settings-label">Project name</label>
              <input id="proj-name" type="text" value="Shadow Warden AI"
                     class="settings-input" />
            </div>
            <div>
              <label class="settings-label">Description</label>
              <textarea id="proj-desc" rows="2"
                        class="settings-input resize-none"
                        >14-layer real-time AI security gateway.</textarea>
            </div>
            <div class="flex items-center gap-3 pt-1">
              <button onclick="saveGeneral()" class="btn-primary-sm">Save changes</button>
              <span id="save-msg" class="text-[12px] hidden" style="color:#10b981">✓ Saved</span>
            </div>
          </div>
        </div>

        <div class="settings-card">
          <h2 class="settings-section-title">Live Config API</h2>
          <p class="settings-section-sub">Tune pipeline parameters without container restarts. Changes propagate in &lt;100ms.</p>
          <div class="mt-5 grid gap-4 max-w-lg">
            <div class="flex items-center justify-between py-3 border-b" style="border-color:rgba(255,255,255,0.06)">
              <div>
                <div class="text-[13px] font-medium" style="color:#cbd5e1">Semantic threshold</div>
                <div class="text-[11px]" style="color:#475569">ML jailbreak score cutoff (0–1)</div>
              </div>
              <input type="number" value="0.72" min="0" max="1" step="0.01"
                     class="w-20 text-center settings-input text-[13px]" />
            </div>
            <div class="flex items-center justify-between py-3 border-b" style="border-color:rgba(255,255,255,0.06)">
              <div>
                <div class="text-[13px] font-medium" style="color:#cbd5e1">Rate limit</div>
                <div class="text-[11px]" style="color:#475569">Requests per minute per tenant</div>
              </div>
              <input type="number" value="240" min="10" max="10000"
                     class="w-24 text-center settings-input text-[13px]" />
            </div>
            <div class="flex items-center justify-between py-3">
              <div>
                <div class="text-[13px] font-medium" style="color:#cbd5e1">Evolution Engine</div>
                <div class="text-[11px]" style="color:#475569">Auto-rule generation via Claude Opus</div>
              </div>
              <label class="toggle-label">
                <input type="checkbox" checked class="sr-only toggle-input" />
                <span class="toggle-track"><span class="toggle-thumb"></span></span>
              </label>
            </div>
          </div>
        </div>
      </div>

      <!-- ── APPEARANCE ── -->
      <div id="tab-appearance" class="tab-panel hidden">
        <div class="settings-card mb-5">
          <h2 class="settings-section-title">Theme</h2>
          <p class="settings-section-sub">Choose between dark and light mode. Preference is stored locally.</p>
          <div class="mt-5 flex gap-3">
            {(['dark','light','system'] as const).map(t => (
              <button
                class="theme-btn flex-1 flex flex-col items-center gap-2 p-4 rounded-xl border transition-all"
                data-theme={t}
                style="border-color:rgba(255,255,255,0.08);background:rgba(255,255,255,0.02)">
                <span class="text-[22px]">
                  {t === 'dark' ? '🌙' : t === 'light' ? '☀️' : '💻'}
                </span>
                <span class="text-[12px] font-medium capitalize" style="color:#94a3b8">{t}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="settings-card">
          <h2 class="settings-section-title">Accessibility</h2>
          <p class="settings-section-sub">WCAG 2.1 AA · EAA 2019/882. Controls are also accessible via the floating ♿ widget.</p>
          <div class="mt-5 grid gap-3">
            {[
              { key: 'contrast',  label: 'High contrast',  hint: 'WCAG 1.4.6' },
              { key: 'motion',    label: 'Reduce motion',  hint: 'WCAG 2.3.3' },
              { key: 'dyslexia', label: 'Dyslexia font',  hint: 'OpenDyslexic' },
              { key: 'focus',     label: 'Enhanced focus', hint: 'WCAG 2.4.11' },
            ].map(item => (
              <div class="flex items-center justify-between py-3 border-b" style="border-color:rgba(255,255,255,0.06)">
                <div>
                  <div class="text-[13px] font-medium" style="color:#cbd5e1">{item.label}</div>
                  <div class="text-[11px]" style="color:#475569">{item.hint}</div>
                </div>
                <label class="toggle-label">
                  <input type="checkbox" data-a11y={item.key} class="sr-only toggle-input a11y-toggle" />
                  <span class="toggle-track"><span class="toggle-thumb"></span></span>
                </label>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- ── SECURITY ── -->
      <div id="tab-security" class="tab-panel hidden">
        <div class="settings-card mb-5">
          <h2 class="settings-section-title">API Keys</h2>
          <p class="settings-section-sub">Per-tenant keys with SHA-256 constant-time compare. Fail-closed — service won't start without a valid key.</p>
          <div class="mt-5 flex gap-3">
            <input type="password" value="sw-key-••••••••••••••••••••••••••••••••"
                   class="settings-input flex-1 font-mono text-[12px]" readonly />
            <button class="btn-secondary-sm" onclick="copyKey(this)">Copy</button>
            <button class="btn-secondary-sm" style="color:#ef4444;border-color:rgba(239,68,68,0.3)">Rotate</button>
          </div>
        </div>

        <div class="settings-card mb-5">
          <h2 class="settings-section-title">Security Features</h2>
          <div class="mt-4 grid gap-3">
            {secFeatures.map(f => (
              <div class="flex items-start gap-4 p-4 rounded-xl" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06)">
                <span class="text-[18px] mt-0.5">{statusIcon[f.status] ?? '📋'}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap mb-1">
                    <span class="text-[13px] font-semibold" style="color:#f1f5f9">{f.feature}</span>
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style={statusBadge[f.status] ?? statusBadge.planned}>
                      {f.status}
                    </span>
                    <span class="text-[10px] px-1.5 py-0.5 rounded" style="color:#475569;background:rgba(255,255,255,0.04)">{f.tier}</span>
                  </div>
                  <p class="text-[12px] leading-relaxed" style="color:#64748b">{f.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="settings-card">
          <h2 class="settings-section-title">Change Password</h2>
          <div class="mt-5 grid gap-3 max-w-md">
            <div>
              <label class="settings-label">Current password</label>
              <input type="password" placeholder="••••••••" class="settings-input" />
            </div>
            <div>
              <label class="settings-label">New password</label>
              <input type="password" placeholder="••••••••" class="settings-input" />
            </div>
            <div>
              <label class="settings-label">Confirm new password</label>
              <input type="password" placeholder="••••••••" class="settings-input" />
            </div>
            <button class="btn-primary-sm w-fit mt-1">Update password</button>
          </div>
        </div>
      </div>

      <!-- ── INTEGRATIONS ── -->
      <div id="tab-integrations" class="tab-panel hidden">
        <div class="settings-card">
          <h2 class="settings-section-title">Connected Integrations</h2>
          <p class="settings-section-sub">Manage connections to external services and tools.</p>
          <div class="mt-5 grid gap-4">
            {integrations.map(f => (
              <div class="flex items-center gap-4 p-4 rounded-xl" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06)">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[20px] flex-shrink-0"
                     style="background:rgba(255,255,255,0.04)">
                  {f.id === 'S-09' ? '🔌' : f.id === 'S-10' ? '💬' : f.id === 'S-11' ? '⚙' : '🔗'}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="text-[13px] font-semibold" style="color:#f1f5f9">{f.feature}</span>
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style={statusBadge[f.status] ?? statusBadge.planned}>
                      {f.status}
                    </span>
                  </div>
                  <p class="text-[12px]" style="color:#64748b">{f.description}</p>
                </div>
                <label class="toggle-label flex-shrink-0">
                  <input type="checkbox" checked={f.status === 'shipped'} class="sr-only toggle-input" />
                  <span class="toggle-track"><span class="toggle-thumb"></span></span>
                </label>
              </div>
            ))}

            <!-- Manual integration cards -->
            {[
              { name: 'PagerDuty', icon: '🚨', desc: 'Real-time HIGH/BLOCK incident escalation via PagerDuty Events API v2.', connected: true },
              { name: 'Splunk HEC', icon: '📊', desc: 'Stream security events to your Splunk SIEM via HTTP Event Collector.', connected: false },
              { name: 'LangChain', icon: '🦜', desc: 'Drop-in WardenCallback for LangChain pipelines. Zero code changes required.', connected: true },
            ].map(item => (
              <div class="flex items-center gap-4 p-4 rounded-xl" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06)">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[20px] flex-shrink-0"
                     style="background:rgba(255,255,255,0.04)">{item.icon}</div>
                <div class="flex-1 min-w-0">
                  <div class="text-[13px] font-semibold mb-0.5" style="color:#f1f5f9">{item.name}</div>
                  <p class="text-[12px]" style="color:#64748b">{item.desc}</p>
                </div>
                <label class="toggle-label flex-shrink-0">
                  <input type="checkbox" checked={item.connected} class="sr-only toggle-input" />
                  <span class="toggle-track"><span class="toggle-thumb"></span></span>
                </label>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- ── GDPR ── -->
      <div id="tab-gdpr" class="tab-panel hidden">
        <div class="settings-card mb-5">
          <h2 class="settings-section-title">Data Governance</h2>
          <p class="settings-section-sub">GDPR Articles 13, 15, 17 controls. Raw content is never logged — metadata only.</p>
          <div class="mt-5 grid gap-3">
            {gdprFeatures.map(f => (
              <div class="flex items-start gap-4 p-4 rounded-xl" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06)">
                <span class="text-[18px] mt-0.5">{statusIcon[f.status] ?? '📋'}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap mb-1">
                    <span class="text-[13px] font-semibold" style="color:#f1f5f9">{f.feature}</span>
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" style={statusBadge[f.status] ?? statusBadge.planned}>{f.status}</span>
                  </div>
                  <p class="text-[12px] leading-relaxed" style="color:#64748b">{f.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="settings-card">
          <h2 class="settings-section-title">Export & Erasure</h2>
          <div class="mt-4 flex flex-wrap gap-3">
            <button class="btn-secondary-sm">Export my data (Art. 15)</button>
            <button class="btn-secondary-sm" style="color:#f59e0b;border-color:rgba(245,158,11,0.3)">
              Request erasure (Art. 17)
            </button>
          </div>
          <p class="text-[11px] mt-3" style="color:#334155">
            Export is delivered to your registered email within 72 hours. Erasure completes within 30 days.
          </p>
        </div>
      </div>

      <!-- ── BILLING ── -->
      <div id="tab-billing" class="tab-panel hidden">

        <!-- Current plan card -->
        <div class="settings-card mb-5">
          <div class="flex items-start justify-between gap-4 mb-5">
            <div>
              <h2 class="settings-section-title">Current Plan</h2>
              <p class="settings-section-sub">Your active subscription and usage.</p>
            </div>
            <a href={BILLING_PORTAL} target="_blank" rel="noopener"
               class="btn-secondary-sm flex-shrink-0 whitespace-nowrap">
              Manage Subscription ↗
            </a>
          </div>

          <!-- Plan display — filled by JS -->
          <div id="billing-loading" class="py-6 text-center text-[13px]" style="color:#475569">
            Loading subscription…
          </div>
          <div id="billing-plan" class="hidden">
            <div class="flex items-center gap-4 p-4 rounded-xl mb-4" style="background:rgba(99,102,241,0.06);border:1px solid rgba(99,102,241,0.15)">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[20px]" style="background:rgba(99,102,241,0.1)">⚡</div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span id="plan-name" class="text-[15px] font-bold" style="color:#f1f5f9">—</span>
                  <span id="plan-status" class="text-[10px] font-bold px-2 py-0.5 rounded-full" style="color:#10b981;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2)">—</span>
                </div>
                <div id="plan-renews" class="text-[12px] mt-0.5" style="color:#64748b">—</div>
              </div>
            </div>

            <!-- Usage bar (mock) -->
            <div class="mb-2 flex items-center justify-between text-[12px]" style="color:#64748b">
              <span>Requests this month</span>
              <span id="usage-count" style="color:#f1f5f9">—</span>
            </div>
            <div class="h-2 rounded-full overflow-hidden mb-5" style="background:rgba(255,255,255,0.06)">
              <div id="usage-bar" class="h-full rounded-full" style="background:linear-gradient(90deg,#6366f1,#8b5cf6);width:0%"></div>
            </div>
          </div>

          <!-- No subscription state -->
          <div id="billing-none" class="hidden text-center py-6">
            <div class="text-[14px] mb-3" style="color:#94a3b8">No active subscription found.</div>
            <a href="/price" class="btn-primary-sm">View Plans →</a>
          </div>

          <!-- Link account -->
          <div id="billing-link" class="hidden">
            <p class="text-[13px] mb-3" style="color:#64748b">
              Enter your Lemon Squeezy Customer ID to load your subscription details.
            </p>
            <div class="flex gap-3 max-w-sm">
              <input id="customer-id-input" type="text" placeholder="e.g. 1234567"
                     class="settings-input flex-1 font-mono text-[12px]" />
              <button id="link-account-btn" class="btn-primary-sm whitespace-nowrap">Link</button>
            </div>
            <p class="text-[11px] mt-2" style="color:#334155">
              Find your Customer ID in your Lemon Squeezy order confirmation email.
            </p>
          </div>
        </div>

        <!-- Payment history (mock) -->
        <div class="settings-card mb-5">
          <h2 class="settings-section-title">Payment History</h2>
          <div class="mt-4 overflow-x-auto">
            <table class="w-full text-[12px]">
              <thead>
                <tr style="border-bottom:1px solid rgba(255,255,255,0.06)">
                  <th class="text-left pb-2 font-semibold" style="color:#475569">Date</th>
                  <th class="text-left pb-2 font-semibold" style="color:#475569">Plan</th>
                  <th class="text-left pb-2 font-semibold" style="color:#475569">Amount</th>
                  <th class="text-left pb-2 font-semibold" style="color:#475569">Status</th>
                  <th class="text-right pb-2 font-semibold" style="color:#475569">Invoice</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { date: 'May 1, 2026',  plan: 'Pro — Monthly',  amount: '$69.00', status: 'Paid' },
                  { date: 'Apr 1, 2026',  plan: 'Pro — Monthly',  amount: '$69.00', status: 'Paid' },
                  { date: 'Mar 1, 2026',  plan: 'Pro — Monthly',  amount: '$69.00', status: 'Paid' },
                ].map(row => (
                  <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
                    <td class="py-2.5" style="color:#94a3b8">{row.date}</td>
                    <td class="py-2.5" style="color:#94a3b8">{row.plan}</td>
                    <td class="py-2.5" style="color:#f1f5f9">{row.amount}</td>
                    <td class="py-2.5"><span class="px-2 py-0.5 rounded-full text-[10px] font-bold" style="color:#10b981;background:rgba(16,185,129,0.1)">{row.status}</span></td>
                    <td class="py-2.5 text-right"><button class="text-[11px]" style="color:#6366f1">PDF ↓</button></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Cancel / downgrade -->
        <div class="settings-card" style="border-color:rgba(239,68,68,0.15)">
          <h2 class="settings-section-title" style="color:#ef4444">Cancel Subscription</h2>
          <p class="settings-section-sub">
            Your plan stays active until the end of the current billing period. All data is preserved.
          </p>
          <div class="mt-4">
            <a href={BILLING_PORTAL} target="_blank" rel="noopener"
               class="btn-secondary-sm"
               style="color:#ef4444;border-color:rgba(239,68,68,0.3)">
              Cancel via Billing Portal ↗
            </a>
          </div>
        </div>
      </div>

      <!-- ── DANGER ZONE ── -->
      <div id="tab-danger-zone" class="tab-panel hidden">
        <div class="rounded-2xl overflow-hidden" style="border:1px solid rgba(239,68,68,0.25)">
          <div class="px-6 py-4" style="background:rgba(239,68,68,0.06);border-bottom:1px solid rgba(239,68,68,0.15)">
            <h2 class="text-[15px] font-bold" style="color:#ef4444">Danger Zone</h2>
            <p class="text-[12px] mt-1" style="color:#9ca3af">Actions here are irreversible. Proceed with caution.</p>
          </div>

          <div class="p-6 grid gap-4">
            <!-- Sign out -->
            <div class="flex items-center justify-between gap-4 pb-4 border-b" style="border-color:rgba(255,255,255,0.06)">
              <div>
                <div class="text-[13px] font-semibold mb-1" style="color:#f1f5f9">Sign out</div>
                <p class="text-[12px]" style="color:#64748b">End your current session. Your data is preserved.</p>
              </div>
              <a href="/logout"
                 class="flex-shrink-0 px-4 py-2 rounded-lg text-[12px] font-medium transition-colors whitespace-nowrap"
                 style="color:#94a3b8;border:1px solid rgba(255,255,255,0.12)">
                Sign out
              </a>
            </div>

            <!-- Delete project -->
            <div class="flex items-center justify-between gap-4">
              <div>
                <div class="text-[13px] font-semibold mb-1" style="color:#ef4444">Delete this project</div>
                <p class="text-[12px]" style="color:#64748b">
                  Permanently delete the project and all associated data. This action cannot be undone.
                  All data will be purged in accordance with GDPR Article 17.
                </p>
              </div>
              <button
                onclick="open_modal-delete()"
                class="flex-shrink-0 px-4 py-2 rounded-lg text-[12px] font-semibold whitespace-nowrap transition-all"
                style="color:#fff;background:#dc2626;border:1px solid rgba(220,38,38,0.5)">
                Delete project
              </button>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /max-w-5xl -->
  </div><!-- /pt-14 -->
</BaseLayout>

<!-- Delete confirmation modal -->
<ConfirmModal
  id="modal-delete"
  title="Delete project?"
  message="This action cannot be undone. All data will be permanently deleted and purged in accordance with GDPR Article 17."
  confirmLabel="Yes, delete project"
  requireText="Shadow Warden AI"
  redirectTo="/goodbye"
  danger={true}
/>

<style>
  .settings-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 24px;
  }
  .settings-section-title {
    font-size: 14px;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 4px;
  }
  .settings-section-sub {
    font-size: 12px;
    color: #64748b;
    line-height: 1.5;
  }
  .settings-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  .settings-input {
    width: 100%;
    padding: 9px 12px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: #f1f5f9;
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
    font-family: inherit;
  }
  .settings-input:focus { border-color: rgba(99,102,241,0.5); }
  .btn-primary-sm {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    color: #fff;
    background: #6366f1;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary-sm:hover { opacity: 0.85; }
  .btn-secondary-sm {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
    color: #94a3b8;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-secondary-sm:hover { border-color: rgba(255,255,255,0.2); color: #f1f5f9; }

  /* Toggle switch */
  .toggle-label { cursor: pointer; }
  .toggle-track {
    display: block;
    width: 40px;
    height: 22px;
    border-radius: 11px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.1);
    position: relative;
    transition: background 0.2s, border-color 0.2s;
  }
  .toggle-thumb {
    position: absolute;
    top: 3px; left: 3px;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: #94a3b8;
    transition: transform 0.2s, background 0.2s;
  }
  .toggle-input:checked + .toggle-track { background: #30D158; border-color: #30D158; }
  .toggle-input:checked + .toggle-track .toggle-thumb { transform: translateX(18px); background: #fff; }

  /* Active tab */
  .tab-btn.active { color: #f1f5f9 !important; border-bottom-color: #6366f1 !important; }
  .tab-btn:hover:not(.active) { color: #94a3b8; }
</style>

<script>
(function () {
  // Tab switching
  const btns   = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.tab-panel');

  function activate(tab: string) {
    btns.forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.tab === tab));
    panels.forEach(p => p.classList.toggle('hidden', p.id !== `tab-${tab}`));
  }
  btns.forEach(b => b.addEventListener('click', () => activate((b as HTMLElement).dataset.tab!)));
  activate('general');

  // Theme buttons
  const themeBtns = document.querySelectorAll('.theme-btn');
  function setTheme(t: string) {
    document.documentElement.classList.toggle('light', t === 'light');
    localStorage.setItem('sw-theme', t);
    themeBtns.forEach(btn => {
      const active = (btn as HTMLElement).dataset.theme === t;
      (btn as HTMLElement).style.borderColor = active ? '#6366f1' : 'rgba(255,255,255,0.08)';
      (btn as HTMLElement).style.background  = active ? 'rgba(99,102,241,0.1)' : 'rgba(255,255,255,0.02)';
    });
  }
  themeBtns.forEach(b => b.addEventListener('click', () => setTheme((b as HTMLElement).dataset.theme!)));
  setTheme(localStorage.getItem('sw-theme') ?? 'dark');

  // Accessibility toggles
  const STORE = 'sw_a11y_v3';
  let a11y: Record<string, boolean> = {};
  try { a11y = JSON.parse(localStorage.getItem(STORE) ?? '{}'); } catch {}
  document.querySelectorAll<HTMLInputElement>('.a11y-toggle').forEach(cb => {
    const key = cb.dataset.a11y!;
    cb.checked = !!a11y[key];
    cb.addEventListener('change', () => {
      a11y[key] = cb.checked;
      document.body.classList.toggle(`a11y-${key}`, cb.checked);
      try { localStorage.setItem(STORE, JSON.stringify(a11y)); } catch {}
    });
  });

  // Copy API key
  (window as any).copyKey = function(btn: HTMLButtonElement) {
    navigator.clipboard.writeText('sw-key-demo-placeholder').then(() => {
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = 'Copy'), 1500);
    });
  };

  // Save general
  (window as any).saveGeneral = function() {
    const msg = document.getElementById('save-msg');
    if (msg) { msg.classList.remove('hidden'); setTimeout(() => msg.classList.add('hidden'), 2000); }
  };

  // ── Billing ──────────────────────────────────────────────────────────────
  const WORKER = 'https://billing.shadow-warden-ai.workers.dev';
  const TIER_LIMITS: Record<string, number> = {
    starter: 1000, individual: 5000, 'community business': 10000, pro: 50000, enterprise: Infinity,
  };

  async function loadBilling(customerId: string) {
    const loading = document.getElementById('billing-loading')!;
    const planEl  = document.getElementById('billing-plan')!;
    const noneEl  = document.getElementById('billing-none')!;
    const linkEl  = document.getElementById('billing-link')!;

    try {
      const res  = await fetch(`${WORKER}/api/subscription/${encodeURIComponent(customerId)}`);
      if (!res.ok) throw new Error('not_found');
      const data = await res.json() as any;

      loading.classList.add('hidden');
      linkEl.classList.add('hidden');
      noneEl.classList.add('hidden');
      planEl.classList.remove('hidden');

      (document.getElementById('plan-name') as HTMLElement).textContent = data.variantName ?? data.plan ?? 'Unknown';
      const statusEl = document.getElementById('plan-status')!;
      statusEl.textContent = data.status ?? '—';
      if (data.status === 'active') {
        statusEl.style.cssText = 'color:#10b981;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2)';
      } else {
        statusEl.style.cssText = 'color:#f59e0b;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2)';
      }

      const renewsEl = document.getElementById('plan-renews')!;
      if (data.renewsAt) {
        renewsEl.textContent = `Renews ${new Date(data.renewsAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}`;
      } else if (data.endsAt) {
        renewsEl.textContent = `Ends ${new Date(data.endsAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}`;
      }

      // Mock usage bar
      const planKey = (data.plan ?? '').toLowerCase();
      const limit   = TIER_LIMITS[planKey] ?? 1000;
      const used    = Math.floor(limit * 0.62);
      (document.getElementById('usage-count') as HTMLElement).textContent =
        `${used.toLocaleString()} / ${limit === Infinity ? '∞' : limit.toLocaleString()}`;
      (document.getElementById('usage-bar') as HTMLElement).style.width =
        limit === Infinity ? '10%' : Math.min(100, (used / limit) * 100) + '%';

    } catch {
      loading.classList.add('hidden');
      planEl.classList.add('hidden');
      noneEl.classList.add('hidden');
      linkEl.classList.remove('hidden');
    }
  }

  // Auto-load if customer id in localStorage or URL
  const params     = new URLSearchParams(window.location.search);
  const urlCid     = params.get('customer_id');
  const storedCid  = localStorage.getItem('sw-customer-id');
  const customerId = urlCid ?? storedCid ?? '';
  if (urlCid) localStorage.setItem('sw-customer-id', urlCid);

  // Only load billing when tab is clicked (lazy)
  const billingTabBtn = document.querySelector<HTMLButtonElement>('.tab-btn[data-tab="billing"]');
  let   billingLoaded = false;
  billingTabBtn?.addEventListener('click', () => {
    if (billingLoaded) return;
    billingLoaded = true;
    if (customerId) {
      loadBilling(customerId);
    } else {
      document.getElementById('billing-loading')!.classList.add('hidden');
      document.getElementById('billing-link')!.classList.remove('hidden');
    }
  });

  // Link account button
  document.getElementById('link-account-btn')?.addEventListener('click', () => {
    const input = document.getElementById('customer-id-input') as HTMLInputElement;
    const cid   = input.value.trim();
    if (!cid) return;
    localStorage.setItem('sw-customer-id', cid);
    document.getElementById('billing-link')!.classList.add('hidden');
    document.getElementById('billing-loading')!.classList.remove('hidden');
    loadBilling(cid);
  });
})();
</script>
