  }
  .info-icon { font-size: 15px; flex-shrink: 0; margin-top: 1px; }
  .info-title { font-size: 10px; font-weight: 800; letter-spacing: 0.06em; color: #f59e0b; margin-bottom: 3px; }
  .info-body  { font-size: 11px; color: #78716c; line-height: 1.5; }
  .info-mono  { font-family: monospace; font-size: 10px; color: #a8a29e; }

  /* Mono hint */
  .mono-hint {
    margin-top: 10px;
    font-family: monospace;
    font-size: 11px;
    color: #334155;
    padding: 6px 10px;
    border-radius: 6px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
  }

  /* Sensitivity segmented button group */
  .btn-group {
    display: inline-flex;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.03);
  }
  .seg-btn {
    padding: 8px 20px;
    font-size: 12px;
    font-weight: 600;
    color: #64748b;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .seg-btn + .seg-btn { border-left: 1px solid rgba(255,255,255,0.08); }
  .seg-btn.active { background: rgba(99,102,241,0.2); color: #c7d2fe; }
  .seg-btn:hover:not(.active) { background: rgba(255,255,255,0.05); color: #94a3b8; }

  /* Rate limit input row */
  .rate-input-row { display: flex; align-items: center; gap: 10px; }
  .rate-input { width: 100px !important; text-align: center; font-weight: 600; }
  .rate-unit { font-size: 12px; color: #475569; }

  /* Save footer (sticky) */
  .save-footer {
    position: fixed;
    bottom: 0;
    right: 0;
    left: 220px;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 32px;
    background: #0d0d14;
    border-top: 1px solid rgba(255,255,255,0.07);
    z-index: 20;
  }
  .save-timestamp { font-size: 11px; color: #334155; flex: 1; }
  .save-actions { display: flex; gap: 8px; }

  /* Settings card (generic) */
  .settings-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 24px;
  }
  .card-title { font-size: 14px; font-weight: 700; color: #f1f5f9; }

  /* Input */
  .settings-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  .settings-input {
    width: 100%;
    padding: 9px 12px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: #f1f5f9;
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
    font-family: inherit;
  }
  .settings-input:focus { border-color: rgba(99,102,241,0.5); }

  /* Toggle switch */
  .toggle-label { cursor: pointer; flex-shrink: 0; }
  .toggle-track {
    display: block;
    width: 40px;
    height: 22px;
    border-radius: 11px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.1);
    position: relative;
    transition: background 0.2s, border-color 0.2s;
  }
  .toggle-thumb {
    position: absolute;
    top: 3px; left: 3px;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: #94a3b8;
    transition: transform 0.2s, background 0.2s;
  }
  .toggle-input:checked + .toggle-track { background: #30D158; border-color: #30D158; }
  .toggle-input:checked + .toggle-track .toggle-thumb { transform: translateX(18px); background: #fff; }

  /* Buttons */
  .btn-primary-sm {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    color: #fff;
    background: #6366f1;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s;
    white-space: nowrap;
  }
  .btn-primary-sm:hover { opacity: 0.85; }
  .btn-secondary-sm {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
    color: #94a3b8;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .btn-secondary-sm:hover { border-color: rgba(255,255,255,0.2); color: #f1f5f9; }

  /* Key rows */
  .key-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .key-row:last-child { border-bottom: none; padding-bottom: 0; }
  .key-icon { font-size: 20px; flex-shrink: 0; }
  .key-info { flex: 1; min-width: 0; }
  .key-name { font-size: 13px; font-weight: 600; color: #f1f5f9; margin-bottom: 2px; }
  .key-meta { font-size: 11px; color: #475569; }
  .key-preview { display: block; font-size: 11px; color: #334155; margin-top: 4px; }
  .key-actions { display: flex; gap: 6px; flex-shrink: 0; }

  /* Rule rows */
  .rule-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 12px;
  }
  .rule-row:last-of-type { border-bottom: none; }
  .rule-id   { color: #334155; font-family: monospace; font-size: 10px; flex-shrink: 0; width: 44px; }
  .rule-name { color: #cbd5e1; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .rule-type { color: #475569; font-size: 10px; font-family: monospace; flex-shrink: 0; }
  .rule-hits { color: #475569; font-size: 11px; flex-shrink: 0; }
  .rule-severity { font-size: 9px; font-weight: 800; padding: 2px 7px; border-radius: 99px; flex-shrink: 0; }
  .sev-high   { color: #ef4444; background: rgba(239,68,68,0.12); }
  .sev-medium { color: #f59e0b; background: rgba(245,158,11,0.12); }

  /* Member roles */
  .member-role {
    font-size: 10px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 99px;
    flex-shrink: 0;
  }
  .role-owner  { color: #f1f5f9; background: rgba(99,102,241,0.2); }
  .role-admin  { color: #10b981; background: rgba(16,185,129,0.12); }
  .role-viewer { color: #64748b; background: rgba(255,255,255,0.06); }

  /* ml-auto utility */
  .ml-auto { margin-left: auto; }

  /* Mobile — stack sidebar on top */
  @media (max-width: 768px) {
    .settings-shell { grid-template-columns: 1fr; }
    .settings-sidebar {
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .sidebar-inner { padding: 16px; }
    .sidebar-nav { flex-direction: row; flex-wrap: wrap; gap: 4px; }
    .nav-item { width: auto; flex-shrink: 0; }
    .save-footer { left: 0; }
