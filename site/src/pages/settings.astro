---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Settings — Shadow Warden AI">
  <div class="pt-14">

    <!-- ── Hero ── -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 pointer-events-none"
           style="background-image:linear-gradient(rgba(48,209,88,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(48,209,88,0.03) 1px,transparent 1px);background-size:56px 56px"></div>
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[900px] h-[500px] pointer-events-none"
           style="background:radial-gradient(ellipse,rgba(48,209,88,0.06) 0%,transparent 65%)"></div>

      <div class="relative z-10 mx-auto max-w-5xl px-6 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6 text-[11px] font-bold tracking-widest uppercase"
             style="color:#30D158;background:rgba(48,209,88,0.08);border:1px solid rgba(48,209,88,0.2)">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#30D158"></span>
          Configuration & Governance
        </div>
        <h1 class="text-[clamp(36px,5vw,68px)] font-black leading-[1.05] tracking-tight mb-5" style="color:#f1f5f9">
          Full Control.<br/>
          <span style="background:linear-gradient(135deg,#30D158,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
            Zero Compromise.
          </span>
        </h1>
        <p class="text-[17px] leading-relaxed max-w-2xl mx-auto mb-4" style="color:#94a3b8">
          Every knob, every policy, every secret — governed, auditable, and live-tunable
          without restarting a single container.
        </p>
      </div>
    </section>

    <!-- ── Stats strip ── -->
    <section class="py-10 border-y" style="border-color:rgba(255,255,255,0.06);background:#0a0a0f">
      <div class="mx-auto max-w-5xl px-4 lg:px-8">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-px rounded-2xl overflow-hidden"
             style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.06)">
          {[
            { val:'8',       label:'Jurisdictions',       color:'#30D158' },
            { val:'5',       label:'Vault connectors',    color:'#06b6d4' },
            { val:'0',       label:'Plaintext in memory', color:'#f59e0b' },
            { val:'7yr',     label:'Attestation TTL',     color:'#6366f1' },
          ].map(s => (
            <div class="px-5 py-5 text-center" style="background:#0a0a0f">
              <div class="text-[26px] font-black leading-none mb-1" style={`color:${s.color}`}>{s.val}</div>
              <div class="text-[10px] font-semibold uppercase tracking-wider" style="color:#475569">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Feature grid ── -->
    <section class="py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold mb-3" style="color:#f1f5f9">
            Every Setting. Every Policy.
          </h2>
          <p class="text-[15px] max-w-xl mx-auto" style="color:#94a3b8">
            Secrets, routing, auth, GDPR — all governed through a single API.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {[
            {
              icon:'🔑', color:'#30D158', tier:'Community Business+',
              title:'Secrets Governance',
              desc:'5 vault connectors: AWS Secrets Manager, Azure Key Vault, HashiCorp Vault, GCP Secret Manager, and env-file. SQLite inventory with risk scoring, expiry alerts, and auto-retire.',
              pills:['AWS SM','Azure KV','HashiCorp','GCP SM'],
            },
            {
              icon:'🌍', color:'#06b6d4', tier:'Enterprise',
              title:'Sovereign Data Routing',
              desc:'8 jurisdictions (EU/US/UK/CA/SG/AU/JP/CH) with MASQUE tunnels over HTTP/3, HTTP/2, or TCP. TOFU TLS pinning. Auto-failover: ACTIVE → DEGRADED → OFFLINE lifecycle.',
              pills:['MASQUE H3','TOFU pinning','8 regions','Auto-failover'],
            },
            {
              icon:'📋', color:'#f59e0b', tier:'Enterprise',
              title:'Transfer Rules Matrix',
              desc:'CLASSIFIED data is always blocked. PHI allowed to 5 jurisdictions (US/EU/UK/CA/CH). GENERAL traffic routed with adequacy checks. Per-tenant overrides per data class.',
              pills:['CLASSIFIED→block','PHI→5 zones','Adequacy check','Per-tenant'],
            },
            {
              icon:'🛡️', color:'#8b5cf6', tier:'Enterprise',
              title:'Sovereignty Attestation',
              desc:'Every routed request gets an HMAC-SHA256 signed attestation stored in Redis with a 7-year TTL. 10,000 attestation cap per tenant. Verify endpoint for auditors.',
              pills:['HMAC-SHA256','7yr TTL','10k cap','Verify API'],
            },
            {
              icon:'🇪🇺', color:'#4d7cfe', tier:'All tiers',
              title:'GDPR Controls',
              desc:'Export and purge APIs for Art. 17/20 requests. Metadata-only logging — zero content stored. Retention scheduler with configurable windows. Art. 30 processing register.',
              pills:['Art.17 purge','Art.20 export','Art.30 register','Retention policy'],
            },
            {
              icon:'🔐', color:'#ef4444', tier:'All tiers',
              title:'Multi-tenant Auth',
              desc:'Per-tenant API keys with SHA-256 constant-time comparison. JSON key-file or env-var backends. Fail-closed startup: refuses to start without a key unless ALLOW_UNAUTHENTICATED=true.',
              pills:['Per-tenant keys','SHA-256 compare','Fail-closed','Key rotation'],
            },
            {
              icon:'🔄', color:'#30D158', tier:'Pro · Enterprise',
              title:'Automated Key Rotation',
              desc:'SOVA agent runs rotation checks at 02:00 UTC daily. Community keypair rotation with classical Ed25519 and hybrid PQC (ML-DSA-65). Rotation history in audit log.',
              pills:['02:00 UTC cron','Ed25519','ML-DSA-65','Audit trail'],
            },
            {
              icon:'⚙️', color:'#94a3b8', tier:'All tiers',
              title:'Live Config API',
              desc:'Tune semantic thresholds, pipeline timeouts, shadow ban strategies, evolution engine, and SIEM targets via REST — no container restart required. Changes applied in < 100ms.',
              pills:['No restart','< 100ms apply','All thresholds','SIEM targets'],
            },
          ].map(f => (
            <div class="p-6 rounded-2xl" style="background:#111118;border:1px solid rgba(255,255,255,0.07)">
              <div class="flex items-start justify-between mb-4">
                <div class="w-11 h-11 rounded-xl flex items-center justify-center text-[20px]"
                     style={`background:${f.color}18`}>{f.icon}</div>
                <span class="text-[10px] font-semibold px-2 py-0.5 rounded-md"
                      style="color:#475569;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06)">
                  {f.tier}
                </span>
              </div>
              <h3 class="text-[15px] font-semibold mb-2" style="color:#f1f5f9">{f.title}</h3>
              <p class="text-[12px] leading-relaxed mb-4" style="color:#64748b">{f.desc}</p>
              <div class="flex flex-wrap gap-1.5">
                {f.pills.map(p => (
                  <span class="text-[10px] px-2 py-0.5 rounded-md font-medium"
                        style={`color:${f.color};background:${f.color}12`}>{p}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Transfer Rules Matrix visual ── -->
    <section class="py-16 border-t" style="border-color:rgba(255,255,255,0.06);background:#0a0a0f">
      <div class="mx-auto max-w-4xl px-4 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-[clamp(1.25rem,2.5vw,1.75rem)] font-bold mb-2" style="color:#f1f5f9">
            Data Transfer Rules Matrix
          </h2>
          <p class="text-[13px]" style="color:#64748b">Enforced at routing layer · no overrides</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-[12px] border-collapse">
            <thead>
              <tr>
                <th class="text-left py-2.5 px-4 font-semibold text-[11px] uppercase tracking-wider" style="color:#475569">Data class</th>
                {['EU','US','UK','CA','SG','AU','JP','CH'].map(j => (
                  <th class="text-center py-2.5 px-3 font-semibold text-[11px] uppercase tracking-wider" style="color:#475569">{j}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {[
                { cls:'CLASSIFIED', color:'#ef4444', bg:'rgba(239,68,68,0.08)', allowed:[] },
                { cls:'PHI',        color:'#f59e0b', bg:'rgba(245,158,11,0.08)', allowed:['EU','US','UK','CA','CH'] },
                { cls:'PII',        color:'#6366f1', bg:'rgba(99,102,241,0.08)', allowed:['EU','US','UK','CA','SG','AU','JP','CH'] },
                { cls:'FINANCIAL',  color:'#06b6d4', bg:'rgba(6,182,212,0.08)',  allowed:['EU','US','UK','CA','SG','AU','JP','CH'] },
                { cls:'GENERAL',    color:'#30D158', bg:'rgba(48,209,88,0.08)',  allowed:['EU','US','UK','CA','SG','AU','JP','CH'] },
              ].map((row, ri) => (
                <tr style={ri % 2 === 0 ? 'background:#0d0d14' : ''}>
                  <td class="py-3 px-4 rounded-l-lg font-semibold" style={`color:${row.color}`}>{row.cls}</td>
                  {['EU','US','UK','CA','SG','AU','JP','CH'].map(j => {
                    const ok = row.allowed.includes(j);
                    return (
                      <td class="text-center py-3 px-3">
                        {row.allowed.length === 0
                          ? <span class="text-[14px]" style="color:#ef4444">✕</span>
                          : ok
                            ? <span class="text-[14px]" style="color:#30D158">✓</span>
                            : <span class="text-[14px]" style="color:#1e2a35">—</span>
                        }
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="py-20 border-t" style="border-color:rgba(255,255,255,0.06)">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-black mb-4" style="color:#f1f5f9">
          Configure your security posture
        </h2>
        <p class="text-[15px] mb-8" style="color:#94a3b8">
          All settings available from the SOC portal. Enterprise plans unlock sovereign routing and PQC.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="https://portal.shadow-warden-ai.com" target="_blank"
             class="px-6 py-3 rounded-xl text-[14px] font-semibold transition-all"
             style="background:linear-gradient(135deg,#30D158,#06b6d4);color:#000;font-weight:700">
            Open Settings →
          </a>
          <a href="/doc/quick-start"
             class="px-6 py-3 rounded-xl text-[14px] font-medium transition-colors"
             style="color:#94a3b8;border:1px solid rgba(255,255,255,0.08)">
            Read the Docs
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
