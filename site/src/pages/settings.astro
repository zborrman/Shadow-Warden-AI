  .danger-item:hover { background: rgba(239,68,68,0.08); color: #ef4444; }
  .danger-item.active { background: rgba(239,68,68,0.12); color: #ef4444; }

  /* ── Main content ──────────────────────────────────────────── */
  .settings-main {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 56px);
