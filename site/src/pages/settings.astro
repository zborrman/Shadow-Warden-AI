<script>
(function () {
  // ── Panel switching ─────────────────────────────────────────
  const navItems = document.querySelectorAll<HTMLButtonElement>('.nav-item');
  const panels   = document.querySelectorAll<HTMLElement>('.settings-panel');
  const titleEl  = document.getElementById('panel-title')!;
  const saveFooter = document.querySelector<HTMLElement>('.save-footer');

  const PANEL_LABELS: Record<string, string> = {
    filter:          'Filter pipeline',
    apikeys:         'API keys',
    secrets:         'Secrets Vault',
    agents:          'Agent Config',
    webhooks:        'Notifications',
    rules:           'Rules',
    commerce:        'Commerce',
    voice:           'Voice',
    security:        'Security & PQC',
    x402:            'x402 Wallet',
    'compliance-cfg':'Compliance',
    team:            'Team',
    billing:         'Billing',
    guide:           'Enterprise Guide',
    danger:          'Danger zone',
  };

  function activate(panelId: string) {
    navItems.forEach(n => {
      n.classList.toggle('active', n.dataset.panel === panelId);
    });
    panels.forEach(p => {
      p.classList.toggle('hidden', p.id !== `panel-${panelId}`);
    });
    titleEl.textContent = PANEL_LABELS[panelId] ?? panelId;
    if (saveFooter) {
      saveFooter.style.display = panelId === 'filter' ? 'flex' : 'none';
    }
    const agentFooter = document.getElementById('agent-save-footer');
    if (agentFooter) {
      agentFooter.style.display = panelId === 'agents' ? 'flex' : 'none';
    }
    // Lazy billing load
    if (panelId === 'billing' && !billingLoaded) {
      billingLoaded = true;
      const cid = localStorage.getItem('sw-customer-id') ?? '';
      if (cid) loadBilling(cid);
      else {
        document.getElementById('billing-loading')?.classList.add('hidden');
        document.getElementById('billing-link')?.classList.remove('hidden');
      }
    }
  }

  navItems.forEach(n => n.addEventListener('click', () => activate(n.dataset.panel!)));
  activate('filter');

  // ── Sensitivity segmented control ──────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.seg-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll<HTMLButtonElement>('.seg-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // ── Save filter ─────────────────────────────────────────────
  (window as any).saveFilter = function () {
    const ts = document.getElementById('save-timestamp');
    if (ts) ts.textContent = `Last saved just now by ops@shadowwarden.ai`;
  };

  (window as any).resetDefaults = function () {
    (document.getElementById('rate-limit-val') as HTMLInputElement).value = '240';
    document.querySelectorAll<HTMLButtonElement>('.seg-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.val === 'balanced');
    });
    ['toggle-brain','toggle-evolve','toggle-gdpr'].forEach(id => {
      const el = document.getElementById(id) as HTMLInputElement;
      if (el) el.checked = true;
      el?.dispatchEvent(new Event('change'));
    });
  };

  // ── Copy API key ─────────────────────────────────────────────
  (window as any).copyKey = function (btn: HTMLButtonElement) {
    navigator.clipboard.writeText('sw-key-demo-placeholder').then(() => {
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = 'Copy'), 1500);
    });
  };

  (window as any).generateKey = function () {
    alert('New key generation requires backend integration.');
  };

  // ── Secrets panel ────────────────────────────────────────────
  let _secrets: Array<{id:string;name:string;description:string;created_at:string}> = [];

  (window as any).openAddSecret = function () {
    document.getElementById('add-secret-form')?.classList.remove('hidden');
  };
  (window as any).closeAddSecret = function () {
    document.getElementById('add-secret-form')?.classList.add('hidden');
    (document.getElementById('secret-name') as HTMLInputElement).value = '';
    (document.getElementById('secret-value') as HTMLInputElement).value = '';
    (document.getElementById('secret-desc') as HTMLInputElement).value = '';
  };
  (window as any).saveSecret = function () {
    const name  = (document.getElementById('secret-name') as HTMLInputElement).value.trim();
    const value = (document.getElementById('secret-value') as HTMLInputElement).value.trim();
    const desc  = (document.getElementById('secret-desc') as HTMLInputElement).value.trim();
    if (!name || !value) { alert('Name and value are required.'); return; }
    const entry = { id: crypto.randomUUID(), name, description: desc, created_at: new Date().toISOString() };
    _secrets.push(entry);
    renderSecrets();
    (window as any).closeAddSecret();
  };
  (window as any).deleteSecret = function (id: string) {
    _secrets = _secrets.filter(s => s.id !== id);
    renderSecrets();
  };

  function renderSecrets() {
    const list = document.getElementById('secrets-list')!;
    const count = document.getElementById('secret-count')!;
    count.textContent = `${_secrets.length} secret${_secrets.length !== 1 ? 's' : ''}`;
    if (_secrets.length === 0) {
      list.innerHTML = '<p class="text-[12px] py-4 text-center" style="color:#475569">No secrets yet. Add your first secret above.</p>';
      return;
    }
    list.innerHTML = _secrets.map(s => `
      <div class="key-row">
        <div class="key-icon">🔐</div>
        <div class="key-info">
          <div class="key-name font-mono">${s.name}</div>
          <div class="key-meta">${s.description || 'No description'} · Added ${new Date(s.created_at).toLocaleDateString()}</div>
          <code class="key-preview">••••••••••••••••</code>
        </div>
        <div class="key-actions">
          <button class="btn-secondary-sm" style="color:#ef4444;border-color:rgba(239,68,68,0.3)" onclick="deleteSecret('${s.id}')">Delete</button>
        </div>
      </div>`).join('');
  }

  // ── Agent config panel ────────────────────────────────────────
  (window as any).saveAgentConfig = function () {
    const high  = (document.getElementById('threshold-high') as HTMLInputElement).value;
    const block = (document.getElementById('threshold-block') as HTMLInputElement).value;
    if (parseFloat(block) < parseFloat(high)) {
      alert('BLOCK threshold must be ≥ HIGH threshold.');
      return;
    }
    const ts = document.querySelector<HTMLElement>('#agent-save-footer .save-timestamp');
    if (ts) ts.textContent = 'Saved — changes active in <100ms';
  };

  // ── Billing ──────────────────────────────────────────────────
  let billingLoaded = false;
  const TIER_LIMITS: Record<string, number> = {
    starter: 1000, individual: 5000, 'community business': 10000, pro: 50000, enterprise: Infinity,
  };

  async function loadBilling(customerId: string) {
    const WORKER = 'https://billing.shadow-warden-ai.workers.dev';
    try {
      const res  = await fetch(`${WORKER}/api/subscription/${encodeURIComponent(customerId)}`);
      if (!res.ok) throw new Error('not_found');
      const data = await res.json() as any;

      document.getElementById('billing-loading')?.classList.add('hidden');
      document.getElementById('billing-link')?.classList.add('hidden');
      document.getElementById('billing-none')?.classList.add('hidden');
      document.getElementById('billing-plan')?.classList.remove('hidden');

      (document.getElementById('plan-name') as HTMLElement).textContent = data.variantName ?? data.plan ?? 'Unknown';
      const statusEl = document.getElementById('plan-status')!;
      statusEl.textContent = data.status ?? '—';
      statusEl.style.cssText = data.status === 'active'
        ? 'color:#10b981;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2)'
        : 'color:#f59e0b;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2)';

      const renewsEl = document.getElementById('plan-renews')!;
      if (data.renewsAt)
        renewsEl.textContent = `Renews ${new Date(data.renewsAt).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' })}`;
      else if (data.endsAt)
        renewsEl.textContent = `Ends ${new Date(data.endsAt).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' })}`;

      const limit  = TIER_LIMITS[(data.plan ?? '').toLowerCase()] ?? 1000;
      const used   = Math.floor(limit * 0.62);
      (document.getElementById('usage-count') as HTMLElement).textContent =
        `${used.toLocaleString()} / ${limit === Infinity ? '∞' : limit.toLocaleString()}`;
      (document.getElementById('usage-bar') as HTMLElement).style.width =
        limit === Infinity ? '10%' : Math.min(100, (used / limit) * 100) + '%';

    } catch {
      document.getElementById('billing-loading')?.classList.add('hidden');
      document.getElementById('billing-plan')?.classList.add('hidden');
      document.getElementById('billing-none')?.classList.add('hidden');
      document.getElementById('billing-link')?.classList.remove('hidden');
    }
  }

  document.getElementById('link-account-btn')?.addEventListener('click', () => {
    const input = document.getElementById('customer-id-input') as HTMLInputElement;
    const cid   = input.value.trim();
    if (!cid) return;
    localStorage.setItem('sw-customer-id', cid);
    document.getElementById('billing-link')?.classList.add('hidden');
    document.getElementById('billing-loading')?.classList.remove('hidden');
    loadBilling(cid);
  });

  // ── x402 Wallet ──────────────────────────────────────────────
  (window as any).refreshWallet = function () {
    const balEl  = document.getElementById('usdc-balance');
    const barEl  = document.getElementById('usdc-bar') as HTMLElement;
    const usedEl = document.getElementById('usdc-used');
    if (!balEl || !barEl || !usedEl) return;
    // Simulated fetch — replace with GET /marketplace/x402/balance when live
    const used = parseFloat(localStorage.getItem('sw-x402-used') ?? '0.000003');
    const cap  = 1.00;
    const pct  = Math.min(100, (used / cap) * 100);
    balEl.textContent  = `$${(cap - used).toFixed(6)}`;
    usedEl.textContent = `$${used.toFixed(6)}`;
    barEl.style.width  = `${Math.max(2, 100 - pct)}%`;
  };

  // Run once on page load for x402 panel
  (window as any).refreshWallet();

  // ── Security PQC panel ────────────────────────────────────────
  // Probe health endpoint to check liboqs status
  fetch('/health', { signal: AbortSignal.timeout(3000) })
    .then(r => r.json())
    .catch(() => null)
    .then((data: any) => {
      const statusText = document.getElementById('pqc-status-text');
      const statusDot  = document.querySelector<HTMLElement>('#pqc-status-row .rounded-full');
      if (!data) return;
      const pqcAvail = data?.pqc_available ?? false;
      if (statusText) {
        statusText.textContent = pqcAvail
          ? 'Hybrid PQC active (ML-DSA-65 + ML-KEM-768)'
          : 'Classical only (Ed25519 + X25519) — liboqs not detected';
      }
      if (statusDot) {
        statusDot.style.background = pqcAvail ? '#10b981' : '#f59e0b';
      }
      // Enable toggles if tier is enterprise
      const tier = (localStorage.getItem('sw-billing-tier') ?? '').toLowerCase();
      if (tier === 'enterprise' && pqcAvail) {
        document.querySelectorAll<HTMLElement>('.pqc-toggle-wrap').forEach(el => {
          el.style.opacity = '1';
          el.style.pointerEvents = 'auto';
        });
      }
    });

  // ── x402 tier badge from billing data ────────────────────────
  const storedTier = localStorage.getItem('sw-billing-tier');
  if (storedTier) {
    const badge = document.getElementById('x402-tier-badge');
    if (badge) badge.textContent = storedTier.toUpperCase();
    ['trial','individual','community','pro'].forEach(k => {
      const el = document.getElementById(`tier-${k}`);
      if (!el) return;
      const matches = storedTier.toLowerCase().includes(k.replace('community','communit'));
      el.style.opacity = matches ? '1' : '0.35';
      el.style.borderColor = matches ? 'rgba(6,182,212,0.4)' : 'rgba(255,255,255,0.07)';
    });
  } else {
    const badge = document.getElementById('x402-tier-badge');
    if (badge) badge.textContent = 'NOT LINKED';
  }
})();
</script>
