  .badge-amber  { color: #f59e0b; background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25); }
  .badge-blue   { color: #38bdf8; background: rgba(56,189,248,0.10); border: 1px solid rgba(56,189,248,0.2); }
  .badge-purple { color: #c084fc; background: rgba(192,132,252,0.10); border: 1px solid rgba(192,132,252,0.2); }

  /* Info box */
  .info-box {
    display: flex;
    gap: 10px;
    margin-top: 12px;
    padding: 12px 14px;
    border-radius: 10px;
    background: rgba(245,158,11,0.06);
