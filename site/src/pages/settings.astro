---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConfirmModal from '../components/ConfirmModal.astro';
import { BILLING_PORTAL } from '../config/lemonsqueezy';
---

<BaseLayout
  title="Settings — Shadow Warden AI"
  description="Configure your pipeline thresholds, manage API keys, GDPR controls, integrations, and account security."
>
  <div class="pt-14 min-h-screen" style="background:#03050f">

    <!-- Shell: sidebar + content -->
    <div class="settings-shell mx-auto">

      <!-- ── SIDEBAR ─────────────────────────────────────────── -->
      <aside class="settings-sidebar">
        <div class="sidebar-inner">
          <div class="sidebar-label">WORKSPACE</div>
          <nav class="sidebar-nav" id="settings-nav">

            <button class="nav-item active" data-panel="filter">
              <span class="nav-icon">⚡</span>
              <span class="nav-text">Filter pipeline</span>
            </button>

            <button class="nav-item" data-panel="apikeys">
              <span class="nav-icon">🔑</span>
              <span class="nav-text">API keys</span>
              <span class="nav-badge">2</span>
            </button>

            <button class="nav-item" data-panel="webhooks">
              <span class="nav-icon">🔗</span>
              <span class="nav-text">Webhooks</span>
            </button>

            <button class="nav-item" data-panel="rules">
              <span class="nav-icon">📋</span>
              <span class="nav-text">Rules</span>
            </button>

            <button class="nav-item" data-panel="team">
              <span class="nav-icon">👥</span>
              <span class="nav-text">Team</span>
              <span class="nav-badge">5</span>
            </button>

            <button class="nav-item" data-panel="billing">
              <span class="nav-icon">💳</span>
              <span class="nav-text">Billing</span>
            </button>

            <button class="nav-item danger-item" data-panel="danger">
              <span class="nav-icon">⚠</span>
              <span class="nav-text">Danger zone</span>
            </button>
          </nav>
        </div>
      </aside>

      <!-- ── MAIN CONTENT ────────────────────────────────────── -->
      <main class="settings-main">

        <!-- Top header bar -->
        <div class="settings-topbar">
          <div id="panel-title" class="topbar-title">Filter pipeline</div>
          <div class="health-badge">
            <span class="health-dot"></span>
            ALL SYSTEMS HEALTHY
          </div>
        </div>

        <!-- ── FILTER PIPELINE ── -->
        <div id="panel-filter" class="settings-panel active">
          <p class="panel-subtitle">
            Tune how Shadow Warden inspects every AI request before it leaves your perimeter.
          </p>

          <!-- SemanticBrain -->
          <div class="feature-card">
            <div class="feature-header">
              <div class="feature-meta">
                <span class="feature-title">SemanticBrain</span>
                <span class="feature-sub">ML cosine</span>
              </div>
              <div class="feature-badges">
                <span class="badge badge-green">RECOMMENDED</span>
              </div>
              <label class="toggle-label ml-auto">
                <input type="checkbox" checked class="sr-only toggle-input" id="toggle-brain" />
                <span class="toggle-track"><span class="toggle-thumb"></span></span>
              </label>
            </div>
            <p class="feature-desc">
              Async ML detection layer using all-MiniLM-L6-v2 embeddings. Catches paraphrased jailbreaks that regex rules miss.
            </p>
            <div class="feature-stats">
              Adds ~15ms latency · +18% recall on adversarial set
            </div>
          </div>

          <!-- EvolutionEngine -->
          <div class="feature-card">
            <div class="feature-header">
              <div class="feature-meta">
                <span class="feature-title">EvolutionEngine</span>
              </div>
              <div class="feature-badges">
                <span class="badge badge-amber">BETA</span>
              </div>
              <label class="toggle-label ml-auto">
                <input type="checkbox" checked class="sr-only toggle-input" id="toggle-evolve" />
                <span class="toggle-track"><span class="toggle-thumb"></span></span>
              </label>
            </div>
            <p class="feature-desc">
              Auto-generate new detection rules from blocked attacks via Claude Opus. Hot-reloads without restart.
            </p>
            <div class="info-box">
              <span class="info-icon">💡</span>
              <div>
                <div class="info-title">BEST PRACTICE</div>
                <div class="info-body">
                  Enable in staging first. Consumes API credits. Review the generated corpus weekly under
                  <span class="info-mono">Rules → Auto-generated</span>.
                </div>
              </div>
            </div>
          </div>

          <!-- GDPR strict mode -->
          <div class="feature-card">
            <div class="feature-header">
              <div class="feature-meta">
                <span class="feature-title">GDPR strict mode</span>
              </div>
              <div class="feature-badges">
                <span class="badge badge-blue">EU</span>
                <span class="badge badge-purple">SOC 2</span>
              </div>
              <label class="toggle-label ml-auto">
                <input type="checkbox" checked class="sr-only toggle-input" id="toggle-gdpr" />
                <span class="toggle-track"><span class="toggle-thumb"></span></span>
              </label>
            </div>
            <p class="feature-desc">
              Never log request content. Only metadata (type, length, timing) is persisted. Required for EU deployments.
            </p>
            <div class="mono-hint">Endpoints /gdpr/export and /gdpr/purge rely on this</div>
          </div>

          <!-- Sensitivity profile -->
          <div class="feature-card">
            <div class="feature-header">
              <div class="feature-meta">
                <span class="feature-title">Sensitivity profile</span>
              </div>
            </div>
            <p class="feature-desc">
              Tradeoff between false-positive rate and recall. Balanced works for most workloads.
            </p>
            <div class="btn-group mt-4" id="sensitivity-group">
              <button class="seg-btn" data-val="strict">Strict</button>
              <button class="seg-btn active" data-val="balanced">Balanced</button>
              <button class="seg-btn" data-val="lenient">Lenient</button>
            </div>
          </div>

          <!-- Rate limit -->
          <div class="feature-card">
            <div class="feature-header">
              <div class="feature-meta">
                <span class="feature-title">Rate limit</span>
                <span class="feature-sub">per API key</span>
              </div>
            </div>
            <p class="feature-desc">
              Hard cap on requests per key per minute. Above 1,000 may require dedicated Redis.
            </p>
            <div class="rate-input-row mt-4">
              <input type="number" id="rate-limit-val" value="240" min="10" max="10000"
                     class="settings-input rate-input" />
              <span class="rate-unit">req / min</span>
            </div>
          </div>

          <!-- Sticky save footer -->
          <div class="save-footer">
            <span class="save-timestamp" id="save-timestamp">Last saved 2 min ago by ops@shadowwarden.ai</span>
            <div class="save-actions">
              <button class="btn-secondary-sm" onclick="resetDefaults()">Reset to defaults</button>
              <button class="btn-primary-sm" onclick="saveFilter()">Save changes</button>
            </div>
          </div>
        </div>

        <!-- ── API KEYS ── -->
        <div id="panel-apikeys" class="settings-panel hidden">
          <p class="panel-subtitle">Per-tenant keys with SHA-256 constant-time compare. Fail-closed — service won't start without a valid key.</p>

          <div class="settings-card mt-6">
            <div class="flex items-center gap-3 mb-5">
              <h3 class="card-title">Active Keys</h3>
              <button class="btn-primary-sm ml-auto" onclick="generateKey()">+ New key</button>
            </div>
            {[
              { name: 'Production key', created: 'Jan 12, 2026', lastUsed: '2 min ago' },
              { name: 'CI / staging',   created: 'Mar 3, 2026',  lastUsed: '1 hour ago' },
            ].map(k => (
              <div class="key-row">
                <div class="key-icon">🔑</div>
                <div class="key-info">
                  <div class="key-name">{k.name}</div>
                  <div class="key-meta">Created {k.created} · Last used {k.lastUsed}</div>
                  <code class="key-preview">sw-key-••••••••••••••••••••••••••••••••</code>
                </div>
                <div class="key-actions">
                  <button class="btn-secondary-sm" onclick="copyKey(this)">Copy</button>
                  <button class="btn-secondary-sm" style="color:#f59e0b;border-color:rgba(245,158,11,0.3)">Rotate</button>
                  <button class="btn-secondary-sm" style="color:#ef4444;border-color:rgba(239,68,68,0.3)">Revoke</button>
                </div>
              </div>
            ))}
          </div>

          <div class="settings-card mt-4">
            <h3 class="card-title mb-3">Change Password</h3>
            <div class="grid gap-3 max-w-md">
              <div>
                <label class="settings-label">Current password</label>
                <input type="password" placeholder="••••••••" class="settings-input" />
              </div>
              <div>
                <label class="settings-label">New password</label>
                <input type="password" placeholder="••••••••" class="settings-input" />
              </div>
              <div>
                <label class="settings-label">Confirm new password</label>
                <input type="password" placeholder="••••••••" class="settings-input" />
              </div>
              <button class="btn-primary-sm w-fit mt-1">Update password</button>
            </div>
          </div>
        </div>

        <!-- ── WEBHOOKS ── -->
        <div id="panel-webhooks" class="settings-panel hidden">
          <p class="panel-subtitle">Push security events to external services in real time.</p>

          <div class="settings-card mt-6">
            <div class="flex items-center gap-3 mb-5">
              <h3 class="card-title">Connected Integrations</h3>
              <button class="btn-primary-sm ml-auto">+ Add webhook</button>
            </div>
            {[
              { name: 'Slack Alerts',  icon: '💬', desc: 'Real-time HIGH/BLOCK alerts to your SOC Slack channel via incoming webhook.', connected: true },
              { name: 'PagerDuty',     icon: '🚨', desc: 'Real-time HIGH/BLOCK incident escalation via PagerDuty Events API v2.', connected: true },
              { name: 'Splunk HEC',    icon: '📊', desc: 'Stream security events to your Splunk SIEM via HTTP Event Collector.', connected: false },
              { name: 'LangChain',     icon: '🦜', desc: 'Drop-in WardenCallback for LangChain pipelines. Zero code changes required.', connected: true },
              { name: 'Elastic ECS',   icon: '🔍', desc: 'Elastic Common Schema event export for Elastic SIEM and Kibana dashboards.', connected: false },
            ].map(item => (
              <div class="key-row">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[18px] flex-shrink-0"
                     style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08)">{item.icon}</div>
                <div class="key-info">
                  <div class="key-name">{item.name}</div>
                  <div class="key-meta">{item.desc}</div>
                </div>
                <label class="toggle-label flex-shrink-0">
                  <input type="checkbox" checked={item.connected} class="sr-only toggle-input" />
                  <span class="toggle-track"><span class="toggle-thumb"></span></span>
                </label>
              </div>
            ))}
          </div>
        </div>

        <!-- ── RULES ── -->
        <div id="panel-rules" class="settings-panel hidden">
          <p class="panel-subtitle">Manage regex and semantic rules. Auto-generated rules from the Evolution Engine appear under the Auto-generated tab.</p>

          <div class="settings-card mt-6">
            <div class="flex items-center gap-3 mb-4">
              <h3 class="card-title">Detection Rules</h3>
              <span class="text-[11px] px-2 py-0.5 rounded-full" style="color:#6366f1;background:rgba(99,102,241,0.1)">153 active</span>
              <button class="btn-primary-sm ml-auto">+ Add rule</button>
            </div>
            {[
              { id: 'R-001', name: 'Jailbreak: role override',    type: 'regex',    severity: 'HIGH',   hits: 412 },
              { id: 'R-002', name: 'Prompt injection: sys leak',   type: 'regex',    severity: 'HIGH',   hits: 208 },
              { id: 'R-003', name: 'DAN variants (semantic)',      type: 'semantic', severity: 'HIGH',   hits: 94  },
              { id: 'R-004', name: 'PII: SSN pattern',             type: 'redactor', severity: 'MEDIUM', hits: 61  },
              { id: 'R-005', name: 'Obfuscated base64 payload',    type: 'decoder',  severity: 'MEDIUM', hits: 29  },
            ].map(r => (
              <div class="rule-row">
                <span class="rule-id">{r.id}</span>
                <span class="rule-name">{r.name}</span>
                <span class="rule-type">{r.type}</span>
                <span class={`rule-severity sev-${r.severity.toLowerCase()}`}>{r.severity}</span>
                <span class="rule-hits">{r.hits} hits</span>
                <button class="btn-secondary-sm text-[11px] px-2 py-1">Edit</button>
              </div>
            ))}
            <div class="text-center pt-4">
              <button class="btn-secondary-sm text-[11px]">View all 153 rules →</button>
            </div>
          </div>
        </div>

        <!-- ── TEAM ── -->
        <div id="panel-team" class="settings-panel hidden">
          <p class="panel-subtitle">Manage who has access to your Shadow Warden workspace.</p>

          <div class="settings-card mt-6">
            <div class="flex items-center gap-3 mb-5">
              <h3 class="card-title">Members</h3>
              <span class="text-[11px] px-2 py-0.5 rounded-full" style="color:#6366f1;background:rgba(99,102,241,0.1)">5 members</span>
              <button class="btn-primary-sm ml-auto">Invite member</button>
            </div>
            {[
              { name: 'ops@shadowwarden.ai',   role: 'Owner',  joined: 'Jan 2026',  avatar: '🛡' },
              { name: 'dev@shadowwarden.ai',    role: 'Admin',  joined: 'Feb 2026',  avatar: '⚙' },
              { name: 'soc@shadowwarden.ai',    role: 'Viewer', joined: 'Mar 2026',  avatar: '🔍' },
              { name: 'ci-bot@shadowwarden.ai', role: 'Viewer', joined: 'Mar 2026',  avatar: '🤖' },
              { name: 'audit@client.com',       role: 'Viewer', joined: 'Apr 2026',  avatar: '📋' },
            ].map(m => (
              <div class="key-row">
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-[16px] flex-shrink-0"
                     style="background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.2)">{m.avatar}</div>
                <div class="key-info">
                  <div class="key-name">{m.name}</div>
                  <div class="key-meta">Joined {m.joined}</div>
                </div>
                <span class={`member-role role-${m.role.toLowerCase()}`}>{m.role}</span>
                {m.role !== 'Owner' && (
                  <button class="btn-secondary-sm text-[11px] px-2 py-1" style="color:#ef4444;border-color:rgba(239,68,68,0.3)">Remove</button>
                )}
              </div>
            ))}
          </div>
        </div>

        <!-- ── BILLING ── -->
        <div id="panel-billing" class="settings-panel hidden">
          <p class="panel-subtitle">Manage your subscription, usage, and payment history.</p>

          <div class="settings-card mt-6 mb-4">
            <div class="flex items-start justify-between gap-4 mb-5">
              <h3 class="card-title">Current Plan</h3>
              <a href={BILLING_PORTAL} target="_blank" rel="noopener"
                 class="btn-secondary-sm flex-shrink-0 whitespace-nowrap">
                Manage Subscription ↗
              </a>
            </div>

            <div id="billing-loading" class="py-6 text-center text-[13px]" style="color:#475569">
              Loading subscription…
            </div>
            <div id="billing-plan" class="hidden">
              <div class="flex items-center gap-4 p-4 rounded-xl mb-4" style="background:rgba(99,102,241,0.06);border:1px solid rgba(99,102,241,0.15)">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[20px]" style="background:rgba(99,102,241,0.1)">⚡</div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span id="plan-name" class="text-[15px] font-bold" style="color:#f1f5f9">—</span>
                    <span id="plan-status" class="text-[10px] font-bold px-2 py-0.5 rounded-full">—</span>
                  </div>
                  <div id="plan-renews" class="text-[12px] mt-0.5" style="color:#64748b">—</div>
                </div>
              </div>
              <div class="mb-2 flex items-center justify-between text-[12px]" style="color:#64748b">
                <span>Requests this month</span>
                <span id="usage-count" style="color:#f1f5f9">—</span>
              </div>
              <div class="h-2 rounded-full overflow-hidden mb-5" style="background:rgba(255,255,255,0.06)">
                <div id="usage-bar" class="h-full rounded-full" style="background:linear-gradient(90deg,#6366f1,#8b5cf6);width:0%"></div>
              </div>
            </div>

            <div id="billing-none" class="hidden text-center py-6">
              <div class="text-[14px] mb-3" style="color:#94a3b8">No active subscription found.</div>
              <a href="/price" class="btn-primary-sm">View Plans →</a>
            </div>

            <div id="billing-link" class="hidden">
              <p class="text-[13px] mb-3" style="color:#64748b">
                Enter your Lemon Squeezy Customer ID to load your subscription details.
              </p>
              <div class="flex gap-3 max-w-sm">
                <input id="customer-id-input" type="text" placeholder="e.g. 1234567"
                       class="settings-input flex-1 font-mono text-[12px]" />
                <button id="link-account-btn" class="btn-primary-sm whitespace-nowrap">Link</button>
              </div>
              <p class="text-[11px] mt-2" style="color:#334155">
                Find your Customer ID in your Lemon Squeezy order confirmation email.
              </p>
            </div>
          </div>

          <div class="settings-card mb-4">
            <h3 class="card-title mb-4">Payment History</h3>
            <div class="overflow-x-auto">
              <table class="w-full text-[12px]">
                <thead>
                  <tr style="border-bottom:1px solid rgba(255,255,255,0.06)">
                    <th class="text-left pb-2 font-semibold" style="color:#475569">Date</th>
                    <th class="text-left pb-2 font-semibold" style="color:#475569">Plan</th>
                    <th class="text-left pb-2 font-semibold" style="color:#475569">Amount</th>
                    <th class="text-left pb-2 font-semibold" style="color:#475569">Status</th>
                    <th class="text-right pb-2 font-semibold" style="color:#475569">Invoice</th>
                  </tr>
                </thead>
                <tbody>
                  {[
                    { date: 'May 1, 2026',  plan: 'Pro — Monthly',  amount: '$69.00', status: 'Paid' },
                    { date: 'Apr 1, 2026',  plan: 'Pro — Monthly',  amount: '$69.00', status: 'Paid' },
                    { date: 'Mar 1, 2026',  plan: 'Pro — Monthly',  amount: '$69.00', status: 'Paid' },
                  ].map(row => (
                    <tr style="border-bottom:1px solid rgba(255,255,255,0.04)">
                      <td class="py-2.5" style="color:#94a3b8">{row.date}</td>
                      <td class="py-2.5" style="color:#94a3b8">{row.plan}</td>
                      <td class="py-2.5" style="color:#f1f5f9">{row.amount}</td>
                      <td class="py-2.5">
                        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold"
                              style="color:#10b981;background:rgba(16,185,129,0.1)">{row.status}</span>
                      </td>
                      <td class="py-2.5 text-right">
                        <button class="text-[11px]" style="color:#6366f1">PDF ↓</button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <div class="settings-card" style="border-color:rgba(239,68,68,0.15)">
            <h3 class="card-title mb-2" style="color:#ef4444">Cancel Subscription</h3>
            <p class="text-[12px] mb-4" style="color:#64748b">
              Your plan stays active until the end of the current billing period. All data is preserved.
            </p>
            <a href={BILLING_PORTAL} target="_blank" rel="noopener"
               class="btn-secondary-sm"
               style="color:#ef4444;border-color:rgba(239,68,68,0.3)">
              Cancel via Billing Portal ↗
            </a>
          </div>
        </div>

        <!-- ── DANGER ZONE ── -->
        <div id="panel-danger" class="settings-panel hidden">
          <p class="panel-subtitle">Actions here are irreversible. Proceed with extreme caution.</p>

          <div class="mt-6 rounded-2xl overflow-hidden" style="border:1px solid rgba(239,68,68,0.25)">
            <div class="px-6 py-4" style="background:rgba(239,68,68,0.06);border-bottom:1px solid rgba(239,68,68,0.15)">
              <h3 class="text-[14px] font-bold" style="color:#ef4444">Danger Zone</h3>
            </div>
            <div class="p-6 grid gap-4">
              <div class="flex items-center justify-between gap-4 pb-4 border-b" style="border-color:rgba(255,255,255,0.06)">
                <div>
                  <div class="text-[13px] font-semibold mb-1" style="color:#f1f5f9">Sign out</div>
                  <p class="text-[12px]" style="color:#64748b">End your current session. Your data is preserved.</p>
                </div>
                <a href="/logout"
                   class="flex-shrink-0 px-4 py-2 rounded-lg text-[12px] font-medium"
                   style="color:#94a3b8;border:1px solid rgba(255,255,255,0.12)">
                  Sign out
                </a>
              </div>
              <div class="flex items-center justify-between gap-4">
                <div>
                  <div class="text-[13px] font-semibold mb-1" style="color:#ef4444">Delete this project</div>
                  <p class="text-[12px]" style="color:#64748b">
                    Permanently delete the project and all associated data. Cannot be undone.
                    All data is purged under GDPR Article 17.
                  </p>
                </div>
                <button
                  onclick="document.getElementById('modal-delete').classList.remove('hidden')"
                  class="flex-shrink-0 px-4 py-2 rounded-lg text-[12px] font-semibold whitespace-nowrap"
                  style="color:#fff;background:#dc2626;border:1px solid rgba(220,38,38,0.5)">
                  Delete project
                </button>
              </div>
            </div>
          </div>
        </div>

      </main>
    </div><!-- /settings-shell -->
  </div>
</BaseLayout>

<ConfirmModal
  id="modal-delete"
  title="Delete project?"
  message="This action cannot be undone. All data will be permanently deleted and purged in accordance with GDPR Article 17."
  confirmLabel="Yes, delete project"
  requireText="Shadow Warden AI"
  redirectTo="/goodbye"
  danger={true}
/>

<style>
  /* ── Shell layout ──────────────────────────────────────────── */
  .settings-shell {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: calc(100vh - 56px);
    max-width: 1200px;
  }

  /* ── Sidebar ───────────────────────────────────────────────── */
  .settings-sidebar {
    border-right: 1px solid rgba(255,255,255,0.06);
    background: #08090f;
    position: sticky;
    top: 56px;
    height: calc(100vh - 56px);
    overflow-y: auto;
  }
  .sidebar-inner { padding: 24px 12px; }
  .sidebar-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #334155;
    padding: 0 8px;
    margin-bottom: 8px;
  }
  .sidebar-nav { display: flex; flex-direction: column; gap: 2px; }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 9px 12px;
    border-radius: 10px;
    border: none;
    background: transparent;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s, color 0.15s;
    color: #64748b;
    font-size: 13px;
    font-weight: 500;
  }
  .nav-item:hover { background: rgba(255,255,255,0.04); color: #94a3b8; }
  .nav-item.active { background: rgba(99,102,241,0.12); color: #f1f5f9; }
  .nav-item.active .nav-icon { color: #6366f1; }
  .nav-icon { font-size: 15px; flex-shrink: 0; }
  .nav-text { flex: 1; }
  .nav-badge {
    font-size: 10px;
    font-weight: 700;
