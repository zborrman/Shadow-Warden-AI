{
  "name": "@shadow-warden/react-acp-widget",
  "version": "1.0.0",
  "description": "Drop-in React widget for Shadow Warden ACP budget authorization",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
